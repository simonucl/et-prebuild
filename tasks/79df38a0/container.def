Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    #!/bin/bash
    set -e

    export DEBIAN_FRONTEND=noninteractive

    # ------------------------------------------------------------------
    # Install required packages
    # ------------------------------------------------------------------
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        openssh-client

    # Install pytest for the checker
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state expected by the task
    # ------------------------------------------------------------------
    # Home directory and .ssh folder for the non-privileged user that will
    # execute the exercise (tests run as the invoking host user, not root).
    mkdir -p /home/user/.ssh

    # Make sure the directories are writable by any UID that ends up running
    # inside the container during testing.
    chmod 0777 /home/user
    chmod 0777 /home/user/.ssh

    # DO NOT create any of the files that the learner is supposed to generate.
    # Leaving them absent is essential for the initial-state tests to pass.

%environment
    chmod 755 /home/user

    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8