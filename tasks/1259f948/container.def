Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    export DEBIAN_FRONTEND=noninteractive

    # Update package index and install required system packages
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        sqlite3 \
        ca-certificates \
        curl

    # Install pytest for the exercise test-suite
    pip3 install --no-cache-dir --upgrade pip
    pip3 install --no-cache-dir pytest

    # Create a writable home directory expected by the exercise
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up apt cache to keep the image small
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure python and pytest are on the PATH
    PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%labels
    Author="Apptainer Build Script"
    Description="Environment for SQLite diagnostics bundle exercise with pytest installed."

%help
    This container provides the tools required for the SQLite diagnostics
    bundle exercise:
      •  sqlite3 CLI
      •  Python 3 and pytest for automated testing

    It intentionally does not contain the /home/user/diagnostics directory
    so that learners can create it during the task.