Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ----------------------------------------------------------------------
    # Basic tooling
    # ----------------------------------------------------------------------
    apt-get update && \
        apt-get install -y --no-install-recommends \
            python3 \
            python3-pip && \
        rm -rf /var/lib/apt/lists/*

    # Install pytest for the grading suite
    pip3 install --no-cache-dir pytest

    # ----------------------------------------------------------------------
    # Pre-populate the required initial filesystem state
    # ----------------------------------------------------------------------
    # Directories
    mkdir -p /home/user/raw_runs/run_42
    mkdir -p /home/user/.metrics_source
    mkdir -p /home/user/experiments

    # Raw artifact placeholders
    : > /home/user/raw_runs/run_42/model.pt            # zero-byte binary placeholder
    printf '{}\n' > /home/user/raw_runs/run_42/metrics.json

    # Simulated metrics CSV (no header row; each line ends with a newline)
    cat > /home/user/.metrics_source/sim_metrics.csv <<'EOF'
23.1,45.2
25.5,46.1
26.3,47.0
24.1,46.5
22.8,45.9
EOF

    # Make sure every normal user can read/write inside /home/user
    chmod -R 777 /home/user

%environment
    chmod 755 /home/user

    export LC_ALL=C.UTF-8
    export PYTHONUNBUFFERED=1

%labels
    Author  MLOps Task Preparer
    Version v1.0
    Description Container providing the initial state for the “experiment archive & system monitoring” task.

%runscript
    echo "Apptainer container ready. Start a shell with:  apptainer exec <container> /bin/bash"