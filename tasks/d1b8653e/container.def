Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Basic utilities and Python tooling
    apt-get update
    apt-get install -y --no-install-recommends \
        python3-pip \
        procps \
        jq
    pip3 install --no-cache-dir pytest
    rm -rf /var/lib/apt/lists/*

    # Create non-root user `user`
    useradd -m -s /bin/bash user

    # Prepare initial dashboard directory and file
    install -d -m 755 /home/user/dashboards

    cat > /home/user/dashboards/app_server_dashboard.json <<'EOF'
{
  "dashboard": "App Server Metrics",
  "panels": [
    {
      "id": 1,
      "metric": "cpu_usage",
      "threshold": 75
    },
    {
      "id": 2,
      "metric": "memory_usage",
      "threshold": 80
    }
  ]
}
EOF

    chmod 644 /home/user/dashboards/app_server_dashboard.json
    chown -R user:user /home/user

%environment
    chmod 755 /home/user

    # Do not override HOME; just ensure common paths are reachable
    export PATH="/home/user/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:${PATH}"

%labels
    Author      "Apptainer Task Setup"
    Description "Base image for process-health tuning exercise"

%runscript
    # Default action: drop into a shell
    exec /bin/bash "$@"