Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Ensure non-interactive apt operations
    export DEBIAN_FRONTEND=noninteractive

    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        gawk \
        sed \
        ca-certificates

    # Install pytest (latest version) for the grader
    pip3 install --no-cache-dir pytest

    # -----------------------------------------------------------------
    # Prepare initial filesystem state expected by the tests
    # -----------------------------------------------------------------
    # Create base directory structure
    mkdir -p /home/user/iot_configs

    # Populate the three device-specific configuration files
    cat >/home/user/iot_configs/dev01.cfg <<'EOF'
device_id=dev01
ip=192.168.1.101
status=online
firmware_version=1.0.2
EOF

    cat >/home/user/iot_configs/dev02.cfg <<'EOF'
device_id=dev02
ip=192.168.1.102
status=offline
firmware_version=1.0.2
EOF

    cat >/home/user/iot_configs/dev03.cfg <<'EOF'
device_id=dev03
ip=192.168.1.103
status=online
firmware_version=1.0.1
EOF

    # Make sure regular (non-root) users can read/write inside /home/user
    chmod -R a+rwx /home/user

%environment
    chmod 755 /home/user

    # Keep standard PATH and Python paths intact; nothing custom required.
    export PYTHONIOENCODING=UTF-8
    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8

%runscript
    echo "This is a build container for the IoT firmware-update task."
    echo "Execute your own scripts/tests inside the container as needed."

%labels
    Author IoT-Firmware-Challenge
    Description "Container with initial state for IoT firmware deployment exercise."
    Version v1.0