# syntax=docker/dockerfile:1
FROM ubuntu:22.04

# Author: Autogenerated by ChatGPT
# Description: Environment for ML data-cleaning task with preset raw files and pytest installed.

# This image contains:
#  • Raw data files needed for the exercise in /home/user/data/raw
#  • Python 3 and pytest for testing
# All directories under /home/user are world-writable so that the
# non-privileged runtime user can create the required output files.

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked --mount=type=cache,target=/var/lib/apt,sharing=locked set -e && \
    echo "Updating apt and installing packages..." && \
    apt-get update -qq && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        jq \
        ca-certificates && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

RUN --mount=type=cache,target=/root/.cache/pip echo "Installing Python testing utilities..." && \
    pip3 install --no-cache-dir --upgrade pip && \
    pip3 install --no-cache-dir pytest

RUN echo "Creating directory structure for raw data..." && \
    mkdir -p /home/user/data/raw

RUN echo "Adding customers.json..." && \
    cat > /home/user/data/raw/customers.json <<'EOF'
[
  {"customer_id": 1, "name": "Alice",   "signup_date": "2021-01-15"},
  {"customer_id": 2, "name": "Bob",     "signup_date": "2021-03-22"},
  {"customer_id": 3, "name": "Charlie", "signup_date": "2021-07-30"},
  {"customer_id": 4, "name": "Dana",    "signup_date": "2022-01-02"}
]
EOF

RUN echo "Adding purchases.csv..." && \
    cat > /home/user/data/raw/purchases.csv <<'EOF'
purchase_id,customer_id,amount,date
1001,1,23.50,2021-02-10
1002,1,99.99,2021-05-17
1003,2,15.00,2021-04-05
1004,3,250.00,2021-09-14
1005,4,80.80,2022-02-20
1006,5,10.00,2021-12-01
EOF

RUN echo "Setting permissions so the non-root runtime user can work..." && \
    chmod -R 777 /home/user

LABEL Author="Autogenerated by ChatGPT" \
      Description="Environment for ML data-cleaning task with preset raw files and pytest installed."