Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
Author agent-prep
Description Sets up initial IR exercise state and installs pytest.

%post
    set -e

    # --------------------------------------------------------------------- #
    # Basic tooling                                                         #
    # --------------------------------------------------------------------- #
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        build-essential
    pip3 install --no-cache-dir pytest

    # --------------------------------------------------------------------- #
    # Create the initial investigation directory tree                       #
    # --------------------------------------------------------------------- #
    BASE_DIR="/home/user/investigation"
    UPLOADS_DIR="${BASE_DIR}/uploads"
    REF_DIR="${BASE_DIR}/reference"

    mkdir -p "${UPLOADS_DIR}"
    mkdir -p "${REF_DIR}"

    # Make everything world-writable so the non-root runtime user can work.
    chmod -R a+rwX /home/user

    # --------------------------------------------------------------------- #
    # Populate uploads/ with the files mentioned in the task description    #
    # --------------------------------------------------------------------- #
    # 1. safe.txt  (contains "hello" without a trailing newline)
    printf 'hello' > "${UPLOADS_DIR}/safe.txt"

    # 2. malicious.bin (zero-byte file)
    : > "${UPLOADS_DIR}/malicious.bin"

    # 3. unknown.dat (contains "test" without a trailing newline)
    printf 'test' > "${UPLOADS_DIR}/unknown.dat"

    # --------------------------------------------------------------------- #
    # Populate reference hash databases                                     #
    # --------------------------------------------------------------------- #
    echo '2cf24dba5fb0a30e26e83b2ac5b9e29e1b161e5c1fa7425e73043362938b9824' \
        > "${REF_DIR}/known_safe_hashes.txt"

    echo 'e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855' \
        > "${REF_DIR}/known_malware_hashes.txt"

    # --------------------------------------------------------------------- #
    # Clean up                                                              #
    # --------------------------------------------------------------------- #
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure Python and Pip are on PATH (they already should be, but be explicit)
    export PATH="/usr/local/bin:/usr/bin:/bin:${PATH}"

%runscript
    echo "Container built for the IR hashing exercise."