Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author      ExerciseMaintainer
    Description Container for “mobile CI pip freeze” task with pytest pre-installed.

%post
    #!/bin/bash
    set -e

    # Basic tooling for Python and pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-setuptools \
        python3-wheel \
        ca-certificates

    # Guarantee that the generic `pip` command exists (not just `pip3`)
    if [ ! -e /usr/bin/pip ]; then
        ln -s /usr/bin/pip3 /usr/bin/pip
    fi

    # Pytest is required by the automated grader
    pip3 install --no-cache-dir pytest

    # Create a writable HOME directory for the runtime user
    mkdir -p /home/user
    chmod 777 /home/user

    # Keep the image lean
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Allow user-installed Python packages to be found if they end up in ~/.local/bin
    export PATH="$PATH:/home/user/.local/bin"

%runscript
    echo "Container for the mobile CI pip-freeze exercise."
    echo "Start a shell to begin."
    exec /bin/bash "$@"