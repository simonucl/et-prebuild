Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Prepare the required incident directory structure and dotenv file
    # ------------------------------------------------------------------
    mkdir -p /home/user/incident

    cat > /home/user/incident/.env.incident <<'EOF'
DB_USER=central
DB_PASS=R3sp0nder!
INCIDENT_ID=ZA-8841
API_TOKEN=762f4e86-9d48-4d6a-8e63-25f00ec3f3c9
EOF

    # Set permissions so the non-root runtime user can read the dotenv file
    # and write inside /home/user/incident.
    chmod 0664 /home/user/incident/.env.incident
    chmod 0777 /home/user/incident

    # Make sure /home/user itself exists and is accessible.
    chmod 0777 /home/user

%environment
    chmod 755 /home/user

    # No HOME override; keep Apptainer defaults
    export PATH=/usr/local/bin:/usr/bin:/bin

%runscript
    # Default runscript does nothing; container is meant for interactive use
    exec "$@"