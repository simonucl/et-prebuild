FROM ubuntu:22.04

# This container supplies the initial filesystem state for the IoT-device
# configuration task and has pytest pre-installed for automated grading.

ENV PYTHONIOENCODING=UTF-8
ENV LC_ALL=C.UTF-8

RUN set -e && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip && \
    pip3 install --no-cache-dir pytest && \
    mkdir -p /home/user/iot_device/config && \
    printf '# Device Configuration\nMAX_THREADS=1\n' > /home/user/iot_device/config/device.conf && \
    chmod -R a+rwX /home/user/iot_device

LABEL Author="Generated by ChatGPT"
LABEL Description="Container providing the initial state for the IoT device configuration task."

CMD ["/bin/bash"]