Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state required by the task
    # ------------------------------------------------------------------

    # Create the base directory hierarchy
    mkdir -p /home/user/iot_device/config

    # Create the initial configuration file with exact contents
    printf '# Device Configuration\nMAX_THREADS=1\n' > /home/user/iot_device/config/device.conf

    # Ensure all users can read/write within /home/user/iot_device
    chmod -R a+rwX /home/user/iot_device

%labels
    chmod 755 /home/user

    Author "Generated by ChatGPT"
    Description "Container providing the initial state for the IoT device configuration task."

%environment
    # Use system python3
    export PYTHONIOENCODING=UTF-8
    export LC_ALL=C.UTF-8

%runscript
    exec /bin/bash "$@"

%help
    This container supplies the initial filesystem state for the IoT-device
    configuration task and has pytest pre-installed for automated grading.