Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package index
    apt-get update

    # Install Python and pip (needed for pytest)
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install pytest for the grading framework
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare writable home for the non-privileged user during runtime
    # ------------------------------------------------------------------
    mkdir -p /home/user
    # Make sure the directory is writable by *any* unprivileged UID that
    # Apptainer may map to inside the container.
    chmod 0777 /home/user

    # Clean up apt caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure the standard user-installed Python tools are on PATH
    export PATH="$PATH:/home/user/.local/bin"

%runscript
    echo "This container is prepared for the DNS/hostname-resolution experiment."
    echo "Invoke an interactive shell to begin working, e.g.:"
    echo "    apptainer exec <image.sif> /bin/bash"

%labels
    Author="Task prepper"
    Description="Base image prepared for DNS/hostname-resolution experiment with pytest pre-installed."