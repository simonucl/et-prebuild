Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # 1. Create an unprivileged “user” account with home directory /home/user
    useradd -m -s /bin/bash user

    # 2. Install Python 3 and pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # 3. Install pytest for the exercise test harness
    pip3 install --no-cache-dir pytest

    # 4. Clean up APT caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    exec /bin/bash "$@"

%labels
    Author      example
    Description "Container for IoT firewall rule preparation exercise – includes Python and pytest only."