Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Create a dedicated user directory structure
    USER_HOME="/home/user"
    RAW_DIR="$USER_HOME/mock_api_data/raw"
    PROC_DIR="$USER_HOME/mock_api_data/processed"

    mkdir -p "$RAW_DIR" "$PROC_DIR"

    # Create the four JSON files with the exact required byte sizes
    truncate -s 512 "$RAW_DIR/payload_01.json"
    truncate -s 256 "$RAW_DIR/payload_02.json"
    truncate -s 128 "$PROC_DIR/response_01.json"
    truncate -s 256 "$PROC_DIR/response_02.json"

    # Ensure everything is writable by the non-root run-time user (UID 1000)
    chown -R 1000:1000 "$USER_HOME"

    # Install Python, pip and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive \
        apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest

    # Clean APT caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Make sure Python uses UTF-8 by default
    export PYTHONIOENCODING=UTF-8