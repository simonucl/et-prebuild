Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install Python plus PyTest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    pip3 install --no-cache-dir pytest

    # -----------------------------------------------------------------
    # Create the initial project directory tree and populate CSS files
    # -----------------------------------------------------------------
    mkdir -p /home/user/project/assets/css

    # style_main.css
    cat > /home/user/project/assets/css/style_main.css <<'EOF'
body { background-color: #ff0000; color: #00ff00; }
h1   { color: #ff0000; }
p    { border: 1px solid #0000ff; }
EOF

    # style_theme.css
    cat > /home/user/project/assets/css/style_theme.css <<'EOF'
.nav    { background: #ABC123; }
.footer { background: #ff0000; }
.btn    { background: #abc123; }
.header { color: #FFF; }   /* 3-digit code must be ignored */
EOF

    # ---------------------------------------------------
    # Set permissions so an unprivileged user can write
    # ---------------------------------------------------
    chmod 777 /home/user/project              # allow write access for task work
    chmod 755 /home/user/project/assets
    chmod 755 /home/user/project/assets/css
    chmod 644 /home/user/project/assets/css/style_main.css
    chmod 644 /home/user/project/assets/css/style_theme.css

%environment
    # Ensure python is on PATH (already true in Ubuntu, but explicit here)
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%runscript
    echo "Container for CSS colour counting task."
    echo "You are inside the runtime environment."
    exec "$@"