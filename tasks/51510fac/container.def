Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "Updating package index and installing system packages..."
    apt-get update
    # Core utilities needed by the student script (df, lsblk, free, ps, ss/netstat)
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        iproute2 \
        net-tools \
        procps \
        util-linux

    echo "Installing pytest for the test harness..."
    pip3 install --no-cache-dir pytest

    echo "Creating writable home directory for the student user..."
    mkdir -p /home/user
    chmod 0777 /home/user      # ensure any non-root user can write here

    echo "Cleaning up apt caches to keep the image small..."
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Keep a sane PATH; do NOT override $HOME (Apptainer will bind the host HOME)
    export PATH=/usr/local/bin:/usr/local/sbin:/usr/sbin:/usr/bin:/sbin:/bin

%labels
    Author="Container Build Script"
    Description="Base image for the Build Diagnostics Report assignment with pytest pre-installed."

%help
    This container provides a clean Ubuntu 22.04 environment with pytest installed.
    No assignment artifacts are pre-created; students must generate them during
    their task execution.