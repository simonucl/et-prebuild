Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    #!/bin/bash
    set -eux

    # Update package lists and install required software
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        iputils-ping \
        python3 \
        python3-pip

    # Install pytest for the verification suite
    pip3 install --no-cache-dir pytest

    # Create the regular user and ensure its home directory exists
    if ! id -u user >/dev/null 2>&1; then
        useradd -m -d /home/user -s /bin/bash user
    fi
    mkdir -p /home/user
    chown -R user:user /home/user

    # Ensure the initial expected state: NO logs directory or log file
    rm -rf /home/user/logs || true

    # Clean up APT caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Standard PATH; no overrides of HOME so that Apptainer binds host $HOME
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

%labels
    Author="Generated by ChatGPT"
    Description="Environment for loopback ping log exercise with pytest and ping installed."