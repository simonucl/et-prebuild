Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ----- Packages ---------------------------------------------------------
    apt-get update && \
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
    && rm -rf /var/lib/apt/lists/*

    # Install pytest for the grading harness
    pip3 install --no-cache-dir pytest

    # ----- Directory / File Fixture ----------------------------------------
    # Create mandatory directory structure and manifest files.
    mkdir -p /home/user/manifests

    cat > /home/user/manifests/deployment.yaml <<'EOF'
apiVersion: apps/v1
kind: Deployment
metadata:
  name: nginx-deployment
spec:
  selector:
    matchLabels:
      app: nginx
  replicas: 2
  template:
    metadata:
      labels:
        app: nginx
    spec:
      containers:
        - name: nginx
          image: nginx:1.19
          ports:
            - containerPort: 80
EOF

    cat > /home/user/manifests/service.yaml <<'EOF'
apiVersion: v1
kind: Service
metadata:
  name: nginx-service
spec:
  type: ClusterIP
  selector:
    app: nginx
  ports:
    - port: 80
      targetPort: 80
EOF

    cat > /home/user/manifests/configmap.yaml <<'EOF'
apiVersion: v1
kind: ConfigMap
metadata:
  name: example-config
data:
  key1: value1
  key2: value2
EOF

    # Ensure accessible permissions
    chmod -R 755 /home/user

%environment
    chmod 755 /home/user

    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8

%labels
    Author="ChatGPT"
    Description="Base image for the Kubernetes Operator – Concurrent Apply Benchmark & Manifest Metrics task."

%runscript
    # Default action: drop into a shell
    exec /bin/bash "$@"