Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Prepare the initial directory structure and example .sif artefacts
    # ------------------------------------------------------------------
    mkdir -p /home/user/container_repo
    chmod 0777 /home/user
    chmod 0777 /home/user/container_repo

    # Create the required .sif files with their exact byte sizes
    truncate -s 5242880  /home/user/container_repo/alpine_3.12.sif      # 5  MiB
    truncate -s 7340032  /home/user/container_repo/centos_7.sif         # 7  MiB
    truncate -s 11288576 /home/user/container_repo/debian_10.sif        # ~10.8 MiB
    truncate -s 12582912 /home/user/container_repo/ubuntu_18.04.sif     # 12 MiB
    truncate -s 15728640 /home/user/container_repo/ubuntu_20.04.sif     # 15 MiB

    # Ensure the non-root runtime user can manipulate the files
    chmod 0666 /home/user/container_repo/*.sif

%environment
    chmod 755 /home/user

    # Make sure Python user base binary directory is on PATH (helpful for pytest)
    export PATH="$HOME/.local/bin:${PATH}"

%labels
    Author  "Auto-generated setup for Singularity cleanup task"

%help
    This container image is pre-configured for the “old .sif cleanup” task.
    Five sample Singularity images are placed in /home/user/container_repo with
    the exact sizes expected by the grading tests. Pytest is installed so that
    the initial-state test suite can be executed.