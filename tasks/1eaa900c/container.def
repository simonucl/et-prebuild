Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ------------------------------------------------------------------
    # Install Python and pytest
    # ------------------------------------------------------------------
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create required directory structure
    # ------------------------------------------------------------------
    mkdir -p /home/user/build_server
    mkdir -p /home/user/deploy_server
    mkdir -p /home/user/sync_logs

    # ------------------------------------------------------------------
    # Populate the source directory with the exact files, sizes and mtimes
    # ------------------------------------------------------------------
    # app-core-1.0.jar  – 1024 bytes, mtime 2023-01-15 10:00:00
    truncate -s 1024 /home/user/build_server/app-core-1.0.jar
    touch -t 202301151000.00 /home/user/build_server/app-core-1.0.jar

    # app-web-1.0.war  – 2048 bytes, mtime 2023-01-15 10:00:00
    truncate -s 2048 /home/user/build_server/app-web-1.0.war
    touch -t 202301151000.00 /home/user/build_server/app-web-1.0.war

    # readme.txt       –   25 bytes, mtime 2023-01-15 09:59:00
    truncate -s 25 /home/user/build_server/readme.txt
    touch -t 202301150959.00 /home/user/build_server/readme.txt

    # ------------------------------------------------------------------
    # Set permissions
    # ------------------------------------------------------------------
    # Source files: read-only for everyone
    chmod 644 /home/user/build_server/app-core-1.0.jar
    chmod 644 /home/user/build_server/app-web-1.0.war
    chmod 644 /home/user/build_server/readme.txt

    # Directories
    chmod 755 /home/user/build_server        # read-only source
    chmod 777 /home/user/deploy_server       # writable destination (for unprivileged user)
    chmod 777 /home/user/sync_logs           # writable log directory

%labels
    Author artifact-sync-preparer
    Description "Environment providing initial state for artifact sync task"

%help
    This container sets up the initial filesystem layout and installs pytest
    so that students can implement and test the artifact-synchronisation task
    described in the assignment.