Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author integration-task-generator
    Description Base image for "API availability check" exercise

%post
    set -e

    # Update package lists and install required packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        curl \
        ca-certificates \
        && rm -rf /var/lib/apt/lists/*

    # Install pytest for the automated grader
    pip3 install --no-cache-dir pytest

    # Ensure /home/user exists and is writable by whoever runs the container
    mkdir -p /home/user
    chmod 0777 /home/user

%environment
    chmod 755 /home/user

    # Make sure Python points to python3
    export PYTHONIOENCODING=utf-8
    export PATH="$PATH:/usr/local/bin"

%runscript
    echo "Container for the API availability check exercise."
    echo "Enter the container with 'apptainer shell' to start working."