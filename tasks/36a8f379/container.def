Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install required OS packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        jq \
        ca-certificates
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the test harness
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state expected by the automated tests
    # ------------------------------------------------------------------
    # Create the directory structure
    mkdir -p /home/user/manifests

    # Make the entire /home/user tree writable by the run-time (non-root) user
    chmod -R 0777 /home/user

    # ------------------------------------------------------------------
    # Create the three Deployment manifest files with exact byte-for-byte
    # content (including trailing newlines)
    # ------------------------------------------------------------------

    # 1. frontend-deploy.json
    cat > /home/user/manifests/frontend-deploy.json <<'EOF_FRONTEND'
{
  "apiVersion": "apps/v1",
  "kind": "Deployment",
  "metadata": {
    "name": "frontend",
    "namespace": "prod",
    "labels": {
      "app": "frontend"
    }
  },
  "spec": {
    "replicas": 3,
    "template": {
      "metadata": {
        "labels": {
          "app": "frontend"
        }
      },
      "spec": {
        "containers": [
          {
            "name": "frontend",
            "image": "company/frontend:v2"
          }
        ]
      }
    }
  }
}
EOF_FRONTEND

    # 2. backend-deploy.json
    cat > /home/user/manifests/backend-deploy.json <<'EOF_BACKEND'
{
  "apiVersion": "apps/v1",
  "kind": "Deployment",
  "metadata": {
    "name": "backend",
    "namespace": "prod",
    "labels": {
      "app": "backend"
    }
  },
  "spec": {
    "replicas": 2,
    "template": {
      "metadata": {
        "labels": {
          "app": "backend"
        }
      },
      "spec": {
        "containers": [
          {
            "name": "backend",
            "image": "company/backend:v1"
          }
        ]
      }
    }
  }
}
EOF_BACKEND

    # 3. worker-deploy.json
    cat > /home/user/manifests/worker-deploy.json <<'EOF_WORKER'
{
  "apiVersion": "apps/v1",
  "kind": "Deployment",
  "metadata": {
    "name": "worker",
    "namespace": "batch",
    "labels": {
      "app": "worker"
    }
  },
  "spec": {
    "replicas": 4,
    "template": {
      "metadata": {
        "labels": {
          "app": "worker"
        }
      },
      "spec": {
        "containers": [
          {
            "name": "worker",
            "image": "company/worker:v5"
          }
        ]
      }
    }
  }
}
EOF_WORKER

    # Ensure correct permissions on the manifest files
    chmod 0644 /home/user/manifests/*.json

%environment
    chmod 755 /home/user

    # Keep environment minimal; do not override HOME so it maps to the host.
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%labels
    Author Kubernetes-Platform-Operator-Setup
    Description "Container with initial state for manifest summarization task"
    Version v1