Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install Python/pip for pytest
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip

    # Install pytest for the test harness
    pip3 install --no-cache-dir pytest

    # Ensure /home/user exists and is writable by any non-root user
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up apt caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # No HOME override; Apptainer will bind the host $HOME automatically
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    echo "Container for timezone task."
    echo "Run your commands or tests as needed."

%help
    This container supplies a minimal Ubuntu 22.04 environment with pytest
    pre-installed.  No task artefacts (e.g., /home/user/logs/timezone_check.log)
    are present so that the learner can create them during the exercise.