FROM ubuntu:22.04

# Author: AI-Generated
# Description: Environment for observability assignment – resolver file pre-populated, pytest installed.

ENV HOME=/home/user

RUN set -e && \
    apt-get update -y && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates && \
    pip3 install --no-cache-dir pytest && \
    mkdir -p /home/user/observability

RUN cat <<'EOF' > /home/user/observability/node.resolv
# Generated by NetworkManager
search corp.local
nameserver 10.98.0.2
nameserver 10.98.0.3
options timeout:1 attempts:3
EOF

RUN chmod 755 /home/user/observability && \
    chmod 644 /home/user/observability/node.resolv && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

LABEL Author="AI-Generated"
LABEL Description="Environment for observability assignment – resolver file pre-populated, pytest installed."