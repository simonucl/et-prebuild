Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install Python + pip
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates

    # Install pytest for the grading framework
    pip3 install --no-cache-dir pytest

    # -----------------------------------------------------------------
    # Prepare the initial file-system state required by the assignment
    # -----------------------------------------------------------------
    # Create the target directory structure
    mkdir -p /home/user/observability

    # Create the resolver configuration exactly as specified
    cat <<'EOF' > /home/user/observability/node.resolv
# Generated by NetworkManager
search corp.local
nameserver 10.98.0.2
nameserver 10.98.0.3
options timeout:1 attempts:3
EOF

    # Ensure permissions are broadly readable
    chmod 755 /home/user/observability
    chmod 644 /home/user/observability/node.resolv

    # Clean up apt cache to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    # Nothing to override here – keep the default HOME (/home/user)

%labels
    Author  AI-Generated
    Description "Environment for observability assignment – resolver file pre-populated, pytest installed."