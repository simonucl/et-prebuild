Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "Updating package lists and installing Python + pip..."
    apt-get update -y
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        locales
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create the expected directory structure and seed data
    # ------------------------------------------------------------------
    echo "Creating /home/user/tickets directory and populating CSV files..."
    mkdir -p /home/user/tickets

    # open_tickets.csv
    cat > /home/user/tickets/open_tickets.csv <<'CSV_EOF'
ticket_id,priority,assigned_to,customer,issue_type,status
TCK-1001,High,alice,Acme Corp,Network,Open
TCK-1002,Medium,bob,Globex Inc,Hardware,Open
TCK-1003,Low,,Initech,Software,Open
TCK-1004,High,charlie,"A&B Consulting",Network,Open
CSV_EOF

    # closed_tickets.csv
    cat > /home/user/tickets/closed_tickets.csv <<'CSV_EOF'
ticket_id,resolution_time_min,assigned_to,customer,issue_type,status
TCK-0901,45,dan,Acme Corp,Network,Closed
TCK-0902,120,alice,Globex Inc,Hardware,Closed
TCK-0903,30,alice,Initech,Software,Closed
TCK-0904,15,bob,Acme Corp,Hardware,Closed
CSV_EOF

    # Ensure all users can write inside /home/user/tickets so the agent (non-root)
    # can generate the required output files during testing.
    chmod -R 0777 /home/user/tickets

%environment
    chmod 755 /home/user

    # Do not alter $HOME; just ensure python and pytest are on PATH.
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author ticket-processing-setup
    Description "Base image for the ticket-processing exercise with initial CSV data and pytest installed."

%help
    This Apptainer image provides the starting environment for the
    “ticket-processing” CLI exercise.  
      • /home/user/tickets/open_tickets.csv  
      • /home/user/tickets/closed_tickets.csv  
    Pytest is pre-installed for the grading harness.