FROM python:3.11-slim

WORKDIR /home/user/reconcilor

RUN useradd -m -s /bin/bash user

RUN mkdir -p /home/user/reconcilor/src/stale_reporter \
    /home/user/reconcilor/data \
    /home/user/reconcilor/out

RUN cat > /home/user/reconcilor/pyproject.toml <<'EOF'
[build-system]
requires = ["setuptools"]
build-backend = "setuptools.build_meta"

[project]
name = "stale-reporter"
version = "0.1.0"
description = "Offline stale asset reporter"
requires-python = ">=3.11"

[project.scripts]
stale-report = "stale_reporter.cli:run"
EOF

RUN cat > /home/user/reconcilor/setup.py <<'EOF'
import setuptools

setuptools.setup(
    name="stale-reporter",
    version="0.1.0",
    package_dir={"": "src"},
    packages=setuptools.find_packages("src"),
    entry_points={"console_scripts": ["stale-report=stale_reporter.cli:run"]},
)
EOF

RUN cat > /home/user/reconcilor/src/stale_reporter/__init__.py <<'EOF'
__all__ = ["__version__"]
__version__ = "0.1.0"
EOF

RUN cat > /home/user/reconcilor/src/stale_reporter/cli.py <<'EOF'
import argparse
import csv
import json
import datetime
import pathlib


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser()
    parser.add_argument("--data-dir", default="/home/user/reconcilor/data")
    parser.add_argument("--output-dir", default="/home/user/reconcilor/out")
    parser.add_argument("--as-of", required=True)
    return parser.parse_args()


def load_checksums(path: pathlib.Path) -> dict[str, str]:
    checksums: dict[str, str] = {}
    for line in path.read_text().splitlines():
        if not line or line.startswith("#"):
            continue
        # BUG: sha256sum files separate digest and path with whitespace, not commas.
        name, digest = line.split(",", 1)
        checksums[name] = digest
    return checksums


def main() -> int:
    args = parse_args()
    data_dir = pathlib.Path(args.data_dir)
    out_dir = pathlib.Path(args.output_dir)
    out_dir.mkdir(parents=True, exist_ok=True)

    as_of = datetime.date.fromisoformat(args.as_of)
    checksums = load_checksums(data_dir / "checksums.sha256")
    rows = []
    with (data_dir / "inventory.csv").open(newline="") as fh:
        for row in csv.DictReader(fh):
            seen = datetime.date.fromisoformat(row["last_seen"])
            age_days = (as_of - seen).days
            # BUG: this ignores classification-specific retention thresholds.
            if age_days > 90:
                row["age_days"] = age_days
                row["sha256"] = checksums.get(row["path"])
                rows.append(row)

    # BUG: output is pretty-printed, sorted by path only, and has the wrong summary shape.
    rows.sort(key=lambda item: item["path"])
    payload = {
        "as_of": args.as_of,
        "stale_assets": rows,
        "summary": {"count": len(rows)},
    }
    (out_dir / "stale_manifest.json").write_text(json.dumps(payload, indent=2) + "\n")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
EOF

RUN cat > /home/user/reconcilor/data/inventory.csv <<'EOF'
path,owner,last_seen,classification
services/api/config.yml,team-api,2024-01-10,prod
services/api/README.md,team-api,2024-03-29,prod
warehouse/daily/export.parquet,team-data,2023-09-01,archive
warehouse/tmp/session.dump,team-data,2024-01-01,ephemeral
security/keys/rotated.key,team-security,2023-02-28,archive
frontend/assets/legacy-logo.svg,team-web,2023-12-01,prod
frontend/assets/current-logo.svg,team-web,2024-04-01,prod
EOF

RUN cat > /home/user/reconcilor/data/checksums.sha256 <<'EOF'
# sha256sum-style manifest generated by the artifact store
aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa  services/api/config.yml
bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb  services/api/README.md
cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc  warehouse/daily/export.parquet
dddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddd  warehouse/tmp/session.dump
eeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeee  frontend/assets/legacy-logo.svg
ffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff  frontend/assets/current-logo.svg
EOF

RUN chown -R user:user /home/user/reconcilor && \
    chmod -R u+rwX,go+rX /home/user/reconcilor

USER user
WORKDIR /home/user/reconcilor

CMD ["bash"]
