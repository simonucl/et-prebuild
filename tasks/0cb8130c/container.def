Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update apt and install Python & pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state for the migration exercise
    # ------------------------------------------------------------------
    mkdir -p /home/user
    cat >/home/user/service_mappings.csv <<'EOF'
Service,OldURL,NewURL
auth,https://old.example.com/auth,https://api.new-corp.io/auth
billing,https://old.example.com/bill,https://api.new-corp.io/billing
catalog,https://old.example.com/catalog,https://api.new-corp.io/catalog
inventory,https://old.example.com/inv,https://api.new-corp.io/inventory
shipping,https://old.example.com/ship,https://api.new-corp.io/shipping
EOF

    # Ensure permissions are world-readable
    chmod 644 /home/user/service_mappings.csv

    # Do NOT create /home/user/migration_report.txt; it must be absent initially
%environment
    chmod 755 /home/user

    # Ensure Python and pytest are on PATH
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%runscript
    echo "Container for CSV-to-report migration task. Execute your commands inside an interactive shell or via 'apptainer exec'."