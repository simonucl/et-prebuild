Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update && \
        apt-get install -y --no-install-recommends python3 python3-pip locales && \
        rm -rf /var/lib/apt/lists/*

    pip install --no-cache-dir pytest

    # Ensure UTF-8 locale is available
    echo "en_US.UTF-8 UTF-8" > /etc/locale.gen
    locale-gen en_US.UTF-8

    # Set up directory structure and seed CSV file
    mkdir -p /home/user/releases

    # Make /home/user and its sub-directories writable for the unprivileged user
    chmod 777 /home/user
    chmod 777 /home/user/releases

    # Create the initial CSV exactly as required (7 lines, each ending with LF)
    cat >/home/user/releases/deployments.csv <<'EOF'
id,project,version,environment,status,release_date
1,frontend,1.4.2,staging,completed,2024-01-12
2,backend,2.3.0,production,pending,2024-03-05
3,api,3.1.1,staging,pending,2024-03-11
4,billing,4.0.0,production,aborted,2024-02-09
5,frontend,1.4.3,production,pending,2024-03-14
6,worker,0.9.8,staging,completed,2024-02-28
EOF

    chmod 644 /home/user/releases/deployments.csv

%environment
    chmod 755 /home/user

    export LANG=en_US.UTF-8
    export LC_ALL=en_US.UTF-8
    export LANGUAGE=en_US:en