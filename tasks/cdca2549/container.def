Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python tooling and pytest
    apt-get update && \
        apt-get install -y --no-install-recommends python3 python3-pip ca-certificates && \
        rm -rf /var/lib/apt/lists/*

    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state required by the grading tests
    # ------------------------------------------------------------------
    mkdir -p /home/user

    # 1. /home/user/api_response.txt — exactly 5 bytes: 'hello' (no newline)
    printf 'hello' > /home/user/api_response.txt

    # 2. /home/user/reference.sha256 — classic sha256sum format, trailing newline
    printf '2cf24dba5fb0a30e26e83b2ac5b9e29e1b161e5c1fa7425e73043362938b9824  api_response.txt\n' \
        > /home/user/reference.sha256

    # Permissions: readable by all; parent dir writable so the student can add files
    chmod 644 /home/user/api_response.txt /home/user/reference.sha256
    chmod 777 /home/user

%environment
    chmod 755 /home/user

    # Ensure Python is on PATH (default for Ubuntu, but keep explicit)
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    exec "$@"

%labels
    Maintainer "Generated for Apptainer task setup"
    Description "Container with initial state for mock-API integrity check exercise"