FROM ubuntu:22.04

# Labels
LABEL Author="Generated by OpenAI ChatGPT"
LABEL Description="Container image for credential-rotation security exercise with pytest pre-installed."

# Help information (as comments)
# This container sets up the initial environment for the credential-rotation
# exercise.  It includes:
#   • Python 3, pip, pytest, and jsonschema
#   • jq for command-line JSON manipulation
#   • The initial secrets under /home/user/secrets
#
# Students run their solution inside the container (non-root) and must:
#   1. Validate credentials.json against its schema.
#   2. Rotate the tokens based on new_tokens.json.
#   3. Write the required rotation.log.
#
# See the task description for full details.

# Install required packages
RUN set -e && \
    apt-get update -y && \
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        jq \
        ca-certificates \
        git \
        locales && \
    pip3 install --no-cache-dir pytest jsonschema && \
    locale-gen en_US.UTF-8 && \
    update-locale LANG=en_US.UTF-8 && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Prepare initial file system state for the exercise
RUN mkdir -p /home/user/secrets && \
    chmod 0777 /home/user && \
    chmod 0777 /home/user/secrets

# credentials.json (two-space indentation, trailing newline)
RUN cat > /home/user/secrets/credentials.json <<'EOF'
[
  {
    "service": "db",
    "token": "db-12345",
    "created": "2022-12-01",
    "expires": "2023-03-01"
  },
  {
    "service": "ci",
    "token": "ci-abcde",
    "created": "2022-12-15",
    "expires": "2023-03-15"
  }
]
EOF

# credentials_schema.json (trailing newline)
RUN cat > /home/user/secrets/credentials_schema.json <<'EOF'
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["service", "token", "created", "expires"],
    "properties": {
      "service": { "type": "string" },
      "token":   { "type": "string" },
      "created": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
      "expires": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" }
    }
  }
}
EOF

# new_tokens.json (trailing newline)
RUN cat > /home/user/secrets/new_tokens.json <<'EOF'
[
  { "service": "db", "token": "db-67890" },
  { "service": "ci", "token": "ci-fghij" }
]
EOF

# Ensure the student (non-root) user will be able to modify the files
RUN chmod 0666 /home/user/secrets/credentials.json && \
    chmod 0666 /home/user/secrets/credentials_schema.json && \
    chmod 0666 /home/user/secrets/new_tokens.json

# Environment variables
ENV LANG=en_US.UTF-8
ENV LC_ALL=en_US.UTF-8
ENV PATH=/usr/local/bin:/usr/bin:/bin

WORKDIR /home/user