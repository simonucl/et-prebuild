BootStrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Update package lists and install Python tooling required for the task
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-venv \
        python3-pip

    # Install pytest for the test harness
    pip3 install --no-cache-dir pytest

    # Create the placeholder home directory expected by the tests
    mkdir -p /home/user
    # Ensure it is writable by whichever unprivileged UID runs inside the container
    chmod 0777 /home/user

    # Clean up APT caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Make sure the pytest entry-point installed by pip is on the PATH
    export PATH="/usr/local/bin:${PATH}"

%runscript
    # Default command: start an interactive shell
    exec /bin/bash