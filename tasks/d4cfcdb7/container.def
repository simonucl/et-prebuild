Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # 1. Base tooling
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        tzdata
    pip3 install --no-cache-dir pytest

    # 2. Prepare initial ETL workspace
    ETL_BASE="/home/user/etl"
    mkdir -p "${ETL_BASE}/input" "${ETL_BASE}/output" "${ETL_BASE}/config" "${ETL_BASE}/logs"

    # Seed input data
    cat > "${ETL_BASE}/input/input_data.csv" <<'CSV'
id,name
1,Alice
CSV

    # Faulty YAML configuration (as described in the task)
    cat > "${ETL_BASE}/config/job_config.yaml" <<'YAML'
# Nightly ETL job configuration (intentionally incorrect)
delimiter: ";"
YAML

    # Historical log containing the delimiter error
    cat > "${ETL_BASE}/logs/etl_2023-01-01.log" <<'LOG'
2023-01-01T00:00:01Z INFO  Starting ETL job
2023-01-01T00:00:02Z ERROR DelimiterMismatchError: expected ';' but found ',' on line 1
LOG

    # 3. Permissions: make everything modifiable by the (non-root) runtime user
    chmod -R 0777 /home/user/etl

%environment
    chmod 755 /home/user

    export PYTHONUNBUFFERED=1

%labels
    Author  = ChatGPT
    Task    = On-prem ETL debug environment
    Purpose = Provide initial failing state for learner to fix