FROM ubuntu:22.04

# %help and descriptive comments
# Author="Generated by ChatGPT"
# Description="Workspace for SHA-256 compliance audit exercise with pytest pre-installed."

RUN set -e && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        coreutils && \
    pip3 install --no-cache-dir pytest && \
    mkdir -p /home/user/compliance_docs && \
    touch /home/user/compliance_docs/passwd_policy_v1.2.txt && \
    chmod 0755 /home/user && \
    chmod 0755 /home/user/compliance_docs && \
    chmod 0644 /home/user/compliance_docs/passwd_policy_v1.2.txt && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

RUN chmod 755 /home/user

ENV PATH="/usr/local/bin:/usr/bin:/bin:${PATH}"

LABEL Author="Generated by ChatGPT"
LABEL Description="Workspace for SHA-256 compliance audit exercise with pytest pre-installed."