Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install Python and utilities.
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        coreutils

    # Install pytest for the automated test suite.
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare the initial filesystem state required for the exercise.
    # ------------------------------------------------------------------

    # Create the compliance_docs directory and the empty policy file.
    mkdir -p /home/user/compliance_docs
    touch /home/user/compliance_docs/passwd_policy_v1.2.txt

    # Set permissions:
    #  • Directories: 0755  (world-readable & traversable)
    #  • File       : 0644  (world-readable)
    chmod 0755 /home/user
    chmod 0755 /home/user/compliance_docs
    chmod 0644 /home/user/compliance_docs/passwd_policy_v1.2.txt

    # Intentionally DO NOT create /home/user/audit_log; the student
    # command must create it as part of the task.

    # Clean up apt caches to keep the image small.
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure Python executables are in PATH.
    export PATH="/usr/local/bin:/usr/bin:/bin:${PATH}"

%labels
    Author="Generated by ChatGPT"
    Description="Workspace for SHA-256 compliance audit exercise with pytest pre-installed."