Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get -y install python3 python3-pip
    pip3 install --no-cache-dir pytest
    # Create the base home directory expected by the tests
    mkdir -p /home/user
    chmod 0777 /home/user   # ensure any non-root user can create sub-directories

%environment
    chmod 755 /home/user

    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author="Generated by ChatGPT"
    Description="Environment for vulnerability-scanning workspace exercise with pytest pre-installed."