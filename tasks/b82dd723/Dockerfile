FROM ubuntu:22.04

# Labels
LABEL Author="Generated by ChatGPT"
LABEL Description="Environment for vulnerability-scanning workspace exercise with pytest pre-installed."

# Post installation commands
RUN set -e && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get -y install python3 python3-pip && \
    pip3 install --no-cache-dir pytest && \
    mkdir -p /home/user && \
    chmod 0777 /home/user

# Environment variables
ENV PATH=/usr/local/bin:/usr/bin:/bin:$PATH