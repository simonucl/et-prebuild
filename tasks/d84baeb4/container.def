Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update -y
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest

    # Create the project directory structure
    mkdir -p /home/user/project

    # Create translations.yml with the initial English and French blocks only
    cat > /home/user/project/translations.yml <<'YAML'
en:
  login: "Login"
  logout: "Logout"

fr:
  login: "Connexion"
  logout: "Déconnexion"
YAML

    # Create settings.toml with the initial values
    cat > /home/user/project/settings.toml <<'TOML'
[localization]
default_locale = "en_US"
fallback_locale = "en_US"
TOML

    # Ensure the user can modify these files later
    chmod -R 0777 /home/user

%labels
    chmod 755 /home/user

    Author localization-task-setup
    Description "Container prepared for the localization editing exercise"

%environment
    # Use Python 3 by default
    export PYTHONIOENCODING=UTF-8
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    echo "Container for localization exercise. Use this shell to complete the task."
    exec /bin/bash "$@"