FROM ubuntu:22.04

# Help / metadata comments
# Author="Autogenerated for role-frequency task"
# Description="Container providing initial state for inventory counting exercise"

ENV LC_ALL=C.UTF-8
ENV LANG=C.UTF-8

RUN set -e && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get -y install --no-install-recommends \
        python3 \
        python3-pip && \
    pip3 install --no-cache-dir pytest && \
    mkdir -p /home/user/provisioning

RUN cat > /home/user/provisioning/inventory.csv <<'EOF'
web-01,web,prod
web-02,web,prod
db-01,db,prod
cache-01,cache,prod
db-02,db,staging
web-03,web,staging
cache-02,cache,staging
queue-01,queue,prod
queue-02,queue,staging
queue-03,queue,dev
web-04,web,dev
db-03,db,dev
EOF

RUN chmod 644 /home/user/provisioning/inventory.csv && \
    chmod 777 /home/user/provisioning && \
    chmod 755 /home/user