Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Basic packages and Python tooling
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get -y install --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create the initial required inventory file for the exercise
    # ------------------------------------------------------------------
    mkdir -p /home/user/provisioning

    cat > /home/user/provisioning/inventory.csv <<'EOF'
web-01,web,prod
web-02,web,prod
db-01,db,prod
cache-01,cache,prod
db-02,db,staging
web-03,web,staging
cache-02,cache,staging
queue-01,queue,prod
queue-02,queue,staging
queue-03,queue,dev
web-04,web,dev
db-03,db,dev
EOF

    # Permissions:
    # • inventory.csv must be world-readable
    # • provisioning directory must be writable so the student can add files
    chmod 644 /home/user/provisioning/inventory.csv
    chmod 777 /home/user/provisioning

    # Ensure parent directory exists and is accessible
    chmod 755 /home/user

%environment
    # Keep default HOME provided by Apptainer runtime; no overrides needed
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%labels
    Author="Autogenerated for role-frequency task"
    Description="Container providing initial state for inventory counting exercise"