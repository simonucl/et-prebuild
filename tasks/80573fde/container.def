Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Update package index and install Python + pip
    apt-get update && \
    apt-get install -y --no-install-recommends python3 python3-pip && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # -----------------------------------------------------------------
    # Pre-seed the required cloud-cost CSV files for the grading tests
    # -----------------------------------------------------------------
    mkdir -p /home/user/cloud_costs

    printf 'aws,2023-09,123.45\n'   > /home/user/cloud_costs/aws_cost_report.csv
    printf 'azure,2023-09,67.89\n'  > /home/user/cloud_costs/azure_cost_report.csv
    printf 'gcp,2023-09,45.67\n'    > /home/user/cloud_costs/gcp_cost_report.csv

    # Set safe permissions so the unprivileged student can read the CSVs
    chmod 755 /home/user
    chmod 755 /home/user/cloud_costs
    chmod 644 /home/user/cloud_costs/*.csv

%environment
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8