Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update && \
        apt-get install -y --no-install-recommends python3 python3-pip && \
        pip3 install --no-cache-dir pytest && \
        rm -rf /var/lib/apt/lists/*

    # Create required directory structure and reference files
    mkdir -p /home/user/system_info

    # timezone.conf  – must be exactly "Etc/UTC\n"
    printf 'Etc/UTC\n' > /home/user/system_info/timezone.conf

    # locale.conf – must be exactly "en_US.UTF-8\n"
    printf 'en_US.UTF-8\n' > /home/user/system_info/locale.conf

    # Set sane permissions
    chmod 0755 /home/user
    chmod 0755 /home/user/system_info
    chmod 0644 /home/user/system_info/timezone.conf /home/user/system_info/locale.conf

%environment
    chmod 755 /home/user

    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    echo "Apptainer image for the Environment Manifest task."
    echo "Start an interactive shell with: apptainer exec <image> /bin/bash"