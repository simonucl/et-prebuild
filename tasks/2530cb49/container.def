Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Basic tooling
    apt-get update && \
    apt-get install -y --no-install-recommends python3 python3-pip && \
    rm -rf /var/lib/apt/lists/*

    # Python test framework for graders
    pip3 install --no-cache-dir pytest

    # Exercise data setup
    mkdir -p /home/user/mock_scans
    chmod 755 /home/user /home/user/mock_scans

    cat >/home/user/mock_scans/10.0.0.5.nmap <<'EOF'
Starting Nmap 7.80 ( https://nmap.org ) at 2023-12-01 10:00 UTC
Nmap scan report for 10.0.0.5
Host is up (0.00020s latency).
Not shown: 997 filtered ports
PORT    STATE SERVICE
22/tcp  open  ssh
80/tcp  open  http
443/tcp closed https

Nmap done: 1 IP address (1 host up) scanned in 1.12 seconds
EOF

    cat >/home/user/mock_scans/10.0.0.8.nmap <<'EOF'
Starting Nmap 7.80 ( https://nmap.org ) at 2023-12-01 10:02 UTC
Nmap scan report for 10.0.0.8
Host is up (0.00025s latency).
Not shown: 998 closed ports
PORT    STATE SERVICE
21/tcp  open  ftp
23/tcp  open  telnet
80/tcp  closed http

Nmap done: 1 IP address (1 host up) scanned in 1.05 seconds
EOF

    cat >/home/user/mock_scans/10.0.0.12.nmap <<'EOF'
Starting Nmap 7.80 ( https://nmap.org ) at 2023-12-01 10:05 UTC
Nmap scan report for 10.0.0.12
Host is up (0.00021s latency).
Not shown: 996 filtered ports
PORT    STATE SERVICE
25/tcp  open  smtp
110/tcp open  pop3
143/tcp open  imap
53/udp  open  domain

Nmap done: 1 IP address (1 host up) scanned in 1.33 seconds
EOF

    chmod 644 /home/user/mock_scans/*.nmap

%environment
    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8

%runscript
    echo "Container ready for the open-ports CSV pipeline exercise."