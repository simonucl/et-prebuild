Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author      ChatGPT
    Description SQLite smoke-test environment with pytest pre-installed.

%post
    set -e

    # Update package index and install required tools
    apt-get update
    apt-get install -y --no-install-recommends \
        sqlite3 \
        python3 \
        python3-pip

    # Install pytest for the runtime checker
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare filesystem layout expected by the test harness
    # ------------------------------------------------------------------
    # Create /home/user and make it writable by any unprivileged user
    mkdir -p /home/user
    chmod 0777 /home/user

    # Create the dev_data directory
    mkdir -p /home/user/dev_data
    chmod 0755 /home/user/dev_data

    # Build the SQLite database with the prescribed schema & seed data
    sqlite3 /home/user/dev_data/api_responses.db <<'SQL'
    CREATE TABLE responses(
        id INTEGER PRIMARY KEY,
        endpoint TEXT,
        status_code INTEGER,
        ts TEXT
    );
    INSERT INTO responses(id, endpoint, status_code, ts) VALUES
        (1, '/v1/accounts', 200, '2023-10-01T10:00:00Z'),
        (2, '/v1/accounts', 500, '2023-10-01T10:01:00Z'),
        (3, '/v1/accounts', 200, '2023-10-01T10:02:00Z'),
        (4, '/v1/payments', 200, '2023-10-01T10:03:00Z');
SQL

    # Ensure database file permissions are readable by all but not writable by group/other
    chmod 0644 /home/user/dev_data/api_responses.db

%environment
    chmod 755 /home/user

    # Ensure pip-installed executables are reachable
    export PATH="/usr/local/bin:$PATH"