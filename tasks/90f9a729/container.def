Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # Update apt metadata and install Python + pip
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-setuptools \
        ca-certificates

    # Install pytest for the test harness
    pip3 install --no-cache-dir pytest

    # Create a writable home directory for the student
    mkdir -p /home/user
    chmod 0777 /home/user     # ensure any UID can read/write/execute

    # Add a nominal 'user' account (UID/GID 1000) pointing to /home/user.
    # This is not strictly required by the tests, but helps some tools.
    if ! grep -qE '^user:' /etc/passwd; then
        echo 'user:x:1000:1000::/home/user:/bin/bash' >> /etc/passwd
        echo 'user:x:1000:' >> /etc/group
    fi

    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Minimal sane environment; do NOT override $HOME.
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

%labels
    Author "container-build-script"
    Description "Ubuntu 22.04 image prepared for capacity planner assignment with pytest installed."

%runscript
    exec /bin/bash "$@"