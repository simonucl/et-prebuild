Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # Set up initial dashboard directory and files
    mkdir -p /home/user/dashboards/new

    # Create single-line JSON files with TEMP-prefixed UIDs (no trailing newlines)
    printf '{"title":"Database Metrics","uid":"TEMP-db789","tags":["database"]}' \
        > /home/user/dashboards/new/db_metrics.json
    printf '{"title":"Queue Depth","uid":"TEMP-queue456","tags":["queues"]}' \
        > /home/user/dashboards/new/queue_depth.json
    printf '{"title":"System Overview","uid":"TEMP-abc123","tags":["system"]}' \
        > /home/user/dashboards/new/system_overview.json

    # Give the runtime (non-root) user write access so the agent can edit files
    chmod 777 /home/user /home/user/dashboards /home/user/dashboards/new
    chmod 666 /home/user/dashboards/new/*.json

%environment
    chmod 755 /home/user

    # Ensure python binaries installed via pip are on PATH
    export PATH="/usr/local/bin:$PATH"