Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 python3-pip

    pip3 install --no-cache-dir pytest

    # -----------------------------------------------------------------
    # Prepare initial workspace state expected by the autograder
    # -----------------------------------------------------------------

    # Create non-privileged user `user` with home directory /home/user
    if ! id -u user >/dev/null 2>&1; then
        useradd -m -s /bin/bash user
    fi

    # Ensure the home directory exists with correct ownership
    mkdir -p /home/user
    chown -R user:user /home/user

    # Seed file: /home/user/sample.env
    cat >/home/user/sample.env <<'EOF'
# Sample environment file
EOF

    chown user:user /home/user/sample.env
    chmod 644 /home/user/sample.env

    # NOTE:
    # * Do NOT create /home/user/pipelines or any of its sub-directories.
    # * Only the single file above should exist before the agent runs.

%environment
    chmod 755 /home/user

    # Keep Python on PATH for convenience
    export PATH=/usr/local/bin:$PATH

%runscript
    echo "Container for CI/CD workspace setup task. Run your commands inside the shell."
    exec "/bin/bash" "$@"

%labels
    Author CI-Task-Builder
    Description "Apptainer image seeded for platform-engineer workspace task"