Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install Python + pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # Create the required /home/user directory (but nothing inside it)
    mkdir -p /home/user
    chmod 755 /home/user

    # Clean up APT cache to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    # Ensure Python and common utilities are on PATH
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author benchmark-setup
    Description "Base container for benchmarking assignment (pytest included)"