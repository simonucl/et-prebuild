Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update and install essentials
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------ #
    # Create the ci_metrics directory and populate the required CSV data #
    # ------------------------------------------------------------------ #
    mkdir -p /home/user/ci_metrics

    cat <<'EOF' > /home/user/ci_metrics/build_2023-05-01.csv
job_id,status,duration_sec
101,success,300
102,failure,420
103,success,210
EOF

    cat <<'EOF' > /home/user/ci_metrics/build_2023-05-02.csv
job_id,status,duration_sec
104,success,180
105,success,240
106,failure,360
107,success,120
EOF

    cat <<'EOF' > /home/user/ci_metrics/build_2023-05-03.csv
job_id,status,duration_sec
108,failure,600
109,failure,450
EOF

    # Ensure the non-root runtime user can read and write here
    chmod -R a+rw /home/user/ci_metrics

%environment
    chmod 755 /home/user

    # Keep environment minimal; rely on container runtime to bind $HOME
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%labels
    Author="Generated by ChatGPT"
    Description="CI metrics exercise environment with fixture CSV files and pytest installed."

%runscript
    echo "This container sets up the initial state for the CI metrics exercise."
    echo "Enter the shell to begin: /bin/bash"