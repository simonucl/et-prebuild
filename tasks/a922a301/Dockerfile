# syntax=docker/dockerfile:1
FROM ubuntu:22.04

# Help / metadata
# Author="Generated by ChatGPT"
# Description="CI metrics exercise environment with fixture CSV files and pytest installed."

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked --mount=type=cache,target=/var/lib/apt,sharing=locked --mount=type=cache,target=/root/.cache/pip set -e && \
    apt-get update && \
    apt-get install -y --no-install-recommends python3 python3-pip && \
    pip3 install --no-cache-dir pytest && \
    mkdir -p /home/user/ci_metrics

RUN cat <<'EOF' > /home/user/ci_metrics/build_2023-05-01.csv
job_id,status,duration_sec
101,success,300
102,failure,420
103,success,210
EOF

RUN cat <<'EOF' > /home/user/ci_metrics/build_2023-05-02.csv
job_id,status,duration_sec
104,success,180
105,success,240
106,failure,360
107,success,120
EOF

RUN cat <<'EOF' > /home/user/ci_metrics/build_2023-05-03.csv
job_id,status,duration_sec
108,failure,600
109,failure,450
EOF

RUN chmod -R a+rw /home/user/ci_metrics && chmod 755 /home/user

ENV LC_ALL=C.UTF-8
ENV LANG=C.UTF-8

CMD echo "This container sets up the initial state for the CI metrics exercise." && \
    echo "Enter the shell to begin: /bin/bash"