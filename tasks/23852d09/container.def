Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author ChatGPT
    Description Environment for diagnostic rsync task – provides initial source files and pytest.

%post
    set -e

    # Update package index and install required tools
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3-pip \
        rsync \
        ca-certificates

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial directory structure and diagnostic files
    # ------------------------------------------------------------------
    # Create /home/user with wide-open permissions so the unprivileged
    # runtime user (unknown UID) can create additional directories/files.
    mkdir -p /home/user
    chmod 0777 /home/user

    # Source directory with diagnostic files
    SRC_DIR="/home/user/support_source"
    mkdir -p "${SRC_DIR}"

    # config.conf
    cat > "${SRC_DIR}/config.conf" <<'EOF'
max_connections=200
log_level=debug
EOF

    # status.json
    cat > "${SRC_DIR}/status.json" <<'EOF'
{
  "service": "web-api",
  "status": "running",
  "uptime": 43200
}
EOF

    # system.log
    cat > "${SRC_DIR}/system.log" <<'EOF'
2024-01-01 00:00:01 INFO System boot
2024-01-01 00:00:05 INFO Diagnostics initialized
2024-01-01 00:10:12 WARN High memory usage detected
EOF

    # Ensure world-readable access to source files and directory
    chmod -R a+r "${SRC_DIR}"
    chmod    a+rx "${SRC_DIR}"

    # Do NOT create /home/user/support_collect or /home/user/diagnostic_sync.
    # The student/agent will create them during task execution.

    # Clean up apt cache to keep image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Make sure Python and pip are on PATH (already true for Ubuntu)
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    echo "This container sets up the environment for the diagnostic rsync task."
    echo "Use \`apptainer exec\` with your own commands or run tests with pytest."