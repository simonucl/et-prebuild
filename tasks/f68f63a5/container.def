Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # Update package index and install required tools
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        tar \
        gzip \
        coreutils

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # --------------------------------------------------------------------- #
    # Prepare the initial filesystem state expected by the automated tests
    # --------------------------------------------------------------------- #
    # Create the backups directory hierarchy
    mkdir -p /home/user/backups/tmp

    # Create the file that will be archived
    printf "Hello backup\n" > /home/user/backups/tmp/hello.txt

    # Build weekly_backup.tar.gz with *only* hello.txt inside
    tar -C /home/user/backups/tmp -czf /home/user/backups/weekly_backup.tar.gz hello.txt

    # Remove temporary build directory
    rm -rf /home/user/backups/tmp

    # Compute SHA-256 of the archive and record it exactly as required
    HASH=$(sha256sum /home/user/backups/weekly_backup.tar.gz | awk '{print $1}')
    echo "${HASH}  weekly_backup.tar.gz" > /home/user/backups/expected_sha256.txt

    # Ensure non-root users can read the prepared files
    chmod -R a+rX /home/user/backups

    # The working directory /home/user/backup_audit/ must NOT exist yet,
    # so we intentionally do not create it here.

%environment
    chmod 755 /home/user

    # Make sure Python and pip are on the PATH
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author backup-integrity-setup
    Description "Container prepared for the Backup Verification task – includes test fixtures and pytest."

%runscript
    exec "$@"