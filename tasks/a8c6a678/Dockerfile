# syntax=docker/dockerfile:1
FROM ubuntu:22.04

# Help text
# This image sets up the initial state for the “myapp” version bump exercise.
# It includes:
#  - A writable directory /home/user/infra-tools/myapp with VERSION and CHANGELOG.md prepared.
#  - pytest installed for automated checking.
# Author: Generated by ChatGPT
# Description: Environment for the 'myapp version bump' task with pytest pre-installed.

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked --mount=type=cache,target=/var/lib/apt,sharing=locked set -eu && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip && \
    rm -rf /var/lib/apt/lists/*

RUN --mount=type=cache,target=/root/.cache/pip python3 -m pip install --no-cache-dir --upgrade pip && \
    python3 -m pip install --no-cache-dir pytest

RUN mkdir -p /home/user/infra-tools/myapp && \
    chmod 0777 /home/user && \
    mkdir -p /home/user/infra-tools && \
    chmod 0777 /home/user/infra-tools && \
    chmod 0777 /home/user/infra-tools/myapp

RUN printf '2.3.4\n' > /home/user/infra-tools/myapp/VERSION && \
    chmod 0666 /home/user/infra-tools/myapp/VERSION

RUN cat > /home/user/infra-tools/myapp/CHANGELOG.md <<'EOF'
## [2.3.4] - 2023-09-15
### Added
 - Initial deployment of system-wide SELinux policies.

## [2.2.0] - 2023-08-02
### Changed
 - Upgraded nginx to 1.22.1

…(older history continues)…
EOF

RUN chmod 0666 /home/user/infra-tools/myapp/CHANGELOG.md

ENV LC_ALL=C.UTF-8
ENV PYTHONIOENCODING=UTF-8