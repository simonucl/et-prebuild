Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eu

    # Update APT and install Python and pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the checker
    python3 -m pip install --no-cache-dir --upgrade pip
    python3 -m pip install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create the initial filesystem state for the “myapp” exercise
    # ------------------------------------------------------------------
    base_dir="/home/user/infra-tools/myapp"
    mkdir -p "${base_dir}"

    # Ensure the directory is writable by the unprivileged user that will
    # run inside the container.
    chmod 0777 /home/user /home/user/infra-tools "${base_dir}"

    # Create VERSION file with initial content
    printf '2.3.4\n' > "${base_dir}/VERSION"
    chmod 0666 "${base_dir}/VERSION"

    # Create initial CHANGELOG.md
    cat > "${base_dir}/CHANGELOG.md" <<'EOF'
## [2.3.4] - 2023-09-15
### Added
 - Initial deployment of system-wide SELinux policies.

## [2.2.0] - 2023-08-02
### Changed
 - Upgraded nginx to 1.22.1

…(older history continues)…
EOF
    chmod 0666 "${base_dir}/CHANGELOG.md"

    # Do NOT create version_bump.log; it must be absent initially.

%environment
    chmod 755 /home/user

    # Make sure Python and pip are on PATH (they are by default)
    export LC_ALL=C.UTF-8
    export PYTHONIOENCODING=UTF-8

%labels
    Author "Generated by ChatGPT"
    Description "Environment for the 'myapp version bump' task with pytest pre-installed."

%help
    This Apptainer image sets up the initial state for the “myapp” version bump
    exercise. It includes:
      • A writable directory /home/user/infra-tools/myapp with VERSION and
        CHANGELOG.md prepared.
      • pytest installed for automated checking.