Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Basic utilities and Python tooling
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 python3-pip \
        gawk sed
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare the initial file-system state expected by the automated tests
    # ------------------------------------------------------------------
    # Create the required directory tree
    mkdir -p /home/user/datasets

    # Ensure the agent (non-root runtime user) can write under /home/user
    chmod 0777 /home/user
    chmod -R 0777 /home/user/datasets

    # Create the raw TSV file with the exact contents (8 lines, UTF-8)
    cat > /home/user/datasets/raw_reviews.tsv << 'EOF'
#id	text	label	extra
1	Hello World	POSITIVE	meta1
2	This is great	POSITIVE	meta2
#3	bad data	NEGATIVE
3	Awful	NEGATIVE	meta3
4	Lovely Day	POSITIVE	meta4

5	terrible	NEGATIVE	meta5
EOF

    # Readability for everyone
    chmod 0666 /home/user/datasets/raw_reviews.tsv

%environment
    chmod 755 /home/user

    # Maintain a sane locale
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
    export PYTHONIOENCODING=utf-8

%runscript
    echo "Container for text-processing task."
    echo "Enter the container with 'apptainer shell' or run your commands directly."

%help
    This container is pre-loaded with:
      • The raw TSV dataset at /home/user/datasets/raw_reviews.tsv
      • GNU awk & sed
      • Python 3 with pytest

    Students can now carry out the processing task strictly from the shell.