Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python tooling and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3-pip \
        ca-certificates
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create a non-root user `user` (uid 1000 / gid 1000)
    # ------------------------------------------------------------------
    if ! getent group 1000 >/dev/null; then
        groupadd -g 1000 user
    fi
    if ! id -u 1000 >/dev/null 2>&1; then
        useradd -m -u 1000 -g 1000 -s /bin/bash user
    fi

    # ------------------------------------------------------------------
    # Prepare initial filesystem state for the exercise
    # ------------------------------------------------------------------
    # Directories
    install -d -o 1000 -g 1000 -m 0755 /home/user/original_configs
    install -d -o 1000 -g 1000 -m 0755 /home/user/linked_configs   # must be empty

    # Configuration files with required content
    cat >/home/user/original_configs/config1.conf <<'EOF'
version=1.0
name=PrimaryConfig
EOF

    cat >/home/user/original_configs/config2.conf <<'EOF'
version=2.1
name=SecondaryConfig
EOF

    # Correct ownership and permissions
    chown 1000:1000 /home/user/original_configs/config1.conf /home/user/original_configs/config2.conf
    chmod 0644 /home/user/original_configs/config1.conf /home/user/original_configs/config2.conf

%environment
    chmod 755 /home/user

    # Allow user-local installs to be found first if the student adds any
    export PATH=/home/user/.local/bin:$PATH

%labels
    Maintainer="task setup for configuration-management exercise"