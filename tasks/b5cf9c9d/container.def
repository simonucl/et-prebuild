Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update APT index and install Python + Pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare dataset directory and the canonical raw_names.txt fixture
    # ------------------------------------------------------------------
    mkdir -p /home/user/datasets

    # Create the file with EXACT expected content (19 lines + final newline)
    cat > /home/user/datasets/raw_names.txt <<'EOF'
Alice
bob
Charlie
alice
Bob
alice   
Alice
charlie
Bob
Dana
Eve
eve
Eve
alice
bob
dana
Eve
Alice
charlie
EOF

    # ------------------------------------------------------------------
    # Ensure permissions allow the non-root agent to work under /home/user
    # ------------------------------------------------------------------
    chmod -R a+rX /home/user        # read & traverse for everyone
    chmod -R u+w,g+w,o+w /home/user # make everything under /home/user writable

%environment
    chmod 755 /home/user

    # Locale settings for consistent text handling
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    echo "Container for the name-frequency cleaning exercise."
    echo "You are now inside the container. Good luck!"