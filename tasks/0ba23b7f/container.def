Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Ensure non-interactive APT installs
    export DEBIAN_FRONTEND=noninteractive

    # Update package lists and install Python plus pip
    apt-get -y update && \
        apt-get -y install --no-install-recommends python3 python3-pip && \
        apt-get clean && rm -rf /var/lib/apt/lists/*

    # Install pytest for the forthcoming test-suite
    pip3 install --no-cache-dir pytest

    ############################################################################
    # Seed the filesystem with the initial state expected by the automated tests
    ############################################################################

    # Base directory for the micro-services
    mkdir -p /home/user/microservices/auth/logs
    mkdir -p /home/user/microservices/payment/logs

    # -----------------------------------------------------------------
    # auth/config.yaml
    # -----------------------------------------------------------------
    cat <<'EOF' > /home/user/microservices/auth/config.yaml
service_name: auth
version: 1.0.0
port: 8000
database:
  host: localhost
  port: 5432
EOF

    # -----------------------------------------------------------------
    # payment/config.yaml
    # -----------------------------------------------------------------
    cat <<'EOF' > /home/user/microservices/payment/config.yaml
service_name: payment
version: 1.0.0
port: 8001
database:
  host: localhost
  port: 5432
EOF

    # -----------------------------------------------------------------
    # Seed log files with non-empty content
    # -----------------------------------------------------------------
    echo "Auth service started at 2024-06-01T00:00:00Z"  > /home/user/microservices/auth/logs/app.log
    echo "No errors detected"                            > /home/user/microservices/auth/logs/error.log

    echo "Payment service started at 2024-06-01T00:00:00Z" > /home/user/microservices/payment/logs/app.log
    echo "No errors detected"                              > /home/user/microservices/payment/logs/error.log

    # -----------------------------------------------------------------
    # Permissions: make everything under /home/user writable so the
    # agent (executing as an unprivileged user) can create backups and
    # delete log directories during its workflow.
    # -----------------------------------------------------------------
    chmod -R a+rwX /home/user

%environment
    chmod 755 /home/user

    # Nothing to override for HOME – Apptainer will handle that naturally
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8