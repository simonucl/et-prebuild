Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update apt metadata and install Python, pip, and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install the latest pytest via pip (guarantees availability)
    python3 -m pip install --no-cache-dir --upgrade pip
    python3 -m pip install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state expected by the automated tests
    # ------------------------------------------------------------------

    # Create working directory
    mkdir -p /home/user/service_cfg

    # Write the initial configuration file exactly as specified
    cat > /home/user/service_cfg/service.conf <<'EOF'
# Application Service Configuration
version=1.8
enable_new_ui=no
EOF

    # Ensure permissive permissions so the non-root runtime user can modify files
    chmod -R 777 /home/user/service_cfg

    # Clean up apt caches to keep the image lean
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure pip-installed executables are in PATH
    export PATH="$PATH:~/.local/bin"

%labels
    Author="Autogenerated by ChatGPT"
    Description="Container for configuration-update task with pytest pre-installed."