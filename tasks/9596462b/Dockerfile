FROM ubuntu:22.04

# %post
RUN set -e && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip && \
    python3 -m pip install --no-cache-dir --upgrade pip && \
    python3 -m pip install --no-cache-dir pytest && \
    mkdir -p /home/user/service_cfg

RUN cat <<'EOF' > /home/user/service_cfg/service.conf
# Application Service Configuration
version=1.8
enable_new_ui=no
EOF

RUN chmod -R 777 /home/user/service_cfg && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# %environment
RUN chmod 755 /home/user
ENV PATH="$PATH:/root/.local/bin"

# %labels
LABEL Author="Autogenerated by ChatGPT"
LABEL Description="Container for configuration-update task with pytest pre-installed."