Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author artifact-filtering-setup

%post
    set -e

    # Update package lists and install required tools
    apt-get update
    DEBIAN_FRONTEND=noninteractive \
        apt-get install -y --no-install-recommends \
            python3 \
            python3-pip \
            jq \
            ca-certificates \
            curl

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # Create workspace and populate initial files
    mkdir -p /home/user/build
    chmod 755 /home/user /home/user/build

    # artifacts.json
    cat > /home/user/build/artifacts.json <<'JSON'
[
  {
    "name": "core-lib",
    "version": "1.2.3",
    "sha256": "abc123def456abc123def456abc123def456abc123def456abc123def456"
  },
  {
    "name": "ui-lib",
    "version": "2.0.1",
    "sha256": "fedcba654321fedcba654321fedcba654321fedcba654321fedcba654321"
  },
  {
    "name": "cli-tool",
    "version": "1.2.0",
    "sha256": "789ghi789ghi789ghi789ghi789ghi789ghi789ghi789ghi789ghi789ghi"
  }
]
JSON

    # artifact_schema.json
    cat > /home/user/build/artifact_schema.json <<'JSON'
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Artifact",
  "type": "object",
  "required": ["name", "version", "sha256"],
  "properties": {
    "name":   { "type": "string" },
    "version":{ "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
JSON

    # Set appropriate permissions
    chmod 644 /home/user/build/artifacts.json /home/user/build/artifact_schema.json

    # Clean up apt caches to keep image lean
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8

%runscript
    echo "Artifact filtering container. Launching shell..."
    exec /bin/bash "$@"