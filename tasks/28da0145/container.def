Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "Updating package index and installing Python tooling..."
    apt-get update -qq
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 python3-pip ca-certificates curl
    pip3 install --no-cache-dir --upgrade pip
    pip3 install --no-cache-dir pytest

    echo "Creating initial release tree..."
    BASE_DIR="/home/user/releases/2024-06-01"
    mkdir -p "${BASE_DIR}"

    # --------------------------------------------------------------------- #
    # auth-service                                                          #
    # --------------------------------------------------------------------- #
    AUTH_DIR="${BASE_DIR}/auth-service"
    mkdir -p "${AUTH_DIR}"

    cat > "${AUTH_DIR}/manifest.yaml" <<'EOF'
metadata:
  service: auth-service
  version: "2.1.0"
  container:
    port: 7000
EOF

    cat > "${AUTH_DIR}/config.env" <<'EOF'
DB_HOST=auth-db.internal
DB_PORT=5432
JWT_SECRET=s3cr3t
LOG_LEVEL=INFO
EOF

    # --------------------------------------------------------------------- #
    # billing-service                                                       #
    # --------------------------------------------------------------------- #
    BILL_DIR="${BASE_DIR}/billing-service"
    mkdir -p "${BILL_DIR}"

    cat > "${BILL_DIR}/manifest.yaml" <<'EOF'
metadata:
  service: billing-service
  version: "3.4.2"
  container:
    port: 7100
EOF

    cat > "${BILL_DIR}/config.env" <<'EOF'
DB_HOST=billing-db.internal
DB_PORT=5432
PAYMENT_GATEWAY_TOKEN=abcd1234
LOG_LEVEL=INFO
CURRENCY=USD
EOF

    # --------------------------------------------------------------------- #
    # report-service                                                        #
    # --------------------------------------------------------------------- #
    REPORT_DIR="${BASE_DIR}/report-service"
    mkdir -p "${REPORT_DIR}"

    cat > "${REPORT_DIR}/manifest.yaml" <<'EOF'
metadata:
  service: report-service
  version: "1.8.0"
  container:
    port: 7200
EOF

    cat > "${REPORT_DIR}/config.env" <<'EOF'
DB_HOST=report-db.internal
DB_PORT=5432
REPORT_CACHE_SIZE=512
LOG_LEVEL=DEBUG
EOF

    echo "Setting permissions..."
    chmod -R 755 /home/user
    find /home/user -type f -exec chmod 644 {} +

%environment
    chmod 755 /home/user

    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%labels
    Author="Apptainer Prep Bot"
    Description="Container image that provides the initial state for the deployment-bundle task, including test input files and pytest installed."

%runscript
    echo "Container for deployment-bundle task."
    echo "You can now start solving the assignment."