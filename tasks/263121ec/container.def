Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install system packages
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        procps \
        ca-certificates

    # Install pytest for the grading harness
    pip3 install --no-cache-dir pytest

    # Prepare a writable home directory for the unprivileged agent
    mkdir -p /home/user
    chmod 0777 /home/user      # ensure the invoking user (unknown UID) can write

    # Optional directory skeleton for the assignment (no output file created)
    mkdir -p /home/user/webdev
    chmod 0755 /home/user/webdev

    # Clean up apt caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Minimal PATH; do NOT override HOME per instructions
    export PATH=/usr/local/bin:/usr/bin:/bin

%labels
    Author="Apptainer Task Preparer"
    Description="Environment for Node.js process snapshot assignment with pytest installed."