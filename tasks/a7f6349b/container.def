Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "Updating package index and installing required tools..."
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    echo "Installing pytest for the validation suite..."
    python3 -m pip install --no-cache-dir --upgrade pip
    python3 -m pip install --no-cache-dir pytest

    echo "Creating the /home/user directory with permissive permissions..."
    mkdir -p /home/user
    chmod 0777 /home/user   # ensure any (non-root) UID can write here

    # Provide a convenient python alias if not already present
    if ! command -v python >/dev/null 2>&1; then
        ln -s /usr/bin/python3 /usr/local/bin/python
    fi

%environment
    chmod 755 /home/user

    # No HOME override – Apptainer will bind the caller's $HOME.
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author build-automation-prep
    Description "Base container for build-environment task: ensures /home/user is writable and pytest is available"

%runscript
    echo "Container for build-environment task. Invoke your shell or command explicitly."