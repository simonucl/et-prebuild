Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update APT index and install Python tooling
    apt-get update
    apt-get install -y --no-install-recommends python3-pip

    # Install pytest for the grader and for student use
    pip3 install --no-cache-dir pytest

    # Ensure the expected home directory is present and writable
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up apt caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Minimal environment settings
    export LC_ALL=C.UTF-8
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author firewall-pack-prep
    Description "Starter container for firewall rules exercise (initial, pre-solution state)"