Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # --------------------------------------------------------------------- #
    # Basic tooling: Python + Pytest (for the grader’s own test-suite)
    # --------------------------------------------------------------------- #
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # --------------------------------------------------------------------- #
    # Create initial directory structure expected by the tests
    # --------------------------------------------------------------------- #
    mkdir -p /home/user/raw_data
    mkdir -p /home/user/processed      # empty; the ETL job will write into here
    mkdir -p /home/user/etl_logs       # empty; no log file must exist yet

    # Make sure the learner (non-root user) can write to /home/user/*
    chmod -R 0777 /home/user

    # --------------------------------------------------------------------- #
    # Populate the two source CSV files with the exact, required contents
    # --------------------------------------------------------------------- #
cat > /home/user/raw_data/sales_q1.csv <<'EOF'
order_id,customer_id,order_date,item_count,item_total,discount
1001,C001,2024-01-05,3,120.50,5.00
1002,C002,2024-01-07,1,45.00,0.00
1003,C003,2024-02-18,2,89.99,10.00
1004,C001,2024-03-22,5,300.00,15.00
EOF

cat > /home/user/raw_data/sales_q2.csv <<'EOF'
order_id,customer_id,order_date,item_count,item_total,discount
1005,C003,2024-04-02,1,40.00,0.00
1006,C004,2024-04-11,2,95.00,5.00
1007,C002,2024-05-27,4,180.00,20.00
1008,C003,2024-06-30,3,135.50,10.50
EOF

    # Ensure files are readable by everyone
    chmod 0644 /home/user/raw_data/sales_q1.csv /home/user/raw_data/sales_q2.csv

%environment
    chmod 755 /home/user

    # No special environment variables are required
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    echo "Container for the sales-summary ETL assignment."
    echo "All prerequisite raw data files are located in /home/user/raw_data."
    echo "Write your solution so that it produces:"
    echo "  • /home/user/processed/customer_summary.csv"
    echo "  • /home/user/etl_logs/etl_2024-08-15T00-00-00Z.log"
    echo "Good luck!"