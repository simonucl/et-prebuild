Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update && \
    apt-get install -y --no-install-recommends python3 python3-pip && \
    pip3 install --no-cache-dir pytest && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

    # Create a regular user `user`
    useradd -m -s /bin/bash user

    # ------------------------------------------------------------------
    # Set up initial directory tree and files for the FinOps task
    # ------------------------------------------------------------------
    CLOUD_DIR="/home/user/cloud_reports"
    mkdir -p "${CLOUD_DIR}"

    # Generate the 12 monthly detailed cost reports
    for m in $(seq -w 1 12); do
        printf "Month,TotalUSD\n2023-%s,1000\n" "$m" > "${CLOUD_DIR}/cost_report_2023-${m}.csv"
    chmod 755 /home/user

    done

    # Yearly summary CSV
    printf "Year,TotalUSD\n2023,12000\n" > "${CLOUD_DIR}/summary_2023.csv"

    # README (content can be arbitrary; keep it simple)
    echo "README for 2023 cloud cost reports. Do not modify." > "${CLOUD_DIR}/README.txt"

    # Ensure ownership for the non-root user
    chown -R user:user /home/user

%labels
    Author="Apptainer Setup Script"
    Description="Environment for FinOps archival task with pytest pre-installed."

%runscript
    exec /bin/bash "$@"