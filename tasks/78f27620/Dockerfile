# syntax=docker/dockerfile:1
FROM ubuntu:22.04

# Labels from Apptainer definition
LABEL Author="Generated by ChatGPT"
LABEL Description="Container image for DevSecOps legacy policy scan task – initial state with tooling and pytest installed."

# Post section: install dependencies and prepare filesystem
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked --mount=type=cache,target=/var/lib/apt,sharing=locked --mount=type=cache,target=/root/.cache/pip set -e && \
    apt-get update -y && \
    apt-get install -y --no-install-recommends python3 python3-pip && \
    pip3 install --no-cache-dir pytest && \
    mkdir -p /home/user/devsecops_tooling

# Create the legacy scanner script with exact required contents
RUN cat > /home/user/devsecops_tooling/legacy_policy_scan.sh << 'EOF'
#!/usr/bin/env bash
echo "Legacy Policy Scanner v0.2"
echo "Checking files..."
echo "PASS: .gitignore - Compliant"
echo "FAIL: Dockerfile - Missing USER directive"
echo "PASS: main.tf - No hard-coded credentials"
echo "Scan complete. 3 files inspected, 1 failure detected."
EOF

# Ensure proper permissions and ensure run_logs directory does not exist
RUN chmod 755 /home/user/devsecops_tooling/legacy_policy_scan.sh && \
    rm -rf /home/user/devsecops_tooling/run_logs || true

# Environment variables from %environment
ENV LC_ALL=C.UTF-8
ENV PYTHONIOENCODING=utf-8

# %help section not provided in source; none to include