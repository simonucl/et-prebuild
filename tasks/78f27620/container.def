Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package index and install Python tooling
    apt-get update -y
    apt-get install -y --no-install-recommends python3 python3-pip

    # Install pytest for the validation suite
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem expected by the tests
    # ------------------------------------------------------------------
    mkdir -p /home/user/devsecops_tooling

    # Create the legacy scanner script with the exact required contents
    cat > /home/user/devsecops_tooling/legacy_policy_scan.sh << 'EOF'
#!/usr/bin/env bash
echo "Legacy Policy Scanner v0.2"
echo "Checking files..."
echo "PASS: .gitignore - Compliant"
echo "FAIL: Dockerfile - Missing USER directive"
echo "PASS: main.tf - No hard-coded credentials"
echo "Scan complete. 3 files inspected, 1 failure detected."
EOF

    # Ensure proper permissions (755)
    chmod 755 /home/user/devsecops_tooling/legacy_policy_scan.sh

    # The run_logs directory must NOT exist yet; ensure it is absent
    rm -rf /home/user/devsecops_tooling/run_logs || true

%environment
    # Do not override HOME; leave default behavior intact
    export LC_ALL=C.UTF-8
    export PYTHONIOENCODING=utf-8

%labels
    Author="Generated by ChatGPT"
    Description="Container image for DevSecOps legacy policy scan task – initial state with tooling and pytest installed."