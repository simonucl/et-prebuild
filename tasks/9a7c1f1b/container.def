Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install required system packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        python3 \
        python3-pip \
        sqlite3

    # Install pytest for the grading harness
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem layout expected by the exercise runner
    # ------------------------------------------------------------------
    # Create the user’s home and project directories
    mkdir -p /home/user/project

    # Make sure non-root users (the agent) can write inside /home/user
    chmod -R 0777 /home/user

    # ------------------------------------------------------------------
    # Create the legacy SQLite database with the specified content
    # ------------------------------------------------------------------
    sqlite3 /home/user/project/old_app.db <<'SQL'
CREATE TABLE users(
    id INTEGER PRIMARY KEY,
    name TEXT,
    email TEXT
);
INSERT INTO users(id,name,email) VALUES
  (1,'Alice','alice@example.com'),
  (2,'Bob','bob@example.com'),
  (3,'Carol','carol@example.com');
SQL

    # Ensure the database file is readable (and writable, if needed) by anyone
    chmod 0666 /home/user/project/old_app.db

%environment
    chmod 755 /home/user

    # Ensure Python is discoverable (usually already true, but explicit is better)
    export PATH=/usr/bin:$PATH

%labels
    Author    You
    Description  Environment for the database-migration task with pytest pre-installed.