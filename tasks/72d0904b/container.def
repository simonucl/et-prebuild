Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author TaskGenerator
    Description "Container for QA task: prepare pristine INI file and install pytest"

%post
    set -e

    echo "Updating apt repositories and installing Python tooling..."
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    echo "Installing pytest for the grading framework..."
    pip3 install --no-cache-dir pytest

    echo "Creating initial directory structure and INI file..."
    mkdir -p /home/user/webapp/config

    cat > /home/user/webapp/config/settings.ini << 'EOF'
[server]
host = 0.0.0.0
port = 8080

[email]
smtp_host = mail.example.com
smtp_port = 587
username = notify@example.com
password = mailingR0cks!

[database]
host = 172.16.24.10
port = 5432
user = webapp
password = s3cr3t!

[feature_flags]
dark_mode = true
beta_payments = false
EOF

    # Ensure readable files and executable search paths for non-root users
    chmod 755 /home/user
    chmod -R 755 /home/user/webapp
    chmod 644 /home/user/webapp/config/settings.ini

    echo "Cleanup apt caches to keep image small..."
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%runscript
    echo "Container built for the QA task. Please execute your solution script separately."

%help
    This container provides the pristine environment required for the QA automation
    task.  It contains:
      • Python 3 and pytest
      • /home/user/webapp/config/settings.ini with the exact required contents

    Students should mount/enter this container and follow the task instructions.