Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update APT index and install required system packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        iproute2 \
        iputils-ping \
        hostname \
        python3-pip \
        ca-certificates

    # Clean APT caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the grading test-suite
    pip3 install --no-cache-dir pytest

    # Create a non-privileged user and its home directory expected by the tests
    if ! id -u user >/dev/null 2>&1; then
        groupadd -g 1000 user
        useradd -m -u 1000 -g 1000 -s /bin/bash user
    fi
    mkdir -p /home/user
    chmod 0755 /home/user

    # Ensure /etc/resolv.conf exists so DNS look-ups (and test) succeed
    if [ ! -f /etc/resolv.conf ]; then
        echo "nameserver 8.8.8.8" > /etc/resolv.conf
    fi

%environment
    chmod 755 /home/user

    # Guarantee a predictable locale and PATH
    export LC_ALL=C
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

%runscript
    echo "Container for FinOps network diagnostics exercise."
    echo "Invoke your commands or open a shell with 'apptainer shell <image>'."