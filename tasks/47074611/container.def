Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "Updating apt cache and installing required packages..."
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        locales \
        sed \
        gawk

    # Install pytest system-wide so it's available to all users.
    echo "Installing pytest..."
    pip3 install --no-cache-dir pytest

    # Ensure /home and the target user directory exist.
    mkdir -p /home/user/qa_logs

    # Populate the initial log files with the exact required contents.
    cat > /home/user/qa_logs/suite1.log <<'EOF'
[2023-08-12 10:12:01] TEST test_login ..... PASS
[2023-08-12 10:12:02] TEST test_logout ..... FAIL
[2023-08-12 10:12:03] TEST test_signup ..... SKIP
[2023-08-12 10:12:04] TEST test_profile_update ..... PASS
[2023-08-12 10:12:05] TEST test_password_reset ..... PASS
EOF

    cat > /home/user/qa_logs/suite2.log <<'EOF'
[2023-08-12 11:15:11] TEST api_fetch_user ..... PASS
[2023-08-12 11:15:12] TEST api_create_user ..... FAIL
[2023-08-12 11:15:13] TEST api_delete_user ..... FAIL
[2023-08-12 11:15:14] TEST api_update_user ..... PASS
EOF

    # Set permissive permissions so the non-root runtime user can create the
    # required output files inside /home/user/qa_logs.
    chmod -R a+rX /home/user
    chmod 0777 /home/user/qa_logs

    # Clean up apt caches to keep image small.
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure Python and pip executables are on PATH (they are by default),
    # but explicitly exporting PATH makes sure /usr/local/bin is included.
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%labels
    Author umbraassistant
    Description "Environment for QA log sanitization task with pytest pre-installed."

%help
    This Apptainer image provides the initial filesystem state for the QA log
    sanitization task.  It contains:
      • /home/user/qa_logs/suite1.log
      • /home/user/qa_logs/suite2.log
    Both files have their exact required contents.  The directory is writable
    by the runtime user, allowing creation of *_clean.log files and the final
    summary_report.csv.  Python 3 and pytest are pre-installed for automated
    grading.