Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # ---------------------------------------------------------------------
    # Install required software
    # ---------------------------------------------------------------------
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        sqlite3
    pip3 install --no-cache-dir pytest

    # ---------------------------------------------------------------------
    # Set up initial directory tree and legacy SQLite database
    # ---------------------------------------------------------------------
    mkdir -p /home/user/legacy_app/data
    chmod 0755 /home/user
    chmod 0755 /home/user/legacy_app
    chmod 0755 /home/user/legacy_app/data

    # Create the legacy database with the expected schema and five rows
    sqlite3 /home/user/legacy_app/data/old_users.db <<'SQL'
    PRAGMA foreign_keys = OFF;
    BEGIN TRANSACTION;
    CREATE TABLE users(
        id INTEGER PRIMARY KEY,
        username TEXT,
        email TEXT
    );
    INSERT INTO users (id, username, email) VALUES
        (1, 'alice', 'alice@example.com'),
        (2, 'bob', 'bob@example.com'),
        (3, 'carol', 'carol@example.com'),
        (4, 'dave', 'dave@example.com'),
        (5, 'eve', 'eve@example.com');
    COMMIT;
SQL
    chmod 0644 /home/user/legacy_app/data/old_users.db

    # ---------------------------------------------------------------------
    # Clean up APT caches to reduce image size
    # ---------------------------------------------------------------------
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure standard binary paths are available
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

%labels
    Author="Apptainer Task Setup"
    Description="Environment with legacy SQLite DB and pytest pre-installed."