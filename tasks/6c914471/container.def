Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "Updating package index and installing required packages..."
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        make \
        procps \
        coreutils \
        tar \
        gzip

    echo "Cleaning up apt caches..."
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    echo "Installing pytest via pip..."
    pip3 install --no-cache-dir --upgrade pip
    pip3 install --no-cache-dir pytest

    echo "Creating writable home directory for the runtime user..."
    mkdir -p /home/user
    # Make sure any non-root caller can write to it.
    chmod 0777 /home/user

%environment
    chmod 755 /home/user

    # Ensure python and standard tools are on PATH
    export PATH="/usr/local/bin:/usr/bin:/bin:${PATH}"

%labels
    Author "Generated by ChatGPT – Apptainer build file for diagnostics-kit exercise"

%help
    This container provides a clean Ubuntu 22.04 userland with Python 3,
    pytest, make and standard Unix utilities pre-installed.
    The /home/user directory is present and writable.
    No diagnostics-kit artefacts are included; students are expected to
    create them as part of the assignment.