# syntax=docker/dockerfile:1
FROM ubuntu:22.04

# Author: Generated by ChatGPT – Apptainer build file for diagnostics-kit exercise

# Update package index and install required packages
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked --mount=type=cache,target=/var/lib/apt,sharing=locked set -e && \
    echo "Updating package index and installing required packages..." && \
    apt-get update -y && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        make \
        procps \
        coreutils \
        tar \
        gzip && \
    echo "Cleaning up apt caches..." && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Install pytest via pip
RUN --mount=type=cache,target=/root/.cache/pip echo "Installing pytest via pip..." && \
    pip3 install --no-cache-dir --upgrade pip && \
    pip3 install --no-cache-dir pytest

# Create writable home directory for the runtime user
RUN echo "Creating writable home directory for the runtime user..." && \
    mkdir -p /home/user && \
    chmod 0777 /home/user

# Ensure correct permissions on home directory
RUN chmod 755 /home/user

# Ensure python and standard tools are on PATH
ENV PATH="/usr/local/bin:/usr/bin:/bin:${PATH}"

LABEL Author="Generated by ChatGPT – Apptainer build file for diagnostics-kit exercise"

# This container provides a clean Ubuntu 22.04 userland with Python 3,
# pytest, make and standard Unix utilities pre-installed.
# The /home/user directory is present and writable.
# No diagnostics-kit artefacts are included; students are expected to
# create them as part of the assignment.