Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ------------------------------------------------------------------
    # Basic tooling
    # ------------------------------------------------------------------
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip ca-certificates
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create unprivileged user (uid/gid = 1000) that will own the sample
    # log tree.  The runtime user on the platform usually has this UID, so
    # ownership will match transparently.
    # ------------------------------------------------------------------
    groupadd -g 1000 user || true
    useradd  -m -u 1000 -g 1000 user || true

    # ------------------------------------------------------------------
    # Directory hierarchy expected by the tests
    # ------------------------------------------------------------------
    mkdir -p /home/user/app1/logs
    mkdir -p /home/user/app2/logs
    mkdir -p /home/user/app3/data
    mkdir -p /home/user/archive
    # Directory that will later hold the student’s output (left empty)
    mkdir -p /home/user/diagnostics

    # ------------------------------------------------------------------
    # Helper functions to create files of the required size categories
    # ------------------------------------------------------------------
    create_large() { dd if=/dev/zero bs=1024 count=2 2>/dev/null > "$1"; }   # 2 KiB
    create_small() { echo "placeholder" > "$1"; }                            # <1 KiB

    # ------------------------------------------------------------------
    # Qualifying log files (≥1024 bytes)
    # ------------------------------------------------------------------
    create_large /home/user/app1/logs/server.log
    create_large /home/user/app1/logs/access.log
    create_large /home/user/app2/logs/error.txt
    create_large /home/user/app2/logs/trace.log
    create_large /home/user/archive/old.log

    # ------------------------------------------------------------------
    # Decoy / non-qualifying files (<1024 bytes)
    # ------------------------------------------------------------------
    create_small /home/user/app1/logs/debug-20230802.log
    create_small /home/user/app2/logs/README.md
    create_small /home/user/app3/data/datafile.log

    # ------------------------------------------------------------------
    # Permissions: make sure everything is owned by uid/gid 1000:1000 and
    # world-readable so the unprivileged tester can access them.
    # ------------------------------------------------------------------
    chown -R 1000:1000 /home/user
    chmod -R u+rwX,go+rX /home/user

%environment
    chmod 755 /home/user

    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH