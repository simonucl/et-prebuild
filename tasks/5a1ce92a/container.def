Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and Pytest
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -qq
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create required directory structure and seed input CSV files
    # ------------------------------------------------------------------
    mkdir -p /home/user/accounts
    chmod 755 /home/user
    chmod 755 /home/user/accounts

    # users_master.csv
    cat <<'EOF' > /home/user/accounts/users_master.csv
user_id,username,full_name,email,status
1,alice,Alice Walker,alice@example.com,ACTIVE
2,bob,Bob Stone,bob@example.com,INACTIVE
3,carol,Carol Smith,carol@example.com,ACTIVE
4,dave,David Johnson,dave@example.com,ACTIVE
5,erin,Erin Brown,erin@example.com,SUSPENDED
6,frank,Frank Harris,frank@example.com,ACTIVE
EOF
    chmod 644 /home/user/accounts/users_master.csv

    # departments.csv
    cat <<'EOF' > /home/user/accounts/departments.csv
username,department
alice,Engineering
bob,Sales
carol,HR
dave,Engineering
erin,Marketing
frank,Support
EOF
    chmod 644 /home/user/accounts/departments.csv

    # login_counts.csv
    cat <<'EOF' > /home/user/accounts/login_counts.csv
username,logins
alice,345
bob,127
carol,512
dave,98
erin,67
frank,250
EOF
    chmod 644 /home/user/accounts/login_counts.csv

    # Ensure correct file permissions
    chmod 644 /home/user/accounts/*.csv

%environment
    # Keep the environment minimal; don't override HOME.
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author  example@example.com
    Description  "Initial state for ACTIVE users report task with Pytest installed."