Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update APT index and install Python & pip
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the evaluation harness
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial workspace for the agent
    # ------------------------------------------------------------------
    mkdir -p /home/user/my-web-app

    # package.json with initial version 1.2.3
    cat >/home/user/my-web-app/package.json <<'EOF'
{
  "name": "my-web-app",
  "version": "1.2.3",
  "description": "Sample web app",
  "dependencies": {}
}
EOF

    # Initial CHANGELOG.md (no 1.3.0 entry yet)
    cat >/home/user/my-web-app/CHANGELOG.md <<'EOF'
# Changelog

All notable changes to this project will be documented in this file.

## [1.2.3] - 2023-07-01
- Initial release.
EOF

    # Ensure the agent (non-root runtime user) can modify the project
    chmod -R a+rwX /home/user

%environment
    chmod 755 /home/user

    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8