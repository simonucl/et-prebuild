Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Update package lists and install required utilities
    apt-get update && \
        DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
            iputils-ping \
            traceroute \
            dnsutils \
            iproute2 \
            python3 \
            python3-pip && \
        rm -rf /var/lib/apt/lists/*

    # Install pytest for the automated checker
    pip3 install --no-cache-dir pytest

    # Create a non-root user with a home directory at /home/user
    if ! id -u user >/dev/null 2>&1; then
        useradd -m -s /bin/bash user
    fi

    # Ensure the home directory exists with appropriate permissions
    chmod 755 /home/user

%labels
    Author="Exercise Container – Network Diagnostic Log Task"

%help
    This container provides the minimal environment for the “network-diagnostic
    log” exercise.  It includes common network tools (ping, traceroute, dig,
    nslookup, ip) and Python with pytest for automated evaluation.