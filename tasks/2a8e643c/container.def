Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ------------------------------------------------------------------
    # Base OS packages
    # ------------------------------------------------------------------
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        curl

    # ------------------------------------------------------------------
    # Python tooling for the test harness
    # ------------------------------------------------------------------
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare the initial exercise data under /home/user
    # ------------------------------------------------------------------
    mkdir -p /home/user/cloud_costs/monthly

    cat <<'EOF' > /home/user/cloud_costs/monthly/cost_2023-04.csv
Date,Service,CostUSD
2023-04-30,Compute,123.45
2023-04-30,Storage,67.89
2023-04-30,Network,10.11
EOF

    cat <<'EOF' > /home/user/cloud_costs/monthly/cost_2023-05.csv
Date,Service,CostUSD
2023-05-31,Compute,150.12
2023-05-31,Storage,70.55
2023-05-31,Network,12.34
EOF

    cat <<'EOF' > /home/user/cloud_costs/monthly/cost_2023-06.csv
Date,Service,CostUSD
2023-06-30,Compute,131.07
2023-06-30,Storage,72.88
2023-06-30,Network,11.98
EOF

    cat <<'EOF' > /home/user/cloud_costs/monthly/cost_2023-07.csv
Date,Service,CostUSD
2023-07-31,Compute,142.33
2023-07-31,Storage,75.66
2023-07-31,Network,13.55
EOF

    # Ensure sane permissions (readable by everyone, writable by owner/root)
    chmod -R 755 /home/user
    find /home/user/cloud_costs/monthly -type f -exec chmod 644 {} \;

%environment
    chmod 755 /home/user

    # Expose pip-installed executables (e.g., pytest) first in PATH
    export PATH="$HOME/.local/bin:/usr/local/bin:/usr/bin:/bin"

%labels
    Author="Generated by OpenAI ChatGPT"
    Description="Container for FinOps symlink standardisation task with pytest pre-installed."

%help
    This container provides the initial filesystem state and tooling
    required for the FinOps symlink exercise.