Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y python3 python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create the initial directory & data structure for the exercise
    # ------------------------------------------------------------------
    mkdir -p /home/user/data_experiments/dataset_A
    mkdir -p /home/user/data_experiments/dataset_B
    mkdir -p /home/user/output

    # Ensure the student can write the output report
    chmod 0777 /home/user/output

    # Populate dataset_A CSV files
    cat > /home/user/data_experiments/dataset_A/file1.csv <<'EOF'
id,value
1,2.5
2,3.1
EOF

    cat > /home/user/data_experiments/dataset_A/file2.csv <<'EOF'
id,value
1,7.2
2,5.4
3,6.0
EOF

    # Populate dataset_B CSV file
    cat > /home/user/data_experiments/dataset_B/measurements.csv <<'EOF'
time,reading
00:00,0.12
01:00,0.11
02:00,0.15
03:00,0.10
EOF

    # Read & execute permissions for datasets
    chmod -R 0755 /home/user/data_experiments

%environment
    chmod 755 /home/user

    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8