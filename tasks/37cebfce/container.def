Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # ------------------------------------------------------------------
    # 1. Essential packages and PyPI tools
    # ------------------------------------------------------------------
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates
    python3 -m pip install --no-cache-dir --upgrade pip
    python3 -m pip install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # 2. Prepare the pristine directory expected by the exercise
    # ------------------------------------------------------------------
    # Create /home/user and the empty artifactory root
    mkdir -p /home/user/artifactory

    # Ensure later, non-root users can work inside the directory tree
    chmod 0755 /home/user
    chmod 0777 /home/user/artifactory   # writable by any user running the container

    # If a uid 1000 account exists inside the image, give it ownership so
    # the most common host UID can write without relying on world-write.
    (getent passwd 1000 && chown 1000:1000 /home/user/artifactory) || true

    # ------------------------------------------------------------------
    # 3. Clean up APT to keep the image small
    # ------------------------------------------------------------------
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Locale / encoding sanity
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
    export PYTHONIOENCODING=UTF-8