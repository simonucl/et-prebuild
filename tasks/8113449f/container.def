Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    apt-get update
    # Install Python and pip
    apt-get install -y python3 python3-pip

    # Install pytest for the test harness
    pip3 install --no-cache-dir pytest

    # Create the required directory structure and seed file
    mkdir -p /home/user/storage_reports
    chmod 777 /home/user/storage_reports   # Ensure the runtime user can write here

    cat <<'EOF' >/home/user/storage_reports/current_usage.csv
filesystem,used_GB,available_GB
/,12,38
/home,40,60
/var/log,4,6
/tmp,1,9
EOF
    chmod 644 /home/user/storage_reports/current_usage.csv

%environment
    chmod 755 /home/user

    export LC_ALL=C
    export LANG=C
    export PATH=/usr/local/bin:/usr/bin:/bin

%labels
    Author user
    Description Initial state for storage usage percentage task with pytest installed