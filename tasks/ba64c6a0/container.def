Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install Python & pip
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install pytest for the grading framework / agent
    pip3 install --no-cache-dir pytest

    # Create an unprivileged user `user` with home directory /home/user
    useradd -m -u 1000 -s /bin/bash user

    # Ensure the home directory is owned by the new user
    chown -R 1000:1000 /home/user

    # Clean up APT caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Allow user-local Python packages (if any) to be found
    export PATH="/home/user/.local/bin:${PATH}"

%runscript
    # Default action: simply exec whatever the caller wants
    exec "$@"