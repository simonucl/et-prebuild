Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author    DevOpsCourse
    Purpose   Initial state for “deployment SSH key-pair” exercise

%post
    set -e

    # Ensure non-interactive apt operations
    export DEBIAN_FRONTEND=noninteractive

    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        openssh-client

    # Install pytest for the evaluation suite
    pip3 install --no-cache-dir pytest

    # Create the non-privileged user expected by the tests
    adduser --disabled-password --gecos "" user

    # Prepare the baseline SSH directory (must exist, nothing else)
    mkdir -p /home/user/.ssh
    chmod 700 /home/user/.ssh
    chown -R user:user /home/user

    # Clean up apt caches to keep image slim
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure Python and pip are on PATH (usually already, but keep explicit)
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%runscript
    echo "Container for the deployment SSH key-pair exercise."