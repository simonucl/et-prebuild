Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # Create project directory structure
    mkdir -p /home/user/project/.github/workflows

    # Populate the initial GitHub Actions workflow file
    cat > /home/user/project/.github/workflows/build.yml <<'EOF'
name: Build Pipeline
on:
  push:
    branches: [ "main" ]
jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v2
      - name: Run build
        run: echo "Building..."
EOF

    # Populate the initial TOML configuration file
    cat > /home/user/project/config.toml <<'EOF'
[server]
port = 8080
EOF

    # Ensure the student can modify everything
    chmod -R 777 /home/user

%labels
    chmod 755 /home/user

    Author Demo

%help
    Container for the configuration-editing exercise.