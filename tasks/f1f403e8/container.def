Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package index and install Python 3 and pip
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip

    # Install pytest for the grading tests
    pip3 install --no-cache-dir pytest

    # -----------------------------------------------------------------
    # Set-up initial directory structure and seed data for the exercise
    # -----------------------------------------------------------------
    # Create the /home/user hierarchy in case it doesn’t exist yet
    mkdir -p /home/user/security

    # Ensure everyone can write inside the directory so the unprivileged
    # learner (whose UID is unknown at build time) can create files.
    chmod 0777 /home/user/security

    # Create the initial limits.csv with the exact required contents
    cat >/home/user/security/limits.csv <<'EOF'
Parameter,Current
nofile,4096
nproc,8192
memlock,16384
fsize,1048576
EOF

%environment
    chmod 755 /home/user

    # Nothing to add here; keep the user’s own $HOME and environment.
    export PYTHONIOENCODING=utf-8

%runscript
    echo "Container for the 'optimize_limits' exercise."
    echo "You can run: python3 /home/user/security/optimize_limits.py"
    echo "or start a shell to work on the task."