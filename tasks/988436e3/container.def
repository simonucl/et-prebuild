Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author    Storage-Reports Task Builder
    Version   v1.0

%post
    set -e

    # Refresh package index and install required system tools
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        python3 \
        python3-pip \
        sqlite3

    # Install pytest for the automated grader
    pip3 install --no-cache-dir pytest

    # Create a writable home directory for the non-root user that
    # the grading system will employ inside the container.
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up apt caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure standard paths are in place
    export PATH=/usr/local/bin:/usr/bin:/bin

%runscript
    echo "Apptainer container ready for the disk-space monitoring task."
    echo "Launch your shell commands within this environment."
    exec /bin/bash "$@"