Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install required packages
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        locales \
        tzdata

    # Generate the locale needed for LANG=de_DE.UTF-8
    locale-gen de_DE.UTF-8
    locale-gen en_US.UTF-8

    # Install pytest for the automated test-suite
    pip3 install --no-cache-dir pytest

    # Create the expected non-root home directory and make it writable
    mkdir -p /home/user
    chmod 0777 /home/user

    # Persist default environment variables for interactive shells
    echo 'export TZ="Europe/Berlin"'  > /etc/profile.d/00-time-locale.sh
    echo 'export LANG="de_DE.UTF-8"' >> /etc/profile.d/00-time-locale.sh
    chmod 0644 /etc/profile.d/00-time-locale.sh

%environment
    chmod 755 /home/user

    # Initial shell environment required by the exercise
    export TZ="Europe/Berlin"
    export LANG="de_DE.UTF-8"

%runscript
    # Default action: start an interactive shell
    exec /bin/bash "$@"