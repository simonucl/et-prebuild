Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package index and install Python and pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        locales

    # Install pytest for the test harness
    pip3 install --no-cache-dir pytest

    # Create a non-privileged user `user` with home directory /home/user
    useradd -m -s /bin/bash user || true
    mkdir -p /home/user
    chown -R user:user /home/user

    # Keep the image lean
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author devsecops-bot
    Description "Apptainer image for DevSecOps time & locale policy exercise. Contains Python 3 and pytest; ensures /home/user exists but required task files are absent."