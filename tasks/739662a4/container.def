Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "Updating package index and installing Python & pip..."
    apt-get update -y
    apt-get install -y --no-install-recommends python3 python3-pip

    echo "Installing pytest for the validation test-suite..."
    pip3 install --no-cache-dir pytest

    echo "Creating writable home directory for the default user..."
    mkdir -p /home/user
    chmod 0777 /home/user   # ensure any UID inside the container can write

    echo "Ensuring /tmp is world-writable (sticky bit keeps it secure)..."
    chmod 1777 /tmp

    echo "Basic sanity check: confirm bash exists."
    bash -c "echo Bash is available."

%environment
    chmod 755 /home/user

    # Keep environment minimal; no HOME override.
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%labels
    Author ExampleBuilder
    Description "Base image for DevSecOps environment-hardening exercise – includes pytest and writable /home/user."

%runscript
    exec /bin/bash "$@"