Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    apt-get install -y --no-install-recommends python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create the initial filesystem state required by the assessment
    # ------------------------------------------------------------------
    mkdir -p /home/user/compliance/service_a
    mkdir -p /home/user/compliance/service_b

    # YAML configuration (pre-audit version)
    cat > /home/user/compliance/service_a/config.yaml <<'YAML_EOF'
apiVersion: v1
service:
  enabled: false
  port: 8080
logging:
  level: INFO
YAML_EOF

    # TOML configuration (pre-audit version)
    cat > /home/user/compliance/service_b/settings.toml <<'TOML_EOF'
[server]
active = false
listen_ip = "0.0.0.0"
listen_port = 9000

[security]
ciphers = ["TLS_AES_128_GCM_SHA256"]
TOML_EOF

    # Ensure non-root users (the students) can read & modify the files
    chmod -R 777 /home/user/compliance

%environment
    chmod 755 /home/user

    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    echo "Container for the 'Audit & Correct YAML/TOML Configuration' task."
    echo "You can start an interactive shell with:  apptainer exec <image> /bin/bash"

%labels
    Author dev-team
    Description Container providing initial state for the YAML/TOML compliance task.
    Maintainer you@example.com