Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Update package index and install Python + pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the forthcoming test-suite
    pip3 install --no-cache-dir pytest

    ###############
    # Task assets #
    ###############
    mkdir -p /home/user/configs

    # Original db_config.yaml
    cat > /home/user/configs/db_config.yaml <<'EOF'
# Database configuration
connection:
  host: localhost
  port: 5432
  user: admin
  password: admin123
performance:
  query_caching: false
  cache_size: 128MB
EOF

    # Original query_optimizer.toml
    cat > /home/user/configs/query_optimizer.toml <<'EOF'
# Query optimizer settings
max_parallel_workers = 2
enable_hashagg = false
enable_bitmapscan = true
EOF

    # Ensure students can edit the files without root privileges
    chmod 777 /home/user/configs
    chmod 666 /home/user/configs/db_config.yaml /home/user/configs/query_optimizer.toml

%labels
    chmod 755 /home/user

    Author="Generated by ChatGPT"
    Description="Environment for configuration-editing task; pytest installed."