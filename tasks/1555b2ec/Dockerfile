FROM ubuntu:22.04

# Author="Generated by ChatGPT"
# Description="Environment for configuration-editing task; pytest installed."
# Note: Original labels section also contained "chmod 755 /home/user"

ENV DEBIAN_FRONTEND=noninteractive

RUN set -eux && \
    apt-get update && \
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates && \
    rm -rf /var/lib/apt/lists/*

RUN pip3 install --no-cache-dir pytest

RUN mkdir -p /home/user/configs

RUN cat > /home/user/configs/db_config.yaml <<'EOF'
# Database configuration
connection:
  host: localhost
  port: 5432
  user: admin
  password: admin123
performance:
  query_caching: false
  cache_size: 128MB
EOF

RUN cat > /home/user/configs/query_optimizer.toml <<'EOF'
# Query optimizer settings
max_parallel_workers = 2
enable_hashagg = false
enable_bitmapscan = true
EOF

RUN chmod 777 /home/user/configs && \
    chmod 666 /home/user/configs/db_config.yaml /home/user/configs/query_optimizer.toml