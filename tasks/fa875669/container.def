Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update APT and install Python tooling.
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3-pip python3-setuptools python3-wheel

    # Install pytest for the grading system.
    pip3 install --no-cache-dir pytest

    # Create an unprivileged user called "user" with home directory /home/user.
    # If the UID/GID already exist (e.g., in a cached layer), ignore the error.
    groupadd -g 1000 user || true
    useradd  -m -u 1000 -g 1000 -s /bin/bash user || true

    # Ensure the home directory exists and has the right ownership.
    mkdir -p /home/user
    chown -R 1000:1000 /home/user

    # Clean up APT caches to keep the image small.
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    # Default action: drop into a shell.
    exec /bin/bash "$@"