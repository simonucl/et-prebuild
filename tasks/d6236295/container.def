Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update apt repository and install required packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install pytest for the checker
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare workspace expected by the automated tests
    # ------------------------------------------------------------------
    WORKDIR="/home/user/utils_workspace"
    mkdir -p "${WORKDIR}"

    # Create script1.sh (36 bytes)
    printf '#!/bin/bash\n'                       >  "${WORKDIR}/script1.sh"
    printf 'echo "Utility script 1"\n'           >> "${WORKDIR}/script1.sh"

    # Create script2.sh (36 bytes)
    printf '#!/bin/bash\n'                       >  "${WORKDIR}/script2.sh"
    printf 'echo "Utility script 2"\n'           >> "${WORKDIR}/script2.sh"

    # Create README.md (22 bytes)
    printf '# Utilities Workspace\n'             >  "${WORKDIR}/README.md"

    # Make sure the directory is writable so the student can add files later
    chmod 0777 "${WORKDIR}"
    chmod 0644 "${WORKDIR}/"*.sh "${WORKDIR}/README.md"

    # Also ensure /home/user exists and is writable
    chmod 0777 /home/user

    # Clean up apt caches to keep image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%labels
    chmod 755 /home/user

    Author  example
    Description  Container for utils_workspace disk-usage reporting task

%help
    This container supplies the predefined workspace and installs pytest so
    that the automated grading system can run its tests.