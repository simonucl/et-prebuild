Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install prerequisites
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        curl

    # Install pytest for the assessment framework
    pip3 install --no-cache-dir pytest

    # Create the expected user account and home directory
    adduser --disabled-password --gecos "" user

    # Ensure the home directory has standard permissions (755)
    chmod 755 /home/user

    # Clean up apt cache to reduce image size
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    # Keep the default HOME binding behaviour; no overrides needed
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    # Default runscript simply opens a shell
    exec /bin/bash "$@"

%help
    This Apptainer image provides a minimal Ubuntu 22.04 environment with
    Python 3 and pytest installed. A non-privileged user “user” is pre-created
    with home directory /home/user, but none of the artefacts required by the
    firewall change-bundle exercise are present.