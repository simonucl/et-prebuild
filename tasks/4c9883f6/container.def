Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python, pip and other minimal utilities
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        tar \
        gzip && \
    rm -rf /var/lib/apt/lists/*

    # Upgrade pip and install pytest (needed by the grading framework)
    python3 -m pip install --no-cache-dir --upgrade pip
    python3 -m pip install --no-cache-dir pytest

    # -----------------------------------------------------------------
    # Prepare initial workspace exactly as described in the task
    # -----------------------------------------------------------------

    # Logs directory with the three required log files
    mkdir -p /home/user/ci_cd/logs
    printf 'Stage 1 completed\n' > /home/user/ci_cd/logs/stage1.log
    printf 'Stage 2 completed\n' > /home/user/ci_cd/logs/stage2.log
    printf 'Stage 3 completed\n' > /home/user/ci_cd/logs/stage3.log

    # Ensure readability
    chmod 0644 /home/user/ci_cd/logs/stage*.log
    chmod -R 0755 /home/user/ci_cd

    # Empty backups directory (must be writable for the unprivileged agent)
    mkdir -p /home/user/backups
    chmod 0777 /home/user/backups

%environment
    chmod 755 /home/user

    # Keep default $HOME binding; only set locale for consistency
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8