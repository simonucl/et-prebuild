Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest for the testing framework
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state expected by the automated tests
    # ------------------------------------------------------------------
    # Create the required directory tree and make /home/user writable so
    # the non-root agent can later create /home/user/archives.
    mkdir -p /home/user/net_logs
    chmod 0777 /home/user

    # Create troubleshooting output files with exact, test-expected content
    cat >/home/user/net_logs/ping_output.txt <<'EOF'
PING 8.8.8.8 (8.8.8.8): 56 data bytes
64 bytes from 8.8.8.8: icmp_seq=0 ttl=115 time=12.3 ms
EOF

    cat >/home/user/net_logs/traceroute_output.txt <<'EOF'
traceroute to 8.8.8.8 (8.8.8.8), 30 hops max
 1  10.0.0.1 (10.0.0.1)  1.123 ms
 2  8.8.8.8 (8.8.8.8)  12.345 ms
EOF

    # Ensure readable by all users
    chmod 0644 /home/user/net_logs/*.txt

%environment
    chmod 755 /home/user

    # Keep a sane PATH; do not override HOME so Apptainer can bind host $HOME
    export PATH=/usr/local/bin:/usr/bin:/bin

%labels
    Author network-backup-container
    Description "Container providing initial state for the network backup exercise"