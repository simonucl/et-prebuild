Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install required packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        sqlite3

    # Install pytest for the grading framework
    pip3 install --no-cache-dir pytest

    # Create the expected directory structure with safe permissions
    mkdir -p /home/user/projects

    # Ensure /home/user and its sub-directory are writable by any unprivileged user
    chmod 0777 /home/user
    chmod 0777 /home/user/projects

%labels
    chmod 755 /home/user

    Author  ChatGPT
    Description  Environment for SQLite file-indexing exercise (pytest pre-checks only)

%environment
    # Ensure Python and sqlite3 are on PATH (they already are, but this makes it explicit)
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%help
    This container provides the dependencies and initial filesystem state
    for the “SQLite file-indexing” exercise. It includes:
      • sqlite3 CLI
      • Python 3 with pytest
    The directory /home/user/projects exists and is writable, but contains
    no database or log files so that students can complete the assignment
    from a clean slate.