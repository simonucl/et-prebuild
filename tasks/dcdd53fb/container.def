Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    ###############################
    # 1. Install Python & pytest  #
    ###############################
    apt-get update -y
    # python3 is already in the base image, but ensure pip is present
    apt-get install -y --no-install-recommends python3-pip
    pip3 install --no-cache-dir pytest

    ###############################
    # 2. Create initial workspace #
    ###############################
    # Create the user’s home directory with permissive rights so the
    # non-root agent running the tests can write into it later on.
    mkdir -p /home/user
    chmod 0777 /home/user

    # Set up /home/user/data with the required source files
    mkdir -p /home/user/data
    chmod 0755 /home/user/data

    # alpha.txt
    cat > /home/user/data/alpha.txt <<'EOF'
Hello Alpha
EOF

    # beta.txt
    cat > /home/user/data/beta.txt <<'EOF'
Beta line1
Beta line2
EOF

    # Ensure correct permissions for files
    chmod 0644 /home/user/data/alpha.txt
    chmod 0644 /home/user/data/beta.txt

    ###############################
    # 3. Clean up APT cache       #
    ###############################
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%labels
    chmod 755 /home/user

    Author backup-exercise-builder
    Description "Environment for backup archiving exercise with pytest pre-installed."

%help
    This Apptainer image provides the initial state required for the
    “backup administrator” exercise.  The student will create
    /home/user/archive/data_backup.tar.gz and update
    /home/user/archive/backup_record.log during the assessment.

%environment
    # Use UTF-8 locale to avoid encoding surprises
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8