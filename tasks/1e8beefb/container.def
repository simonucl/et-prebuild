Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Ensure the system is up-to-date and has Python tools
    apt-get update && \
    apt-get install -y --no-install-recommends python3 python3-pip && \
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the automated checker
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Set up the initial workspace expected by the task/test framework
    # ------------------------------------------------------------------
    # Directory structure
    mkdir -p /home/user/deployment/staging
    mkdir -p /home/user/deployment/prod

    # Create the pristine nginx.conf in the staging area
    cat >/home/user/deployment/staging/nginx.conf <<'EOF'
user  nginx;
worker_processes  1;

events {
    worker_connections  1024;
}

http {
    include       mime.types;
    default_type  application/octet-stream;

    sendfile        on;
    keepalive_timeout  65;

    server {
        listen       80;
        server_name  localhost;

        location / {
            root   /usr/share/nginx/html;
            index  index.html index.htm;
        }
    }
}
EOF

    # Permissions: make everything owned by the container user (same UID as host user)
    chmod 755 /home/user /home/user/deployment /home/user/deployment/staging /home/user/deployment/prod
    chmod 644 /home/user/deployment/staging/nginx.conf

%labels
    Author="Apptainer Automation"
    Description="Environment for Nginx deployment optimization task with pytest pre-installed"

%runscript
    echo "Container for the Nginx deployment optimization task is ready."
    echo "Run your commands or tests inside this container."