Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Ensure basic development tools
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        python3 \
        python3-pip

    # Install pytest for the checker
    pip3 install --no-cache-dir pytest

    # Provide writable home for the unprivileged runtime user
    mkdir -p /home/user
    chmod 777 /home/user

    # Clean up apt caches to keep image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
    export PYTHONUNBUFFERED=1

%runscript
    exec "$@"