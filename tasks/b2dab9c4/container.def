Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Update APT and install Python plus pip
    apt-get update && apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state expected by the grading tests
    # ------------------------------------------------------------------
    # Ensure the /home/user directory tree exists
    mkdir -p /home/user

    # 1. Create /home/user/docs with the required index.html file
    mkdir -p /home/user/docs
    echo '<h1>Technical Documentation Home</h1>' > /home/user/docs/index.html
    chmod 755 /home/user/docs
    chmod 644 /home/user/docs/index.html

    # 2. Create an empty, writable /home/user/logs directory
    mkdir -p /home/user/logs
    chmod 777 /home/user/logs      # Writable by any unprivileged user

    # Clean up APT caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    # Ensure Python is the default interpreter name
    export PYTHON=python3
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author="Generated by OpenAI ChatGPT"
    Description="Container for web-server background task. Provides initial docs and logs directories and installs pytest."