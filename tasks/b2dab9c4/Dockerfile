FROM ubuntu:22.04

# Labels
LABEL Author="Generated by OpenAI ChatGPT"
LABEL Description="Container for web-server background task. Provides initial docs and logs directories and installs pytest."

# Update APT and install Python plus pip
RUN apt-get update && apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

# Install pytest for the grader
RUN pip3 install --no-cache-dir pytest

# ------------------------------------------------------------------
# Prepare initial filesystem state expected by the grading tests
# ------------------------------------------------------------------
# Ensure the /home/user directory tree exists
RUN mkdir -p /home/user

# 1. Create /home/user/docs with the required index.html file
RUN mkdir -p /home/user/docs && \
    echo '<h1>Technical Documentation Home</h1>' > /home/user/docs/index.html && \
    chmod 755 /home/user/docs && \
    chmod 644 /home/user/docs/index.html

# 2. Create an empty, writable /home/user/logs directory
RUN mkdir -p /home/user/logs && \
    chmod 777 /home/user/logs

# Clean up APT caches to keep the image small
RUN apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Environment variables
ENV PYTHON=python3
ENV PATH=/usr/local/bin:/usr/bin:/bin:$PATH