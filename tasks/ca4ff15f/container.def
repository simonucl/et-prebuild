Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -ex

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # Prepare an empty, writable home for the student
    mkdir -p /home/user
    chmod 0777 /home/user

%environment
    chmod 755 /home/user

    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author  task-preparer
    Description "Clean environment for monitoring exercise with pytest pre-installed"