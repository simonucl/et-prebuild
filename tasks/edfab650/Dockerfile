FROM ubuntu:22.04

RUN set -e && \
    apt-get update && \
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        tar \
        gzip \
        coreutils && \
    pip3 install --no-cache-dir pytest && \
    mkdir -p /home/user/important_data && \
    mkdir -p /home/user/secure_backups && \
    printf 'Alpha\n' > /home/user/important_data/file1.txt && \
    printf 'Beta\n'  > /home/user/important_data/file2.txt && \
    touch /home/user/secure_backups/backup.log && \
    chmod 755 /home/user && \
    chmod 755 /home/user/important_data && \
    chmod 777 /home/user/secure_backups && \
    chmod 644 /home/user/important_data/file1.txt /home/user/important_data/file2.txt && \
    chmod 666 /home/user/secure_backups/backup.log && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

RUN chmod 755 /home/user

ENV LC_ALL=C
ENV LANG=C
ENV PATH=$PATH:/usr/local/bin