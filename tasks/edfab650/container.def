Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install runtime necessities
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        tar \
        gzip \
        coreutils

    # Install pytest for the test harness
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare the initial filesystem expected by the automated tests
    # ------------------------------------------------------------------

    # Create the user’s home hierarchy
    mkdir -p /home/user/important_data
    mkdir -p /home/user/secure_backups

    # Populate /home/user/important_data with the required files
    printf 'Alpha\n' > /home/user/important_data/file1.txt
    printf 'Beta\n'  > /home/user/important_data/file2.txt

    # (Optional) create an empty log file; tests allow it to be empty or absent
    touch /home/user/secure_backups/backup.log

    # Permissions:
    #  - important_data needs to be readable
    #  - secure_backups must be writable by ANY unprivileged user who runs the container
    chmod 755  /home/user
    chmod 755  /home/user/important_data
    chmod 777  /home/user/secure_backups
    chmod 644  /home/user/important_data/file1.txt /home/user/important_data/file2.txt
    chmod 666  /home/user/secure_backups/backup.log

    # Clean up APT caches to keep the image lean
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    export LC_ALL=C
    export LANG=C
    export PATH=$PATH:/usr/local/bin

%labels
    Author="Generated by AI"
    Description="Container image prepared for the backup-administration single-command task."

%help
This Apptainer image provides the initial filesystem layout and tools
necessary for the “secure backups” exercise.  The automated test suite
will run inside this container to verify the student’s solution.