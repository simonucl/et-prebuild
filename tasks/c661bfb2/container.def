Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Basic tooling
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # Create initial project structure
    mkdir -p /home/user/project

    # VERSION file (initial state: 1.4.2)
    printf '1.4.2\n' > /home/user/project/VERSION

    # CHANGELOG.md with initial 1.4.2 notes
    cat > /home/user/project/CHANGELOG.md <<'EOF'
# Changelog
All notable changes to this project will be documented in this file.

## [1.4.2] - 2023-12-14
### Changed
* Switched default output from JSON to YAML.
EOF

    # Ensure the agent (non-root) will be able to write to the project tree
    chmod -R 777 /home/user/project

%environment
    chmod 755 /home/user

    # Nothing special; inherit default environment.
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8