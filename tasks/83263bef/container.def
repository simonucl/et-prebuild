Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package list and install Python + pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        tzdata

    # Upgrade pip and install pytest for the grading framework
    python3 -m pip install --no-cache-dir --upgrade pip
    python3 -m pip install --no-cache-dir pytest

    # Ensure the workspace directory expected by the assignment exists
    mkdir -p /home/user
    # Make it writable for any non-root user that will run inside the container
    chmod 0777 /home/user

    # Clean up apt caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Preserve a sensible default PATH and locale settings
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8

%runscript
    # Default action when the container is executed without arguments
    exec "$@"

%test
    # Minimal self-check that Python and pytest are available
    python3 - << 'PY'
import sys, pytest, textwrap, os
print("Python version:", sys.version)
print("pytest version:", pytest.__version__)
PY