Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Refresh APT metadata and install required packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        sysbench \
        fio \
        stress-ng \
        ca-certificates \
        gnupg \
        && apt-get clean && rm -rf /var/lib/apt/lists/*

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # Prepare a writable working directory for the learner
    mkdir -p /home/user
    chmod 0777 /home/user  # allow the non-root learner process to write here

%labels
    chmod 755 /home/user

    Author benchmark-setup
    Description Container for on-call performance benchmark task with pytest pre-installed.

%runscript
    echo "This container is prepared for the performance-benchmark exercise."
    echo "Invoke your own scripts/tests after entering the shell."