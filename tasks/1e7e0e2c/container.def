Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install required packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        pigz \
        pbzip2 \
        bzip2 \
        xz-utils \
        tar \
        gzip \
        ca-certificates \
        git \
        coreutils

    # Install pytest for the forthcoming test-suite
    pip3 install --no-cache-dir --upgrade pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create unprivileged user and its home directory
    # ------------------------------------------------------------------
    # Use UID 1000 (common default); if the runtime UID differs it will
    # still be able to use /home/user because we open permissions later.
    useradd -m -u 1000 -s /bin/bash user || true

    # ------------------------------------------------------------------
    # Prepare initial directory tree and sample data files
    # ------------------------------------------------------------------
    BASE=/home/user
    DATA_DIR=${BASE}/data
    mkdir -p "${DATA_DIR}/projectA" "${DATA_DIR}/projectB"

    # projectA files
    printf 'Annual Report 2023 final version\n' > "${DATA_DIR}/projectA/report.txt"
    printf 'temporary data\n'                           > "${DATA_DIR}/projectA/draft.tmp"

    # projectB files
    printf '# sample configuration\nversion = 1.0\nenabled = true\n' > \
        "${DATA_DIR}/projectB/config.cfg"

    printf 'Meeting notes for upcoming release\nRemember to update changelog.\n' > \
        "${DATA_DIR}/projectB/notes.txt"

    # Ensure correct permissions so the (non-root) test user can work freely
    chmod -R a+rwx /home/user

%environment
    chmod 755 /home/user

    # Ensure Python and pip are in PATH for the unprivileged user
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%runscript
    # Default action when the container is executed without a command.
    # Provide a helpful message for human users; CI systems will supply
    # their own command anyway.
    echo "Container for backup-task exercises."
    echo "Invoke your desired command inside the container as usual."
%labels
    Author="Auto-generated container for backup task"
    Description="Provides the initial state and dependencies for the backup exercise"