Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    ##############################################
    # 1. Install runtime dependencies
    ##############################################
    apt-get update
    # `parallel` satisfies the explicit-parallelism requirement of the assignment.
    apt-get install -y --no-install-recommends python3 python3-pip moreutils parallel
    pip3 install --no-cache-dir pytest

    ##############################################
    # 2. Create baseline filesystem layout
    ##############################################
    # Base directories
    mkdir -p /home/user/releases/1.2.0
    mkdir -p /home/user/releases/1.3.0
    mkdir -p /home/user/releases/2.0.0-beta
    # Directory where the agent will write its output; make it world-writable
    mkdir -p /home/user/deployment
    chmod 0777 /home/user/deployment

    ##############################################
    # 3. Populate input files
    ##############################################

    # ---- Version 1.2.0 ----
    cat > /home/user/releases/1.2.0/artifacts.txt <<'EOF'
app-1.2.0.jar
lib-1.2.0.so
docs-1.2.0.zip
EOF

    cat > /home/user/releases/1.2.0/release_notes.txt <<'EOF'
Bug fixes and performance improvements.
EOF

    # ---- Version 1.3.0 ----
    cat > /home/user/releases/1.3.0/artifacts.txt <<'EOF'
app-1.3.0.jar
lib-1.3.0.so
docs-1.3.0.zip
cli-1.3.0.tar.gz
EOF

    cat > /home/user/releases/1.3.0/release_notes.txt <<'EOF'
Added new CLI support and minor enhancements.
EOF

    # ---- Version 2.0.0-beta ----
    cat > /home/user/releases/2.0.0-beta/artifacts.txt <<'EOF'
app-2.0.0-beta.jar
lib-2.0.0-beta.so
docs-2.0.0-beta.zip
cli-2.0.0-beta.tar.gz
migrator-2.0.0-beta.sh
EOF

    cat > /home/user/releases/2.0.0-beta/release_notes.txt <<'EOF'
Major release beta featuring new architecture overhaul.
EOF

    ##############################################
    # 4. Set permissive permissions so the non-root
    #    agent can read everything and write to
    #    /home/user/deployment
    ##############################################
    chmod -R a+rX /home/user/releases
    # deployment dir already 0777
    :

%environment
    chmod 755 /home/user

    # Make sure Python and parallel are in PATH (they already are, but be explicit)
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8