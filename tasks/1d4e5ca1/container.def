Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
set -eux

# Install Python and pytest
apt-get update
DEBIAN_FRONTEND=noninteractive apt-get install -y python3 python3-pip
pip3 install --no-cache-dir pytest

# ------------------------------------------------------------------
# Prepare initial filesystem state for the “configs” assignment
# ------------------------------------------------------------------

# 1. Directory layout
mkdir -p /home/user/projects/configs/available
mkdir -p /home/user/projects/configs/enabled

# 2. Initial regular files
echo -e "app configuration\n" > /home/user/projects/configs/available/app.conf
echo -e "db configuration\n"  > /home/user/projects/configs/available/db.conf

# 3. Broken symlink (must stay dangling)
ln -s ../available/old.conf /home/user/projects/configs/enabled/old.conf

# 4. Make directories world-writable so the unprivileged agent can modify them
chmod -R 0777 /home/user/projects

%environment
    chmod 755 /home/user

# Keep a sensible default PATH (do NOT alter $HOME)
export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

%runscript
# Default runscript: simply execute given command
exec "$@"