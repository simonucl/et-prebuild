Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "Updating package lists and installing prerequisites..."
    apt-get update -qq
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        tzdata

    echo "Installing pytest via pip..."
    pip3 install --no-cache-dir --upgrade pip
    pip3 install --no-cache-dir pytest

    echo "Creating writable /home/user directory with open permissions..."
    mkdir -p /home/user
    # Grant full rwx to everyone so whichever non-root UID runs the container
    # can create the required sub-directory and files.
    chmod 0777 /home/user

    # Clean up APT caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%labels
    chmod 755 /home/user

    Author  "Container setup for UTC timestamp logging task"
    Purpose "Prepare initial state for learner—pytest installed, /home/user present"