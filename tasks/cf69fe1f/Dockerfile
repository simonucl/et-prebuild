FROM ubuntu:22.04

# Labels
LABEL Author="Generated by ChatGPT"
LABEL Description="Environment for unhealthy Docker container reporting task"
LABEL Version="1.0"

# Install Python and pytest
RUN set -e && \
    apt-get update && \
    apt-get install -y --no-install-recommends python3 python3-pip && \
    pip3 install --no-cache-dir pytest && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Prepare the initial filesystem state expected by the automated tests
RUN mkdir -p /home/user/incident

RUN cat > /home/user/incident/docker_ps.out <<'EOF'
CONTAINER ID   IMAGE          COMMAND                  CREATED        STATUS                       PORTS                   NAMES
1a2b3c4d5e6f   nginx:1.25     "/docker-entrypoint.…"   2 hours ago    Up 2 hours (healthy)         0.0.0.0:8080->80/tcp    web-frontend
7e8f9a0b1c2d   redis:7.0      "docker-entrypoint.s…"   3 hours ago    Exited (1) 30 minutes ago                            redis-cache
3d4e5f6a7b8c   postgres:15    "docker-entrypoint.s…"   3 hours ago    Restarting (1) 5 seconds ago 0.0.0.0:5432->5432/tcp db-primary
EOF

# Set permissions so the runtime (non-root) user can write the output file
RUN chmod 0777 /home/user/incident && \
    chmod 0644 /home/user/incident/docker_ps.out

# Environment variables
ENV LC_ALL=C
ENV LANG=C
ENV PYTHONUNBUFFERED=1

# Set permissions on /home/user at runtime via entrypoint or keep it in build
RUN chmod 755 /home/user