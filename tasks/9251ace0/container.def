Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Basic useful packages + Python tooling
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends \
        openssh-client \
        python3 \
        python3-pip \
        ca-certificates \
        tzdata \
        hostname \
        coreutils
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Python packages needed for the grader / student
    pip3 install --no-cache-dir pytest

    # Create the non-privileged workspace
    mkdir -p /home/user
    chmod 0777 /home/user         # allow whichever host UID runs inside to write

    # Optional: add a minimal passwd/group entry for uid 1000 (common case)
    if ! getent passwd 1000 >/dev/null 2>&1; then
        echo "user:x:1000:1000::/home/user:/bin/bash" >> /etc/passwd
        echo "user:x:1000:" >> /etc/group
    fi

%runscript
    chmod 755 /home/user

    # Default entry drops the user into a shell; useful for interactive debugging
    exec /bin/bash "$@"

%environment
    # No HOME override – Apptainer will handle host mapping
    export PATH=/usr/local/bin:/usr/bin:/bin