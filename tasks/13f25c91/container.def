Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python tooling and pytest
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip ca-certificates
    pip3 install --no-cache-dir pytest

    # Create required directory structure and seed source files
    mkdir -p /home/user/net_logs

    cat >/home/user/net_logs/ip_list.txt <<'EOF'
192.168.0.1:80
192.168.0.2:443
10.0.0.1:22
EOF

    cat >/home/user/net_logs/ping_ms.txt <<'EOF'
32
85
12
EOF

    # Ensure the agent (non-root) can read/write these paths
    chmod -R a+rwx /home/user

%environment
    chmod 755 /home/user

    export PATH="/usr/local/bin:/usr/bin:/bin:${PATH}"
    export PYTHONIOENCODING="utf-8"

%runscript
    exec "$@"