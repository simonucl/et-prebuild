Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update -y
    apt-get install -y python3 python3-pip
    pip3 install --no-cache-dir pytest

    # Create an unprivileged user
    useradd -m -s /bin/bash user

    # Prepare initial filesystem state
    mkdir -p /home/user/app

    # Create the initial .env file with the required content
    printf 'APP_DB_USER=olduser\nAPP_DB_PASS=oldpass123\n' > /home/user/app/.env

    # Set correct permissions (world-readable, writable by owner)
    chmod 0644 /home/user/app/.env

    # Ensure ownership belongs to the unprivileged user
    chown -R user:user /home/user

%environment
    chmod 755 /home/user

    # Nothing extra needed; preserve default HOME binding and environment.

%runscript
    # Default runscript: drop to a shell
    exec /bin/bash "$@"