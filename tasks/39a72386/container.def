Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # Update package lists and install required software
    apt-get update
    apt-get install -y --no-install-recommends \
        cron \
        iputils-ping \
        python3-pip

    # Install pytest for the grading framework
    pip3 install --no-cache-dir pytest

    # Create the directory expected by the exercise (write-able by any user)
    mkdir -p /home/user
    chmod 0777 /home/user

    # Reduce image size
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%labels
    chmod 755 /home/user

    Author: exercise-preparer
    Description: Base image for “Schedule Periodic Connectivity-Check with a User Cron Job” task. Installs cron, ping, and pytest.