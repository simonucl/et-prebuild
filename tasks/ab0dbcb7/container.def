Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # Install Python and pytest
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # --------------------------------------------------------------------------
    # Create initial directory structure and seed data for the task
    # --------------------------------------------------------------------------
    mkdir -p /home/user/downloads
    mkdir -p /home/user/projects
    # NOTE: /home/user/projects/behavioral_study/ must NOT exist at build time.

    # Seed TSV files in /home/user/downloads
    cat > /home/user/downloads/demographics.tsv <<'EOF'
id\tage\tgender
1\t34\tF
2\t29\tM
EOF

    cat > /home/user/downloads/reaction_times.tsv <<'EOF'
participant_id\ttime_ms
1\t532
2\t489
EOF

    cat > /home/user/downloads/survey_responses.tsv <<'EOF'
pid\tq1\tq2\tq3
1\t4\t3\t5
2\t5\t4\t4
EOF

    # Ensure the learner can write to the relevant areas
    chmod -R a+rwx /home/user

%environment
    chmod 755 /home/user

    export PYTHONDONTWRITEBYTECODE=1

%labels
    Author behavioral-study-task-initializer

%help
    This container sets up the initial filesystem and data required for the
    “behavioral_study” organizational task. It installs pytest and places three
    TSV files in /home/user/downloads while leaving
    /home/user/projects/behavioral_study/ absent so that learners can complete
    the exercise.