Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install Python + pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates

    # Install pytest for the upcoming test-suite
    pip3 install --no-cache-dir pytest

    # Create the non-privileged user account expected by the exercise
    groupadd -g 1000 user
    useradd  -m -u 1000 -g 1000 -s /bin/bash user

    # Ensure the home directory has the correct ownership
    chown -R user:user /home/user

    # Clean up apt cache to keep the image lean
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Add the default user’s local bin directory to PATH (if the student uses it)
    export PATH=/home/user/.local/bin:$PATH

%labels
    Author "Apptainer Task Setup"
    Description "Base image with pytest installed and a clean filesystem for the cloud migration symlink exercise."