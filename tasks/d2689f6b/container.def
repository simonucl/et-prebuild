Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package index and install required tools
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        sqlite3 \
        ca-certificates

    # Upgrade pip and install pytest (needed by the grader)
    python3 -m pip install --no-cache-dir --upgrade pip
    python3 -m pip install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare directory structure and seed the legacy SQLite database
    # ------------------------------------------------------------------
    mkdir -p /home/user/legacy

    # Create the legacy database with the required schema and rows
    sqlite3 /home/user/legacy/old_db.sqlite <<'SQL'
CREATE TABLE employees (
    id INTEGER PRIMARY KEY,
    first_name TEXT,
    last_name TEXT,
    department TEXT
);
INSERT INTO employees (id, first_name, last_name, department) VALUES
    (1,'Ava','Moore','Engineering'),
    (2,'Liam','Johnson','Finance'),
    (3,'Emma','Davis','Marketing'),
    (4,'Noah','Wilson','HR'),
    (5,'Mia','Brown','Sales');
SQL

    # Ensure the /home/user directory tree is writable by any
    # non-root user who will run inside the container
    chmod -R 0777 /home/user

    # Clean up APT cache to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8