Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author ReleaseManagerPrep
    Description Base image for deployment-cron exercise. Provides Python, pytest and cron; ensures /home/user is writable.

%post
    set -e

    # Ensure non-interactive apt operations
    export DEBIAN_FRONTEND=noninteractive

    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        cron \
        ca-certificates \
        build-essential

    # Clean up apt caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Upgrade pip and install pytest for the student’s tests
    python3 -m pip install --upgrade pip setuptools
    python3 -m pip install pytest

    # Prepare writable workspace for the student
    mkdir -p /home/user
    chmod 0777 /home/user

%environment
    chmod 755 /home/user

    # Ensure Python is in PATH (typically already) and set default editor for crontab if needed
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"
    export EDITOR="vi"

%runscript
    # Default action: start an interactive shell
    exec /bin/bash "$@"