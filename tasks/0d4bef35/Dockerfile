FROM ubuntu:22.04

# Help:
# This image provides the initial state for the diagnostics collection assignment.
# Guarantees:
# - /home/user exists and is readable.
# - /home/user/diagnostics is absent.
# - pytest is installed.

LABEL Author="Generated by ChatGPT"
LABEL Purpose="Container for diagnostics collection task – initial state setup"

ENV PATH="/usr/local/bin:${PATH}"

RUN set -e && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip && \
    pip3 install --no-cache-dir pytest && \
    mkdir -p /home/user && \
    chmod 755 /home/user && \
    rm -rf /home/user/diagnostics || true