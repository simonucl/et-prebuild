Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install Python + pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install pytest for the grading suite
    pip3 install --no-cache-dir pytest

    # Ensure the required home directory exists and is accessible
    mkdir -p /home/user
    chmod 755 /home/user

    # Make absolutely sure the diagnostics directory is absent
    rm -rf /home/user/diagnostics || true

%environment
    # Ensure Python and pip-installed executables are on PATH
    export PATH="/usr/local/bin:$PATH"

%labels
    Author="Generated by ChatGPT"
    Purpose="Container for diagnostics collection task – initial state setup"

%help
    This Apptainer image provides the initial state for the diagnostics
    collection assignment.  It guarantees:
      • /home/user exists and is readable.
      • /home/user/diagnostics and its contents are absent.
      • pytest is installed for the grader.