Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ---------------------------------------------------------------------
    # Basic utilities + Python tooling
    # ---------------------------------------------------------------------
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    pip3 install --no-cache-dir pytest

    # ---------------------------------------------------------------------
    # Prepare initial data state expected by the tests
    # ---------------------------------------------------------------------
    # Directory structure
    mkdir -p /home/user/data/raw

    # Make /home/user/data writable by the non-root runtime user so that
    # the agent can create additional files/directories inside it.
    chmod 777 /home/user/data

    # Create the raw TSV file with the exact expected contents
    cat <<'EOF' > /home/user/data/raw/user_events.tsv
user_id	event_type	timestamp
u01	click	2023-05-01T10:00:00Z
u02	view	2023-05-01T10:02:00Z
u01	click	2023-05-01T10:00:00Z
u03	purchase	2023-05-01T10:05:00Z
u02	view	2023-05-01T10:02:00Z
u04	click	2023-05-01T10:10:00Z
u02	click	2023-05-01T10:12:00Z
u03	view	2023-05-01T10:15:00Z
EOF

    chmod 644 /home/user/data/raw/user_events.tsv

%environment
    chmod 755 /home/user

    # Nothing to set; keep default environment so $HOME is correctly bound.

%help
    This container provides the initial dataset and Python tooling (pytest) for
    the click-stream processing task.