Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Ensure working directory for the student exists and is writable
    mkdir -p /home/user
    chmod 0777 /home/user || true   # allow the unprivileged run-time user to write

    # Provide an (almost) empty .bashrc that does NOT contain the ulimit lines
    if [ ! -f /home/user/.bashrc ]; then
        touch /home/user/.bashrc
        echo "" >> /home/user/.bashrc   # single blank line, acceptable for the tests
    fi

%environment
    chmod 755 /home/user

    # Add local-user Python tools (pytest, etc.) to the PATH
    export PATH="/home/user/.local/bin:$PATH"

%runscript
    echo "Container for the security-hardening exercise."
    echo "Invoke your shell or commands as needed."