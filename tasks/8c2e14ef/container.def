Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive \
        apt-get install -y --no-install-recommends \
            python3 \
            python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create initial filesystem state expected by the automated tests
    # ------------------------------------------------------------------

    # 1. Create the project_files directory with the required contents
    mkdir -p /home/user/project_files

    printf 'Hello Backup\n'          > /home/user/project_files/file1.txt
    printf 'Data Integrity Test\n'   > /home/user/project_files/file2.txt

    # 2. Ensure that /home/user/backups does NOT exist yet
    rm -rf /home/user/backups

    # 3. Make sure everything is readable/writable by the invoking user
    chmod -R a+rX,u+w /home/user

%environment
    chmod 755 /home/user

    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%labels
    Author="Container Build Script"
    Description="Apptainer image for backup integrity task with pytest pre-installed"