Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package index and install Python + pip
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip

    # Install pytest for the grading tests
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create a non-privileged user `user` (UID/GID 1000) and its HOME.
    # Even though Apptainer will map the calling user at runtime,
    # having this account guarantees that /home/user exists inside
    # the image with the correct tree pre-staged for the assignment.
    # ------------------------------------------------------------------
    groupadd -g 1000 user || true
    useradd  -m -u 1000 -g 1000 -d /home/user user || true

    # ------------------------------------------------------------------
    # Pre-stage the “project” workspace with the exact structure and
    # permissions required by the tests.
    # ------------------------------------------------------------------
    mkdir -p /home/user/project/scripts
    mkdir -p /home/user/project/data

    # Files with placeholder content
    echo "# sample config"                 > /home/user/project/config.cfg
    echo -e "#!/bin/bash\necho Building…"  > /home/user/project/scripts/build.sh
    echo "raw data"                        > /home/user/project/data/raw.txt

    # Set permissions exactly as specified
    chmod 0755 /home/user/project
    chmod 0644 /home/user/project/config.cfg
    chmod 0755 /home/user/project/scripts
    chmod 0750 /home/user/project/scripts/build.sh
    chmod 0700 /home/user/project/data
    chmod 0600 /home/user/project/data/raw.txt

    # Ensure ownership is consistent
    chown -R 1000:1000 /home/user

%environment
    chmod 755 /home/user

    export LC_ALL=C
    export LANG=C

%runscript
    exec "$@"