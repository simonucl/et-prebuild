Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python tooling and pytest
    apt-get update && \
        apt-get install -y --no-install-recommends python3 python3-pip && \
        rm -rf /var/lib/apt/lists/*
    pip3 install --no-cache-dir pytest

    # Create a non-privileged user
    useradd -m -s /bin/bash user

    # Set up initial directory structure
    mkdir -p /home/user/mlops/experiments/exp42
    mkdir -p /home/user/mlops/logs
    mkdir -p /home/user/remote_store

    # Populate the experiment artifacts
    printf 'DUMMY MODEL DATA\n' > /home/user/mlops/experiments/exp42/model.pkl

    cat <<'EOF' > /home/user/mlops/experiments/exp42/metrics.json
{
  "accuracy": 0.93,
  "loss": 0.12
}
EOF

    # Ensure the regular user can read/write everything under /home/user
    chown -R user:user /home/user
    chmod -R u+rwX,go+rX /home/user

%environment
    chmod 755 /home/user

    # Make sure user-installed Python tools (if any) are found first
    export PATH="/home/user/.local/bin:${PATH}"