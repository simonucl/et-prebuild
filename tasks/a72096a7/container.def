Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author BuildArtifactsExercise
    Description Base image with pytest installed and a writable /home/user directory.

%post
    set -e

    # Update package lists and install Python + pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # Create the workspace for the student
    mkdir -p /home/user
    chmod 0777 /home/user   # ensure the unprivileged runtime UID can write here

    # Clean up APT caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%runscript
    echo "Container ready. Launch a shell to begin the task."