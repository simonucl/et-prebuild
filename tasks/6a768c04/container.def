Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # Set up initial filesystem state for the assignment
    mkdir -p /home/user/legacy_configs

    cat >/home/user/legacy_configs/payment_service.conf <<'EOF'
SERVICE_NAME=payment
SERVICE_PORT=8080
DB_HOST=localhost
DB_PORT=5432
EOF

    # Ensure the student can write inside /home/user
    chmod -R 0777 /home/user

    # Clean up apt caches to reduce image size
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%labels
    chmod 755 /home/user

    Author ExampleAuthor
    Description Initial state for migration assignment with pytest installed