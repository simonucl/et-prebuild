Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    ############################################################
    # 1. System packages and Python tooling
    ############################################################
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    ############################################################
    # 2. Create required directory structure and files
    ############################################################
    # Base directories
    mkdir -p /home/user/builds/android
    mkdir -p /home/user/builds/channels

    # Helper function for VERSION files
    add_version () {
        dir="$1"; channel="$2"; ver="$3"
        mkdir -p "/home/user/builds/android/${dir}"
        cat > "/home/user/builds/android/${dir}/VERSION" <<EOF
channel=${channel}
version=${ver}
EOF
    }

    # Android build artefacts
    add_version "1.2.0"        "stable" "1.2.0"
    add_version "1.3.0-beta"   "beta"   "1.3.0-beta"
    add_version "1.4.0"        "stable" "1.4.0"
    add_version "2.0.0-alpha"  "canary" "2.0.0-alpha"
    add_version "2.0.0"        "stable" "2.0.0"

    ############################################################
    # 3. Pre-existing channel symlinks (no canary yet)
    ############################################################
    ln -s "/home/user/builds/android/1.4.0"     /home/user/builds/channels/stable
    ln -s "/home/user/builds/android/1.3.0-beta" /home/user/builds/channels/beta
    # (do NOT create canary link)

    ############################################################
    # 4. Permissions – allow non-root agent to modify contents
    ############################################################
    chmod -R 0777 /home/user/builds

%labels
    chmod 755 /home/user

    Author  "task-prep-automation"

%help
This container pre-provisions the filesystem layout required for the
Android-build channel-symlink exercise. Pytest is installed so that the
verification suite can run inside the container.