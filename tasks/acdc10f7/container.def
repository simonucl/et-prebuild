Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Install Python tooling for pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Create the non-root user expected by the exercise
    if ! getent group 1000 >/dev/null; then
        groupadd -g 1000 user
    fi
    if ! id -u 1000 >/dev/null 2>&1; then
        useradd -m -u 1000 -g 1000 -s /bin/bash user
    fi

    # Prepare the initial Kubernetes manifest files
    mkdir -p /home/user/manifests

    cat >/home/user/manifests/deployment.yaml <<'EOF'
apiVersion: apps/v1
kind: Deployment
metadata:
  name: demo-deployment
  namespace: demo
EOF

    cat >/home/user/manifests/service.yaml <<'EOF'
apiVersion: v1
kind: Service
metadata:
  name: demo-service
  namespace: demo
EOF

    # Ensure the files and directories belong to the non-root user
    chown -R 1000:1000 /home/user

%environment
    chmod 755 /home/user

    # Ensure Python is in PATH
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%labels
    Author your_name
    Description "Container for Kubernetes manifest documentation exercise"