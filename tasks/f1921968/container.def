Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Basic tooling
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # Prepare exercise scaffolding ------------------------------------------------
    mkdir -p /home/user

    # Helper script that the student must work with
    cat >/home/user/backup.sh <<'EOF'
#!/bin/bash
echo "backup executed"
EOF

    # Ensure correct permissions: NOT executable yet
    chmod 0644 /home/user/backup.sh

    # Give ownership to uid 1000 (the most common regular-user uid);
    # if such a user is absent in /etc/passwd that is fine – numeric
    # ownership is sufficient for Apptainer’s overlay model.
    chown 1000:1000 /home/user/backup.sh
    chown 1000:1000 /home/user
    chmod 0755 /home/user

%environment
    chmod 755 /home/user

    # Nothing special required; inherit host environment
    :

%labels
    Author database-backup exercise scaffold

%help
    This container sets up the initial state for the “database backup” task.
    It provides /home/user/backup.sh (not executable) and no further artefacts.
    Pytest is pre-installed so that the automated checker can validate both the
    initial and final states.