Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # Update package lists and install Python + pip
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install pytest for the exercise test-suite
    pip3 install --no-cache-dir pytest

    # Ensure the required home directory exists and is writable
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up apt caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Make sure user-installed Python tools (if any) are on the PATH
    export PATH="${PATH}:/home/${USER:-user}/.local/bin"

%runscript
    echo "Apptainer container ready for the migration baseline task."