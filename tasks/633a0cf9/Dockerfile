FROM ubuntu:22.04

# Update package lists and install Python tooling
RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        python3-pip \
        python3-setuptools && \
    # Install pytest for the grading framework
    pip3 install --no-cache-dir pytest && \
    # Prepare a writable home directory for the learner
    mkdir -p /home/user && \
    chmod 0777 /home/user && \
    # Clean up APT caches to keep the image lean
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Set labels
LABEL Author="Generated by ChatGPT"
LABEL Description="Environment for filesystem permission exercise with pytest pre-installed."

# Set working directory
WORKDIR /home/user

# Default action when the container is executed
CMD ["/bin/bash"]