Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install Python tooling
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        python3-pip \
        python3-setuptools

    # Install pytest for the grading framework
    pip3 install --no-cache-dir pytest

    # Prepare a writable home directory for the learner
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up APT caches to keep the image lean
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%runscript
    chmod 755 /home/user

    # Default action when the container is executed
    exec /bin/bash "$@"

%labels
    Author="Generated by ChatGPT"
    Description="Environment for filesystem permission exercise with pytest pre-installed."