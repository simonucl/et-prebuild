Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author      Capacity-Planning Exercise
    Description Base image providing the raw input data and test framework

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # ---- System packages -----------------------------------------------------
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ---- Python packages -----------------------------------------------------
    pip3 install --no-cache-dir pytest

    # ---- User and directory setup -------------------------------------------
    # Create an unprivileged user whose $HOME is /home/user
    if ! id -u user >/dev/null 2>&1; then
        # Prefer UID 1000 if it is free; fall back to the next available UID
        useradd -m -u 1000 -s /bin/bash user || useradd -m -s /bin/bash user
    fi

    # ---- Raw capacity-planning data -----------------------------------------
    mkdir -p /home/user/capacity/raw

    cat > /home/user/capacity/raw/serverA.csv <<'EOF'
timestamp,cpu_pct,mem_mb
2023-07-01T00:00:00,55.5,2048
2023-07-01T01:00:00,65.0,2100
2023-07-01T02:00:00,70.2,2200
2023-07-01T03:00:00,60.1,2000
EOF

    cat > /home/user/capacity/raw/serverB.csv <<'EOF'
timestamp,cpu_pct,mem_mb
2023-07-01T00:00:00,35.2,1024
2023-07-01T01:00:00,45.5,1100
2023-07-01T02:00:00,50.0,1150
2023-07-01T03:00:00,40.3,1080
EOF

    # Ensure files are world-readable and that the student can create new artefacts
    chmod -R a+rX /home/user/capacity
    chmod a+rwx /home/user/capacity

    # Make sure no artefact directories/files that the student must create exist
    rm -rf /home/user/capacity/analysis || true
    rm -rf /home/user/capacity/logs     || true

%environment
    chmod 755 /home/user

    export PYTHONUNBUFFERED=1

%runscript
    echo "Capacity-planning base container. No default command defined."
    echo "Launch your own scripts inside this container as needed."