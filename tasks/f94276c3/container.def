Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    ###########################################################################
    # 1. Install system packages and pytest
    ###########################################################################
    apt-get update \
        && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
           python3 python3-venv python3-pip ca-certificates \
        && apt-get clean \
        && rm -rf /var/lib/apt/lists/*

    # pytest for the grader
    pip3 install --no-cache-dir pytest

    ###########################################################################
    # 2. Create initial filesystem layout expected by the exercise
    ###########################################################################
    # Create the home directory hierarchy
    mkdir -p /home/user/data

    # Write the backup_requirements.txt file with EXACT content and LF endings
    cat > /home/user/data/backup_requirements.txt <<'EOF'
certifi==2023.7.22
charset-normalizer==3.3.2
idna==3.4
urllib3==2.0.7
requests==2.31.0
EOF

    ###########################################################################
    # 3. Set permissions so the unprivileged runtime user can work freely
    ###########################################################################
    # Allow write access to /home/user so the agent can create files/directories
    chmod 0777 /home/user
    # Make sure the requirements file is readable by everyone
    chmod -R a+r /home/user/data

%environment
    chmod 755 /home/user

    # Nothing special here; keep default HOME handling
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8