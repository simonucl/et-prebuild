Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update APT and install Python & pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install pytest for the upcoming test harness
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare filesystem layout and raw CSV logs for the FinOps exercise
    # ------------------------------------------------------------------
    mkdir -p /home/user/cloud_logs
    chmod 0777 /home/user/cloud_logs   # allow learner to create 'reports' later

    # September 2023 log
    cat <<'EOF' > /home/user/cloud_logs/usage-2023-09.csv
resource_id,service,usage_hours,cost
r1,Compute Engine,720,96.00
r2,Cloud Storage,5000,25.00
r3,BigQuery,100,150.00
r4,Compute Engine,100,13.33
r5,Cloud SQL,200,90.00
r6,Cloud Storage,3000,15.00
EOF

    # October 2023 log
    cat <<'EOF' > /home/user/cloud_logs/usage-2023-10.csv
resource_id,service,usage_hours,cost
r1,Compute Engine,744,99.20
r2,Cloud Storage,5500,27.50
r3,BigQuery,90,135.00
r4,Compute Engine,120,16.00
r7,Cloud Functions,1000000,5.00
r6,Cloud Storage,3500,17.50
EOF

    chmod 0644 /home/user/cloud_logs/usage-2023-09.csv
    chmod 0644 /home/user/cloud_logs/usage-2023-10.csv

%environment
    chmod 755 /home/user

    # Ensure Python and user binaries are on PATH
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author="Apptainer auto-setup for FinOps cost summary task"