Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Prepare initial filesystem state for the exercise
    # ------------------------------------------------------------------
    # Create the required user directory tree
    mkdir -p /home/user/disk_usage
    chmod 755 /home/user
    chmod 755 /home/user/disk_usage

    # Create the raw TSV report with the exact expected contents
    cat > /home/user/disk_usage/full_report.tsv <<'EOF'
Server	Mount	Total_GB	Used_GB	Free_GB	Use_percent
srv1	/	500	350	150	70%
srv2	/	1000	600	400	60%
srv3	/data	2000	1200	800	60%
srv4	/backup	1500	1200	300	80%
EOF
    chmod 644 /home/user/disk_usage/full_report.tsv

%environment
    export LC_ALL=C.UTF-8
    export PYTHONIOENCODING=utf-8

%labels
    Author "Apptainer build script for disk utilisation task"
    Version "1.0"