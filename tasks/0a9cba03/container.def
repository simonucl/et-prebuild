Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest for the verification suite
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Prepare the initial filesystem state expected by the tests
    # ------------------------------------------------------------------
    mkdir -p /home/user/test_env
    chmod 0777 /home/user/test_env   # Allow the unprivileged runtime user to write here

    # Create the qa_cases.log file with the exact required contents
    cat > /home/user/test_env/qa_cases.log <<'EOF'
SEC_Login
SEC_Login
SEC_Logout
UI_Homepage_Load
UI_Homepage_Load
UI_Homepage_Load
API_GetUser
API_GetUser
API_GetUser
API_GetUser
EOF
    chmod 0644 /home/user/test_env/qa_cases.log

    # Ensure the output file does NOT exist yet
    rm -f /home/user/test_env/freq_report.txt

%labels
    chmod 755 /home/user

    Author task-setup
    Description "Initial environment for QA log frequency report task"