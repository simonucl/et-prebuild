Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install required tools
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        python3 \
        python3-pip \
        zip \
        tar

    # Install pytest for the test-runner
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Pre-stage the web project exactly as specified
    # ------------------------------------------------------------------
    mkdir -p /home/user/web_project/css
    mkdir -p /home/user/web_project/js
    mkdir -p /home/user/web_project/images

    # index.html  (100 bytes)
    cat > /home/user/web_project/index.html <<'EOF'
<!DOCTYPE html>
<html>
<head><title>Demo</title></head>
<body>
<h1>Hello World</h1>
</body>
</html>
EOF

    # css/style.css  (41 bytes)
    cat > /home/user/web_project/css/style.css <<'EOF'
body { font-family: Arial, sans-serif; }
EOF

    # js/app.js  (28 bytes)
    cat > /home/user/web_project/js/app.js <<'EOF'
console.log('Hello World');
EOF

    # images/logo.png  (22 bytes ‑ placeholder text)
    cat > /home/user/web_project/images/logo.png <<'EOF'
PNG IMAGE PLACEHOLDER
EOF

    # Ensure non-root users can work inside /home/user
    chmod -R 777 /home/user

%runscript
    chmod 755 /home/user

    echo "Container for archive-creation exercise.  Invoke bash to start:"
    exec /bin/bash "$@"

%help
    This container pre-stages a small front-end project under /home/user/web_project
    and has Python/pytest available for automated grading.