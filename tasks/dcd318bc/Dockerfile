FROM ubuntu:22.04

# Labels
LABEL Author="Autogenerated for mobile build dashboard scraping task"

# Help information (as comments)
# This container provides the initial workspace and dependencies for the
# mobile build dashboard scraping exercise. It includes:
#   • Python 3 with pytest pre-installed for automated grading.
#   • The HTML dashboard at /home/user/webpages/mobile_builds.html
#     that the learner must read.
#   • An empty /home/user/reports/ directory where the solution should
#     write latest_build_versions.log.

# Environment
ENV PATH="/usr/local/bin:/usr/bin:/bin:${PATH}"

# Base tooling
RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        curl && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Python test framework
RUN pip3 install --no-cache-dir pytest

# Task-specific seed data - Workspace skeleton
RUN mkdir -p /home/user/webpages && \
    mkdir -p /home/user/reports

# Dashboard HTML with the required version spans
RUN cat >/home/user/webpages/mobile_builds.html <<'EOF'
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Internal Mobile Build Dashboard</title>
</head>
<body>
<h1>Latest Android Builds</h1>
<ul id="build-list">
  <li><span class="version">v2.3.1</span>  –  2024-03-01 14:22</li>
  <li><span class="version">v2.3.0</span>  –  2024-02-17 09:51</li>
  <li><span class="version">v2.2.5</span>  –  2024-02-03 18:07</li>
  <li><span class="version">v2.2.4</span>  –  2024-01-19 11:35</li>
</ul>
</body>
</html>
EOF

# Permissions
RUN chmod 755 /home/user && \
    chmod 755 /home/user/webpages && \
    chmod 755 /home/user/reports && \
    chmod 644 /home/user/webpages/mobile_builds.html