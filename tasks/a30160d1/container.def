Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package index and install Python + pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # Provide a convenient 'python' alias
    ln -sf /usr/bin/python3 /usr/bin/python

    # Create a writable home directory for the unprivileged agent.
    # Leave it otherwise empty so the student starts from a clean state.
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up APT caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure that pip-installed executables are found first.
    export PATH="/home/user/.local/bin:$PATH"

%runscript
    # Default action: drop into a shell
    exec /bin/bash "$@"