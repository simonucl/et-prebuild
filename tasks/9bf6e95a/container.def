Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author MobileCI Task Setup
    Description "Initial state for mobile_builder CID extraction task"

%post
    set -e

    # Install Python and pytest
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest

    # Create the non-root user `user`
    useradd -m -s /bin/bash -u 1000 user

    # Create required directory structure and file
    su - user -c '
        mkdir -p /home/user/.ci
        cat > /home/user/.ci/containers_running.txt << "EOF"
CONTAINER ID   IMAGE                COMMAND               CREATED        STATUS          PORTS     NAMES
a1b2c3d4e5f6   mobile-app-builder   "/entrypoint.sh"      2 hours ago    Up 2 hours               mobile_builder
d7e8f9g0h1i2   test-runner          "/start.sh"           30 minutes ago Up 30 minutes            test_runner
EOF
    '

    # Ensure correct permissions
    chown -R user:user /home/user

%environment
    chmod 755 /home/user

    export PATH="/home/user/.local/bin:$PATH"

%runscript
    echo "Container for mobile_builder CID extraction task."
    echo "Switch to the 'user' account to begin:  su - user"