Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "Updating package index and installing required packages..."
    apt-get update -y
    # Essential utilities plus Python tooling
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 python3-pip python3-setuptools python3-wheel \
        ca-certificates \
        grep gawk coreutils

    echo "Installing pytest for grading..."
    pip3 install --no-cache-dir pytest

    echo "Creating working directory structure..."
    mkdir -p /home/user
    chmod 755 /home/user

    echo "Seeding the raw ping-capture file..."
    cat > /home/user/network_raw.log <<'EOF'
[2024-05-10 10:00:01] --- 8.8.8.8 ping statistics ---
4 packets transmitted, 4 received, 0% packet loss, time 3004ms
rtt min/avg/max/mdev = 13.942/14.235/14.588/0.249 ms

[2024-05-10 10:00:05] --- 1.1.1.1 ping statistics ---
4 packets transmitted, 4 received, 0% packet loss, time 3005ms
rtt min/avg/max/mdev = 30.120/30.312/30.701/0.215 ms

[2024-05-10 10:00:09] --- example.com (93.184.216.34) ping statistics ---
4 packets transmitted, 0 received, 100% packet loss, time 4087ms
EOF

    chmod 644 /home/user/network_raw.log

    # Ensure the diagnostics directory exists without the target file.
    rm -rf /home/user/network_diagnostics
    mkdir -p /home/user/network_diagnostics
    chmod 755 /home/user/network_diagnostics

    echo "Container setup complete."

%environment
    export LC_ALL=C
    export LANG=C
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

%labels
    Author connectivity-report-template
    Description "Environment for connectivity summary exercise with pytest pre-installed."

%runscript
    echo "Container for connectivity-report exercise."
    echo "Enter the shell with:  apptainer exec <image> /bin/bash"