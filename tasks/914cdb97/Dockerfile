FROM ubuntu:22.04

# Author      autogenerated
# Description Starting state for log-processing assignment
#
# This container provides the deterministic starting filesystem state
# required for the log-processing assignment. Pytest is installed so the
# automated test harness can verify the environment setup.

#-----------------------------------------------------------------------
# Base OS packages and Python tooling
#-----------------------------------------------------------------------
RUN set -e && \
    apt-get update -y && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip && \
    pip3 install --no-cache-dir pytest && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

#-----------------------------------------------------------------------
# Prepare initial project directory and log files
#-----------------------------------------------------------------------
RUN mkdir -p /home/user/project/logs

RUN cat > /home/user/project/logs/app_2024-05-08.log <<'EOF'
INFO bootstrap
WARN deprecated
ERROR panic
EOF

RUN cat > /home/user/project/logs/app_2024-05-09.log <<'EOF'
INFO foo
INFO bar
EOF

RUN cat > /home/user/project/logs/app_2024-05-10.log <<'EOF'
INFO Server started
WARN Low memory
INFO Connection established
ERROR Failed to save data
INFO Request processed
EOF

RUN cat > /home/user/project/logs/app_2024-05-11.log <<'EOF'
INFO Task queued
INFO Worker started
WARN Disk space
WARN Disk space
ERROR Crash
ERROR Crash
INFO Recovered
EOF

RUN cat > /home/user/project/logs/app_2024-05-12.log <<'EOF'
INFO Ping
INFO Pong
EOF

#-----------------------------------------------------------------------
# Permissions: make sure the runtime (non-root) user can write results
#-----------------------------------------------------------------------
RUN chmod -R 777 /home/user