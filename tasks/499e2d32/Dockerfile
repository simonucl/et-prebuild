FROM ubuntu:22.04

# Help / metadata
# Author="Apptainer Task Prep - Generated by ChatGPT"

# Environment variables
ENV PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

# Install Python and pytest
RUN set -e && \
    apt-get update && \
    apt-get install -y --no-install-recommends python3 python3-pip ca-certificates && \
    rm -rf /var/lib/apt/lists/* && \
    pip3 install --no-cache-dir pytest

# Create initial filesystem state and configuration file
RUN mkdir -p /home/user/build/config
RUN cat > /home/user/build/config/app_release.ini <<'EOF'
[App]
versionCode=42
versionName=2.3.1

[Build]
buildId=CI-5567
target=release
EOF

# Adjust permissions
RUN chmod -R 777 /home/user/build
RUN chmod 755 /home/user