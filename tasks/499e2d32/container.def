Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # --- Install Python and pytest ------------------------------------------------
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip ca-certificates
    rm -rf /var/lib/apt/lists/*
    pip3 install --no-cache-dir pytest

    # --- Set up initial filesystem state -----------------------------------------
    # Create the required directory structure and INI file
    mkdir -p /home/user/build/config
    cat > /home/user/build/config/app_release.ini <<'EOF'
[App]
versionCode=42
versionName=2.3.1

[Build]
buildId=CI-5567
target=release
EOF

    # Ensure the student can create files/directories under /home/user/build
    chmod -R 777 /home/user/build

%labels
    chmod 755 /home/user

    Author="Apptainer Task Prep - Generated by ChatGPT"

%environment
    # Make sure Python is easily accessible
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"