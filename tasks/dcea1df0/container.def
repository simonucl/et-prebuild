Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install system packages needed for Python work
    apt-get update -y && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-venv \
        python3-pip \
        ca-certificates && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

    # Install pytest for the validation test-suite
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------ #
    # Create the initial project tree expected by the automated checker  #
    # ------------------------------------------------------------------ #
    PROJECT_ROOT=/home/user/project
    mkdir -p \
        "${PROJECT_ROOT}/locale/templates" \
        "${PROJECT_ROOT}/locale/en_US/LC_MESSAGES" \
        "${PROJECT_ROOT}/locale/fr_FR/LC_MESSAGES"

    # Template .pot file
    cat > "${PROJECT_ROOT}/locale/templates/app.pot" <<'EOF'
msgid ""
msgstr ""
"Project-Id-Version: app 1.0\n"
"Content-Type: text/plain; charset=UTF-8\n"

#: src/main.py:10
msgid "HELLO_WORLD"
msgstr "Hello, World!"

#: src/main.py:20
msgid "MSG_NEW"
msgstr "A new message"
EOF

    # English .po file (HELLO_WORLD only)
    cat > "${PROJECT_ROOT}/locale/en_US/LC_MESSAGES/app.po" <<'EOF'
msgid ""
msgstr ""
"Project-Id-Version: app 1.0\n"
"Content-Type: text/plain; charset=UTF-8\n"

#: src/main.py:10
msgid "HELLO_WORLD"
msgstr "Hello, World!"
EOF

    # French .po file (HELLO_WORLD only)
    cat > "${PROJECT_ROOT}/locale/fr_FR/LC_MESSAGES/app.po" <<'EOF'
msgid ""
msgstr ""
"Project-Id-Version: app 1.0\n"
"Content-Type: text/plain; charset=UTF-8\n"

#: src/main.py:10
msgid "HELLO_WORLD"
msgstr "Bonjour, Monde!"
EOF

    # Make sure every participant can read/write the project directory
    chmod -R a+rwx /home/user || true

%environment
    chmod 755 /home/user

    # Ensure 'python' maps to the default Python 3 interpreter
    export PATH=/usr/local/bin:/usr/bin:/bin
    if [ -x /usr/bin/python3 ] && [ ! -e /usr/bin/python ]; then
        ln -sf /usr/bin/python3 /usr/local/bin/python
    fi