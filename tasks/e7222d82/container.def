Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install required packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        python3 \
        python3-pip \
        locales

    # Generate the British UTF-8 locale so `locale` recognises it
    locale-gen en_GB.UTF-8

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # Create a writable home directory for the unprivileged user
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up apt caches to reduce image size
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Keep the environment minimal; do not pre-set LANG
    export PATH=/usr/local/bin:$PATH

%labels
    Author ai-generated

%runscript
    exec /bin/bash "$@"