Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install required packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        cron

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # Create an unprivileged user called "user" with home directory /home/user
    if ! id -u user >/dev/null 2>&1; then
        # Prefer UID 1000 (common default); fall back to the next free UID if 1000 is taken
        if id -u 1000 >/dev/null 2>&1; then
            useradd -m -s /bin/bash user
        else
            useradd -m -u 1000 -s /bin/bash user
        fi
    fi

    # Ensure /home/user exists and is owned by the correct user
    mkdir -p /home/user
    chown -R user:user /home/user

    # Prepare cron spool directory with correct permissions
    mkdir -p /var/spool/cron/crontabs
    chmod 1730 /var/spool/cron/crontabs
    chown root:crontab /var/spool/cron/crontabs

%environment
    chmod 755 /home/user

    # Do not override $HOME; let Apptainer handle home binding.

%labels
    Author user