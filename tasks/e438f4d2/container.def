Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare the initial filesystem state expected by the test harness
    # ------------------------------------------------------------------
    # Create data directory
    mkdir -p /home/user/data

    # Seed file: hosts.txt  (must end with a single trailing newline)
    printf 'web01\nweb02\ndb01\ncache01\n' > /home/user/data/hosts.txt

    # Seed file: metrics.txt  (must end with a single trailing newline)
    printf 'cpu=23 mem=40\ncpu=87 mem=66\ncpu=55 mem=72\ncpu=92 mem=31\n' > /home/user/data/metrics.txt

    # Ensure the student can read/write within /home/user
    chmod -R a+rwX /home/user

%environment
    chmod 755 /home/user

    # Minimal environment setup; do NOT override $HOME
    export LC_ALL=C.UTF-8
    export PATH=/usr/local/bin:/usr/bin:/bin