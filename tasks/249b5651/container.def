Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author example
    Description "Container pre-populated with CI/CD metrics artefacts and pytest"

%post
    set -e

    ## Install required packages
    apt-get update && \
        DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
            python3 \
            python3-pip \
            sqlite3 \
        && rm -rf /var/lib/apt/lists/*

    ## Install pytest for later use by the grader
    pip3 install --no-cache-dir pytest

    ## ---------------------------------------------------------------------
    ## Prepare filesystem artefacts expected by the grading tests
    ## ---------------------------------------------------------------------
    USER_HOME="/home/user"
    WORK_DIR="${USER_HOME}/cicd_db_work"

    mkdir -p "${WORK_DIR}"
    cd "${WORK_DIR}"

    ## --- 1. SQL audit log -------------------------------------------------
    cat > cicd_sql_audit.log <<'EOF'
CREATE TABLE build_metrics (id INTEGER PRIMARY KEY, pipeline_name TEXT NOT NULL, status TEXT CHECK(status IN ('success','failed')) NOT NULL, build_time_seconds INTEGER NOT NULL, build_date DATE NOT NULL);
INSERT INTO build_metrics (id, pipeline_name, status, build_time_seconds, build_date) VALUES (1,'web-frontend','success',420,'2023-09-01');
INSERT INTO build_metrics (id, pipeline_name, status, build_time_seconds, build_date) VALUES (2,'api-service','failed',370,'2023-09-01');
INSERT INTO build_metrics (id, pipeline_name, status, build_time_seconds, build_date) VALUES (3,'database-migrations','success',255,'2023-09-02');
EOF

    ## --- 2. SQLite database ----------------------------------------------
    sqlite3 ci_cd_metrics.db <<'SQL'
CREATE TABLE build_metrics (id INTEGER PRIMARY KEY, pipeline_name TEXT NOT NULL, status TEXT CHECK(status IN ('success','failed')) NOT NULL, build_time_seconds INTEGER NOT NULL, build_date DATE NOT NULL);
INSERT INTO build_metrics (id, pipeline_name, status, build_time_seconds, build_date) VALUES (1,'web-frontend','success',420,'2023-09-01');
INSERT INTO build_metrics (id, pipeline_name, status, build_time_seconds, build_date) VALUES (2,'api-service','failed',370,'2023-09-01');
INSERT INTO build_metrics (id, pipeline_name, status, build_time_seconds, build_date) VALUES (3,'database-migrations','success',255,'2023-09-02');
SQL

    ## --- 3. Average build time text file ---------------------------------
    AVG_VALUE=$(sqlite3 ci_cd_metrics.db "SELECT ROUND(AVG(build_time_seconds),2) FROM build_metrics;")
    printf 'average_build_time_seconds:%s\n' "${AVG_VALUE}" > build_time_average.txt
    chmod 755 /home/user


    ## --- 4. CSV export of the table --------------------------------------
    sqlite3 -header -csv ci_cd_metrics.db \
        "SELECT id, pipeline_name, status, build_time_seconds, build_date FROM build_metrics ORDER BY id;" \
        > metrics_export.csv

    ## Ensure world-readable artefacts for the non-root runtime user
    chmod -R a+r "${WORK_DIR}"

%environment
    # Ensure python and pytest are in the PATH
    export PATH="/usr/local/bin:/usr/bin:${PATH}"

%runscript
    echo "Container for CI/CD metrics task ready."