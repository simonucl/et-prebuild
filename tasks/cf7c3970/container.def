Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python tooling and pytest
    apt-get update -qq
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 python3-pip ca-certificates
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create the required input directory tree and fixture CSV contents
    # ------------------------------------------------------------------
    INPUT_DIR="/home/user/projects/api_test/input"
    mkdir -p "${INPUT_DIR}"

    # orders.csv
    cat > "${INPUT_DIR}/orders.csv" <<'EOF'
order_id,customer_id,order_date,amount
1001,C001,2023-01-05,250.75
1002,C002,2023-01-17,400.00
1003,C001,2023-02-03,125.50
1004,C003,2023-03-12,98.00
EOF

    # customers.csv
    cat > "${INPUT_DIR}/customers.csv" <<'EOF'
customer_id,name,country
C001,Alice Smith,USA
C002,Bob Jones,Canada
C003,Carla Ruiz,Mexico
EOF

    # Ensure world-readable permissions so the non-root runtime user can access them
    chmod 755 /home /home/user /home/user/projects /home/user/projects/api_test /home/user/projects/api_test/input
    chmod 644 "${INPUT_DIR}/orders.csv" "${INPUT_DIR}/customers.csv"

%environment
    chmod 755 /home/user

    # Make sure Python is on PATH
    export PATH="/usr/local/bin:/usr/bin:/bin:${PATH}"

%labels
    Author dev
    Description "Environment for the 'Merge CSV data, apply date-filter, convert to JSON' task. Provides input CSV fixtures and pytest."

%help
    This container image sets up the initial state expected by the grading
    framework for the CSV-merging exercise. It pre-installs pytest and ships the
    two required input CSV files under:
      /home/user/projects/api_test/input