Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install Python + pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install pytest for the verification suite
    pip3 install --no-cache-dir pytest

    # Ensure /home/user exists and is writable by any non-root user
    mkdir -p /home/user
    chmod 777 /home/user

    # Clean up apt cache to keep the image small
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure Python and pip are on PATH
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%runscript
    # Default action prints Python and pytest versions
    python3 --version
    pytest --version