Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
set -eux

# Install Python and pytest
apt-get update
DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 python3-pip ca-certificates
pip3 install --no-cache-dir pytest
rm -rf /var/lib/apt/lists/*

# --------------------------------------------------------------------
# Prepare initial filesystem state expected by the grading tests
# --------------------------------------------------------------------

# Create the required source directory and populate it
mkdir -p /home/user/source_configs

cat >/home/user/source_configs/config1.yaml <<'EOF'
---
service: web
replicas: 3
EOF

cat >/home/user/source_configs/config2.ini <<'EOF'
[database]
host = db.internal
port = 5432
EOF

cat >/home/user/source_configs/app.env <<'EOF'
APP_ENV=production
DEBUG=false
EOF

# Permissions:
#  - /home/user must be writable so the (non-root) agent can create /home/user/backups
#  - Source files should be read-only for others
chmod 0777 /home/user
chmod 0755 /home/user/source_configs
chmod 0644 /home/user/source_configs/*

# NOTE: Deliberately *do not* create /home/user/backups; the agent must create it.

%environment
    chmod 755 /home/user

export LANG=C.UTF-8
export LC_ALL=C.UTF-8

%labels
Author "OpenAI ChatGPT"
Description "Apptainer image for backup-creation task. Provides initial source files and installs pytest."

%runscript
exec "$@"