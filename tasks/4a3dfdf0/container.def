Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update APT and install Python, pip, and the `python` symlink.
    apt-get update -qq
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python-is-python3 \
        ca-certificates \
        curl

    # Install pytest for the grader.
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create the initial dataset directory structure and sample CSV file
    # ------------------------------------------------------------------
    mkdir -p /home/user/datasets

    # Ensure directory permissions are 755 (rwxr-xr-x).
    chmod 755 /home/user /home/user/datasets

    # Create the required sales.csv with the exact contents.
    cat >/home/user/datasets/sales.csv <<'EOF'
date,region,sales
2023-01-01,North,100
2023-01-02,South,150
EOF

    # Set file permissions to 644 (rw-r--r--).
    chmod 644 /home/user/datasets/sales.csv

%environment
    # Ensure that Python and pip are in PATH (should already be, but explicit is better).
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%runscript
    # Default runscript does nothing; the student will launch their own commands.
    exec /bin/bash "$@"

%help
    This container provides:
      • Python (accessible via `python`) with the built-in http.server module
      • pytest (used by the autograder)
      • An initial dataset directory at /home/user/datasets containing sales.csv
    Students will create a throw-away web-server and log-file as per the task instructions.