Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author certificate-bundle-setup
    Description Base image for “certificate bundle” exercise. Installs Python, pip, pytest and OpenSSL but leaves /home/user/profiling untouched so the agent can create the required artefacts during evaluation.

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # Update APT index and install minimal dependencies
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        openssl \
        ca-certificates

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # Prepare baseline home directory expected by grader.
    # DO NOT create the profiling/certs sub-directories here.
    mkdir -p /home/user
    chmod 755 /home/user

    # Clean up APT caches to keep image size small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    # Keep stdout/stderr unbuffered and ensure pip-installed binaries are in PATH
    export PYTHONUNBUFFERED=1
    export PATH=/usr/local/bin:$PATH

%runscript
    # Default runscript just executes provided command
    exec "$@"