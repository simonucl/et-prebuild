Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Install Python, pip, and pytest
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip install --no-cache-dir pytest
    rm -rf /var/lib/apt/lists/*

    # Set up initial filesystem expected by the tests
    mkdir -p /home/user/db
    echo "SELECT 1;" > /home/user/db/improved_query.sql   # non-empty SQL file

    # Ensure the future agent has write permissions
    chmod -R a+rwx /home/user

%environment
    chmod 755 /home/user

    # Nothing special needed; keep user’s HOME unmodified
%labels
    Author ChatGPT
    Description "Container for move-and-log SQL file task – includes pytest and initial directory layout."