Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ------------------------------------------------------------------
    # Basic tooling
    # ------------------------------------------------------------------
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        tzdata
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Create the simulator directory structure and static feed files
    # ------------------------------------------------------------------
    SIM_ROOT="/home/user/iot_simulator"
    mkdir -p "${SIM_ROOT}/nodeA" "${SIM_ROOT}/nodeB" "${SIM_ROOT}/nodeC"

    # ------------------------------------------------------------------
    # Populate nodeA feed
    # ------------------------------------------------------------------
    cat > "${SIM_ROOT}/nodeA/metrics_feed" << 'EOF'
2024-05-01T12:00:00,10,5,85,102400,0,0,20,10
2024-05-01T12:00:05,10,5,85,102400,0,0,20,10
2024-05-01T12:00:10,10,5,85,102400,0,0,20,10
2024-05-01T12:00:15,10,5,85,102400,0,0,20,10
2024-05-01T12:00:20,10,5,85,102400,0,0,20,10
2024-05-01T12:00:25,10,5,85,102400,0,0,20,10
2024-05-01T12:00:30,10,5,85,102400,0,0,20,10
2024-05-01T12:00:35,10,5,85,102400,0,0,20,10
2024-05-01T12:00:40,10,5,85,102400,0,0,20,10
2024-05-01T12:00:45,10,5,85,102400,0,0,20,10
2024-05-01T12:00:50,10,5,85,102400,0,0,20,10
2024-05-01T12:00:55,10,5,85,102400,0,0,20,10
EOF

    # ------------------------------------------------------------------
    # Populate nodeB feed
    # ------------------------------------------------------------------
    cat > "${SIM_ROOT}/nodeB/metrics_feed" << 'EOF'
2024-05-01T12:00:00,15,7,78,98304,0,0,25,12
2024-05-01T12:00:05,15,7,78,98304,0,0,25,12
2024-05-01T12:00:10,15,7,78,98304,0,0,25,12
2024-05-01T12:00:15,15,7,78,98304,0,0,25,12
2024-05-01T12:00:20,15,7,78,98304,0,0,25,12
2024-05-01T12:00:25,15,7,78,98304,0,0,25,12
2024-05-01T12:00:30,15,7,78,98304,0,0,25,12
2024-05-01T12:00:35,15,7,78,98304,0,0,25,12
2024-05-01T12:00:40,15,7,78,98304,0,0,25,12
2024-05-01T12:00:45,15,7,78,98304,0,0,25,12
2024-05-01T12:00:50,15,7,78,98304,0,0,25,12
2024-05-01T12:00:55,15,7,78,98304,0,0,25,12
EOF

    # ------------------------------------------------------------------
    # Populate nodeC feed
    # ------------------------------------------------------------------
    cat > "${SIM_ROOT}/nodeC/metrics_feed" << 'EOF'
2024-05-01T12:00:00,20,9,71,81920,0,0,30,15
2024-05-01T12:00:05,20,9,71,81920,0,0,30,15
2024-05-01T12:00:10,20,9,71,81920,0,0,30,15
2024-05-01T12:00:15,20,9,71,81920,0,0,30,15
2024-05-01T12:00:20,20,9,71,81920,0,0,30,15
2024-05-01T12:00:25,20,9,71,81920,0,0,30,15
2024-05-01T12:00:30,20,9,71,81920,0,0,30,15
2024-05-01T12:00:35,20,9,71,81920,0,0,30,15
2024-05-01T12:00:40,20,9,71,81920,0,0,30,15
2024-05-01T12:00:45,20,9,71,81920,0,0,30,15
2024-05-01T12:00:50,20,9,71,81920,0,0,30,15
2024-05-01T12:00:55,20,9,71,81920,0,0,30,15
EOF

    # Ensure appropriate permissions so the non-root runtime user can read/write
    chmod -R 0755 /home/user

%environment
    chmod 755 /home/user

    # Add Python to PATH explicitly
    export PATH="/usr/bin:${PATH}"