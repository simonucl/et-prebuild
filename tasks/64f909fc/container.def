Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial on-disk state expected by the autograder
    # ------------------------------------------------------------------
    BACKUP_DIR="/home/user/db_backup"

    # Create directory structure
    mkdir -p "${BACKUP_DIR}"

    # Create config.yaml with the INITIAL content
    cat > "${BACKUP_DIR}/config.yaml" <<'EOF'
database:
  host: "localhost"
  port: 5432
  name: "maindb"
backup:
  enabled: false
  schedule: "not_set"
  compression: "none"
EOF

    # Create retention.toml with the INITIAL content
    cat > "${BACKUP_DIR}/retention.toml" <<'EOF'
[retention]
max_backups = 0
keep_days   = 0
cold_storage = true
EOF

    # Do NOT create changes.log – it must not exist at start

    # Make sure the regular (non-root) user can read/write these files
    chmod 777 /home/user
    chmod 777 "${BACKUP_DIR}"
    chmod 666 "${BACKUP_DIR}/config.yaml" "${BACKUP_DIR}/retention.toml"

%environment
    chmod 755 /home/user

    # Nothing special needed; keep default HOME
    export PYTHONUNBUFFERED=1