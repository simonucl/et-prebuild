Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install Python & PyTest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install the latest pytest via pip to guarantee availability
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state expected by the grading tests
    # ------------------------------------------------------------------
    # Create the logs directory and populate it with the provided log file
    mkdir -p /home/user/logs

    cat > /home/user/logs/webapp.log << 'EOF'
2023-07-01 12:01:04 INFO  User login successful
2023-07-01 12:02:13 ERROR PAYMENT_FAILURE OrderID=12345
2023-07-01 12:03:27 WARN  Retry attempt
2023-07-01 12:05:33 INFO  Cart updated
2023-07-01 12:06:45 ERROR PAYMENT_FAILURE OrderID=12346
2023-07-01 12:07:51 ERROR INVENTORY_OUT OrderID=12347
2023-07-01 12:08:59 INFO  User logout
2023-07-01 12:12:11 ERROR PAYMENT_FAILURE OrderID=12348
2023-07-01 12:15:23 INFO  Promo applied
2023-07-01 12:17:31 ERROR PAYMENT_FAILURE OrderID=12349
2023-07-01 12:18:45 ERROR PAYMENT_TIMEOUT OrderID=12350
2023-07-01 12:19:06 ERROR PAYMENT_FAILURE OrderID=12351
2023-07-01 12:22:17 INFO  System health check OK
2023-07-01 12:24:29 ERROR PAYMENT_FAILURE OrderID=12352
2023-07-01 12:26:30 WARN  Slow response detected
2023-07-01 12:28:41 ERROR INVENTORY_OUT OrderID=12353
2023-07-01 12:30:52 ERROR PAYMENT_FAILURE OrderID=12354
2023-07-01 12:33:03 INFO  Background job finished
2023-07-01 12:35:14 INFO  Cache cleared
2023-07-01 12:37:25 ERROR SERVER_DOWN
EOF

    # Ensure permissions allow the non-privileged user to read the logs
    chmod 755 /home/user
    chmod 755 /home/user/logs
    chmod 644 /home/user/logs/webapp.log

%environment
    # Ensure python defaults to python3
    export PYTHONIOENCODING=UTF-8
    export LC_ALL=C.UTF-8

%labels
    Author "Generated by ChatGPT – Apptainer task setup"
    Description "Container for diagnostic log-analysis task; includes pytest and prepared log file."