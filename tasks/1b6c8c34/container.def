Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "Updating apt repositories and installing required packages..."
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        sqlite3 \
        ca-certificates

    echo "Installing pytest via pip..."
    pip3 install --no-cache-dir pytest

    echo "Creating initial directory structure and database..."
    mkdir -p /home/user

    # Build the initial SQLite database with the expected schema and row.
    sqlite3 /home/user/security_settings.db <<'SQL'
CREATE TABLE system_config (
        param TEXT PRIMARY KEY,
        val   TEXT NOT NULL
);
INSERT INTO system_config (param, val) VALUES ('permit_remote_root', 'yes');
SQL

    # Ensure appropriate permissions so the non-root runtime user can modify the DB
    chmod 777 /home/user
    chmod 666 /home/user/security_settings.db

    # Guarantee the log file does NOT exist at build time
    rm -f /home/user/operation_done.log

    echo "Container build complete."

%environment
    chmod 755 /home/user

    # Ensure Python and pip are in PATH
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%runscript
    echo "This container sets up the environment for the SSH hardening task."
    echo "Open a shell inside the container to begin working:"
    exec /bin/bash