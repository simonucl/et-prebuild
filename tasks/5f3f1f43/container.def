Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update && \
        apt-get install -y --no-install-recommends python3 python3-pip && \
        pip3 install --no-cache-dir pytest && \
        apt-get clean && \
        rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Create initial dataset required by the task
    # ------------------------------------------------------------------
    mkdir -p /home/user/data_project

    # important.txt
    printf 'ALPHA BACKUP DATA\n' \
        > /home/user/data_project/important.txt

    # notes.md
    printf 'Original notes for the backup-restore test.\n' \
        > /home/user/data_project/notes.md

    # Ensure the unprivileged runtime user can read/write these files
    chmod -R a+rwX /home/user || true
    chown -R 1000:1000 /home/user || true   # best-effort; ignore if UID 1000 not present

%environment
    chmod 755 /home/user

    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8