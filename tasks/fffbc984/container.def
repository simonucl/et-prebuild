Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # Create the non-root user `user`
    useradd -m -s /bin/bash user

    # Prepare the repository structure
    install -d -m 0755 /home/user/sys-hardener

    # Create config.yaml with the pre-bump version
    cat > /home/user/sys-hardener/config.yaml <<'EOF'
version: 1.3.4
hardening:
  ssh:
    permit_root_login: "no"
    password_authentication: "no"
EOF

    # Create the initial CHANGELOG.md
    cat > /home/user/sys-hardener/CHANGELOG.md <<'EOF'
## [1.3.3] - 2023-07-01
### Fixed
- Corrected sysctl typo that prevented IPv6 RA filtering.

## [1.3.2] - 2023-06-10
### Security
- Updated default TLS cipher suite list.
EOF

    # Set ownership so the agent (running as `user`) can modify the files
    chown -R user:user /home/user/sys-hardener

%environment
    chmod 755 /home/user

    export PATH="$HOME/.local/bin:$PATH"

%labels
    Author sys-hardener-prep