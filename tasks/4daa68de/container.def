Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python, pip, and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create the required directory structure and CSV source files
    # ------------------------------------------------------------------
    # Ensure a 'user' account exists with home directory /home/user
    if ! id -u user >/dev/null 2>&1; then
        useradd -m -d /home/user -s /bin/bash user
    fi

    # Create the data directory
    mkdir -p /home/user/data

    # Create the three CSV files with the exact required contents
    cat > /home/user/data/sales_q1.csv <<'EOF'
id,value
1,100
2,200
3,300
EOF

    cat > /home/user/data/sales_q2.csv <<'EOF'
id,value
1,400
2,500
EOF

    cat > /home/user/data/sales_q3.csv <<'EOF'
id,value
1,600
2,700
3,800
4,900
EOF

    # Ensure proper permissions (read-only files, readable directory)
    chmod 755 /home/user
    chmod 755 /home/user/data
    chmod 644 /home/user/data/sales_q1.csv \
             /home/user/data/sales_q2.csv \
             /home/user/data/sales_q3.csv

%environment
    # Make sure the standard binary locations are in PATH
    export PATH="/usr/local/bin:/usr/bin:/bin:${PATH}"