Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # Prepare the microservice repository with the required initial files
    mkdir -p /home/user/microservice

    # version.txt with the initial version
    cat > /home/user/microservice/version.txt <<'EOF'
1.2.4
EOF

    # CHANGELOG.md with the baseline entry
    cat > /home/user/microservice/CHANGELOG.md <<'EOF'
# Changelog

## [1.2.4] - 2023-01-15
### Added
- Initial release.
EOF

    # Ensure the non-root runtime user can modify the repository
    chmod -R a+rwX /home/user/microservice
    chmod -R a+rwX /home/user

%environment
    chmod 755 /home/user

    # Keep Python output unbuffered
    export PYTHONUNBUFFERED=1