FROM ubuntu:22.04

# Author: Autogenerated by OpenAI Assistant
# Description: Environment for UTF-16 to UTF-8 conversion task with pytest pre-installed.

RUN set -e && \
    apt-get update && \
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates && \
    rm -rf /var/lib/apt/lists/*

RUN pip3 install --no-cache-dir pytest

RUN mkdir -p /home/user/profiling

RUN python3 - << 'PY'
import pathlib

profiling_dir = pathlib.Path("/home/user/profiling")
profiling_dir.mkdir(parents=True, exist_ok=True)

text = (
    "Profile Summary\n"
    "Function compute() took 12ms\n"
    "Function save_results() took 8ms\n"
)

( profiling_dir / "output_utf16.txt" ).write_text(text, encoding="utf-16")
PY

RUN chmod -R a+rX /home/user

# Environment settings
ENV LC_ALL=C.UTF-8
ENV PYTHONIOENCODING=utf-8

# This chmod was in %environment but must be a RUN command
RUN chmod 755 /home/user

LABEL Author="Autogenerated by OpenAI Assistant"
LABEL Description="Environment for UTF-16 to UTF-8 conversion task with pytest pre-installed."