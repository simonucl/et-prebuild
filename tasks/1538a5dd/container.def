Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ---- Install required software ----
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates
    rm -rf /var/lib/apt/lists/*

    # pytest for the grading framework
    pip3 install --no-cache-dir pytest

    # ---- Prepare initial directory structure & UTF-16 file ----
    mkdir -p /home/user/profiling

    # Create the UTF-16 LE file with BOM and the required text
    python3 - << 'PY'
import pathlib

profiling_dir = pathlib.Path("/home/user/profiling")
profiling_dir.mkdir(parents=True, exist_ok=True)

text = (
    "Profile Summary\n"
    "Function compute() took 12ms\n"
    "Function save_results() took 8ms\n"
)

# Writing with encoding='utf-16' adds a BOM automatically and uses little-endian
# on x86_64 (the platform for this container).
( profiling_dir / "output_utf16.txt" ).write_text(text, encoding="utf-16")
PY

    # Make sure everything is world-readable so the unprivileged agent can access it
    chmod -R a+rX /home/user

%environment
    chmod 755 /home/user

    export LC_ALL=C.UTF-8
    export PYTHONIOENCODING=utf-8

%labels
    Author="Autogenerated by OpenAI Assistant"
    Description="Environment for UTF-16 to UTF-8 conversion task with pytest pre-installed."