Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Create directory structure and starter CSV files
    mkdir -p /home/user/incidents

    cat >/home/user/incidents/failed_attempts.csv <<'EOF'
SessionID,IP
1001,192.0.2.10
1002,203.0.113.55
1003,198.51.100.30
1004,203.0.113.77
1005,198.51.100.88
EOF

    cat >/home/user/incidents/successful_attempts.csv <<'EOF'
SessionID,IP
1001,198.51.100.23
1002,198.51.100.24
1003,203.0.113.60
1004,192.0.2.44
1005,203.0.113.90
EOF

    # Ensure appropriate permissions
    chmod 755 /home/user
    chmod 755 /home/user/incidents
    chmod 644 /home/user/incidents/*.csv

%environment
    export PATH=/usr/local/bin:$PATH
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    echo "Container for incident response exercise.  Use it as instructed."