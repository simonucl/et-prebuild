Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "Updating APT and installing prerequisites..."
    apt-get update -y
    # Install Python 3, pip and other essentials
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        bash \
        git \
        wget

    # Install pytest for the automated grader
    pip3 install --no-cache-dir --upgrade pip
    pip3 install --no-cache-dir pytest

    echo "Creating required directory structure with permissive permissions ..."

    # Ensure /home and /home/user exist
    mkdir -p /home/user

    # Create scripts and test_envs directories
    mkdir -p /home/user/scripts
    mkdir -p /home/user/test_envs

    # Make sure the current (non-root) user at runtime can read/write/execute
    chmod 0777 /home
    chmod 0777 /home/user
    chmod 0777 /home/user/scripts
    chmod 0777 /home/user/test_envs

    # Clean apt cache to minimize image size
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure a sane locale and PATH
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

%labels
    Author ChatGPT
    Description "Base image for QA test-environment automation task – provides pytest and required writable directories."

%help
    This container supplies the initial filesystem state expected by the
    automated grading suite.  Key points:
      • /home/user/scripts exists and is writable/executable.
      • /home/user/test_envs exists and is writable (though the assignment
        allows for its absence; we provide it for convenience).
      • pytest is installed for the grader.