Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update apt index and install Python and pip
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates

    # Install pytest for the grading tests
    pip3 install --no-cache-dir --upgrade pytest

    # ------------------------------------------------------------------
    # Prepare initial project state for the “cloud-migrate” version-bump
    # exercise.  The agent will later mutate these files.
    # ------------------------------------------------------------------

    # Create /home/user if it doesn't already exist
    mkdir -p /home/user

    # Create project directory
    PROJECT_DIR="/home/user/cloud-migrate"
    mkdir -p "${PROJECT_DIR}"

    # Create VERSION file with initial content
    printf '1.2.3\n' > "${PROJECT_DIR}/VERSION"

    # Create CHANGELOG.md with the initial 1.2.3 entry
    cat > "${PROJECT_DIR}/CHANGELOG.md" <<'EOF'
## [1.2.3] - 2023-09-30
### Added
- Initial deployment pipeline for staging.
EOF

    # The log file must NOT exist yet; ensure it is absent
    rm -f "${PROJECT_DIR}/version_bump.log"

    # Make sure the agent (non-root) can modify everything
    chmod -R 777 /home/user

%environment
    chmod 755 /home/user

    # Ensure Python executables are on PATH
    PATH=/usr/local/bin:/usr/bin:/bin:$PATH