Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Basic tooling
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest

    # -----------------------------------------------------------------
    # Prepare initial filesystem state for the “quarterly CSV” exercise
    # -----------------------------------------------------------------
    BASE_DIR=/home/user/data
    ORIG_DIR=${BASE_DIR}/original
    CURR_DIR=${BASE_DIR}/current

    # Create directory hierarchy
    mkdir -p "${ORIG_DIR}" "${CURR_DIR}"

    # Populate ORIGINAL_DIR with the required CSV files
    cat > "${ORIG_DIR}/inventory_2023_Q1.csv" <<'EOF'
month,units,value
Jan,45,720
EOF

    cat > "${ORIG_DIR}/marketing_2023_Q1.csv" <<'EOF'
channel,impressions,spend
Social,12000,350
EOF

    cat > "${ORIG_DIR}/sales_2023_Q1.csv" <<'EOF'
month,units,revenue
Jan,100,1200
Feb,130,1500
EOF

    cat > "${ORIG_DIR}/sales_2022_Q4.csv" <<'EOF'
month,units,revenue
Dec,90,1100
EOF

    # Create the single outdated symlink inside CURRENT_DIR
    ln -s ../original/sales_2022_Q4.csv "${CURR_DIR}/sales_latest.csv"

    # Make everything under /home/user writable so the unprivileged
    # runtime user can modify the staging area.
    chmod -R a+rwX /home/user

%environment
    chmod 755 /home/user

    # Ensure Python and Pip are on PATH (usually already, but explicit is better)
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author "Apptainer Setup Script"
    Description "Container with initial state for quarterly CSV staging-area task."