Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # 1. Create non-root user 'user' with home directory /home/user
    groupadd -g 1000 user || true
    useradd  -m -u 1000 -g 1000 -s /bin/bash user || true

    # 2. Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates
    pip3 install --no-cache-dir pytest

    # 3. Set up initial webapp directory structure and files
    mkdir -p /home/user/services/webapp

    # app.conf with required initial contents
    cat > /home/user/services/webapp/app.conf <<'EOF'
PORT=8080
DEBUG=False
EOF

    # restart.sh helper script
    cat > /home/user/services/webapp/restart.sh <<'EOF'
#!/bin/bash
echo "Webapp restarted on port $(grep '^PORT' "$(dirname "$0")/app.conf" | cut -d'=' -f2)"
EOF
    chmod +x /home/user/services/webapp/restart.sh

    # 4. Ensure correct ownership
    chown -R 1000:1000 /home/user

    # 5. Clean up apt cache to keep image lean
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    export HOME=/home/user
    export PATH=/usr/local/bin:/usr/bin:/bin

%runscript
    exec /bin/bash "$@"