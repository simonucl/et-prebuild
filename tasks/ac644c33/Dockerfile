FROM ubuntu:22.04

# Labels
LABEL Author="Generated by OpenAI ChatGPT"
LABEL Description="Initial state for the 'login-success audit' exercise."

# Basic packages and Python tooling needed for the exercise
RUN set -e && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        locales \
        tzdata && \
    python3 -m pip install --no-cache-dir pytest

# Create a non-privileged "user" account that matches the exercise
# narrative and give it a home directory.
RUN if ! id -u user >/dev/null 2>&1; then \
        adduser --disabled-password --gecos "" --home /home/user --uid 1000 user; \
    fi

# Create logs directory
RUN mkdir -p /home/user/logs

# Provision the raw security log exactly as required.
RUN cat <<'EOF' >/home/user/logs/auth_2023-01-07.log
2023-01-07 09:12:45 | user=jdoe   | action=LOGIN     | status=SUCCESS
2023-01-07 09:13:20 | user=jdoe   | action=LOGOUT    | status=SUCCESS
2023-01-07 10:05:12 | user=asmith | action=LOGIN     | status=SUCCESS
2023-01-07 11:15:55 | user=asmith | action=DOWNLOAD  | file=report.pdf | status=SUCCESS
2023-01-07 12:45:06 | user=mbrown | action=LOGIN     | status=SUCCESS
2023-01-07 16:02:11 | user=mbrown | action=LOGIN     | status=FAILED
2023-01-07 17:00:35 | user=admin  | action=DELETE    | target=userdata | status=SUCCESS
EOF

# Ensure proper ownership and permissions so the non-root agent can work.
RUN chown -R user:user /home/user && \
    chmod 755 /home/user && \
    chmod 755 /home/user/logs && \
    chmod 644 /home/user/logs/auth_2023-01-07.log

# Clean up apt caches to keep the image small.
RUN apt-get clean && \
    rm -rf /var/lib/apt/lists/*

USER user
WORKDIR /home/user

CMD ["/bin/bash", "-c", "echo 'Container for the login-success audit exercise.' && echo 'Refer to the exercise instructions for further details.'"]