Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update apt indexes and install required packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        locales

    # Clean up apt caches to keep image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the grading tests
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state required by the assignment
    # ------------------------------------------------------------------

    # Create the directory structure
    mkdir -p /home/user/hardening/input
    mkdir -p /home/user/hardening/reports
    mkdir -p /home/user/hardening/logs

    # Ensure the directories are world-writable so the unprivileged
    # runtime user (whose UID/GID is not known at build time) can write.
    chmod 0777 /home/user
    chmod -R 0777 /home/user/hardening

    # Populate the input CSV file with the baseline data
    cat >/home/user/hardening/input/ssh_audit.csv <<'EOF'
line_number,hostname,PermitRootLogin,PasswordAuthentication,Port
1,server1,yes,yes,22
2,server2,no,no,2222
3,server3,yes,no,22
4,server4,no,yes,22
EOF
    chmod 0644 /home/user/hardening/input/ssh_audit.csv

%environment
    chmod 755 /home/user

    # Keep environment minimal; do not override HOME.
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    echo "Container for SSH hardening assessment task."
    echo "This image only provides the initial state; execute your solution script separately."

%labels
    Author SSH-Hardening-Task
    Description "Provides initial state and pytest for SSH hardening assessment exercise"