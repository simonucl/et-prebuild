Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package index
    apt-get update

    # Ensure required utilities and Python tooling are present
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        bash \
        coreutils \
        grep \
        python3 \
        python3-pip \
        python3-setuptools \
        python3-wheel

    # Install pytest for the test harness
    pip3 install --no-cache-dir pytest

    # Create a writable /home/user directory for the learner
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up APT caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Basic locale and PATH settings; do not override HOME
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

%runscript
    # Default runscript just drops the user into a shell
    exec /bin/bash "$@"