Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and supporting tools
    apt-get update && \
    apt-get install -y --no-install-recommends \
        python3 \
        python3-venv \
        python3-pip && \
    rm -rf /var/lib/apt/lists/*

    # Install pytest globally (needed by the grader)
    pip3 install --no-cache-dir pytest

    # Prepare a writable home directory for the exercise
    mkdir -p /home/user
    chmod 0777 /home/user   # allow the non-root agent to create its workspace

%environment
    chmod 755 /home/user

    export PATH=/usr/local/bin:$PATH

%labels
    Author="ChatGPT"
    Description="Container for the Archive VENV setup exercise"