Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ------------------------------------------------------------------
    # Install Python tooling and Pytest (required by the autograder)
    # ------------------------------------------------------------------
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Create the initial project directory tree and populate files
    # ------------------------------------------------------------------
    # Ensure the /home/user hierarchy exists and is writable by the
    # non-root runtime user (UID is unknown at build time).
    mkdir -p /home/user
    chmod 777 /home/user

    # Project directories
    mkdir -p /home/user/projects/portfolio_site/assets
    mkdir -p /home/user/projects/portfolio_site/scripts
    mkdir -p /home/user/projects/portfolio_site/styles

    # Populate source files with EXACT contents expected by the tests
    printf 'PNGLOGO123\n'          > /home/user/projects/portfolio_site/assets/logo.png
    printf 'JPGHERO123\n'          > /home/user/projects/portfolio_site/assets/hero.jpg
    printf "console.log('hi');\n"  > /home/user/projects/portfolio_site/scripts/app.js
    printf 'body{background:#fff}\n' > /home/user/projects/portfolio_site/styles/style.css

    # Permissions: read/execute for all, write for owner
    chmod -R 755 /home/user/projects

%environment
    chmod 755 /home/user

    export LC_ALL=C.UTF-8
    export PYTHONIOENCODING=UTF-8

%labels
    Author YourName
    Description "Environment for timestamped backup procedure task with pytest installed."