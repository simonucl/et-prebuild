Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update && \
    apt-get install -y --no-install-recommends python3 python3-pip && \
    pip3 install --no-cache-dir pytest && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Prepare initial filesystem state for the backup-rotation exercise
    # ------------------------------------------------------------------

    # Create the required directory tree and populate sample .conf files
    mkdir -p /home/user/configs

    cat <<'EOF' > /home/user/configs/httpd.conf
ServerRoot /etc/httpd
Listen 80
EOF

    cat <<'EOF' > /home/user/configs/nginx.conf
worker_processes  1;
error_log  /var/log/nginx/error.log;
EOF

    cat <<'EOF' > /home/user/configs/ssh.conf
Port 22
PermitRootLogin no
EOF

    # Ensure permissions allow the unprivileged runtime user to modify files
    chmod -R 777 /home/user

%environment
    chmod 755 /home/user

    # Do not overwrite $HOME; leave the runtime environment intact.
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

%runscript
    exec "$@"