Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest for the test harness
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest

    # Create the initial directory structure and CSV file
    mkdir -p /home/user/docs

    cat > /home/user/docs/source_documentation.csv <<'EOF'
endpoint,method,description,author
/users,GET,Retrieve all users,alice
/users,POST,Create a user,bob
/orders,GET,Retrieve all orders,carol
EOF

    # Make sure the student (non-root) can write into /home/user/docs
    chmod -R a+rwx /home/user/docs

%environment
    chmod 755 /home/user

    export LC_ALL=C

%labels
    Author "Generated by ChatGPT"
    Description "Apptainer image for column-manipulation CLI task; provides initial CSV and pytest."