FROM ubuntu:22.04

# Install Python and pytest for the test harness
RUN apt-get update && \
    apt-get install -y --no-install-recommends python3 python3-pip && \
    pip3 install --no-cache-dir pytest && \
    rm -rf /var/lib/apt/lists/*

# Create the initial directory structure and CSV file
RUN mkdir -p /home/user/docs

RUN cat > /home/user/docs/source_documentation.csv <<'EOF'
endpoint,method,description,author
/users,GET,Retrieve all users,alice
/users,POST,Create a user,bob
/orders,GET,Retrieve all orders,carol
EOF

# Permissions
RUN chmod -R a+rwx /home/user/docs && \
    chmod 755 /home/user

ENV LC_ALL=C

LABEL Author="Generated by ChatGPT"
LABEL Description="Apptainer image for column-manipulation CLI task; provides initial CSV and pytest."