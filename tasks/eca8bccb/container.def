Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Update package index and install required system packages
    apt-get update
    # Basic utilities plus Python & pip
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        coreutils \
        findutils \
        tar \
        gzip
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # Create a writable home directory for the normal user.
    # DO NOT create any task-specific sub-directories – the grader
    # expects a pristine workspace except for /home/user itself.
    mkdir -p /home/user
    chmod 0777 /home/user

%environment
    chmod 755 /home/user

    # Prepend the (to-be-created) bin directory to PATH to make any
    # future user scripts easily discoverable.
    export PATH=/home/user/bin:$PATH