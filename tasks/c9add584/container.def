Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Refresh package list and install Python + pip.
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        tzdata
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the test harness.
    pip3 install --no-cache-dir pytest

    # -----------------------------------------------------------------
    # Prepare the initial filesystem state expected by the exercise.
    # -----------------------------------------------------------------

    # 1. Ensure /home/user exists and is writable by the unprivileged user
    #    that will run inside the container.  Making it world-writable
    #    guarantees the agent (whose UID/GID is unknown at build time)
    #    can create /home/user/logs later on.
    mkdir -p /home/user
    chmod 0777 /home/user

    # 2. Create the backups directory and the empty image file.
    mkdir -p /home/user/backups
    chmod 0755 /home/user/backups
    touch /home/user/backups/weekly_backup.img
    chmod 0644 /home/user/backups/weekly_backup.img

    # 3. Intentionally DO NOT create /home/user/logs so tests can verify
    #    its absence before the agent performs the task.

%environment
    chmod 755 /home/user

    # Nothing extra needed; inherit the caller’s environment.

%runscript
    echo "Container for the weekly_backup verification task."
    echo "Run your commands inside an interactive shell:"
    echo "  apptainer exec <image.sif> /bin/bash"