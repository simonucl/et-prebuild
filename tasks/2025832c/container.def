Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Install Python and pytest
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest

    # Create initial directory structure
    mkdir -p /home/user/service/logs

    # Create VERSION file with initial content
    echo '2.4.1' > /home/user/service/VERSION

    # Create CHANGELOG.md with required initial contents
    cat > /home/user/service/CHANGELOG.md <<'EOF'
# Changelog

## [2.4.1] - 2023-01-15
### Fixed
- Memory leak in worker pool (#1220)

EOF

    # Ensure the non-root user (who will run the tasks/tests) can modify the files
    chmod -R 777 /home/user/service

%environment
    chmod 755 /home/user

    # Make sure Python is on PATH (should already be, but keep it explicit)
    export PATH="/usr/bin:$PATH"

%labels
    Author devops-task-preparer
    Description "Environment for version-bump single-command task"