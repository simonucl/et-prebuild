# syntax=docker/dockerfile:1
FROM ubuntu:22.04

# Labels
LABEL Author="Autogenerated setup for Kubernetes inventory task"
LABEL Description="Provides an SQLite database and environment for the student to query Deployment counts."

# Install packages
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked --mount=type=cache,target=/var/lib/apt,sharing=locked set -e && \
    apt-get update && \
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        sqlite3 && \
    rm -rf /var/lib/apt/lists/*

# Install pytest
RUN --mount=type=cache,target=/root/.cache/pip pip3 install --no-cache-dir pytest

# Prepare workspace
RUN mkdir -p /home/user && chmod 0777 /home/user

# Create SQLite database
RUN sqlite3 /home/user/cluster_state.db <<'EOSQL'
CREATE TABLE manifests(
    id      INTEGER PRIMARY KEY,
    name    TEXT    NOT NULL,
    kind    TEXT    NOT NULL
);
INSERT INTO manifests (id, name, kind) VALUES
    (1, 'nginx-deployment', 'Deployment'),
    (2, 'redis',            'StatefulSet'),
    (3, 'api-config',       'ConfigMap'),
    (4, 'frontend',         'Deployment');
EOSQL

# Set permissions and remove report directory
RUN chmod 0644 /home/user/cluster_state.db && \
    rm -rf /home/user/report && \
    chmod 755 /home/user

# Environment variables
ENV PATH="/usr/local/bin:$PATH"