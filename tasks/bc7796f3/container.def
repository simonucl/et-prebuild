Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package index and install necessary packages
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        sqlite3

    # Install pytest for the test-runner
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare workspace under /home/user
    # ------------------------------------------------------------------
    mkdir -p /home/user
    # Make sure the unprivileged runtime user can create files/directories here
    chmod 0777 /home/user

    # ------------------------------------------------------------------
    # Create the SQLite database with the required schema & data
    # ------------------------------------------------------------------
    sqlite3 /home/user/cluster_state.db <<'EOSQL'
CREATE TABLE manifests(
    id      INTEGER PRIMARY KEY,
    name    TEXT    NOT NULL,
    kind    TEXT    NOT NULL
);
INSERT INTO manifests (id, name, kind) VALUES
    (1, 'nginx-deployment', 'Deployment'),
    (2, 'redis',            'StatefulSet'),
    (3, 'api-config',       'ConfigMap'),
    (4, 'frontend',         'Deployment');
EOSQL

    # Read-only permissions are sufficient for the tests
    chmod 0644 /home/user/cluster_state.db

    # Ensure the report directory is absent so the student must create it
    rm -rf /home/user/report

%environment
    chmod 755 /home/user

    # Guarantee that executables installed via pip are on PATH
    export PATH="/usr/local/bin:$PATH"

%labels
    Author="Autogenerated setup for Kubernetes inventory task"
    Description="Provides an SQLite database and environment for the student to query Deployment counts."