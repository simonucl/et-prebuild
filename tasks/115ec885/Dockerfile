FROM ubuntu:22.04

# Labels
LABEL Author="automated-setup"
LABEL Description="Environment for UTIL_SCRIPTS configuration task"

RUN set -eux && \
    # Update apt metadata and install Python + pip
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        python3 \
        python3-pip && \
    # Install pytest for the grading tests
    pip3 install --no-cache-dir pytest && \
    # Create the non-root user expected by the grading environment
    useradd -m -s /bin/bash user && \
    # Prepare the initial filesystem state required by the task
    # 1. /home/user/scripts directory (must exist and be empty)
    mkdir -p /home/user/scripts && \
    # 2. /home/user/.bashrc with the exact boiler-plate lines
    printf '# .bashrc autogenerated for training\n# feel free to add new exports below this line\n' \
        > /home/user/.bashrc && \
    # Ensure correct ownership so the unprivileged user can work
    chown -R user:user /home/user

# Environment variables
ENV PATH=/usr/local/bin:/usr/bin:/bin

# Set permissions on /home/user at runtime and keep minimal PATH
RUN chmod 755 /home/user

# Default entrypoint drops into a shell
CMD ["/bin/bash"]