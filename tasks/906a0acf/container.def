Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author build-script
    Description "Environment for log-processing DevOps task with pytest pre-installed."

%post
    set -e

    ###--- Update APT and install Python/pip ---------------------------------
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        gzip \
        ca-certificates

    # Upgrade pip and install pytest for the runtime user
    python3 -m pip install --no-cache-dir --upgrade pip
    python3 -m pip install --no-cache-dir pytest

    ###--- Prepare directory tree -------------------------------------------
    # Base application directories
    mkdir -p /home/user/app/logs/archived
    mkdir -p /home/user/app/debug

    # Ensure the debug directory is writable for any (non-root) user
    chmod 0777 /home/user/app/debug

    ###--- Create uncompressed *.log files ----------------------------------
    cat > /home/user/app/logs/service-a_2024-03-25.log << 'EOF'
2024-03-25 10:02:15 INFO  Starting service
2024-03-25 10:15:02 ERROR Connection timeout
2024-03-25 10:18:47 WARN  Retrying
2024-03-25 11:07:11 ERROR Failed to reconnect
EOF

    cat > /home/user/app/logs/service-b_2024-03-24.log << 'EOF'
2024-03-24 09:45:00 INFO  Scheduled task
2024-03-24 09:46:21 INFO  Task running
2024-03-24 09:47:33 ERROR Task failed
EOF

    cat > /home/user/app/logs/service-a_2024-03-14.log << 'EOF'
2024-03-14 13:01:09 INFO  Old record
2024-03-14 13:05:17 WARN  Still fine
2024-03-14 13:06:45 ERROR Historical issue
EOF

    ###--- Create auxiliary files -------------------------------------------
    # Simple read-me helper
    echo "This directory stores application log files." > /home/user/app/logs/readme.txt

    # Valid gzip archive (content is irrelevant for tests)
    echo "Archived log – not relevant for current diagnostics." | \
        gzip -c > /home/user/app/logs/archived/archived_2024-03-20.log.gz

    ###--- Final permissions -------------------------------------------------
    # Give read access to all users for the entire /home/user subtree
    chmod -R a+r /home/user
    # Executable bit on directories so they can be traversed
    find /home/user -type d -exec chmod a+x {} +

%environment
    chmod 755 /home/user

    # Ensure Python and pip are on the PATH for the executing user
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%runscript
    echo "Container for DevOps log-processing exercise. Run your commands inside an interactive shell."
    exec "/bin/bash" -l

%help
    This container image provides the directory layout and sample log files
    required for the DevOps “weekly error report” exercise.  pytest is already
    installed so that automated grading can verify the initial state.