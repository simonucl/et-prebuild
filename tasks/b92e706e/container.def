Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author      DevSecOps-Setup
    Description Base Ubuntu 22.04 image with Python and pytest pre-installed.
                 Provides a writable /home/user directory for the student’s task.

%post
    set -e

    # Install Python and pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Install pytest for task validation
    pip3 install --no-cache-dir pytest

    # Ensure a writable /home/user exists (student will work here)
    mkdir -p /home/user
    chmod 0777 /home/user

%environment
    chmod 755 /home/user

    # Basic PATH setup (do NOT override $HOME)
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH