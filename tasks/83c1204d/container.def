Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author "Apptainer Task Preparer"
    Description "Base image for stub-API exercise – provides curl, Python, and pytest, but leaves the required exercise artefacts absent."

%post
    set -e

    # Update apt metadata and install required tooling.
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        curl \
        ca-certificates

    # Upgrade pip then install pytest.
    python3 -m pip install --no-cache-dir --upgrade pip
    python3 -m pip install --no-cache-dir pytest

    # Create a writable home directory for the learner.
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up apt caches to keep the image small.
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure the default Python and pip are easily discoverable.
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%runscript
    # By default just launch an interactive shell.
    exec /bin/bash