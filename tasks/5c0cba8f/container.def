Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author "AI Assistant"
    Description "Ubuntu 22.04 base with Python, sqlite3, and pytest pre-installed for the compliance_audit task."

%post
    set -eux

    # Refresh package index and install required utilities
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-venv \
        sqlite3

    # Install pytest for the automated test harness
    pip3 install --no-cache-dir pytest

    # Clean up APT caches to keep the image slim
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Ensure the expected home directory exists (but DO NOT create task artefacts)
    mkdir -p /home/user

%environment
    chmod 755 /home/user

    # Guarantee /usr/local/bin (where pip installs executables) is on PATH
    export PATH=/usr/local/bin:$PATH