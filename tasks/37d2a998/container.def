Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # --------------------------------------------------------------------
    # Install Python tooling (pytest is required for the automated tests)
    # --------------------------------------------------------------------
    apt-get update
    apt-get install -y --no-install-recommends python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # --------------------------------------------------------------------
    # Prepare initial directory layout and seed data for the exercise
    # --------------------------------------------------------------------
    mkdir -p /home/user/releases/release_2023-09-01
    mkdir -p /home/user/releases/release_2023-09-08
    mkdir -p /home/user/deployments

    # --- build.info for 2023-09-01 --------------------------------------
    cat >/home/user/releases/release_2023-09-01/build.info <<'EOF'
BUILD_ID: 202309011230
VERSION: v1.4.2
COMMIT: 1a2b3c4d
EOF

    # --- build.info for 2023-09-08 --------------------------------------
    cat >/home/user/releases/release_2023-09-08/build.info <<'EOF'
BUILD_ID: 202309081305
VERSION: v1.5.0
COMMIT: 5d6e7f8g
EOF

    # --- deployment_status.log -----------------------------------------
    cat >/home/user/deployments/deployment_status.log <<'EOF'
[2023-09-01 12:30] release_2023-09-01: SUCCESS
[2023-09-01 12:45] release_2023-09-01: DEPLOYED
[2023-09-08 13:15] release_2023-09-08: FAILED
[2023-09-08 13:40] release_2023-09-08: ROLLBACK_COMPLETED
EOF

    # --------------------------------------------------------------------
    # Permissions: allow the unprivileged runtime user to work in /home/user
    # --------------------------------------------------------------------
    chmod -R a+rX /home/user
    chmod -R a+w  /home/user/releases /home/user/deployments

%environment
    chmod 755 /home/user

    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8