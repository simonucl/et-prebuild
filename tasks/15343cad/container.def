Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ------------------------------------------------------------------
    # Basic tooling
    # ------------------------------------------------------------------
    apt-get update
    DEBIAN_FRONTEND=noninteractive \
        apt-get install -y --no-install-recommends \
            python3 \
            python3-pip \
            ca-certificates
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state expected by the grader
    # ------------------------------------------------------------------
    mkdir -p /home/user/builds/2023-05-01
    mkdir -p /home/user/builds/2023-05-02
    mkdir -p /home/user/builds/2023-05-03

    # 2023-05-01 log ----------------------------------------------------
    cat <<'EOF' > /home/user/builds/2023-05-01/artifacts.log
app-core|1.0.0|1500|abc111|OK
app-ui|1.0.0|500|def222|FAIL
lib-utils|2.1.3|300|ghi333|OK
EOF

    # 2023-05-02 log ----------------------------------------------------
    cat <<'EOF' > /home/user/builds/2023-05-02/artifacts.log
app-core|1.0.1|1520|abc444|OK
app-ui|1.0.1|520|def555|OK
lib-utils|2.1.3|300|ghi333|FAIL
plugin-auth|0.9.0|200|jkl666|OK
EOF

    # 2023-05-03 log ----------------------------------------------------
    cat <<'EOF' > /home/user/builds/2023-05-03/artifacts.log
app-core|1.0.1|1520|abc777|FAIL
plugin-auth|0.9.1|210|jkl999|OK
EOF

    # ------------------------------------------------------------------
    # Permissions
    # ------------------------------------------------------------------
    # Directories must be writable by any non-root user who will run the task
    chmod -R 777 /home/user
    # Logs need to be world-readable (and writable so the agent can edit them)
    chmod 666 /home/user/builds/2023-05-*/artifacts.log

%environment
    chmod 755 /home/user

    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%runscript
    echo "Container ready for the build-log processing task."
    echo "Enter an interactive shell with:  apptainer exec <image> /bin/bash"

%labels
    Author="ChatGPT"
    Description="Ubuntu 22.04 base with pytest installed and initial build-log data for the artifacts task."