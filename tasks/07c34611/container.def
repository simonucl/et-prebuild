Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # Create initial directory layout and JSON files
    mkdir -p /home/user/workflows/input

    printf '{"name": "serviceA", "enabled": true}\n' \
        > /home/user/workflows/input/config1.json
    printf '{"name": "serviceB", "enabled": false}\n' \
        > /home/user/workflows/input/config2.json
    printf '{"name": "serviceC", "enabled": true}\n' \
        > /home/user/workflows/input/config3.json

    # Ensure the non-root runtime user can read/write within /home/user
    chmod -R a+rwX /home/user

%environment
    chmod 755 /home/user

    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    exec "$@"