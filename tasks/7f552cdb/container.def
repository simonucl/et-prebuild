Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install Python + pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates

    # Install pytest for the upcoming test suite
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare the initial filesystem expected by the automated tests
    # ------------------------------------------------------------------

    # Create the log directory hierarchy
    mkdir -p /home/user/logs

    # Populate the single-day uptime log with the exact required lines
    cat > /home/user/logs/site-01-2023-10-05.log << 'EOF'
2023-10-05T13:00:00Z site-01 OK response_time=120ms
2023-10-05T13:05:00Z site-01 ERROR connection_timeout
2023-10-05T13:10:00Z site-01 OK response_time=118ms
2023-10-05T13:15:00Z site-01 WARNING high_latency response_time=350ms
2023-10-05T13:20:00Z site-01 OK response_time=119ms
2023-10-05T13:25:00Z site-01 CRITICAL host_unreachable
2023-10-05T13:30:00Z site-01 OK response_time=117ms
EOF

    # Ensure write permissions for any non-root user executing inside
    chmod -R 0777 /home/user

    # Do NOT create /home/user/output; the learner will create it.

%environment
    chmod 755 /home/user

    # Ensure Python is discoverable
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"
    export PYTHONUNBUFFERED=1