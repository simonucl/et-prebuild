Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # --------------------------------------------------------------------- #
    # Install Python and pytest                                             #
    # --------------------------------------------------------------------- #
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # --------------------------------------------------------------------- #
    # Create user ‘user’ (UID/GID 1000) and its home directory              #
    # --------------------------------------------------------------------- #
    if ! getent group 1000 >/dev/null 2>&1; then
        groupadd -g 1000 user
    fi
    if ! id -u 1000 >/dev/null 2>&1; then
        useradd -m -u 1000 -g 1000 user
    fi

    # --------------------------------------------------------------------- #
    # Prepare the initial workspace                                         #
    # --------------------------------------------------------------------- #
    mkdir -p /home/user/hardening
    chmod 0755 /home/user/hardening

    cat > /home/user/hardening/tuned.conf <<'EOF'
# Kernel scheduler settings
sched_migration_cost_ns = 500000
sched_latency_ns = 6000000
sched_min_granularity_ns = 750000
# end
EOF

    chmod 0644 /home/user/hardening/tuned.conf

    # Ensure ownership is consistent
    chown -R 1000:1000 /home/user || true

%environment
    chmod 755 /home/user

    # Keep standard paths; do not override $HOME.
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"