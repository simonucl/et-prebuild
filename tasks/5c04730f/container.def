Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "Updating apt repositories and installing Python tooling..."
    apt-get update -qq
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        && apt-get clean && rm -rf /var/lib/apt/lists/*

    echo "Installing pytest for the grader..."
    pip3 install --no-cache-dir pytest

    echo "Setting up initial directory structure and log files..."
    # Ensure the /home/user directory exists
    mkdir -p /home/user/build_logs

    # Create Android build log
    cat > /home/user/build_logs/build_android.log <<'ANDROID_EOF'
[2024-05-22T14:01:07Z] Starting Android build job
[INFO] Build status: SUCCESS
[WARN] Deprecated API warnings found: 5
[INFO] Total tests run: 120
[DEBUG] Some verbose gradle output…
[INFO] Tests failed: 3
[INFO] Total time: 7 minutes 35 seconds
[2024-05-22T14:08:45Z] Build finished
ANDROID_EOF

    # Create iOS build log
    cat > /home/user/build_logs/build_ios.log <<'IOS_EOF'
2024-05-22 15:10:03.912 xcodebuild[4231:778921] note: Using new build system
[INFO] Build status: FAILURE
[INFO] Total tests run: 110
[ERROR] Code signing step failed on app-extension target
[INFO] Tests failed: 11
[INFO] Total time: 8 minutes 22 seconds
[INFO] Some post-processing step failed
IOS_EOF

    echo "Adjusting permissions..."
    chmod -R a+rX /home/user
    find /home/user/build_logs -type f -exec chmod 0644 {} +

%environment
    chmod 755 /home/user

    # Ensure Python and Pip are in PATH
    export PATH="/usr/local/bin:/usr/bin:/bin:${PATH}"

%labels
    Author "Container build script autogenerated for mobile build log parsing task"