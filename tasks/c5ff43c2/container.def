Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eu

    # Update package index and install required packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        curl \
        ca-certificates
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the test runner
    pip3 install --no-cache-dir pytest

    # Prepare writable home directory for the student
    mkdir -p /home/user
    # Make sure any UID that runs the container can write here
    chmod 0777 /home/user

%runscript
    chmod 755 /home/user

    echo "Apptainer container for the emergency static site exercise."
    echo "Launch a shell and follow the task instructions."

%environment
    # Keep HOME as inherited; just ensure common vars are present
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8