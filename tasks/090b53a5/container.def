Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    #--------------------------------------------------
    # 1. OS packages and Python tooling
    #--------------------------------------------------
    apt-get update && \
        DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
            python3 \
            python3-pip \
            ca-certificates \
            bash \
        && \
        apt-get clean && \
        rm -rf /var/lib/apt/lists/*

    # Install pytest for the validation suite
    pip3 install --no-cache-dir pytest

    #--------------------------------------------------
    # 2. Prepare the legacy environment in /home/user
    #--------------------------------------------------
    mkdir -p /home/user/legacy_tools

    # --- Legacy Bash script ---
    cat > /home/user/legacy_tools/legacy_uptime_checker.sh <<'EOF'
#!/usr/bin/env bash
# === Legacy uptime checker – do not edit ===
# Reads two columns (hostname and status) from mock_ping_results.dat
# and prints the result in the format "<hostname>: <status>".

while read -r host status; do
    if [[ "$status" == "UP" ]]; then
        echo "${host}: UP"
    else
        echo "${host}: DOWN"
    fi
done < "$(dirname "$0")/mock_ping_results.dat"
EOF

    # --- Mock data file the script consumes ---
    cat > /home/user/legacy_tools/mock_ping_results.dat <<'EOF'
web01 UP
web02 DOWN
db01 UP
cache01 DOWN
EOF

    # --- Ancillary hosts list (not used by the script) ---
    cat > /home/user/legacy_tools/hosts.txt <<'EOF'
web01
web02
db01
cache01
EOF

    #--------------------------------------------------
    # 3. Permissions – match exercise expectations
    #--------------------------------------------------
    chmod 755 /home/user
    chmod 755 /home/user/legacy_tools
    chmod 755 /home/user/legacy_tools/legacy_uptime_checker.sh
    chmod 644 /home/user/legacy_tools/mock_ping_results.dat
    chmod 644 /home/user/legacy_tools/hosts.txt

%labels
    Author "OpenAI ChatGPT"
    Description "Environment for the legacy uptime checker exercise with pytest pre-installed."

%help
This container image provides the starting point for the “legacy uptime checker”
exercise.  It supplies:
  • A legacy Bash script and its data files in /home/user/legacy_tools
  • Python 3 and pytest for automated validation

No deliverable log files are present; those are to be generated by the learner.