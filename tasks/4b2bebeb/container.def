Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # Prepare writable workspace for the student
    mkdir -p /home/user
    chmod 0777 /home/user

%labels
    chmod 755 /home/user

    Author      AutomationExercise
    Description Container for “workflow.service” single-command task with pytest pre-installed.