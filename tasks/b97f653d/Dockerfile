# syntax=docker/dockerfile:1
FROM ubuntu:22.04

# Install Python and pytest
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked --mount=type=cache,target=/var/lib/apt,sharing=locked --mount=type=cache,target=/root/.cache/pip apt-get update && apt-get install -y --no-install-recommends python3 python3-pip && pip3 install --no-cache-dir pytest

# Prepare application directory structure
RUN mkdir -p /home/user/app/releases && \
    bash -c 'for ver in v1.0 v1.1 v2.0; do \
        mkdir -p "/home/user/app/releases/${ver}" ; \
        printf "%s\n" "${ver}" > "/home/user/app/releases/${ver}/version.txt" ; \
    done' && \
    chmod 755 /home/user

# Create symlink to v1.0
RUN ln -sfn /home/user/app/releases/v1.0 /home/user/app/current

# Create empty deploy log
RUN touch /home/user/app/deploy.log

# Ensure permissions
RUN chmod -R 777 /home/user

# Environment variables
ENV PATH=/usr/local/bin:/usr/bin:/bin

# Labels
LABEL Author="Generated by ChatGPT"
LABEL Description="Environment for deployment script task with pytest pre-installed."