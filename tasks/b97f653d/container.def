Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare application directory structure expected by the tests
    # ------------------------------------------------------------------
    mkdir -p /home/user/app/releases

    for ver in v1.0 v1.1 v2.0; do
        mkdir -p "/home/user/app/releases/${ver}"
        printf "%s\n" "${ver}" > "/home/user/app/releases/${ver}/version.txt"
    chmod 755 /home/user

    done

    # Create the initial 'current' symlink pointing to v1.0
    ln -sfn /home/user/app/releases/v1.0 /home/user/app/current

    # Create an empty deploy log
    touch /home/user/app/deploy.log

    # Ensure the non-root user running inside the container can modify everything
    chmod -R 777 /home/user

%environment
    # Minimal PATH setup
    export PATH=/usr/local/bin:/usr/bin:/bin

%labels
    Author="Generated by ChatGPT"
    Description="Environment for deployment script task with pytest pre-installed."