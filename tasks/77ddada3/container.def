Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    ############################
    # 1) System dependencies   #
    ############################
    apt-get update -y
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        jq \
        ca-certificates
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    ############################
    # 2) Python tooling        #
    ############################
    pip3 install --no-cache-dir pytest

    ############################
    # 3) Runtime user setup    #
    ############################
    # Create a non-root user “user” with UID/GID 1000 so that
    # the calling host user (commonly also UID 1000) can own
    # and write to the policy directory inside the container.
    groupadd -g 1000 user || true
    useradd  -m -u 1000 -g 1000 user || true

    ############################
    # 4) Pre-provisioned files #
    ############################
    POLICY_DIR="/home/user/devsecops/policy"
    mkdir -p "${POLICY_DIR}"

    cat > "${POLICY_DIR}/inventory.txt" <<'EOF'
22:ssh/tcp
53:dns/udp
80:http/tcp
443:https/tcp
8080:http-alt/tcp
EOF

    ############################
    # 5) Permissions           #
    ############################
    chmod 0755 /home/user
    chmod 0755 /home/user/devsecops
    chmod 0755 "${POLICY_DIR}"
    chmod 0644 "${POLICY_DIR}/inventory.txt"

    # Give ownership to UID/GID 1000 (“user”) so that the
    # unprivileged runtime user can create new files later.
    chown -R 1000:1000 /home/user

%environment
    chmod 755 /home/user

    # Ensure Python and pip executables are on PATH
    export PATH=/usr/local/bin:/usr/bin:/bin

%labels
    Author devsecops-task-prep
    Description "Base image for small DevSecOps port-inventory exercise"

%help
    This Apptainer image provides the initial filesystem state for the
    “network-exposure” policy exercise. Pytest is pre-installed so that the
    automated grading harness can run its tests.