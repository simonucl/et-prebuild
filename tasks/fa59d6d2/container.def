Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "==> Updating apt and installing Python + pip"
    apt-get update -qq
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        && apt-get clean \
        && rm -rf /var/lib/apt/lists/*

    echo "==> Installing pytest"
    pip3 install --no-cache-dir --upgrade pip setuptools
    pip3 install --no-cache-dir pytest

    echo "==> Creating support_case directory structure"
    mkdir -p /home/user/support_case
    chmod 0777 /home/user
    chmod 0777 /home/user/support_case

    echo "==> Populating initial app_config.yaml"
    cat > /home/user/support_case/app_config.yaml <<'EOF'
service:
  name: "FileProcessor"
  version: "1.2.3"
  enabled: false

logging:
  level: "info"
  path: "/var/log/fileprocessor/"
EOF

    echo "==> Populating initial system_info.toml"
    cat > /home/user/support_case/system_info.toml <<'EOF'
[cpu]
cores = 4
model = "Intel(R) Core(TM) i5-8250U"

[memory]
total_gb = 8

[os]
name = "Ubuntu"
version = "20.04"
EOF

    chmod 0666 /home/user/support_case/app_config.yaml
    chmod 0666 /home/user/support_case/system_info.toml

%environment
    chmod 755 /home/user

    # Ensure Python and user-installed tools are on PATH
    export PATH="/usr/local/bin:/usr/local/sbin:/usr/bin:/usr/sbin:/bin:/sbin"

%labels
    Author support_engineering_example
    Description "Base container for support-case exercise with initial configuration files and pytest installed."