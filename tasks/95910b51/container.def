Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    #-----------------------------------------------------------------------
    # Install Python and pytest
    #-----------------------------------------------------------------------
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    #-----------------------------------------------------------------------
    # Create required directory structure and seed source configuration files
    #-----------------------------------------------------------------------
    mkdir -p /home/user/migration/source_configs
    mkdir -p /home/user/migration/archives
    mkdir -p /home/user/migration/restore

    # Populate the two source configuration files with exact contents
    cat > /home/user/migration/source_configs/config1.conf <<'EOF'
server_name=alpha
port=8080
EOF

    cat > /home/user/migration/source_configs/config2.conf <<'EOF'
server_name=beta
port=9090
EOF

    #-----------------------------------------------------------------------
    # Ensure the non-root runtime user can freely modify everything in /home/user
    #-----------------------------------------------------------------------
    chmod -R 777 /home/user

%labels
    chmod 755 /home/user

    Author  Cloud-Architecture Task Setup
    Description  Environment prepared for migration-archive exercise with pytest pre-installed.

%help
    This container image provides the initial filesystem layout required for the
    migration task and includes pytest for automated grading.