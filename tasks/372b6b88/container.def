Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # --------------------------------------------------------------------- #
    # Install Python tooling and pytest                                      #
    # --------------------------------------------------------------------- #
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # --------------------------------------------------------------------- #
    # Set up initial project scaffold                                       #
    # --------------------------------------------------------------------- #
    # Create the required directory tree with correct permissions
    mkdir -p /home/user/solver_demo
    chmod 755 /home/user
    chmod 755 /home/user/solver_demo

    # Create the run_lp.py script with exact required contents and mode 755
    cat > /home/user/solver_demo/run_lp.py <<'EOF'
#!/usr/bin/env python3
print("objective=22.0")
print("x=4.0")
print("y=5.0")
EOF
    chmod 755 /home/user/solver_demo/run_lp.py

%environment
    # Nothing to override; default HOME binding is left intact.

%labels
    Author Automated Build
    Description Scaffold for linear-programming workflow testing.