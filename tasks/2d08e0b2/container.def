Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Update package index and install Python + pip
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the forthcoming test-suite
    pip3 install --no-cache-dir pytest

    # Create the initial directory structure and seed CSV file
    mkdir -p /home/user/project/test_data

    # Seed file: /home/user/project/test_data/raw_metrics.csv
    cat <<'EOF' > /home/user/project/test_data/raw_metrics.csv
test_case,module,status,execution_time
TC001,login,pass,2.1
TC002,signup,fail,3.4
TC003,logout,pass,1.7
EOF

    # Ensure the agent can create new files in the same directory
    chmod 777 /home/user/project/test_data
    chmod 666 /home/user/project/test_data/raw_metrics.csv

%environment
    chmod 755 /home/user

    # Make sure `python3` and `pip3` are on PATH (they already are, but be explicit)
    PATH=/usr/local/bin:/usr/bin:/bin:$PATH
    export PATH