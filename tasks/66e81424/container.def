Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package index and install required utilities
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        python3 \
        python3-pip \
        iputils-ping \
        --no-install-recommends

    # Clean up apt caches to keep image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the test harness
    pip3 install --no-cache-dir pytest

    # Ensure baseline home directory exists and is writable
    mkdir -p /home/user
    chmod 0777 /home/user

%environment
    chmod 755 /home/user

    # Guarantee consistent encoding
    export PYTHONIOENCODING="utf-8"

%labels
    Author="Apptainer build script"
    Description="Environment for network-diagnostic heartbeat exercise"