Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install python + pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Prepare initial filesystem state required by the exercise
    # ------------------------------------------------------------------
    mkdir -p /home/user/manifests

    # 1) web-deployment.yaml
    cat > /home/user/manifests/web-deployment.yaml << 'EOF'
apiVersion: v1
kind: Service
metadata:
  name: web-service
spec:
  selector:
    app: web
  type: NodePort
  ports:
    - port: 80
      targetPort: 8080
      protocol: TCP
      nodePort: 30080
  clusterIP: 10.96.0.10
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: web-deployment
spec:
  replicas: 2
  selector:
    matchLabels:
      app: web
  template:
    metadata:
      labels:
        app: web
    spec:
      containers:
        - name: web
          image: nginx:1.19
          ports:
            - containerPort: 8080
          readinessProbe:
            httpGet:
              path: /
              port: 8080
          livenessProbe:
            httpGet:
              path: /
              port: 8080
EOF

    # 2) api-gateway.yaml
    cat > /home/user/manifests/api-gateway.yaml << 'EOF'
apiVersion: v1
kind: Service
metadata:
  name: api-gateway
spec:
  selector:
    app: gateway
  type: NodePort
  ports:
    - port: 443
      targetPort: 8443
      protocol: TCP
      nodePort: 40000
  clusterIP: 10.96.0.20
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: gateway-deployment
spec:
  replicas: 1
  selector:
    matchLabels:
      app: gateway
  template:
    metadata:
      labels:
        app: gateway
    spec:
      containers:
        - name: gateway
          image: envoyproxy/envoy:v1.18.3
          ports:
            - containerPort: 8443
          readinessProbe:
            tcpSocket:
              port: 8443
          livenessProbe:
            tcpSocket:
              port: 8443
EOF

    # 3) db.yaml
    cat > /home/user/manifests/db.yaml << 'EOF'
apiVersion: v1
kind: Service
metadata:
  name: postgres
spec:
  selector:
    app: postgres
  ports:
    - port: 5432
      protocol: TCP
  clusterIP: 10.96.0.30
---
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: postgres-stateful
spec:
  serviceName: postgres
  replicas: 1
  selector:
    matchLabels:
      app: postgres
  template:
    metadata:
      labels:
        app: postgres
    spec:
      containers:
        - name: postgres
          image: postgres:13
          ports:
            - containerPort: 5432
          readinessProbe:
            tcpSocket:
              port: 5432
          livenessProbe:
            tcpSocket:
              port: 5432
EOF

    # Ensure files are world-readable
    chmod -R a+r /home/user/manifests

%environment
    chmod 755 /home/user

    # Keep environment minimal; rely on Apptainer default HOME binding.
    export PYTHONUNBUFFERED=1

%labels
    Author network-audit-sre-exercise
    Description "Initial container state for Kubernetes service-level network audit task"