Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update -y
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest

    # ---------------------------------------------------------------------
    # Create the required directory tree and files for /home/user/opt_project
    # ---------------------------------------------------------------------
    mkdir -p /home/user/opt_project/src/models
    mkdir -p /home/user/opt_project/data
    mkdir -p /home/user/opt_project/tests
    mkdir -p /home/user/opt_project/legacy

    # Create placeholder files
    echo "Project README" > /home/user/opt_project/README.md
    echo "from setuptools import setup" > /home/user/opt_project/setup.py
    echo "def solve(): pass" > /home/user/opt_project/src/solver.py

    echo "\\* Model A LP content *\\" > /home/user/opt_project/src/models/modelA.lp
    echo "\\* Model B MPS content *\\" > /home/user/opt_project/src/models/modelB.mps
    echo "demand,quantity" > /home/user/opt_project/data/demand.csv
    echo "\\* Scenario LP *\\" > /home/user/opt_project/data/scenario.lp
    echo "def test_parser():\n    assert True" > /home/user/opt_project/tests/test_parser.py
    echo "\\* Legacy MPS *\\" > /home/user/opt_project/legacy/old_model.mps

    # Ensure appropriate permissions so the non-root agent can write
    chmod -R 777 /home/user/opt_project

%environment
    chmod 755 /home/user

    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    echo "Container for optimisation-project task."