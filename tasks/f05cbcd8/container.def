Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    ##--------------------------------------------------------------------
    ## 1. Base OS packages and Python tooling
    ##--------------------------------------------------------------------
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest

    ##--------------------------------------------------------------------
    ## 2. Create non-root user and group with UID/GID 1000
    ##    (matches the most common host UID/GID and allows write-access)
    ##--------------------------------------------------------------------
    if ! getent group 1000 >/dev/null; then
        groupadd -g 1000 user
    fi
    if ! id -u 1000 >/dev/null 2>&1; then
        useradd -m -u 1000 -g 1000 -s /bin/bash user
    fi

    ##--------------------------------------------------------------------
    ## 3. Directory structure for the exercise
    ##--------------------------------------------------------------------
    mkdir -p /home/user/incidents/tickets
    mkdir -p /home/user/resources

    ##--------------------------------------------------------------------
    ## 4. Populate initial artefacts
    ##--------------------------------------------------------------------
    # 4a. Ticket file
    cat > /home/user/incidents/tickets/dns_incident_2024.txt <<'EOF'
app.web.internal
example.com
localhost
EOF

    # 4b. mock_hosts file
    cat > /home/user/resources/mock_hosts <<'EOF'
127.0.0.1   localhost
::1         localhost
10.0.0.5    app.web.internal
EOF

    # 4c. mock DNS records (deterministic JSON)
    cat > /home/user/resources/mock_dns_records.json <<'EOF'
{
  "app.web.internal": { "A": "", "AAAA": "" },
  "example.com":      { "A": "93.184.216.34",
                        "AAAA":"2606:2800:220:1:248:1893:25c8:1946"},
  "localhost":        { "A": "127.0.0.1", "AAAA":"::1" }
}
EOF

    ##--------------------------------------------------------------------
    ## 5. File permissions
    ##    - rw for owner, r/w for group optional, no world-write
    ##--------------------------------------------------------------------
    chmod 0660 /home/user/incidents/tickets/dns_incident_2024.txt
    chmod 0660 /home/user/resources/mock_hosts
    chmod 0660 /home/user/resources/mock_dns_records.json

    ## Make sure the non-root ‘user’ owns everything under /home/user
    chown -R 1000:1000 /home/user

%environment
    chmod 755 /home/user

    # Extend PATH so a future student-installed ~/.local/bin is honoured
    export PATH="$PATH:/home/user/.local/bin"

%labels
    Author="Container build script (operations exercise)"
    Description="Sandbox for DNS resolution incident triage task"