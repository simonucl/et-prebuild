Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
Author db-reliability-task
Description "Base image for dotenv + env capture exercise"

%post
    set -e

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # Create the expected home directory structure and make it writable
    mkdir -p /home/user/db_backup
    chmod -R 0777 /home/user

    # Clean up apt caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure python3 is the default python
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%runscript
    echo "Container for the dotenv + env capture exercise."