FROM ubuntu:22.04

# Help:
# This container provides the fixed input data and tooling (jq, pytest)
# needed for the “table-top restore test” programming exercise.

LABEL Author="Generated by ChatGPT"
LABEL Description="Environment for backup-manifest restore/validation task with jq and pytest installed."

ENV PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

RUN set -eux && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        jq \
        python3 \
        python3-pip \
        ca-certificates && \
    python3 -m pip install --no-cache-dir --upgrade pip && \
    python3 -m pip install --no-cache-dir pytest && \
    mkdir -p /home/user && \
    chmod 0777 /home/user && \
    mkdir -p /home/user/archives && \
    mkdir -p /home/user/schemas && \
    mkdir -p /tmp/daily

RUN cat >/tmp/daily/valid_manifest.json <<'EOF'
{
  "backupId": "bku-20231015-01",
  "timestamp": "2023-10-15T02:15:30Z",
  "files": [
    { "filename": "etc/passwd", "checksum": "a54d88e06612d820bc3be72877c74f257b561b19" },
    { "filename": "etc/shadow", "checksum": "2c1743a391305fbf367df8e4f069f9f9a46b3be2" }
  ]
}
EOF

RUN cat >/tmp/daily/invalid_manifest.json <<'EOF'
{
  "backupId": "bku-20231015-02",
  "timestamp": "2023-10-15T02:16:00Z",
  "files": "should-be-array-but-is-string"
}
EOF

RUN tar -C /tmp -czf /home/user/archives/daily_backup.tar.gz daily && \
    rm -rf /tmp/daily

RUN cat >/home/user/schemas/backup_manifest.schema.json <<'EOF'
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["backupId", "timestamp", "files"],
  "properties": {
    "backupId": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["filename", "checksum"],
        "properties": {
          "filename": { "type": "string" },
          "checksum": { "type": "string", "pattern": "^[a-f0-9]{40}$" }
        }
      }
    }
  }
}
EOF

RUN chmod -R a+rX /home/user/archives /home/user/schemas && \
    chmod 755 /home/user