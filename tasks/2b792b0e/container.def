Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Update apt index and install required tools
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        jq \
        python3 \
        python3-pip \
        ca-certificates

    # Upgrade pip and install pytest (required by autograder)
    python3 -m pip install --no-cache-dir --upgrade pip
    python3 -m pip install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare directory structure expected by the exercise
    # ------------------------------------------------------------------
    mkdir -p /home/user
    chmod 0777 /home/user        # allow the non-root agent to create new dirs/files

    # Fixed, read-only input data supplied to the student
    mkdir -p /home/user/archives
    mkdir -p /home/user/schemas

    # ------------------------------------------------------------------
    # Create the JSON manifests that will be packaged into the tarball
    # ------------------------------------------------------------------
    mkdir -p /tmp/daily

    cat >/tmp/daily/valid_manifest.json <<'EOF'
{
  "backupId": "bku-20231015-01",
  "timestamp": "2023-10-15T02:15:30Z",
  "files": [
    { "filename": "etc/passwd", "checksum": "a54d88e06612d820bc3be72877c74f257b561b19" },
    { "filename": "etc/shadow", "checksum": "2c1743a391305fbf367df8e4f069f9f9a46b3be2" }
  ]
}
EOF

    cat >/tmp/daily/invalid_manifest.json <<'EOF'
{
  "backupId": "bku-20231015-02",
  "timestamp": "2023-10-15T02:16:00Z",
  "files": "should-be-array-but-is-string"
}
EOF

    # ------------------------------------------------------------------
    # Package the manifests into the required tarball
    # ------------------------------------------------------------------
    tar -C /tmp -czf /home/user/archives/daily_backup.tar.gz daily
    rm -rf /tmp/daily

    # ------------------------------------------------------------------
    # Create the JSON schema file
    # ------------------------------------------------------------------
    cat >/home/user/schemas/backup_manifest.schema.json <<'EOF'
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["backupId", "timestamp", "files"],
  "properties": {
    "backupId": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["filename", "checksum"],
        "properties": {
          "filename": { "type": "string" },
          "checksum": { "type": "string", "pattern": "^[a-f0-9]{40}$" }
        }
      }
    }
  }
}
EOF

    # Ensure read permissions for all users
    chmod -R a+rX /home/user/archives /home/user/schemas

%environment
    chmod 755 /home/user

    # Ensure Python and JQ are in the default PATH
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%labels
    Author  "Generated by ChatGPT"
    Description "Environment for backup-manifest restore/validation task with jq and pytest installed."

%help
    This container provides the fixed input data and tooling (jq, pytest)
    needed for the “table-top restore test” programming exercise.