Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ------------------------------------------------------------------ #
    # Base tools and Python/pytest                                        #
    # ------------------------------------------------------------------ #
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------ #
    # Initial dataset setup                                               #
    # ------------------------------------------------------------------ #
    mkdir -p /home/user/data_to_archive/docs
    mkdir -p /home/user/data_to_archive/media

    # Populate docs
    printf 'Quarterly Report Q1 2024\n' > /home/user/data_to_archive/docs/report1.txt
    printf 'Quarterly Report Q2 2024\n' > /home/user/data_to_archive/docs/report2.txt

    # Populate media
    printf 'FAKEJPEGDATA\n'   > /home/user/data_to_archive/media/image1.jpg
    printf 'FAKEMP4DATA\n'    > /home/user/data_to_archive/media/video1.mp4

    # Permissions: readable by everyone, writable by the owning user/group
    chmod -R a+rX,ug+w /home/user/data_to_archive

    # Ensure the backups directory is NOT present
    if [ -d /home/user/backups ]; then
        rm -rf /home/user/backups
    fi

%environment
    chmod 755 /home/user

    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    echo "Apptainer container ready for the backup task."