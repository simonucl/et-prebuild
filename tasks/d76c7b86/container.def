Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Basic OS preparation
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-venv \
        python3-pip \
        ca-certificates \
        curl \
        build-essential

    # Install pytest for the test harness
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare the starting workspace for the student
    #   • /home/user/projects/simple_app/ must exist
    #   • Nothing else (venv, files, logs dir) should exist yet
    # ------------------------------------------------------------------
    mkdir -p /home/user/projects/simple_app

    # Make sure the student (non-root runtime user) can write inside
    chmod -R 0777 /home/user

    # Clean up apt caches to keep image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%labels
    chmod 755 /home/user

    Author "Apptainer build script – starter project environment"

%help
    This container sets up the initial filesystem state for the
    “starter-project” exercise.  Only the base directory
    /home/user/projects/simple_app exists; students will create the rest.