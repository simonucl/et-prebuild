Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install Python tooling
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-venv \
        python3-setuptools \
        python3-wheel \
        ca-certificates \
        build-essential

    # Upgrade pip and install pytest (needed by the grading harness)
    python3 -m pip install --no-cache-dir --upgrade pip
    python3 -m pip install --no-cache-dir pytest

    # Prepare writable directory for the learner’s output
    mkdir -p /home/user
    chmod 0777 /home/user   # ensure any UID can write here

    # Clean up APT cache to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Add user-level bin directories to PATH and disable byte-code generation
    export PATH="$PATH:$HOME/.local/bin:/home/user/.local/bin"
    export PYTHONDONTWRITEBYTECODE=1
    export PIP_DISABLE_PIP_VERSION_CHECK=1