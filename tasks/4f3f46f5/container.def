BootStrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "Updating APT and installing required packages..."
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-jsonschema \
        jq \
        ca-certificates
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    echo "Installing pytest via pip..."
    python3 -m pip install --no-cache-dir --upgrade pip
    python3 -m pip install --no-cache-dir pytest

    echo "Creating /home/user with starter JSON files..."
    mkdir -p /home/user
    chmod 0777 /home/user   # allow the unprivileged runtime user to write results here

    cat > /home/user/tickets.json << 'EOF'
[
  {
    "id": 1001,
    "title": "Router reboot required",
    "status": "open",
    "team": "network"
  },
  {
    "id": 1002,
    "title": "Email account locked",
    "status": "closed",
    "team": "support"
  },
  {
    "id": 1003,
    "title": "Switch firmware upgrade",
    "status": "open",
    "team": "network"
  },
  {
    "id": 1004,
    "title": "Printer not responding",
    "status": "open",
    "team": "support"
  }
]
EOF
    chmod 0644 /home/user/tickets.json

    cat > /home/user/ticket_schema.json << 'EOF'
{
  "type": "array",
  "items": {
    "type": "object",
    "required": [ "id", "title", "status", "team" ],
    "properties": {
      "id":    { "type": "integer" },
      "title": { "type": "string"  },
      "status":{ "type": "string"  },
      "team":  { "type": "string"  }
    }
  }
}
EOF
    chmod 0644 /home/user/ticket_schema.json

%environment
    chmod 755 /home/user

    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8
    export PYTHONUNBUFFERED=1

%labels
    Author="Auto-generated definition for help-desk tickets task"
    Description="Container with baseline files and tools for validating and filtering help-desk tickets"