Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update apt index and install Python + pip
    apt-get update -y
    apt-get install -y python3 python3-pip

    # Install pytest (required by the grading harness)
    pip3 install --no-cache-dir pytest

    # ----------------------------------------------------------------------------
    # Prepare initial filesystem state expected by the tests
    # ----------------------------------------------------------------------------
    # 1. Create /home/user with write permissions so the unprivileged runtime user
    #    can create additional files/directories such as /home/user/compliance/.
    mkdir -p /home/user
    chmod 0777 /home/user

    # 2. Create the repository layout and configuration files.
    mkdir -p /home/user/repo/config

    # sshd_config
    cat > /home/user/repo/config/sshd_config <<'EOF'
# OpenSSH server configuration
Port 22
Protocol 2
PasswordAuthentication yes
# allow root login
PermitRootLogin yes
ChallengeResponseAuthentication no
EOF

    # sshd_config_alt
    cat > /home/user/repo/config/sshd_config_alt <<'EOF'
# Alternative config
Port 2222
Protocol 2
PermitRootLogin no
EOF

    # Ensure repository files are readable
    chmod -R a+r /home/user/repo

%labels
    chmod 755 /home/user

    Author DevSecOps-PolicyTask
    Description "Container for policy-as-code compliance automation task."

%help
    This container provides the initial repository layout required for the
    “policy-as-code” task.  Pytest is pre-installed so the grading harness can
    execute its test-suite.  The runtime user is expected to create
    /home/user/compliance/root_login_findings.log as described in the assignment.