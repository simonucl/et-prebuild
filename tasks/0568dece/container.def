Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package index and install required utilities
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        iputils-ping \
        python3-pip

    # Clean up APT cache to keep the image small
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the automated grader
    pip3 install --no-cache-dir pytest

    # Create a non-privileged user and its home directory expected by the tests
    if ! id -u user >/dev/null 2>&1; then
        useradd --create-home --home-dir /home/user --shell /bin/bash user
    fi
    chmod 0755 /home/user

%environment
    chmod 755 /home/user

    # Preserve default environment; do not override $HOME
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    echo "This container is prepared for the IT-support ticket #9901 exercise."
    echo "Run a shell inside the container to begin working:"
    echo "  apptainer exec <image.sif> /bin/bash"

%labels
    Author IT-Support-Exercise
    Description "Base image prepared for ticket #9901 assignment. Contains ping, pytest, and /home/user directory."