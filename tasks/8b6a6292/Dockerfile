FROM ubuntu:22.04

# Labels
LABEL Author="Generated by ChatGPT"
LABEL Description="Container for Kubernetes manifest backup task with pytest pre-installed"

# Environment variables
ENV PYTHONIOENCODING="utf-8"
ENV LANG="C.UTF-8"
ENV LC_ALL="C.UTF-8"

# Update apt repositories and install Python + pip
RUN apt-get update -y && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        tzdata && \
    pip3 install --no-cache-dir pytest && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Create the user home directory and the manifest directory structure
RUN mkdir -p /home/user/k8s-manifests

# deployment.yaml
RUN cat >/home/user/k8s-manifests/deployment.yaml <<'EOF'
apiVersion: apps/v1
kind: Deployment
metadata:
  name: nginx-deployment
spec:
  replicas: 3
  selector:
    matchLabels:
      app: nginx
  template:
    metadata:
      labels:
        app: nginx
    spec:
      containers:
      - name: nginx
        image: nginx:1.14.2
        ports:
        - containerPort: 80
EOF

# service.yaml
RUN cat >/home/user/k8s-manifests/service.yaml <<'EOF'
apiVersion: v1
kind: Service
metadata:
  name: nginx-service
spec:
  selector:
    app: nginx
  ports:
  - protocol: TCP
    port: 80
    targetPort: 80
  type: ClusterIP
EOF

# configmap.yaml
RUN cat >/home/user/k8s-manifests/configmap.yaml <<'EOF'
apiVersion: v1
kind: ConfigMap
metadata:
  name: nginx-config
data:
  nginx.conf: |
    events {}
    http {
      server {
        listen 80;
        location / {
          return 200 'Hello, Kubernetes!';
        }
      }
    }
EOF

# Ensure proper permissions so the non-root runtime user can read the files
RUN chmod -R 755 /home/user && \
    chmod 644 /home/user/k8s-manifests/*.yaml

# Ensure that the backup directory does NOT exist at build time
RUN rm -rf /home/user/k8s-backup || true

WORKDIR /home/user