Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update apt repositories and install Python + pip
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        tzdata

    # Install pytest for the runtime user
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state expected by the test harness
    # ------------------------------------------------------------------

    # Create the user home directory and the manifest directory structure
    mkdir -p /home/user/k8s-manifests

    # deployment.yaml
    cat >/home/user/k8s-manifests/deployment.yaml <<'EOF'
apiVersion: apps/v1
kind: Deployment
metadata:
  name: nginx-deployment
spec:
  replicas: 3
  selector:
    matchLabels:
      app: nginx
  template:
    metadata:
      labels:
        app: nginx
    spec:
      containers:
      - name: nginx
        image: nginx:1.14.2
        ports:
        - containerPort: 80
EOF

    # service.yaml
    cat >/home/user/k8s-manifests/service.yaml <<'EOF'
apiVersion: v1
kind: Service
metadata:
  name: nginx-service
spec:
  selector:
    app: nginx
  ports:
  - protocol: TCP
    port: 80
    targetPort: 80
  type: ClusterIP
EOF

    # configmap.yaml
    cat >/home/user/k8s-manifests/configmap.yaml <<'EOF'
apiVersion: v1
kind: ConfigMap
metadata:
  name: nginx-config
data:
  nginx.conf: |
    events {}
    http {
      server {
        listen 80;
        location / {
          return 200 'Hello, Kubernetes!';
        }
      }
    }
EOF

    # Ensure proper permissions so the non-root runtime user can read the files
    chmod -R 755 /home/user
    chmod 644 /home/user/k8s-manifests/*.yaml

    # Ensure that the backup directory does NOT exist at build time
    rm -rf /home/user/k8s-backup || true

    # Clean apt cache to keep image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Make sure python3 is the default python, useful for some runners
    export PYTHONIOENCODING="utf-8"
    export LANG="C.UTF-8"
    export LC_ALL="C.UTF-8"

%labels
    Author="Generated by ChatGPT"
    Description="Container for Kubernetes manifest backup task with pytest pre-installed"