Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update apt index and install Python & pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        bash

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare filesystem expected by the testing harness
    # ------------------------------------------------------------------

    # Create the user’s home directory structure
    mkdir -p /home/user
    chmod 755 /home/user

    # Provide a minimal .bashrc (must NOT yet contain the source line)
    if [ ! -f /home/user/.bashrc ]; then
        printf "# Minimal bashrc for test harness – do not modify\n" > /home/user/.bashrc
    fi
    chmod 644 /home/user/.bashrc

    # Create the top-level deployments directory; it must be empty
    mkdir -p /home/user/deployments
    chmod 755 /home/user/deployments

    # ------------------------------------------------------------------
    # Clean up apt cache to keep image small
    # ------------------------------------------------------------------
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    # Ensure python and pip are on PATH
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author release-manager task setup
    Description Base image prepared for DevOps environment-variable task
    Version 1.0