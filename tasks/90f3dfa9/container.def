Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists
    apt-get update -y

    # Install required packages: Python, pip and cron (for the `crontab` binary)
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        cron

    # Install pytest for the grading tests
    pip3 install --no-cache-dir pytest

    # Ensure the expected home directory exists and is writable by any user
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up apt caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%labels
    chmod 755 /home/user

    Author    Apptainer Build System
    Description "Base image for credential-rotation exercise; includes Python, pytest, and cron."

%environment
    # Ensure pip-installed binaries are in PATH
    export PATH="/usr/local/bin:${PATH}"