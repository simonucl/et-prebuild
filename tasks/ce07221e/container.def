Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install Python and tooling
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        python3 \
        python3-pip \
        ca-certificates

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state expected by the assignment
    # ------------------------------------------------------------------
    # Create the user home and configuration directory
    mkdir -p /home/user/configs

    # Populate the initial configuration file with the exact contents
    cat > /home/user/configs/app.cfg <<'EOF'
# Application Configuration
VERSION=1.4.2
ENABLED=false
LOG_LEVEL=info
EOF

    # Set reasonable permissions so the unprivileged agent can read/write
    chmod 755 /home/user
    chmod 755 /home/user/configs
    chmod 644 /home/user/configs/app.cfg

    # Clean up apt caches to keep image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    # Ensure Python and pip are in PATH
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author="Apptainer Task Preparer"
    Description="Image prepared for configuration-management toggle task with pytest pre-installed."

%help
    This Apptainer image provides the initial state required for the
    configuration-management audit exercise. It contains:
      • /home/user/configs/app.cfg with ENABLED=false
      • Python and pytest for automated grading