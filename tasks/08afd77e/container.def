Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python tooling and pytest
    apt-get update -y
    apt-get install -y python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Prepare initial dataset
    # ------------------------------------------------------------------
    # Directory structure
    mkdir -p /home/user/data/raw

    # Ensure correct permissions (directories: 755, file: 644)
    chmod 755 /home/user
    chmod 755 /home/user/data
    chmod 755 /home/user/data/raw

    # Create the Windows-1252–encoded CSV file exactly as specified
    python3 - << 'PY'
import os, pathlib

content = (
    "id,name,city\n"
    "1,José,Montréal\n"
    "2,Léa,Berlin\n"
    "3,O'Connor,Dublin\n"
)

path = pathlib.Path("/home/user/data/raw/customers_win1252.csv")
path.write_bytes(content.encode("cp1252"))
os.chmod(path, 0o644)
PY

%labels
    Author encoding-conversion setup

%help
    Container pre-configured for the “encoding-conversion” exercise.
    Includes pytest and the initial Windows-1252 CSV dataset under
    /home/user/data/raw.