Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install Python + pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        build-essential \
        locales
    pip3 install --no-cache-dir --upgrade pytest

    # Make sure `python` command is available (some CI expects it)
    ln -sf /usr/bin/python3 /usr/local/bin/python

    # Create the required directory structure and input file
    mkdir -p /home/user/releases

    cat >/home/user/releases/services_2023-10.txt <<'EOF'
auth
billing
auth
reports
auth
billing
search
search
analytics
EOF

    # Ensure correct permissions (file: 644, dir: 755)
    chmod 755 /home/user/releases
    chmod 644 /home/user/releases/services_2023-10.txt

    # Clean up apt caches to keep image slim
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    # Ensure pip-installed binaries are in PATH
    export PATH="/usr/local/bin:$PATH"

%labels
    Author="AI Container Builder"
    Description="Environment for release-manager frequency report exercise with pytest pre-installed."