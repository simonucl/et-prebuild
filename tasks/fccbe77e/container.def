Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    #!/bin/bash
    set -eux

    # ------------------------------------------------------------------
    # Install Python tooling required for the tests
    # ------------------------------------------------------------------
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Set up the initial filesystem state expected by the tests
    # ------------------------------------------------------------------
    mkdir -p /home/user/stack

    cat > /home/user/stack/compose-auth.yml <<'EOF'
services:
  auth-db:
    image: postgres:13
  auth-service:
    image: myregistry/auth-service:1.2.0
EOF

    cat > /home/user/stack/compose-data.yml <<'EOF'
services:
  redis:
    image: redis:6-alpine
  data-service:
    image: myregistry/data-service:3.4.5
  auth-db:
    image: postgres:13
EOF

    cat > /home/user/stack/compose-api.yml <<'EOF'
services:
  api-gateway:
    image: myregistry/api-gateway:2.0.0
  auth-service:
    image: myregistry/auth-service:1.2.0
EOF

    # Ensure the files are readable by the unprivileged runtime user
    chmod -R a+rX /home/user

%environment
    chmod 755 /home/user

    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"