Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update APT and install Python & pip
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the grading framework
    pip3 install --no-cache-dir pytest

    # -----------------------------------------------------------------
    # Prepare initial filesystem state for the “DNS allow-list audit”
    # exercise.
    # -----------------------------------------------------------------
    # Create the required directory hierarchy
    mkdir -p /home/user/policy

    # Ensure directory permissions are world-executable so non-root users
    # can traverse them and read files inside.
    chmod 0755 /home/user
    chmod 0755 /home/user/policy

    # Create the allow-list file with exact, line-delimited contents
    printf 'localhost\ninvalid.local\n' > /home/user/policy/dns_allowlist.txt

    # Set permissions to 0644 (rw-r--r--)
    chmod 0644 /home/user/policy/dns_allowlist.txt

%environment
    chmod 755 /home/user

    # No HOME override; Apptainer will bind the caller’s $HOME by default.
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%labels
    Author "Apptainer task setup"

%help
    Container for the “DNS allow-list audit” exercise.
    Includes pytest and pre-creates the initial policy directory with
    dns_allowlist.txt.