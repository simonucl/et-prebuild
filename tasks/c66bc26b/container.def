Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    #
    # Install Python 3 and pytest (via pip)
    #
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    #
    # Prepare initial filesystem state expected by the grading tests
    #
    # 1. Ensure /home and /home/user exist
    #
    mkdir -p /home/user

    # Make /home/user writable by any (non-root) UID that will run inside
    # the container, so the agent can create the required artefacts.
    chmod 0777 /home/user

    #
    # 2. Create the baseline log file with the exact five lines required.
    #
    cat >/home/user/config_changes.log <<'EOF'
2024-01-15 10:12:03 CONFIG: /etc/ssh/sshd_config status=UNCHANGED checksum=b1946ac92492d2347c6235b4d2611184
2024-01-15 10:12:04 CONFIG: /etc/ssh/sshd_config status=MODIFIED checksum=87acec17cd9dcd20a716cc2cf67417b71c8a7016
2024-01-15 10:12:05 CONFIG: /etc/nginx/nginx.conf status=MODIFIED checksum=3b5d5c3712955042212316173ccf37be
2024-01-15 10:12:06 CONFIG: /etc/passwd status=CREATED checksum=764efa883dda1e11db47671c4a3bbd9e
2024-01-15 10:12:07 CONFIG: /etc/nginx/nginx.conf status=UNCHANGED checksum=cb837b763cf375a3530d9cf68bbee585
EOF

    # Make the file readable (and immutable) for the agent; no write needed
    chmod 0644 /home/user/config_changes.log

%environment
    chmod 755 /home/user

    # Ensure Python and pip are on the PATH
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%labels
    Author "Apptainer task setup autogenerated"

%runscript
    exec "$@"