Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    apt-get install -y python3 python3-pip
    pip3 install --no-cache-dir pytest

    # Create project directory structure
    mkdir -p /home/user/project/config

    # Create initial configuration files with exact required content
    cat > /home/user/project/config/app.yaml <<'EOF'
name: SampleApp
version: 1.2.3
settings:
  debug: false
  max_connections: 50
EOF

    cat > /home/user/project/config/database.toml <<'EOF'
[database]
host = "localhost"
port = 5432
user = "appuser"
password = "secret"
timeout = 30
EOF

    # Set correct permissions
    chmod 644 /home/user/project/config/app.yaml /home/user/project/config/database.toml

%environment
    chmod 755 /home/user

    # Keep environment simple; just ensure Python in PATH
    export PYTHONUNBUFFERED=1