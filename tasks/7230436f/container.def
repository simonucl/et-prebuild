Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update -y
    apt-get install -y python3 python3-pip
    rm -rf /var/lib/apt/lists/*
    pip3 install --no-cache-dir pytest

    # Create the documentation directory structure
    mkdir -p /home/user/docs

    # Populate the required draft files (each ends with a single newline)
    printf 'Frequently-asked questions draft.\n' > /home/user/docs/faq_draft.txt
    printf 'Introduction section draft.\n'           > /home/user/docs/intro_draft.txt
    printf 'Usage instructions draft.\n'             > /home/user/docs/usage_draft.txt

    # Ensure the future runtime user has full access
    chmod -R 0777 /home/user/docs

%environment
    chmod 755 /home/user

    export LANG=C.UTF-8

%runscript
    echo "Apptainer container ready for the batch-rename task."
    exec "$@"