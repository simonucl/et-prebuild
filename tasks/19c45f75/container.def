Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package index and install Python and pip
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state for the FinOps task
    # ------------------------------------------------------------------

    # Ensure /home and /home/user exist
    mkdir -p /home/user
    chmod 755 /home /home/user

    # Create project directory with required permissions
    mkdir -p /home/user/finops-tool
    chmod 755 /home/user/finops-tool

    # ------------------ version.txt ------------------
    cat >/home/user/finops-tool/version.txt <<'EOF'
2.1.4
EOF
    chmod 644 /home/user/finops-tool/version.txt

    # ------------------ CHANGELOG.md -----------------
    cat >/home/user/finops-tool/CHANGELOG.md <<'EOF'
# Changelog

## [2.1.4] - 2023-07-15
### Fixed
- Fixed tagging bug in cost explorer sync (#32)

## [2.1.3] - 2023-06-10
### Added
- Added forecast cost anomaly detection (#28)
EOF
    chmod 644 /home/user/finops-tool/CHANGELOG.md

    # Do NOT create bump.log; the student/agent will create it.

%environment
    # No overrides required; keep default environment

%labels
    Author FinOps Task Setup
    Description "Container with initial state for FinOps version bump task. Pytest installed."