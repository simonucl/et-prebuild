Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    export DEBIAN_FRONTEND=noninteractive

    # Update package lists and install required utilities
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-setuptools \
        sqlite3 \
        ca-certificates

    # Upgrade pip and install pytest for later grading
    pip3 install --no-cache-dir --upgrade pip
    pip3 install --no-cache-dir pytest

    # Create a writable home directory for the non-privileged agent
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up APT caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure Python and local bin are on PATH
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author="Apptainer Build Script"
    Description="Base image for compliance-lab exercise; contains Python, pytest, sqlite3, and an empty /home/user directory."