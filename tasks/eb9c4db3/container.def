Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Maintainer pip-health exercise container

%post
    set -e

    # Refresh package index and install minimal Python toolchain.
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python-is-python3

    # Install pytest for the test harness.
    pip3 install --no-cache-dir pytest

    # Ensure the Python environment is dependency-clean (build fails if not).
    python -m pip check

    # Prepare the base workspace directory required by the tests.
    mkdir -p /home/user
    chmod 0777 /home/user

    # House-keeping to keep the image small.
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%runscript
    chmod 755 /home/user

    exec "$@"