Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Update package lists and install Python tooling required for both
    # creating virtual environments and running pytest.
    apt-get update && \
    apt-get install -y --no-install-recommends \
        python3 \
        python3-venv \
        python3-pip && \
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the grading harness.
    pip3 install --no-cache-dir pytest

    # Prepare the writable workspace for the student.
    mkdir -p /home/user
    # Make sure the student (who will not have elevated privileges) can write here.
    chmod 777 /home/user

%environment
    chmod 755 /home/user

    # Ensure user-installed Python packages are discoverable.
    export PATH="/home/user/.local/bin:${PATH}"

%runscript
    echo "Container built for the virtual-environment assignment."