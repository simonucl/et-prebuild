Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # Create initial directory structure and data file
    mkdir -p /home/user
    chmod 0777 /home/user     # Allow the unprivileged agent to create files here

    cat > /home/user/user_accounts.txt <<'EOF'
john ENABLED
mary DISABLED
peter ENABLED
susan DISABLED
david DISABLED
EOF
    chmod 0644 /home/user/user_accounts.txt

    # Clean up APT cache to reduce image size
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH
    export LC_ALL=C.UTF-8
    export PYTHONUNBUFFERED=1

%runscript
    exec "$@"