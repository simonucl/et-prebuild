Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Maintainer ChatGPT
    Description "Initial state for artifact-deployment task. Provides /home/user/source/app.jar and pytest."

%post
    set -e

    # Install Python tooling and pytest
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Prepare the initial filesystem state expected by the exercise
    # ------------------------------------------------------------------
    # 1. Create /home/user and make it writable by any unprivileged user
    mkdir -p /home/user
    chmod 0777 /home/user

    # 2. Create the source directory and the dummy JAR file
    mkdir -p /home/user/source
    echo -n "dummy-artifact" > /home/user/source/app.jar
    chmod 644 /home/user/source/app.jar

    # Do NOT create /home/user/build – it must be absent at start.

%runscript
    chmod 755 /home/user

    # Default runscript – just execute the given command
    exec "$@"