Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package index and install Python tooling
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3-pip \
        ca-certificates \
        curl
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the grading framework
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare the initial filesystem state expected by the tests
    # ------------------------------------------------------------------

    # Create /home/user structure with correct permissions
    mkdir -p /home/user/mock_api
    chmod 755 /home/user
    chmod 755 /home/user/mock_api

    # Place the reference JSON file with the exact required content
    cat > /home/user/mock_api/ok.json <<'EOF'
{"status":"ok"}
EOF
    # Ensure the file ends with a single newline and has the right perms
    chmod 644 /home/user/mock_api/ok.json

%environment
    # Make sure python and pip are available in PATH
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author "Apptainer Task Setup"
    Description "Environment prepared for API-level connectivity task with pytest pre-installed."

%runscript
    echo "Container ready. Drop into a shell or execute your task commands."
    exec /bin/bash "$@"