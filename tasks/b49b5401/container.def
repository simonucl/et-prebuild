Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # Update APT index and install Python + pip
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates

    # Upgrade pip and install required Python packages
    python3 -m pip install --no-cache-dir --upgrade pip
    python3 -m pip install --no-cache-dir numpy==1.24.2 pytest

    # Prepare the canonical home directory expected by the tests
    mkdir -p /home/user
    chmod 0777 /home/user   # Make it writable for any unprivileged host user

    # Clean up APT caches to reduce image size
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Basic UTF-8 locale and convenience PATH
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
    export PATH=/usr/local/bin:$PATH
    alias python=python3

%labels
    Author "Task Preparer"
    Description "Environment for NumPy version pinning task (NumPy 1.24.2 pre-installed with pytest)"