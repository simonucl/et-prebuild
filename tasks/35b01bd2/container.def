Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ------------------------------------------------------------------
    # Install Python tooling and pytest
    # ------------------------------------------------------------------
    apt-get update -qq
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state required by the task
    # ------------------------------------------------------------------
    mkdir -p /home/user/builds
    chmod 0777 /home/user
    chmod 0777 /home/user/builds

    cat > /home/user/builds/2024-05-01_daily_build_status.csv <<'EOF'
BuildID,Platform,Duration,Result,Artifact
B001,Android,15m,PASS,app-android-B001.apk
B002,iOS,17m,FAIL,app-ios-B002.ipa
B003,Android,18m,FAIL,app-android-B003.apk
B004,iOS,15m,PASS,app-ios-B004.ipa
EOF
    chmod 0666 /home/user/builds/2024-05-01_daily_build_status.csv

    # Clean up APT caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure the usual paths are available
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%labels
    Author="Apptainer Task Preparation"
    Description="Container with initial state for the failed-artifact extraction task."