Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    #!/bin/bash
    set -e

    # Update apt index and install Python plus pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state required by the assignment
    # ------------------------------------------------------------------
    mkdir -p /home/user/cloud_costs/raw

    # Create the exact CSV file with the expected content (including the
    # required trailing newline)
    cat > /home/user/cloud_costs/raw/march_2024_spend.csv <<'EOF'
Date,Account,Service,CostUSD
2024-03-01,Dev,Compute,15.50
2024-03-02,Prod,Compute,25.00
2024-03-03,Dev,Storage,5.25
2024-03-04,Prod,Storage,12.75
2024-03-05,Dev,Database,20.00
2024-03-06,Prod,Database,30.00
2024-03-07,Dev,Networking,7.00
2024-03-08,Prod,Networking,14.00
EOF

    # Pre-create the results directory (agent may re-create but it must be writable)
    mkdir -p /home/user/cloud_costs/results

    # Make sure the student (non-root in runtime) can write into results dir
    chmod -R a+rwX /home/user/cloud_costs

%environment
    chmod 755 /home/user

    # Nothing special needed; keep default environment
    export LC_ALL=C.UTF-8
    export PYTHONUNBUFFERED=1