FROM ubuntu:22.04

# Update package lists and install Python with pip
RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Install pytest
RUN pip3 install --no-cache-dir pytest

# Prepare initial project state
RUN mkdir -p /home/user/myutil

RUN printf '1.2.3\n' > /home/user/myutil/VERSION

RUN cat <<'EOF' > /home/user/myutil/CHANGELOG.md
## [1.2.3] – 2023-04-01
### Added
- Initial public release.
EOF

RUN chmod -R a+rwX /home/user

# Environment variables
RUN chmod 755 /home/user
ENV LC_ALL=C.UTF-8
ENV PYTHONUNBUFFERED=1

# Labels
LABEL Author="Generated by ChatGPT – Apptainer setup for version-bump task"