Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Update package lists and install Python with pip
    apt-get update && \
        DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip && \
        apt-get clean && \
        rm -rf /var/lib/apt/lists/*

    # Install pytest (needed by the autograder)
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare the initial project state expected by the test suite
    # ------------------------------------------------------------------
    mkdir -p /home/user/myutil
    cd /home/user/myutil

    # VERSION file with initial version
    printf '1.2.3\n' > VERSION

    # CHANGELOG.md with initial heading and entry
    cat > CHANGELOG.md <<'EOF'
## [1.2.3] – 2023-04-01
### Added
- Initial public release.
EOF

    # Make sure the student (non-root runtime user) can freely modify files
    chmod -R a+rwX /home/user

%environment
    chmod 755 /home/user

    export LC_ALL=C.UTF-8
    export PYTHONUNBUFFERED=1

%labels
    Author "Generated by ChatGPT – Apptainer setup for version-bump task"