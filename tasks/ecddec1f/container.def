Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install Python and pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # Create an unprivileged user `user`
    useradd -m -s /bin/bash user

    # Prepare the required directory structure and configuration file
    mkdir -p /home/user/db_backup

    cat <<'EOF' > /home/user/db_backup/db_backup.ini
[database]
host = localhost
port = 5432
name = prod_db
user = backup_user

[backup]
backup_dir = /home/user/db_backup/archives
compression = true
method = pg_dump

[retention]
retention_days = 30
EOF

    # Ensure correct ownership so the non-root user can work with the files
    chown -R user:user /home/user/db_backup

%environment
    chmod 755 /home/user

    # Make sure Python and pip are in PATH for all users
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author OpenAI ChatGPT
    Description "Container for PostgreSQL backup auditing task – initial state only."

%runscript
    echo "This container is set up for the PostgreSQL backup auditing task."
    echo "Switch to the 'user' account to begin:  su - user"