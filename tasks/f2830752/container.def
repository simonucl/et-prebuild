Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python 3 and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state expected by the automated tests
    # ------------------------------------------------------------------
    mkdir -p /home/user/configs
    chmod 0777 /home/user
    chmod 0777 /home/user/configs

    # 1. Initial, **insecure** ssh_app.yml (exact content + single newline)
    cat > /home/user/configs/ssh_app.yml <<'EOF'
port: 22
permit_root_login: yes
password_authentication: yes
max_auth_tries: 6
EOF

    # 2. Initial etcd_service.toml (exact content + single newline)
    cat > /home/user/configs/etcd_service.toml <<'EOF'
[Service]
enable_debug = true
quota_backend_bytes = 0

[Security]
token = "simple"
client_cert_auth = false
EOF

    # Make the files writable by the non-root user that will execute tests
    chmod 0666 /home/user/configs/ssh_app.yml /home/user/configs/etcd_service.toml

%environment
    chmod 755 /home/user

    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8

%runscript
    exec "$@"