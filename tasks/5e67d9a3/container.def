Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    #--------------------------------------------------
    # Base tools + Python test framework
    #--------------------------------------------------
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        python3 \
        python3-pip \
        --no-install-recommends
    pip3 install --no-cache-dir pytest

    #--------------------------------------------------
    # Prepare initial project tree and localisation files
    #--------------------------------------------------
    mkdir -p /home/user/project/locale

    # Master English INI
    cat <<"EOF_EN" > /home/user/project/locale/en_US.ini
[CORE]
greeting = Hello
farewell = Goodbye
prompt   = What would you like to do?
thanks   = Thank you
error_message = An unexpected error has occurred.
EOF_EN

    # French translation INI (missing two new keys)
    cat <<"EOF_FR" > /home/user/project/locale/fr_FR.ini
[CORE]
greeting = Bonjour
farewell = Au revoir
prompt   = Que voulez-vous faire ?
EOF_FR
    # Ensure there is exactly one trailing newline
    echo >> /home/user/project/locale/fr_FR.ini

    # Make everything under /home/user writable by the
    # unprivileged agent who will run inside the container.
    chmod -R a+rwX /home/user

%environment
    chmod 755 /home/user

    # Ensure Python and local binaries are available
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%runscript
    echo "Container for localisation sync task."
    echo "Run your commands inside an interactive shell or via 'apptainer exec'."