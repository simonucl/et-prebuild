Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update && \
        apt-get install -y --no-install-recommends python3 python3-pip && \
        pip3 install --no-cache-dir pytest && \
        apt-get clean && rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Prepare initial state for the “incident triage” exercise
    # ------------------------------------------------------------------
    mkdir -p /home/user/incident_triage/input

    # solver_a.log
    cat > /home/user/incident_triage/input/solver_a.log <<'EOF'
[INFO] Solver: OptiMax v2.0
[START] 2023-02-04T12:00:00Z
status=OPTIMAL
iterations=145
objective=1234.5678
solve_time_sec=2.345
[END] 2023-02-04T12:00:02Z
EOF

    # solver_b.log
    cat > /home/user/incident_triage/input/solver_b.log <<'EOF'
[INFO] Solver: OptiMax v2.0
[START] 2023-02-04T12:05:00Z
status=INFEASIBLE
iterations=87
objective=nan
solve_time_sec=1.230
[END] 2023-02-04T12:05:02Z
EOF

    # solver_c.log
    cat > /home/user/incident_triage/input/solver_c.log <<'EOF'
[INFO] Solver: OptiPlus v1.4
[START] 2023-02-04T12:10:00Z
status=TIME_LIMIT
iterations=1000
objective=99999.999
solve_time_sec=60.000
[END] 2023-02-04T12:11:00Z
EOF

    # Ensure writable permissions for the running (non-root) user.
    chmod -R 777 /home/user

%environment
    chmod 755 /home/user

    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author incident-triage-container