Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author      Apptainer Task Prep Bot
    Description Base image for the “monitoring-alerts” exercise with pytest pre-installed.

%post
    set -e

    # Install Python and required tooling
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-venv \
        python3-pip \
        ca-certificates

    # Upgrade pip and install pytest for the grader
    python3 -m pip install --no-cache-dir --upgrade pip
    python3 -m pip install --no-cache-dir pytest

    # Create a writable home directory for the non-root user at runtime
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"