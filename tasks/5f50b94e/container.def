Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest jsonschema

    # -------------------------------------------------------------------------
    # Create initial directory structure and sample data
    # -------------------------------------------------------------------------
    mkdir -p /home/user/logs
    mkdir -p /home/user/schemas

    # alerts.json (newline-delimited JSON)
    cat > /home/user/logs/alerts.json <<'EOF'
{"id":"a1","timestamp":"2024-05-01T10:00:00Z","host":"web01","severity":"low","signature":"SQLi attempt","src_ip":"10.0.0.5"}
{"id":"a2","timestamp":"2024-05-01T10:05:00Z","host":"web02","severity":"high","signature":"XSS attempt","src_ip":"10.0.0.6"}
{"id":"a3","timestamp":"2024-05-01T10:10:00Z","host":"db01","severity":"medium","signature":"Login failure","src_ip":"10.0.0.7"}
{"id":"a4","timestamp":"2024-05-01T10:15:00Z","host":"web02","severity":"high","signature":"SQLi attempt","src_ip":"10.0.0.8"}
{"id":"a5","timestamp":"2024-05-01T10:20:00Z","host":"web03","severity":"low","signature":"Port scan","src_ip":"10.0.0.9"}
EOF

    # alert_schema.json (JSON-Schema Draft-07)
    cat > /home/user/schemas/alert_schema.json <<'EOF'
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["id", "timestamp", "host", "severity", "signature", "src_ip"],
  "properties": {
    "id":        { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "host":      { "type": "string" },
    "severity":  { "type": "string", "enum": ["low", "medium", "high"] },
    "signature": { "type": "string" },
    "src_ip":    { "type": "string", "format": "ipv4" }
  },
  "additionalProperties": false
}
EOF

    # -------------------------------------------------------------------------
    # Permissions: allow any user to create /home/user/incident2024 later
    # -------------------------------------------------------------------------
    chmod 0777 /home/user
    chmod 0755 /home/user/logs /home/user/schemas
    chmod 0644 /home/user/logs/alerts.json /home/user/schemas/alert_schema.json

    # Clean up
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    export LC_ALL=C
    export LANG=C

%labels
    Author="Incident Responder Setup"
    Description="Initial state container for the IDS alert validation assignment."

%help
This container provides the starting environment for the “incident responder”
exercise.  It includes:
  • The sample ND-JSON alerts file and its corresponding JSON Schema.
  • Python 3 with pytest (and jsonschema) for automated grading.
No output artefacts for the assignment are present; those must be generated by
the student’s solution during execution.