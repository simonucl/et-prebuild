Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive

    # -------------------------------------------------------------------------
    # 1. Essential packages
    # -------------------------------------------------------------------------
    apt-get update
    apt-get install -y --no-install-recommends \
        python3           \
        python3-pip       \
        jq                \
        ca-certificates
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Python tooling (pytest for the test-harness, jsonschema for convenience)
    pip3 install --no-cache-dir pytest jsonschema

    # -------------------------------------------------------------------------
    # 2. Prepare initial exercise data
    # -------------------------------------------------------------------------
    mkdir -p /home/user/diagnostics/raw
    mkdir -p /home/user/diagnostics/schema

    # --- Raw log files -------------------------------------------------------
    cat > /home/user/diagnostics/raw/log1.json <<'EOF'
{
  "service": "auth",
  "status": "running",
  "errors": []
}
EOF

    cat > /home/user/diagnostics/raw/log2.json <<'EOF'
{
  "service": "payments",
  "status": "degraded",
  "errors": ["timeout connecting to db", "retry failure"]
}
EOF

    cat > /home/user/diagnostics/raw/log3.json <<'EOF'
{
  "status": "running",
  "errors": []
}
EOF

    # --- JSON Schema ---------------------------------------------------------
    cat > /home/user/diagnostics/schema/diagnostic.schema.json <<'EOF'
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["service", "status", "errors"],
  "properties": {
    "service": { "type": "string" },
    "status":  { "type": "string" },
    "errors":  {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
EOF

    # -------------------------------------------------------------------------
    # 3. Permissions
    # -------------------------------------------------------------------------
    # Make the diagnostics tree writable for the unprivileged runtime user so
    # they can add the required output files later on.
    chmod -R a+rwX /home/user/diagnostics
    # Raw input and schema files themselves should be read-only (644).
    find /home/user/diagnostics -type f -exec chmod 644 {} \;

%environment
    chmod 755 /home/user

    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%runscript
    echo "Container for the diagnostics validation exercise."
    echo "This container only provides the initial dataset and tooling."