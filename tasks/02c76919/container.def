Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Install Python and pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the verification suite
    pip3 install --no-cache-dir pytest

    # Guarantee that /home/user exists and is writable, but DO NOT create
    # any of the task-related artefacts (deployment dir or files).
    mkdir -p /home/user
    chmod 0777 /home/user

%environment
    chmod 755 /home/user

    # Make sure user-level Python tools (if any) are discoverable.
    export PATH="/home/user/.local/bin:${PATH}"