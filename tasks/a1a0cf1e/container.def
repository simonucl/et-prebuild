Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    export DEBIAN_FRONTEND=noninteractive

    # ------------------------------------------------------------------
    # Install system packages
    # ------------------------------------------------------------------
    apt-get update
    apt-get install -y --no-install-recommends \
        jq \
        python3 \
        python3-pip \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Install Python packages
    # ------------------------------------------------------------------
    pip3 install --no-cache-dir \
        pytest \
        jsonschema \
        check-jsonschema

    # ------------------------------------------------------------------
    # Prepare required filesystem layout and seed data
    # ------------------------------------------------------------------
    mkdir -p /home/user/data
    mkdir -p /home/user/output

    # Allow the (non-root) runtime user to write into /home/user/output
    chmod 0777 /home/user/output

    # ------------------------ uptime_checks.json -----------------------
    cat > /home/user/data/uptime_checks.json <<'EOF'
[{"service_name":"auth","status":"OK","response_time_ms":120},{"service_name":"billing","status":"FAIL","response_time_ms":310},{"service_name":"search","status":"OK","response_time_ms":95},{"service_name":"cart","status":"OK","response_time_ms":210},{"service_name":"email","status":"FAIL","response_time_ms":275}]
EOF

    # ------------------------ uptime_schema.json -----------------------
    cat > /home/user/data/uptime_schema.json <<'EOF'
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["service_name", "status", "response_time_ms"],
    "properties": {
      "service_name": { "type": "string" },
      "status": { "type": "string", "enum": ["OK", "FAIL"] },
      "response_time_ms": { "type": "number", "minimum": 0 }
    },
    "additionalProperties": false
  }
}
EOF

    chmod 0644 /home/user/data/uptime_checks.json /home/user/data/uptime_schema.json

%environment
    chmod 755 /home/user

    # Nothing special needed; rely on container defaults
    export PATH=/usr/local/bin:/usr/local/sbin:/usr/bin:/usr/sbin:/bin:/sbin

%runscript
    echo "Container for uptime-check validation task."
    echo "Use jq and a JSON-Schema validator as described in the assignment."