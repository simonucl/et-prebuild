Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    #!/bin/bash
    set -e

    ## Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    ## Set up initial filesystem state
    mkdir -p /home/user/infra

    # Create the three *.cfg files with the 2022 passwords
    printf 'username=db_user\npassword=db_pass_2022\n'   > /home/user/infra/db.cfg
    printf 'username=redis_user\npassword=redis_pass_2022\n' > /home/user/infra/redis.cfg
    printf 'username=api_user\npassword=api_pass_2022\n' > /home/user/infra/api.cfg

    ## Ensure the unprivileged runtime user can modify everything under /home/user
    chmod -R 0777 /home/user

%environment
    chmod 755 /home/user

    export PYTHONIOENCODING=UTF-8
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8