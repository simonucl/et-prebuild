Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author apptainer-task-prep
    Description "Initial state for SSH key-pair + CSV aggregation task"

%post
    set -e

    echo "Updating apt repositories and installing required packages..."
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        openssh-client \
        python3 \
        python3-pip

    echo "Installing pytest via pip..."
    pip3 install --no-cache-dir pytest

    echo "Creating user 'user' with home directory /home/user ..."
    useradd -m -s /bin/bash user

    echo "Setting up directory structure..."
    install -d -m 0700  /home/user/.ssh
    install -d -m 0755  /home/user/datasets
    install -d -m 0755  /home/user/outputs
    install -d -m 0700  /home/user/server_access

    echo "Populating CSV input files..."
    cat > /home/user/datasets/sales_q1.csv <<'EOF'
Category,Revenue
A,100
B,150
C,200
EOF

    cat > /home/user/datasets/sales_q2.csv <<'EOF'
Category,Revenue
A,120
B,130
D,90
EOF

    chmod 0644 /home/user/datasets/sales_q1.csv /home/user/datasets/sales_q2.csv

    echo "Creating initial authorized_keys_data with dummy key..."
    cat > /home/user/server_access/authorized_keys_data <<'EOF'
ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIJdummYPvOjJk9pc6V5u5W0bkxz0eG4DLXo8boxexisting existing_key
EOF
    chmod 0600 /home/user/server_access/authorized_keys_data

    echo "Ensuring correct ownership..."
    chown -R user:user /home/user

%environment
    chmod 755 /home/user

    # Ensure python and pip are in PATH
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%runscript
    echo "Container for data-pipeline task. Drop into a shell with:"
    echo "   apptainer exec <image.sif> bash"