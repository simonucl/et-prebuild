Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    #-----------------------------------------------------------------------#
    # System packages and Python tooling
    #-----------------------------------------------------------------------#
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    #-----------------------------------------------------------------------#
    # Directory structure for the exercise
    #-----------------------------------------------------------------------#
    mkdir -p /home/user/data
    mkdir -p /home/user/output

    #-----------------------------------------------------------------------#
    # Create the required CSV source files with exact content (LF endings)
    #-----------------------------------------------------------------------#
    cat > /home/user/data/sales_q1.csv <<'EOF'
Region,Product,Sales
East,Gadget,1200
West,Widget,800
East,Widget,950
North,Gadget,620
East,Doohickey,300
EOF

    cat > /home/user/data/sales_q2.csv <<'EOF'
Region,Product,Sales
South,Gadget,730
East,Gadget,660
West,Doohickey,410
East,Widget,540
East,Doohickey,200
EOF

    #-----------------------------------------------------------------------#
    # Permissions: make sure the non-root user inside the container can write
    #-----------------------------------------------------------------------#
    chmod 0777 /home/user /home/user/data /home/user/output
    chmod 0666 /home/user/data/sales_q1.csv /home/user/data/sales_q2.csv

%environment
    chmod 755 /home/user

    export PYTHONUNBUFFERED=1

%runscript
    echo "Container for the 'East-region product sales summary' exercise."
    exec "$@"