Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python3, pip, and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        coreutils
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create non-root user “user” (UID 1000) with home directory
    # ------------------------------------------------------------------
    groupadd -g 1000 user
    useradd  -m -u 1000 -g 1000 -s /bin/bash user

    # ------------------------------------------------------------------
    # Prepare initial project tree and source data file
    # ------------------------------------------------------------------
    PROJECT_DIR="/home/user/projects/flowdata"
    mkdir -p "${PROJECT_DIR}"

    cat > "${PROJECT_DIR}/flows.log" <<'EOF'
2023-05-01T10:00:01Z	192.168.1.10	TCP	10.0.0.5	443	1024
2023-05-01T10:00:02Z	192.168.1.11	UDP	10.0.0.6	53	512
2023-05-01T10:00:03Z	192.168.1.12	TCP	10.0.0.7	22	2048
2023-05-01T10:00:04Z	192.168.1.13	UDP	10.0.0.8	161	256
EOF

    # Permissions: directory 0755, file 0644, owned by “user”
    chown -R 1000:1000 /home/user/projects
    chmod 0755 "${PROJECT_DIR}"
    chmod 0644 "${PROJECT_DIR}/flows.log"

%environment
    chmod 755 /home/user

    # Minimal PATH augmentation; do NOT override $HOME
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%runscript
    # Default entry opens a shell; can be overridden at runtime
    exec /bin/bash "$@"