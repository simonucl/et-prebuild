Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    #------------------------------------------------------------------
    # Basic tooling: Python + PyTest
    #------------------------------------------------------------------
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    pip3 install --no-cache-dir pytest

    #------------------------------------------------------------------
    # Create required initial filesystem state for the task
    #------------------------------------------------------------------
    # 1. Home and config directories
    mkdir -p /home/user/configs
    chmod 0777 /home/user
    chmod 0777 /home/user/configs

    # 2. INI file: /home/user/configs/app1.ini
    cat >/home/user/configs/app1.ini <<'EOF'
[General]
Version=2.0
ComplianceLevel=PCI-DSS
Encryption=AES256

[Network]
Port=443
Protocol=HTTPS
EOF

    # 3. INI file: /home/user/configs/app2.ini
    cat >/home/user/configs/app2.ini <<'EOF'
[General]
Version=1.4
ComplianceLevel=HIPAA
Encryption=AES128

[Network]
Port=8443
Protocol=HTTPS
EOF

    # Make sure the files are readable and writable by any user who runs
    chmod 0666 /home/user/configs/app1.ini /home/user/configs/app2.ini

%environment
    chmod 755 /home/user

    # Nothing to override; default environment is sufficient.

%labels
    Author="Automatic container setup for INI audit task"