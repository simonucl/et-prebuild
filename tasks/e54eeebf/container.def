Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Basic tooling
    apt-get update -y && \
    apt-get install -y --no-install-recommends python3 python3-pip && \
    pip3 install --no-cache-dir pytest && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Prepare the initial state expected by the exercise’s test-suite.
    # ------------------------------------------------------------------
    # 1. Create the directory hierarchy for the in-house API versions.
    mkdir -p /home/user/apis/v1.2.3

    # 2. Make sure the student (a non-root UID at runtime) can modify
    #    everything inside /home/user without privilege escalation.
    chmod -R 0777 /home/user

%environment
    chmod 755 /home/user

    # Keep Python user base installs (should the agent need them) out of
    # system-wide directories.
    export PYTHONUSERBASE=/home/user/.local
    export PATH="$PYTHONUSERBASE/bin:$PATH"

%labels
    Author      ExampleCourse
    Description "Environment for the 'Symbolic-link housekeeping for an API integration sandbox' exercise."

%help
    This container supplies the initial filesystem state and tools (Python,
    pytest) required for the symbolic-link housekeeping exercise.