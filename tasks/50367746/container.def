Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
set -e
export DEBIAN_FRONTEND=noninteractive

#--------------------------------------------------------------------#
# 1. Install required software                                       #
#--------------------------------------------------------------------#
apt-get update
apt-get install -y --no-install-recommends \
        git \
        python3 \
        python3-pip
pip3 install --no-cache-dir pytest

#--------------------------------------------------------------------#
# 2. Prepare the initial workspace                                   #
#--------------------------------------------------------------------#
# Create the home directory expected by the assignment
mkdir -p /home/user
chmod 777 /home/user    # ensure the runtime (non-root) user can write here

#--------------------------------------------------------------------#
# 3. Seed the Git repository in its pristine state                   #
#--------------------------------------------------------------------#
cd /home/user
mkdir -p storage-utils
chmod 777 storage-utils
cd storage-utils

# -------- cleanup.sh (executable) ----------------------------------#
cat > cleanup.sh <<'EOF'
#!/usr/bin/env bash
# Simple placeholder for cleaning /tmp
freed=123
echo "Freed ${freed} MiB"
EOF
chmod 777 cleanup.sh   # read/write/execute for all so the unprivileged user can modify it

# -------- VERSION --------------------------------------------------#
printf "1.2.0\n" > VERSION
chmod 666 VERSION

# -------- CHANGELOG.md --------------------------------------------#
cat > CHANGELOG.md <<'EOF'
## [1.2.0] - 2023-05-01
### Changed
- Improved file deletion speed.
## [1.1.0] - 2023-04-15
### Added
- Initial cleanup implementation.
EOF
chmod 666 CHANGELOG.md

#--------------------------------------------------------------------#
# 4. Initialise Git repository                                       #
#--------------------------------------------------------------------#
git init -b main .
git config user.email "builder@example.com"
git config user.name  "Builder"
git add cleanup.sh VERSION CHANGELOG.md
git commit -m "chore: initial import 1.2.0"

# Guarantee write permissions for future, including .git directory
chmod -R a+rwX /home/user/storage-utils

%labels
    chmod 755 /home/user

Author storage-task-preparer

%help
This container image provides the starting point for the “storage-utils”
exercise.  It installs git, python3, and pytest, and seeds a repository at
/home/user/storage-utils in the exact initial state expected by the automated
grader.