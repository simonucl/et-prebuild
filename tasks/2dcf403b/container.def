Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package list and install Python + pip
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the forthcoming test runner
    pip3 install --no-cache-dir pytest

    # Prepare the base home directory expected by the exercises
    mkdir -p /home/user
    # Ensure the forthcoming non-root learner can write inside /home/user
    chmod 0777 /home/user

%runscript
    chmod 755 /home/user

    exec "$@"