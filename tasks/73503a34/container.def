Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install required software
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        jq

    # Install pytest for the grading harness
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create non-root user `user` with home directory /home/user
    # ------------------------------------------------------------------
    useradd -m -s /bin/bash user

    # ------------------------------------------------------------------
    # Prepare directory structure and initial data files
    # ------------------------------------------------------------------
    mkdir -p /home/user/data
    mkdir -p /home/user/output

    # training_samples.json ------------------------------------------------
    cat > /home/user/data/training_samples.json <<'JSON'
[
  {"id":"001","features":[0.1,0.5,0.2],"label":"positive"},
  {"id":"002","features":[0.3,0.6],"label":"negative"},
  {"id":"003","features":[0.4,0.2,0.1],"label":"neutral"},
  {"id":"004","features":[0.8,0.9,0.7],"label":"negative"},
  {"id":"005","id_extra":"something","features":[0.2,0.4,0.5],"label":"positive"}
]
JSON

    # feature_schema.json --------------------------------------------------
    cat > /home/user/data/feature_schema.json <<'JSON'
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["id", "features", "label"],
  "properties": {
    "id":  { "type": "string" },
    "features": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 3,
      "maxItems": 3
    },
    "label": {
      "type": "string",
      "enum": ["positive", "negative"]
    }
  },
  "additionalProperties": true
}
JSON

    # Ensure correct ownership for the non-root user
    chown -R user:user /home/user

    # Clean up apt caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    export HOME=/home/user
    export PATH=$PATH:/home/user/.local/bin

%labels
    Author="Container Builder"
    Description="Apptainer image for jq filtering task with pytest pre-installed."

%runscript
    exec /bin/bash "$@"