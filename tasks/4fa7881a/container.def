Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    #!/bin/bash
    set -e

    # Basic development tools
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        jq \
        csvtool

    # Clean up apt cache to keep image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Python packages
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial workspace state expected by the task/test suite
    # ------------------------------------------------------------------
    # Create home directory for the non-root user that will run tests
    mkdir -p /home/user
    chmod 0777 /home/user   # ensure write access for any UID

    # Create experiments directory and seed metrics.csv
    mkdir -p /home/user/experiments
    chmod 0777 /home/user/experiments

    cat > /home/user/experiments/metrics.csv <<'EOF'
run_id,accuracy,loss
run_001,0.87,0.34
run_002,0.91,0.29
run_003,0.89,0.31
EOF

    chmod 0666 /home/user/experiments/metrics.csv

%environment
    chmod 755 /home/user

    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

%runscript
    exec /bin/bash "$@"