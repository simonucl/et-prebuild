Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        python3 \
        python3-pip \
        --no-install-recommends

    # Install pytest for the grading framework
    pip3 install --no-cache-dir pytest

    # Ensure the base directory expected by the assignment exists
    mkdir -p /home/user
    # Make it writable for whichever UID/GID runs inside the container
    chmod 0777 /home/user

    # Clean up apt caches to keep the image lean
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure the standard paths are available
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%runscript
    # Default action when the container is executed without arguments
    exec "$@"

%labels
    Author="Generated by ChatGPT"
    Description="Environment for the flat-file user database exercise with pytest pre-installed."