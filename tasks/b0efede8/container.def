Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install Python tooling
    apt-get update && \
        apt-get install -y --no-install-recommends python3 python3-pip && \
        pip3 install --no-cache-dir pytest && \
        apt-get clean && \
        rm -rf /var/lib/apt/lists/*

    # Prepare the exercise workspace
    mkdir -p /home/user
    # Grant write access to whichever unprivileged UID runs inside the container
    chmod 0777 /home/user

%environment
    chmod 755 /home/user

    # Ensure user-level Python tools are discoverable
    export PATH="${PATH}:/home/user/.local/bin"

%labels
    Author="Generated by ChatGPT"
    Description="Container for micro-services migration readiness exercise. Pytest pre-installed; /home/user prepared."