Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install Python & pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install pytest for the testing framework
    pip3 install --no-cache-dir pytest

    # Prepare a writable home area needed by the task checker/agent
    mkdir -p /home/user/bin
    chmod 0777 /home/user
    chmod 0777 /home/user/bin

%environment
    chmod 755 /home/user

    # Make the user's bin directory available in PATH
    export PATH=/home/user/bin:$PATH