Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    #------------------------------------------------------------------
    # Install Python and pytest (needed by the automated grading suite)
    #------------------------------------------------------------------
    apt-get update -qq
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    #------------------------------------------------------------------
    # Create the expected user environment and original evidence files
    #------------------------------------------------------------------
    # Ensure the “user” account exists (UID 1000 is common for non-root)
    if ! id -u 1000 >/dev/null 2>&1; then
        useradd -m -u 1000 -s /bin/bash user
    fi

    # Directory structure for the initial evidence
    mkdir -p /home/user/logs

    # http-access-incident.log  (each line ends with a newline)
    cat > /home/user/logs/http-access-incident.log <<'EOF'
192.168.1.50 - - [14/Jun/2024:02:15:23 +0000] "GET /admin/login.php HTTP/1.1" 404 560 "-" "Mozilla/5.0"
203.0.113.77 - - [14/Jun/2024:02:16:01 +0000] "POST /wp-login.php HTTP/1.1" 200 482 "-" "Mozilla/5.0"
198.51.100.23 - - [14/Jun/2024:02:16:22 +0000] "GET / HTTP/1.1" 200 762 "-" "curl/7.68.0"
EOF

    # firewall-20240614.log  (each line ends with a newline)
    cat > /home/user/logs/firewall-20240614.log <<'EOF'
Jun 14 02:15:24 host kernel: [UFW BLOCK] IN=eth0 OUT= MAC=00:0c:29:4f:8e:35 SRC=203.0.113.77 DST=192.168.1.10 LEN=60 TOS=0x00 PREC=0x00 TTL=47 ID=54321 DF PROTO=TCP SPT=55932 DPT=80 WINDOW=29200 RES=0x00 SYN URGP=0
Jun 14 02:16:10 host kernel: [UFW BLOCK] IN=eth0 OUT= MAC=00:0c:29:4f:8e:35 SRC=198.51.100.23 DST=192.168.1.10 LEN=60 TOS=0x00 PREC=0x00 TTL=49 ID=12345 DF PROTO=TCP SPT=49000 DPT=22 WINDOW=29200 RES=0x00 SYN URGP=0
EOF

    #------------------------------------------------------------------
    # Make sure everything is readable/writable by the non-root user
    #------------------------------------------------------------------
    chmod -R a+rwX /home/user

%environment
    chmod 755 /home/user

    # Do not modify \$HOME; simply ensure commonly-used variables exist.
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%labels
    Author incident-response-task
    Description "Base image for incident-response exercise with initial evidence and pytest installed"