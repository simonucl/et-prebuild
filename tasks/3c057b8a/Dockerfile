FROM ubuntu:22.04

# Help:
# This Apptainer image is set up for the “local-vs-remote documentation sync” exercise.
# It provides:
# • Python 3 and pytest (pre-installed)
# • rsync utility
# • Pre-created directories:
#     /home/user/docs_working        (empty)
#     /home/user/production_docs     (contains introduction.md & obsolete.txt)
#     /home/user/sync_logs           (empty)
# Students can run tests with: pytest -q

LABEL Author="Generated by ChatGPT"
LABEL Description="Environment for the documentation sync task – includes pytest and the required initial filesystem state."

RUN set -e && \
    apt-get update -y && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        rsync \
        ca-certificates && \
    pip3 install --no-cache-dir pytest

RUN mkdir -p /home/user/docs_working && \
    mkdir -p /home/user/production_docs && \
    mkdir -p /home/user/sync_logs

RUN printf 'Old content\n' > /home/user/production_docs/introduction.md
RUN printf 'remove me\n' > /home/user/production_docs/obsolete.txt

RUN chmod -R 777 /home/user/docs_working /home/user/production_docs /home/user/sync_logs

# From %environment: apply required permissions
RUN chmod 755 /home/user