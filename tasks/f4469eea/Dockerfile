FROM ubuntu:22.04

# Help / labels
LABEL Author="Generated by AI — Apptainer task setup"
LABEL Description="Container image for timezone/locale configuration task with pytest pre-installed."

RUN set -e && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends python3 python3-pip && \
    pip3 install --no-cache-dir pytest && \
    mkdir -p /home/user/system_config && \
    echo 'TIMEZONE=UTC' > /home/user/system_config/timezone.conf && \
    echo 'LANG=C' > /home/user/system_config/locale.conf && \
    chmod 0777 /home/user && \
    chmod 0777 /home/user/system_config && \
    chmod 0666 /home/user/system_config/timezone.conf && \
    chmod 0666 /home/user/system_config/locale.conf

RUN chmod 755 /home/user

ENV PATH="/usr/local/bin:$PATH"
ENV PYTHONIOENCODING="utf-8"