Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package list and install Python / pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial file-system state for the exercise
    # ------------------------------------------------------------------

    # Create user home and configuration directory
    mkdir -p /home/user/system_config

    # Create the two default configuration files with exactly
    # the required initial contents (each terminated by a newline)
    echo 'TIMEZONE=UTC' >  /home/user/system_config/timezone.conf
    echo 'LANG=C'        >  /home/user/system_config/locale.conf

    # Ensure the agent (non-root) can modify the files and directory later
    chmod 0777 /home/user
    chmod 0777 /home/user/system_config
    chmod 0666 /home/user/system_config/timezone.conf
    chmod 0666 /home/user/system_config/locale.conf

    # Do NOT create /home/user/config-changes or the log file;
    # the student must create them during the task.

%environment
    chmod 755 /home/user

    # Make sure Python and pip executables are on PATH
    export PATH="/usr/local/bin:$PATH"
    export PYTHONIOENCODING="utf-8"

%labels
    Author="Generated by AI — Apptainer task setup"
    Description="Container image for timezone/locale configuration task with pytest pre-installed."