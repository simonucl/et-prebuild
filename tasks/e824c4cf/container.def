Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip && \
    pip3 install --no-cache-dir pytest && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

    # Prepare writable home for the non-root runtime user without
    # contaminating the exercise target paths.
    mkdir -p /home/user
    chmod 0777 /home/user

%environment
    chmod 755 /home/user

    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%labels
    Author the-architect
    Description Base image for dotenv migration exercise – pytest pre-installed, clean initial state.

%runscript
    echo "Container for dotenv migration exercise."
    echo "Pytest is available.  Start your work!"