Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Update package lists and install Python + pip
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-setuptools \
        ca-certificates \
        build-essential
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare a non-privileged “user” account and its home directory.
    # This directory must exist for the tests, but the task artefacts
    # themselves (project_utils, backup.sh, log) must NOT exist yet.
    # ------------------------------------------------------------------
    # Create group and user with UID/GID 1000 if they don’t exist
    if ! getent group 1000 >/dev/null; then
        groupadd -g 1000 user
    fi

    if ! id -u 1000 >/dev/null 2>&1; then
        useradd -m -u 1000 -g 1000 -s /bin/bash user
    fi

    # Ensure the home directory exists and is owned by UID/GID 1000
    mkdir -p /home/user
    chown -R 1000:1000 /home/user

%environment
    chmod 755 /home/user

    # Add the local Python user-install directory to PATH for convenience
    export PATH="/home/user/.local/bin:${PATH}"

%labels
    Author YourName
    Description "Environment for the project_utils/secure_scripts permissions task. Pytest pre-checks installed."

%runscript
    exec "${@}"