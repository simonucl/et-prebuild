Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package index and install Python & pip
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates

    # Install pytest for the runtime tests
    pip3 install --no-cache-dir pytest

    # Create required project structure
    mkdir -p /home/user/projects/l10n

    # ------------------------------------------------------------------
    # /home/user/projects/l10n/en_US.csv  (with single trailing newline)
    # ------------------------------------------------------------------
    cat <<'EOF' > /home/user/projects/l10n/en_US.csv
key,text
app.title,Weather App
app.greeting,Hello!
error.network,Network error
menu.settings,Settings
menu.quit,Quit
EOF

    # ------------------------------------------------------------------
    # /home/user/projects/l10n/fr_FR.json (pretty-printed, trailing LF)
    # ------------------------------------------------------------------
    cat <<'EOF' > /home/user/projects/l10n/fr_FR.json
{
  "app.title": "Application Météo",
  "menu.settings": "Paramètres"
}
EOF

    # Ensure writability for the non-root user who will run inside the container
    chmod -R 777 /home/user/projects/l10n

%labels
    chmod 755 /home/user

    Author "Apptainer Build Script"
    Description "Environment for localization synchronisation task with pytest pre-installed."

%help
    This container provides the initial filesystem and dependencies required
    for the localization synchronisation task. pytest is installed so the
    provided tests can be executed inside the container.