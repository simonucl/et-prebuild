FROM ubuntu:22.04

# Labels
LABEL Author="Autogenerated by ChatGPT"
LABEL Description="Container providing the required initial filesystem state and pytest."

# Environment variables
ENV LC_ALL=C.UTF-8
ENV LANG=C.UTF-8

# Install Python and pytest
RUN set -e && \
    apt-get update && \
    apt-get install -y --no-install-recommends python3 python3-pip && \
    pip3 install --no-cache-dir pytest && \
    rm -rf /var/lib/apt/lists/*

# Create user and home directory
RUN useradd -m -s /bin/bash user

# Create the logs directory and initialization script directory
RUN mkdir -p /home/user/logs && \
    mkdir -p /etc/profile.d

# Create the initialization script
RUN cat << 'EOF' > /etc/profile.d/91-setup-logs.sh
# This script is sourced automatically for every shell session.
# It ensures the initial filesystem state expected by the autograder.

LOGS_DIR="/home/user/logs"

# Create the directory if it does not exist
mkdir -p "${LOGS_DIR}"

# Remove any extraneous regular files so that only the canonical three remain
for entry in "${LOGS_DIR}"/*; do
    [ -e "${entry}" ] || continue
    base="$(basename "${entry}")"
    case "${base}" in
        web.log|api.log|db.log) : ;;   # keep
        *) rm -rf "${entry}" ;;
    esac
done

# Helper to (re)create a canonical log file
create_log() {
    local fname="$1"
    local service="$2"
    local fpath="${LOGS_DIR}/${fname}"
    printf '[%s] Service started successfully.\n' "${service}" > "${fpath}"
    chmod 755 /home/user

    chmod 0644 "${fpath}"
}

create_log "web.log" "web"
create_log "api.log" "api"
create_log "db.log"  "db"

# Set directory permissions
chmod 0755 "${LOGS_DIR}"
EOF

RUN chmod 0755 /etc/profile.d/91-setup-logs.sh

# Create initial log files and set permissions
RUN mkdir -p /home/user/logs && \
    echo '[web] Service started successfully.' > /home/user/logs/web.log && \
    echo '[api] Service started successfully.' > /home/user/logs/api.log && \
    echo '[db] Service started successfully.' > /home/user/logs/db.log && \
    chmod 0644 /home/user/logs/*.log && \
    chmod 0755 /home/user/logs && \
    chmod 755 /home/user && \
    chown -R user:user /home/user

USER user
WORKDIR /home/user