Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest

    # -----------------------------------------------------------------
    # Create an initialization script that guarantees the required
    # /home/user/logs directory and its canonical files exist with the
    # correct permissions and ownership *at runtime* (i.e., after the
    # user’s $HOME has been bind-mounted into the container).
    # -----------------------------------------------------------------
    mkdir -p /.singularity.d/env

    cat << 'EOF' > /.singularity.d/env/91-setup-logs.sh
# This script is sourced automatically by Apptainer for every
# shell/exec/run action.  It ensures the initial filesystem state
# expected by the autograder.

LOGS_DIR="/home/user/logs"

# Create the directory if it does not exist
mkdir -p "${LOGS_DIR}"

# Remove any extraneous regular files so that only the canonical three remain
for entry in "${LOGS_DIR}"/*; do
    [ -e "${entry}" ] || continue
    base="$(basename "${entry}")"
    case "${base}" in
        web.log|api.log|db.log) : ;;   # keep
        *) rm -rf "${entry}" ;;
    esac
done

# Helper to (re)create a canonical log file
create_log() {
    local fname="$1"
    local service="$2"
    local fpath="${LOGS_DIR}/${fname}"
    printf '[%s] Service started successfully.\n' "${service}" > "${fpath}"
    chmod 755 /home/user

    chmod 0644 "${fpath}"
}

create_log "web.log" "web"
create_log "api.log" "api"
create_log "db.log"  "db"

# Set directory permissions
chmod 0755 "${LOGS_DIR}"
EOF

    chmod 0755 /.singularity.d/env/91-setup-logs.sh

%environment
    # Nothing to export explicitly; the setup script will run automatically.
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%labels
    Author "Autogenerated by ChatGPT"
    Description "Container providing the required initial filesystem state and pytest."