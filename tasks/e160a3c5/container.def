Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update APT and install minimal packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3-pip \
        iputils-ping

    # Install pytest for the grader/agent
    pip3 install --no-cache-dir pytest

    # Prepare writable home directory for the agent
    mkdir -p /home/user
    chmod 0777 /home/user   # Allow any non-root user to create sub-items here

    # Clean up APT caches to keep the image small
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    export PATH=/usr/local/bin:$PATH

%labels
    Author      "Generated by ChatGPT"
    Description "Apptainer image for the netdiag task; pytest pre-installed, clean initial state."