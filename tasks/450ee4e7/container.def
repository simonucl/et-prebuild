Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # --------------------------------------------------------------------- #
    # Base tooling                                                          #
    # --------------------------------------------------------------------- #
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        sqlite3 \
        python3 \
        python3-pip \
        ca-certificates
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # --------------------------------------------------------------------- #
    # Incident-response exercise set-up                                     #
    # --------------------------------------------------------------------- #
    # Create working directory writable by any user so the student can add
    # the required CSV later.
    mkdir -p /home/user/ir_case
    chmod 0777 /home/user/ir_case

    # Build the SQLite database with the required schema and data.
    sqlite3 /home/user/ir_case/logs.db <<'SQL_EOF'
    CREATE TABLE auth(
        id     INTEGER PRIMARY KEY,
        ts     TEXT,
        user   TEXT,
        status TEXT
    );
    INSERT INTO auth VALUES
        (1,'2023-08-01 11:23:31','alice','OK'),
        (2,'2023-08-01 11:24:02','bob','FAIL'),
        (3,'2023-08-01 11:25:15','charlie','FAIL'),
        (4,'2023-08-01 11:26:45','alice','FAIL'),
        (5,'2023-08-01 11:28:17','dave','OK'),
        (6,'2023-08-01 11:30:00','charlie','FAIL'),
        (7,'2023-08-01 11:32:12','eve','FAIL'),
        (8,'2023-08-01 11:34:05','bob','OK'),
        (9,'2023-08-01 11:35:19','frank','FAIL');
SQL_EOF

    # Correct permissions: read-only DB, writable directory.
    chmod 0644 /home/user/ir_case/logs.db
    rm -f /home/user/ir_case/logs.db-shm /home/user/ir_case/logs.db-wal || true

%environment
    chmod 755 /home/user

    # Minimal locale / PATH setup
    export LANG=C
    export LC_ALL=C
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

%labels
    Author incident-responder exercise container
    Description Container that sets up the initial state for the failed-login incident response task.