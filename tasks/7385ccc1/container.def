Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install required tools
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        jq \
        ca-certificates

    # Install pytest (and jsonschema CLI for convenience)
    pip3 install --no-cache-dir pytest jsonschema

    # ------------------------------------------------------------------
    # Create initial filesystem state required by the assignment
    # ------------------------------------------------------------------
    mkdir -p /home/user/server_data

    # inventory.json
    cat > /home/user/server_data/inventory.json <<'EOF'
{
  "servers": [
    {
      "hostname": "web-01",
      "ip": "10.0.0.11",
      "kernel": "5.15.0-60-generic",
      "os_release": "Ubuntu 22.04"
    },
    {
      "hostname": "db-01",
      "ip": "10.0.0.21",
      "kernel": "4.19.0-17-amd64",
      "os_release": "Debian 10"
    },
    {
      "hostname": "cache-01",
      "ip": "10.0.0.31",
      "kernel": "5.10.0-18-amd64",
      "os_release": "Debian 11"
    },
    {
      "hostname": "legacy-01",
      "ip": "10.0.0.41",
      "kernel": "3.10.0-1160.el7.x86_64",
      "os_release": "CentOS 7"
    }
  ]
}
EOF

    # inventory_schema.json
    cat > /home/user/server_data/inventory_schema.json <<'EOF'
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Server Inventory",
  "type": "object",
  "required": ["servers"],
  "properties": {
    "servers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["hostname", "ip", "kernel", "os_release"],
        "properties": {
          "hostname": { "type": "string" },
          "ip": {
            "type": "string",
            "pattern": "^(?:[0-9]{1,3}\\.){3}[0-9]{1,3}$"
          },
          "kernel": { "type": "string" },
          "os_release": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
EOF

    # Set permissions so that the (non-root) runtime user can create log files
    chmod 644 /home/user/server_data/inventory.json /home/user/server_data/inventory_schema.json
    chmod 777 /home/user/server_data

%environment
    chmod 755 /home/user

    # Ensure Python and jq are on PATH (they are by default, but be explicit)
    export PATH=/usr/local/bin:/usr/bin:/bin

%labels
    Author="Generated by ChatGPT"
    Description="Container for JSON inventory validation task – includes pytest and initial data set."

%help
    This container provides the starting environment for the JSON inventory
    validation task.  It contains:
      • Python 3 with the 'jsonschema' library
      • pytest (used by the grader)
      • jq (for JSON processing)
      • Pre-populated /home/user/server_data with inventory.json and its schema