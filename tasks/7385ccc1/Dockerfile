# syntax=docker/dockerfile:1
FROM ubuntu:22.04

LABEL Author="Generated by ChatGPT" \
      Description="Container for JSON inventory validation task – includes pytest and initial data set."

# Update package lists and install required tools
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked --mount=type=cache,target=/var/lib/apt,sharing=locked set -e && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        jq \
        ca-certificates && \
    rm -rf /var/lib/apt/lists/*

# Install pytest and jsonschema
RUN --mount=type=cache,target=/root/.cache/pip pip3 install --no-cache-dir pytest jsonschema

# Create initial filesystem state required by the assignment
RUN mkdir -p /home/user/server_data

# inventory.json
RUN cat > /home/user/server_data/inventory.json <<'EOF'
{
  "servers": [
    {
      "hostname": "web-01",
      "ip": "10.0.0.11",
      "kernel": "5.15.0-60-generic",
      "os_release": "Ubuntu 22.04"
    },
    {
      "hostname": "db-01",
      "ip": "10.0.0.21",
      "kernel": "4.19.0-17-amd64",
      "os_release": "Debian 10"
    },
    {
      "hostname": "cache-01",
      "ip": "10.0.0.31",
      "kernel": "5.10.0-18-amd64",
      "os_release": "Debian 11"
    },
    {
      "hostname": "legacy-01",
      "ip": "10.0.0.41",
      "kernel": "3.10.0-1160.el7.x86_64",
      "os_release": "CentOS 7"
    }
  ]
}
EOF

# inventory_schema.json
RUN cat > /home/user/server_data/inventory_schema.json <<'EOF'
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Server Inventory",
  "type": "object",
  "required": ["servers"],
  "properties": {
    "servers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["hostname", "ip", "kernel", "os_release"],
        "properties": {
          "hostname": { "type": "string" },
          "ip": {
            "type": "string",
            "pattern": "^(?:[0-9]{1,3}\\.){3}[0-9]{1,3}$"
          },
          "kernel": { "type": "string" },
          "os_release": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
EOF

# Set permissions so that the (non-root) runtime user can create log files
RUN chmod 644 /home/user/server_data/inventory.json /home/user/server_data/inventory_schema.json && \
    chmod 777 /home/user/server_data && \
    chmod 755 /home/user

# Environment configuration
ENV PATH=/usr/local/bin:/usr/bin:/bin

# This container provides the starting environment for the JSON inventory
# validation task. It contains:
#  • Python 3 with the 'jsonschema' library
#  • pytest (used by the grader)
#  • jq (for JSON processing)
#  • Pre-populated /home/user/server_data with inventory.json and its schema