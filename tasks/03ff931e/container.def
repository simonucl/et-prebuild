Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Install Python and pytest
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create an unprivileged user that mirrors the expected runtime user
    # ------------------------------------------------------------------
    groupadd -g 1000 user || true
    useradd  -m -u 1000 -g 1000 user || true

    # ------------------------------------------------------------------
    # Prepare directory structure and files required by the tests
    # ------------------------------------------------------------------
    mkdir -p /home/user/server
    mkdir -p /home/user/data

    # 1. Create an empty tarball (zero-byte file)
    touch /home/user/data/backup.tar.gz

    # 2. Compute its SHA-256 (hash of an empty stream)
    HASH=$(python3 - <<'PY'
import hashlib, sys
path = "/home/user/data/backup.tar.gz"
with open(path, "rb") as f:
    data = f.read()
print(hashlib.sha256(data).hexdigest())
PY
    )

    # 3. Generate the HTML status page containing exactly one <code>…</code> hash
    cat > /home/user/server/backup_report.html <<EOF
<!DOCTYPE html>
<html>
<head><title>Nightly Backup Report</title></head>
<body>
<h1>Backup Verification</h1>
<p>The SHA256 checksum for the latest tarball is: <code>${HASH}</code></p>
</body>
</html>
EOF

    # Ensure ownership for the unprivileged user
    chown -R 1000:1000 /home/user

%environment
    chmod 755 /home/user

    # No special environment needed; keep default user environment.

%labels
    Author "Container generator"
    Description "Environment for backup verification task with pytest installed"