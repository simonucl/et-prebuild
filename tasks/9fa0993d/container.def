Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author automated-generator
    Description "Base image for the network-health check task. Provides Python, pytest, and standard networking tools."

%post
    set -e

    echo "Updating package index..."
    apt-get update -y

    echo "Installing required system packages..."
    # python3 and pip for pytest; iputils-ping for `ping`; iproute2 for `ip addr`
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        python3 \
        python3-pip \
        iputils-ping \
        iproute2 \
        ca-certificates

    echo "Installing pytest via pip..."
    pip3 install --no-cache-dir --upgrade pip
    pip3 install --no-cache-dir pytest

    echo "Creating non-root user 'user' with home directory /home/user ..."
    groupadd -g 1000 user
    useradd  -m -u 1000 -g 1000 -s /bin/bash user

    # Ensure /home/user exists (created by useradd) and is accessible
    chmod 755 /home/user

    echo "Cleaning up APT caches..."
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    # Do NOT override HOME so that the caller's $HOME is preserved.
    export PATH=/usr/local/bin:/usr/local/sbin:/usr/bin:/usr/sbin:/bin:/sbin

%runscript
    echo "Container for the network-health check task."
    echo "Invoke your commands or tests as needed."