Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package index and install Python + pip
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state for the incident-response exercise
    # ------------------------------------------------------------------

    # Create the responder’s home directory and give broad write access so
    # whatever unprivileged UID runs inside the container can modify files.
    mkdir -p /home/user
    chmod 0777 /home/user

    # Create an initial .bashrc that does NOT already contain the required export.
    printf "# Initial Bash configuration for incident-response exercise\n" > /home/user/.bashrc
    chmod 0666 /home/user/.bashrc

    # Ensure no confirmation log exists at build time.
    rm -f /home/user/ir_run.log

    # Clean up apt caches to keep the image small.
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Nothing special required; leave HOME untouched.
    :