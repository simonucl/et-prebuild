Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package index and install required packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        sqlite3 \
        locales \
        ca-certificates

    # Generate a UTF-8 locale so Python / csv behaves consistently
    locale-gen en_US.UTF-8
    update-locale LANG=en_US.UTF-8

    # Install pytest for the grading harness
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create the initial directory structure and seed CSV data files
    # ------------------------------------------------------------------
    mkdir -p /home/user/datasets

    cat > /home/user/datasets/species_A.csv << 'EOF'
id,name,weight,length
1,Panthera leo,190,2.0
2,Panthera pardus,,1.5
3,,120,1.1
4,Panthera tigris,220,2.3
5,Acinonyx jubatus,72,
EOF

    cat > /home/user/datasets/species_B.csv << 'EOF'
id,name,weight,length
6,Canis lupus,45,1.3
7,Canis latrans,15,0.9
8,,33,1.0
9,Canis aureus,,1.1
EOF

    # Ensure non-root container users have full read/write access so they
    # can create the SQLite database and validation log during the exercise.
    chmod -R a+rwx /home/user/datasets

    # Optionally create a matching user entry (not required for access but
    # helps some tools that look up passwd data).
    useradd -m -u 1000 -s /bin/bash user || true

    # Clean up package lists to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    export LANG=en_US.UTF-8
    export LC_ALL=en_US.UTF-8
    export PYTHONUNBUFFERED=1