Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # 1. Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip install --no-cache-dir pytest

    # 2. Prepare directory structure and seed files
    mkdir -p /home/user/projects/old

    # Top-level Python utilities
    echo '# sample Python file' > /home/user/projects/alpha.py
    echo '# sample Python file' > /home/user/projects/beta.py
    echo '# sample Python file' > /home/user/projects/gamma_processor.py
    echo '# sample Python file' > /home/user/projects/zeta.py

    # Non-Python files
    echo 'Sample README' > /home/user/projects/readme.md
    echo 'id,value'       > /home/user/projects/data.csv

    # Sub-directory with legacy utility
    echo '# legacy Python file' > /home/user/projects/old/legacy.py

    # 3. Permissions
    #    Allow the unprivileged runtime user to create new files in /home/user/projects
    chmod 0777 /home/user/projects
    chmod 0777 /home/user/projects/old

    #    Files only need read permission; writeable anyway for simplicity
    chmod 0666 /home/user/projects/*.py
    chmod 0666 /home/user/projects/readme.md
    chmod 0666 /home/user/projects/data.csv
    chmod 0666 /home/user/projects/old/legacy.py

%labels
    chmod 755 /home/user

    Author task-prep-bot
    Description "Setup initial filesystem state for Python file listing task"