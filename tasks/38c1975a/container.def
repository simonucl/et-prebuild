Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install required system packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        jq \
        python3 \
        python3-pip
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # Create a normal user “user” (uid/gid 1000) with home directory
    groupadd -g 1000 user
    useradd  -m -u 1000 -g user -s /bin/bash user

    # ------------------------------------------------------------------
    # Seed the filesystem with the data required by the task
    # ------------------------------------------------------------------
    install -d -m 0755 /home/user/data

    # inventory.json  (exact canonical content expected by the tests)
    cat > /home/user/data/inventory.json <<'EOF'
{
  "warehouse": "central",
  "items": [
    {"id":101,"name":"blue widget","quantity":5},
    {"id":102,"name":"red widget","quantity":25},
    {"id":203,"name":"green gizmo","quantity":7},
    {"id":304,"name":"yellow gizmo","quantity":12}
  ]
}
EOF

    # inventory_schema.json (not used by tests but provided for realism)
    cat > /home/user/data/inventory_schema.json <<'EOF'
{
  "$schema":"http://json-schema.org/draft-07/schema#",
  "type":"object",
  "required":["warehouse","items"],
  "properties":{
    "warehouse":{"type":"string"},
    "items":{
      "type":"array",
      "items":{
        "type":"object",
        "required":["id","name","quantity"],
        "properties":{
          "id":{"type":"integer"},
          "name":{"type":"string"},
          "quantity":{"type":"integer","minimum":0}
        }
      }
    }
  }
}
EOF

    # Ensure correct permissions and ownership
    chown -R 1000:1000 /home/user
    chmod 0755 /home/user/data

%environment
    chmod 755 /home/user

    # No HOME override; use Apptainer default binding behaviour
    export LC_ALL=C.UTF-8
    export PATH=$PATH:/home/user/.local/bin

%runscript
    echo "This container is prepared for the inventory validation task."
    echo "Invoke your commands manually inside an interactive shell."
    exec "$@"