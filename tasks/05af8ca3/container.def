Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python, pip, tar, gzip, coreutils and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        tar \
        gzip \
        coreutils
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Create required directory structure and files
    mkdir -p /home/user/data
    echo "alpha" > /home/user/data/file1.txt
    echo "beta"  > /home/user/data/file2.txt

    # Prepare empty backup directory with write permissions for any user
    mkdir -p /home/user/backup
    chmod 0777 /home/user/backup

%environment
    chmod 755 /home/user

    export PYTHONUNBUFFERED=1

%labels
    Author backup-task-preparer
    Description "Container for backup creation task – provides initial filesystem state and pytest."