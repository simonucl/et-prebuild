Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Maintainer localization-task-prep
    Description "Base container for translation diagnostics exercise"

%post
    set -e

    # Update package lists and install Python and pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install pytest for the automated checks
    pip3 install --no-cache-dir pytest

    # Create a writable home directory for the exercise user
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure pip-installed binaries such as `pytest` are in PATH
    export PATH="/usr/local/bin:${PATH}"

%runscript
    echo "Container for translation diagnostics exercise."
    echo "Use this shell to work on your tasks."
    exec "${@:-/bin/bash}"