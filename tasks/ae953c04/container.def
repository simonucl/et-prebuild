Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update APT indexes and install system-level Python tooling
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-venv \
        python3-setuptools \
        python3-wheel \
        ca-certificates \
        curl

    # Upgrade pip inside the container’s system Python and install pytest
    python3 -m pip install --no-cache-dir --upgrade pip
    python3 -m pip install --no-cache-dir pytest

    # Create the working directory for the normal user.
    # Do NOT pre-create any of the task artefacts (venv, requirement file, etc.).
    mkdir -p /home/user
    # Make sure the directory is writable by whoever runs inside the container
    chmod 0777 /home/user

    # Clean up apt caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure that `python` and `pip` resolve to the Python 3 binaries
    export PATH="/usr/bin:$PATH"
    export PYTHONDONTWRITEBYTECODE=1

%runscript
    # Default entrypoint simply opens a shell for interactive work
    exec /bin/bash

%labels
    Author performance-engineer
    Description "Base image for the virtual-environment profiling task. Includes Python 3, venv support, and pytest."