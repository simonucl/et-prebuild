Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # ----- Install Python tooling ------------------------------------------------
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ----- Ensure the regular user exists ---------------------------------------
    if ! id -u user >/dev/null 2>&1; then
        useradd -m -s /bin/bash user
    fi

    # ----- Create initial configuration state -----------------------------------
    install -d -m 755 /home/user/configs

    # app.conf : exactly "abc" (no trailing newline)
    echo -n "abc" > /home/user/configs/app.conf

    # db.conf : empty file
    : > /home/user/configs/db.conf

    # web.conf : exactly the given sentence (no trailing newline)
    echo -n "The quick brown fox jumps over the lazy dog" > /home/user/configs/web.conf

    # Make sure the regular user owns their home directory
    chown -R user:user /home/user

%environment
    chmod 755 /home/user

    # Make sure scripts installed by pip are reachable
    export PATH="$PATH:/home/user/.local/bin"

%labels
    Author="Generated by ChatGPT – Apptainer setup for integrity manifest task"