Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install required packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        locales \
        ca-certificates

    # Install pytest for the testing framework
    pip3 install --no-cache-dir pytest

    # Make sure the UTF-8 locale is available
    locale-gen C.UTF-8

    # Create the non-privileged user’s home directory with appropriate permissions
    mkdir -p /home/user
    chmod 0775 /home/user

    # Clean up APT caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Keep the environment minimal; do not preset LC_ALL or TZ
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

%labels
    Author="Your Name"
    Description="Container for the 'Temporarily switch shell to UTC & C.UTF-8 and generate verification log' task. Includes pytest for automated grading."