Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package list and install required software
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        python3 \
        python3-pip \
        sqlite3 \
        ca-certificates

    # Install pytest for the test harness
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial workspace
    # ------------------------------------------------------------------
    # Directory structure
    mkdir -p /home/user/projects/sales_analysis

    # Starter CSV file with exact required content
    cat > /home/user/projects/sales_analysis/sales_q1.csv <<'EOF'
region,product,quantity,unit_price
North,Widget,10,2.5
South,Gadget,5,5.25
East,Widget,7,2.5
West,Gizmo,3,10.00
EOF

    # Ensure non-root users can work within /home/user
    chmod -R a+rwX /home/user

%environment
    chmod 755 /home/user

    # Keep output unbuffered for easier debugging
    export PYTHONUNBUFFERED=1

%labels
    Author  "Task Setup Generator"
    Purpose "Initial container for the sales analysis SQLite exercise"