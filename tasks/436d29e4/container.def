Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author benchmark-setup

%post
    set -e

    # Basic development utilities and Python
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates

    # Install pytest for the grading harness
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create required directory structure and benchmark scripts
    # ------------------------------------------------------------------
    BENCH_ROOT="/home/user/perf_bench"
    APPS_DIR="${BENCH_ROOT}/apps"

    # Create directories
    mkdir -p "${APPS_DIR}"

    # Create app_sort.py
    cat > "${APPS_DIR}/app_sort.py" << 'EOF'
#!/usr/bin/env python3
print("benchmark_result_ms:42")
EOF

    # Create app_math.py
    cat > "${APPS_DIR}/app_math.py" << 'EOF'
#!/usr/bin/env python3
print("benchmark_result_ms:84")
EOF

    # Ensure executability
    chmod 0755 "${APPS_DIR}/app_sort.py" "${APPS_DIR}/app_math.py"

    # Set safe permissions for the whole /home/user tree
    chmod -R a+rx /home/user

%environment
    chmod 755 /home/user

    export PYTHONUNBUFFERED=1