Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Prepare initial workspace expected by the autograder
    # ------------------------------------------------------------------
    mkdir -p /home/user/projects/customer_churn/raw_data

    # customers_2021.csv  (includes one completely blank line at the end)
    cat > /home/user/projects/customer_churn/raw_data/customers_2021.csv <<'EOF'
id,name,age,subscription
1,Alice,30,Basic
2,Bob,25,Premium
3,Charlie,35,Basic
2,Bob,25,Premium

EOF

    # customers_2022.csv  (no extra blank line at the end)
    cat > /home/user/projects/customer_churn/raw_data/customers_2022.csv <<'EOF'
id,name,age,subscription
4,David,40,Premium
5,Eva,28,Basic
4,David,40,Premium
EOF

    # ------------------------------------------------------------------
    # Ensure the agent (non-root) can create new directories & files
    # ------------------------------------------------------------------
    chmod -R a+rX /home/user          # readable by anyone
    chmod -R a+w  /home/user/projects/customer_churn  # writable for future work

%environment
    chmod 755 /home/user

    # Add Python user base binary directory (when pip installs with --user)
    export PATH="$HOME/.local/bin:$PATH"
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8