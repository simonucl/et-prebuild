Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # -----------------------------------------------------------------
    # Prepare the diagnostic directory and seed files for the exercise
    # -----------------------------------------------------------------
    mkdir -p /home/user/diag

    # cpu_usage.log
    cat >/home/user/diag/cpu_usage.log <<'EOF'
2023-07-15T10:00:00 12
2023-07-15T10:05:00 18
2023-07-15T10:10:00 20
2023-07-15T10:15:00 25
EOF

    # mem_usage.log
    cat >/home/user/diag/mem_usage.log <<'EOF'
2023-07-15T10:00:00 2048
2023-07-15T10:05:00 2100
2023-07-15T10:10:00 2150
2023-07-15T10:15:00 2200
EOF

    # Permissions: make directory writable so the learner can create files
    chmod 777 /home/user/diag
    chmod 644 /home/user/diag/*.log

%labels
    chmod 755 /home/user

    Author="Generated for performance-log merging exercise"