FROM ubuntu:22.04

# Labels
LABEL Author="Generated by OpenAI ChatGPT"
LABEL Description="Container for Nmap parsing exercise – provides initial raw input and pytest."

# Update package lists and install Python + pip
RUN apt-get update && \
    apt-get -y install python3 python3-pip

# Install pytest for the grading framework
RUN pip3 install --no-cache-dir pytest

# Create non-root user `user` (home directory: /home/user)
RUN adduser --disabled-password --gecos "" user

# Prepare the assessment input directory structure
RUN su - user -c 'mkdir -p /home/user/assessment/raw'

# Create the nmap file
RUN cat <<'EOF' > /home/user/assessment/raw/host1_nmap.txt
Starting Nmap 7.80 ( https://nmap.org ) at 2023-01-01 00:00 UTC
Nmap scan report for localhost (127.0.0.1)
Host is up (0.00012s latency).
Not shown: 997 closed ports
PORT     STATE  SERVICE VERSION
22/tcp   open   ssh     OpenSSH 8.2 (protocol 2.0)
80/tcp   closed http
443/tcp  open   https   Apache httpd 2.4.41 ((Ubuntu))
8080/tcp filtered http-proxy
MAC Address: AA:BB:CC:DD:EE:FF (Unknown)
Service detection performed. Please report any incorrect results at https://nmap.org/submit/ .
Nmap done: 1 IP address (1 host up) scanned in 0.48 seconds
EOF

# Ensure correct ownership so the student (running as `user`) can access
RUN chown -R user:user /home/user/assessment

# Set permissions on home directory
RUN chmod 755 /home/user

# Environment variables
ENV PATH=/home/user/.local/bin:/usr/local/bin:/usr/bin:/bin

# Set working directory
WORKDIR /home/user

# Default command
CMD echo "Container for the Nmap parsing exercise." && \
    echo "Switch to the 'user' account to begin:" && \
    echo "  docker exec -it --user user <container> /bin/bash"