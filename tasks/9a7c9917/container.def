Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install Python tooling
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3-pip python3-setuptools python3-wheel
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Ensure writable home directory for the runtime (non-root) user
    mkdir -p /home/user
    chmod 0777 /home/user

    # Create required policies directory and CSV file with exact content
    mkdir -p /home/user/policies
    cat > /home/user/policies/service_ports.csv <<'EOF'
service,port
ssh,22
http,80
https,443
custom-app,8080
db-mysql,3306
db-postgres,5432
old-telnet,23
custom-admin,10022
dev-service,12000
EOF
    chmod 644 /home/user/policies/service_ports.csv

%environment
    chmod 755 /home/user

    # Ensure Python and pip are in the PATH
    export PATH="/usr/local/bin:$PATH"

%runscript
    echo "Container for DevSecOps port-compliance exercise. Open a shell to begin."