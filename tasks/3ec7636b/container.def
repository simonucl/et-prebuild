Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
#!/bin/bash
set -e

########## 1. System packages & Python tooling ##########
export DEBIAN_FRONTEND=noninteractive
apt-get update
apt-get install -y --no-install-recommends python3 python3-pip
pip3 install --no-cache-dir pytest
apt-get clean
rm -rf /var/lib/apt/lists/*

########## 2. Create the baseline directory tree ##########
BASE_DIR="/home/user/projects/microservices"

# Create required directories
mkdir -p "${BASE_DIR}/serviceA" \
         "${BASE_DIR}/serviceB" \
         "${BASE_DIR}/serviceC"

########## 3. Populate configuration & ancillary files ##########
# serviceA
printf "version: 'A'\\n"                         > "${BASE_DIR}/serviceA/deploy.yaml"
printf "SERVICE=serviceA\\nDB=mysql\\n"          > "${BASE_DIR}/serviceA/.env"
printf "Service A documentation\\n"              > "${BASE_DIR}/serviceA/readme.txt"

# serviceB
printf "service: B\\nreplicas: 3\\n"             > "${BASE_DIR}/serviceB/app.yaml"
printf "SERVICE=serviceB\\nDB=postgres\\n"       > "${BASE_DIR}/serviceB/.env"

# serviceC
printf "infra: true\\nregion: us-east-1\\n"      > "${BASE_DIR}/serviceC/infra.yaml"
printf "SERVICE=serviceC\\nDB=mongodb\\n"        > "${BASE_DIR}/serviceC/.env"

########## 4. Permissions ##########
# Make everything under /home/user/projects writable by any unprivileged user.
find /home/user/projects -type d -exec chmod 0777 {} \;
find /home/user/projects -type f -exec chmod 0666 {} \;

########## 5. Clean up ##########
unset DEBIAN_FRONTEND

%labels
    chmod 755 /home/user

Author="Apptainer exercise preparation"
Description="Provision initial state for microservices config-backup task. Installs pytest and pre-populates the /home/user/projects/microservices tree."

%runscript
exec /bin/bash "$@"