Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update && \
        apt-get install -y --no-install-recommends python3 python3-pip coreutils && \
        rm -rf /var/lib/apt/lists/*

    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Set up initial filesystem state for the mini artifact-tracking task
    # ------------------------------------------------------------------
    mkdir -p /home/user/exp_runs/run_01
    mkdir -p /home/user/exp_runs/run_02

    # Create run list with exact required content (each line terminated by \n)
    printf "run_01\nrun_02\n" > /home/user/exp_runs/run_list.txt

    # Create the empty model.bin for run_01
    : > /home/user/exp_runs/run_01/model.bin

    # Ensure all users have write access (agent will be non-root)
    chmod -R a+rwx /home/user

%environment
    chmod 755 /home/user

    # Ensure Python is available through `python3` and `pip`
    export PATH="/usr/local/bin:/usr/bin:/bin:${PATH}"

%help
    This container provides the starting environment for the “mini artifact-tracking”
    exercise.  It includes:
      • pytest (for autograding)
      • The predefined /home/user/exp_runs/ directory structure exactly as required.
    The /home/user/artifact_store/ directory is intentionally NOT created;
    students must generate it during their solution.