FROM ubuntu:22.04

# Labels
LABEL Author="Generated by OpenAI ChatGPT"
LABEL Description="Environment for Active Users Inventory exercise with pytest pre-installed."

# ------------------------------------------------------------------
# 1. Install Python and Pytest
# ------------------------------------------------------------------
RUN set -e && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip && \
    pip3 install --no-cache-dir pytest && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# ------------------------------------------------------------------
# 2. Create non-root user "user" with home directory /home/user
# ------------------------------------------------------------------
RUN if ! id -u user >/dev/null 2>&1; then \
        useradd -m -s /bin/bash user; \
    fi

# ------------------------------------------------------------------
# 3. Prepare initial dataset
#    (The /home/user/output directory must NOT exist yet.)
# ------------------------------------------------------------------
RUN install -d -m 0755 /home/user/data

RUN cat > /home/user/data/raw_users.csv <<'EOF'
user_id,username,status,last_login
1,alice,active,2023-08-01
2,bob,inactive,2023-07-15
3,charlie,active,2023-08-02
4,dave,locked,2023-07-29
5,eve,active,2023-08-03
6,frank,active,2023-07-31
7,grace,inactive,2023-08-01
EOF

RUN chmod 0644 /home/user/data/raw_users.csv

# Give ownership of everything in /home/user to the unprivileged user
RUN chown -R user:user /home/user

# ------------------------------------------------------------------
# Environment variables
# ------------------------------------------------------------------
ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8

# Set home directory permissions at runtime and default to bash
RUN chmod 755 /home/user

# By default just start a shell as the unprivileged user
CMD ["/bin/bash"]