Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install required packages and pytest
    apt-get update && \
        DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
            python3-pip \
            python3-setuptools \
            python3-venv \
            jq \
            coreutils \
            procps \
            ca-certificates && \
        rm -rf /var/lib/apt/lists/*

    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare workspace expected by the exercise
    # ------------------------------------------------------------------
    # 1. Create /home/user and experiments directory
    mkdir -p /home/user/experiments

    # 2. Provide the dummy training script
    cat > /home/user/train_dummy.sh <<'EOF'
#!/usr/bin/env bash
# ------------------------------------------------------------
# Dummy training script for the MLOps exercise.
# Produces deterministic start/end markers and some sample lines.
# ------------------------------------------------------------
echo "=== DUMMY TRAINING START ==="
for i in $(seq 1 5); do
    echo "epoch ${i}: loss $(( RANDOM % 100 ))"
    chmod 755 /home/user

    sleep 0.1
done
echo "=== DUMMY TRAINING END ==="
exit 0
EOF

    chmod +x /home/user/train_dummy.sh

    # 3. Ensure write permissions for non-root users (the student)
    chmod -R 0777 /home/user

%environment
    # Minimal PATH setup
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

%runscript
#!/usr/bin/env bash
# Default runscript: just execute the given command inside the container
exec "$@"

%labels
    Author="Auto-generated for MLOps Experiment Task"
    Description="Provides initial environment with dummy training script and writable experiments directory."