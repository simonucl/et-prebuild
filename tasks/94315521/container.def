Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # ------------------------------------------------------------------
    # 1. Install runtime dependencies + pytest
    # ------------------------------------------------------------------
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # 2. Create the initial workspace expected by the tests
    # ------------------------------------------------------------------
    # Directory structure
    mkdir -p /home/user/build_configs
    chmod 755 /home/user/build_configs

    # app.yaml (mode 644)
    cat > /home/user/build_configs/app.yaml <<'EOF'
name: sample-app
version: "1.2.3"
EOF
    chmod 644 /home/user/build_configs/app.yaml

    # release.toml (mode 644)
    cat > /home/user/build_configs/release.toml <<'EOF'
[build]
number = 102

[metadata]
checksum = ""
EOF
    chmod 644 /home/user/build_configs/release.toml

%environment
    # Ensure pip-installed binaries are in PATH
    export PATH="$PATH:~/.local/bin"

%help
    This container sets up the initial state for the "build configuration
    update" exercise and includes pytest for automated validation.