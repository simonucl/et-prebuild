Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Install Python, pip and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state expected by the grading tests
    # ------------------------------------------------------------------
    # Create /home/user with world-writable permissions so the unprivileged
    # runtime user can create new files/directories inside it.
    mkdir -p /home/user/logs
    chmod 777 /home/user

    # Create the unfiltered application log with the exact required content.
    cat > /home/user/logs/app.log <<'EOF'
2023-07-15 13:59:58,123 INFO auth - User login successful: user_id=15
2023-07-15 14:00:02,456 ERROR db - Connection timeout to replica set
2023-07-15 14:05:34,789 WARNING cache - Cache miss for key=session_42
2023-07-15 14:15:03,101 CRITICAL api - Null pointer dereference in handler /api/data
2023-07-15 14:45:00,000 INFO scheduler - Task completed: daily_sync
2023-07-15 15:00:01,987 ERROR auth - Token expired for user_id=38
2023-07-15 15:05:22,333 INFO api - Request processed in 120ms
EOF

    # Set appropriate permissions: readable by everyone, not writable.
    chmod 644 /home/user/logs/app.log

    # Ensure /home/user/output does NOT exist at build time.
    # (The grading script expects it to be absent initially.)
    [ ! -d /home/user/output ] || rmdir /home/user/output

%environment
    chmod 755 /home/user

    # Ensure Python and pip are on PATH
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH
    export PYTHONUNBUFFERED=1

%labels
    Author "Generated by ChatGPT"
    Description "Base container for log-filtering task. Contains initial logs and pytest."