Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # Create required directory structure
    mkdir -p /home/user/observability/templates

    # Create the baseline template file with exact required contents
    cat > /home/user/observability/templates/metrics_base.json <<'EOF'
{
  "id": null,
  "title": "Base Metrics Dashboard",
  "uid": "base-metrics",
  "tags": [
    "base"
  ],
  "refresh": "10s",
  "panels": []
}
EOF

    # Set permissions
    chmod 0755 /home/user
    chmod -R 0755 /home/user/observability
    chmod 0644 /home/user/observability/templates/metrics_base.json

%environment
    chmod 755 /home/user

    export PYTHONUNBUFFERED=1