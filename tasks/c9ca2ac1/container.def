Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create a normal user with UID 1000 so that the runtime UID
    # (usually the host user) maps correctly and has write access
    # inside /home/user during execution.
    # ------------------------------------------------------------------
    if ! id -u 1000 >/dev/null 2>&1; then
        groupadd -g 1000 user
        useradd  -m -u 1000 -g 1000 -s /bin/bash user
    fi

    # ------------------------------------------------------------------
    # Set up initial experiment artifacts
    # ------------------------------------------------------------------
    EXP_BASE="/home/user/experiments"
    mkdir -p "${EXP_BASE}/run_01" "${EXP_BASE}/run_02"

    # run_01 files
    cat > "${EXP_BASE}/run_01/config.env" <<'EOF'
DB_PASSWORD=mydbpw
SECRET_KEY=abc123xyz
EOF

    cat > "${EXP_BASE}/run_01/notes.txt" <<'EOF'
Training accuracy reached 0.93
Need to regenerate data
EOF

    # run_02 files
    cat > "${EXP_BASE}/run_02/config.env" <<'EOF'
API_TOKEN=notasecret
ENDPOINT=https://api.internal
EOF

    cat > "${EXP_BASE}/run_02/metrics.json" <<'EOF'
{
  "loss": 0.123,
  "accuracy": 0.932
}
EOF

    # Ensure correct ownership and permissions
    chown -R 1000:1000 /home/user
    chmod -R u+rwX,go=rX /home/user

%environment
    chmod 755 /home/user

    # Minimal locale to avoid some Python warnings
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%labels
    Author="Generated by ChatGPT"
    Description="Container for security-scan task with initial experiment artifacts and pytest installed."

%help
    This container provides the initial filesystem layout required for the
    security-hygiene scan task. It includes pytest for automated grading.