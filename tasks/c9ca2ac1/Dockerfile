FROM ubuntu:22.04

# Labels
LABEL Author="Generated by ChatGPT"
LABEL Description="Container for security-scan task with initial experiment artifacts and pytest installed."

# Install Python and pytest
RUN set -e && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip && \
    pip3 install --no-cache-dir pytest

# Create a normal user with UID 1000
RUN if ! id -u 1000 >/dev/null 2>&1; then \
        groupadd -g 1000 user && \
        useradd -m -u 1000 -g 1000 -s /bin/bash user; \
    fi

# Set up initial experiment artifacts
RUN mkdir -p /home/user/experiments/run_01 /home/user/experiments/run_02

# Create run_01/config.env
RUN cat > /home/user/experiments/run_01/config.env <<'EOF'
DB_PASSWORD=mydbpw
SECRET_KEY=abc123xyz
EOF

# Create run_01/notes.txt
RUN cat > /home/user/experiments/run_01/notes.txt <<'EOF'
Training accuracy reached 0.93
Need to regenerate data
EOF

# Create run_02/config.env
RUN cat > /home/user/experiments/run_02/config.env <<'EOF'
API_TOKEN=notasecret
ENDPOINT=https://api.internal
EOF

# Create run_02/metrics.json
RUN cat > /home/user/experiments/run_02/metrics.json <<'EOF'
{
  "loss": 0.123,
  "accuracy": 0.932
}
EOF

# Ensure correct ownership and permissions
RUN chown -R 1000:1000 /home/user && \
    chmod -R u+rwX,go=rX /home/user

# Environment variables
ENV LC_ALL=C.UTF-8
ENV LANG=C.UTF-8

# Set working directory
WORKDIR /home/user

# Help information (as comment):
# This container provides the initial filesystem layout required for the
# security-hygiene scan task. It includes pytest for automated grading.