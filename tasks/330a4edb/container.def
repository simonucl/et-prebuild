Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # --- Install Python and pytest -------------------------------------------------
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # --- Prepare project directory and seed files ----------------------------------
    mkdir -p /home/user/data_project
    chmod 0777 /home/user
    chmod 0777 /home/user/data_project

    # version.txt (exactly '1.3.5\n')
    printf '1.3.5\n' > /home/user/data_project/version.txt

    # CHANGELOG.md (exact initial snapshot)
    cat > /home/user/data_project/CHANGELOG.md <<'EOF'
# Changelog

## [1.3.5] - 2023-06-30
- Added median calculation for quarterly_sales.csv
EOF

    # Make the files writable by any non-root user who will run inside the container
    chmod 0666 /home/user/data_project/version.txt
    chmod 0666 /home/user/data_project/CHANGELOG.md

%environment
    chmod 755 /home/user

    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8