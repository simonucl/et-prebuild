Bootstrap: localimage
From: ./ubuntu_22.04.sif

%help
Base container for the “APP_PROFILING one-liner” exercise.
Includes:
  • Python 3 and pip
  • pytest for the grading framework
Also pre-creates the unprivileged account “user” with home directory
/home/user, as required by the test-suite’s initial-state checks.

%post
    set -e

    # Update APT package lists and install Python and build essentials
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-setuptools \
        python3-wheel

    # Install pytest for test execution
    pip3 install --no-cache-dir --upgrade pytest

    # Create a dedicated non-root user ‘user’ with UID/GID 1000 and home dir /home/user
    if ! getent group 1000 >/dev/null; then
        groupadd -g 1000 user
    fi
    if ! id -u 1000 >/dev/null 2>&1; then
        useradd -m -u 1000 -g 1000 -s /bin/bash user
    fi

    # Ensure the home directory exists and is owned correctly
    mkdir -p /home/user
    chown -R 1000:1000 /home/user

    # Clean up APT caches to minimise image size
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # No APP_PROFILING variable is set here; the exercise requires it to be
    # introduced interactively by the learner.

%runscript
    exec /bin/bash

%labels
    Author="Exercise Maintainer"
    Description="Container environment for the APP_PROFILING one-line command exercise."