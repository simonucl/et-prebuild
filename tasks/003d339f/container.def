Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # Basic tooling
    apt-get update
    apt-get install -y --no-install-recommends python3-pip
    pip3 install --no-cache-dir pytest

    # Ensure a writable home for the student
    mkdir -p /home/user
    chmod 0777 /home/user   # world-writable so any invoking UID can work here

    # House-keeping
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Default HOME fallback (Apptainer will bind the caller’s HOME if possible)
    if [ -z "${HOME}" ]; then
        export HOME=/home/user
    fi
    export PYTHONDONTWRITEBYTECODE=1

%labels
    Author      Provisioning-Skeleton-Task
    Description Base image for the provisioning skeleton exercise with pytest installed.