Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    ########################################################################
    # 1. Install Python tooling required by the automated grader
    ########################################################################
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates
    pip3 install --no-cache-dir pytest

    ########################################################################
    # 2. Create initial filesystem state expected by the tests
    ########################################################################
    # Ensure /home/user is present and writable by the non-privileged user
    mkdir -p /home/user
    chmod 0777 /home/user

    # Application directories
    mkdir -p /home/user/app/logs

    # VERSION file
    cat <<'EOF' > /home/user/app/VERSION
v2.5.1-beta
EOF

    # Log files
    cat <<'EOF' > /home/user/app/logs/app01.log
2023-04-01T12:00:00Z INFO Application started
2023-04-01T12:00:05Z ERROR Failed to read config
2023-04-01T12:00:06Z INFO Retrying
EOF

    cat <<'EOF' > /home/user/app/logs/app02.log
2023-04-01T12:05:00Z INFO Task begin
2023-04-01T12:05:10Z INFO Task complete
EOF

    cat <<'EOF' > /home/user/app/logs/app03.log
2023-04-01T12:10:00Z DEBUG Verbose output
2023-04-01T12:10:01Z ERROR Connection lost
2023-04-01T12:10:02Z DEBUG Reconnecting
2023-04-01T12:10:03Z INFO Connection re-established
EOF

    # Set appropriate permissions: readable by anyone; writeable by owner
    chmod -R a+rX /home/user/app
    chmod 0644 /home/user/app/VERSION /home/user/app/logs/*.log

%runscript
    chmod 755 /home/user

    echo "Container for Support Diagnostics task. No default runtime action."