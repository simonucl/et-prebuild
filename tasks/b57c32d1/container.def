Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Basic utilities and Python tooling
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        passwd
    pip3 install --no-cache-dir pytest

    #
    # Create dedicated non-root user that will own the working area
    #
    useradd -m -u 1000 user

    #
    # Construct the initial release directory tree
    #
    RELEASE_DIR=/home/user/releases/v1.0
    mkdir -p "${RELEASE_DIR}/bin" "${RELEASE_DIR}/config"

    # 1) README.md
    echo "Project v1.0 — release notes." > "${RELEASE_DIR}/README.md"

    # 2) bin/start.sh
    printf '#!/usr/bin/env bash\necho '\''Starting v1.0'\''\n' \
        > "${RELEASE_DIR}/bin/start.sh"
    chmod 755 "${RELEASE_DIR}/bin/start.sh"

    # 3) config/settings.conf
    printf 'mode=production\nversion=1.0\n' \
        > "${RELEASE_DIR}/config/settings.conf"

    #
    # Directory where the student will place their artefacts
    #
    mkdir -p /home/user/releases_packages

    #
    # Ownership and permissions
    #
    chown -R user:user /home/user
    chmod 755 /home/user /home/user/releases /home/user/releases/v1.0 \
        /home/user/releases/v1.0/bin /home/user/releases/v1.0/config \
        /home/user/releases_packages
    chmod 644 "${RELEASE_DIR}/README.md" \
        "${RELEASE_DIR}/config/settings.conf"

%environment
    # Allow user-installed Python tools (if any) to be easily found
    export PATH="/home/user/.local/bin:${PATH}"

%labels
    Author    example
    Version   1.0
    Description "Environment for release-packaging exercise (pytest included)"