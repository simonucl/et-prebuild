Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ------------------------------------------------------------------
    # Install Python and pytest
    # ------------------------------------------------------------------
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create the required input directory and TSV file
    # ------------------------------------------------------------------
    mkdir -p /home/user/data
    chmod 0777 /home/user
    chmod 0777 /home/user/data

cat >/home/user/data/sales_2023.tsv <<'EOF'
order_id	product	units	unit_price	region
1001	Widget-A	25	9.99	NA
1002	Widget-B	50	19.99	EU
1003	Widget-C	10	4.99	APAC
EOF

    chmod 0666 /home/user/data/sales_2023.tsv

%environment
    chmod 755 /home/user

    # No special environment variables needed; keep the defaults.