Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Install Python and pytest
    apt-get update && \
        apt-get install -y --no-install-recommends python3 python3-pip && \
        pip3 install --no-cache-dir pytest && \
        apt-get clean && \
        rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Set up the initial workspace expected by the grading tests
    # ------------------------------------------------------------------
    mkdir -p /home/user/dev_project/raw_data

    # alpha.csv
    cat > /home/user/dev_project/raw_data/alpha.csv <<'EOF'
id,name,score
1,Alice,88
2,Bob,92
3,Charlie,67
EOF

    # beta.csv
    cat > /home/user/dev_project/raw_data/beta.csv <<'EOF'
id,name,score
4,Denise,75
5,Evan,83
6,Faith,91
EOF

    # Make sure the future (non-root) agent can read/write/move files
    chmod -R 0777 /home/user

%environment
    chmod 755 /home/user

    export PYTHONUNBUFFERED=1

%labels
    Author          "AI autogenerated"
    Description     "Container preset with initial dataset and pytest"