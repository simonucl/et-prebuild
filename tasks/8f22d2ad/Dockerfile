FROM ubuntu:22.04

# Help / labels
# Author: "AI autogenerated"
# Description: "Container preset with initial dataset and pytest"
LABEL Author="AI autogenerated" \
      Description="Container preset with initial dataset and pytest"

# Install Python and pytest
RUN apt-get update && \
    apt-get install -y --no-install-recommends python3 python3-pip && \
    pip3 install --no-cache-dir pytest && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Create workspace
RUN mkdir -p /home/user/dev_project/raw_data

# Create alpha.csv
RUN cat > /home/user/dev_project/raw_data/alpha.csv <<'EOF'
id,name,score
1,Alice,88
2,Bob,92
3,Charlie,67
EOF

# Create beta.csv
RUN cat > /home/user/dev_project/raw_data/beta.csv <<'EOF'
id,name,score
4,Denise,75
5,Evan,83
6,Faith,91
EOF

# Permissions
RUN chmod -R 0777 /home/user

# Environment settings
ENV PYTHONUNBUFFERED=1

# From %environment: chmod command must be executed at build time
RUN chmod 755 /home/user