Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ------------------------------------------------------------------ #
    # Basic tooling & pytest                                              #
    # ------------------------------------------------------------------ #
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------ #
    # Provision the initial ETL workspace                                #
    # ------------------------------------------------------------------ #
    mkdir -p /home/user/etl/input

    cat > /home/user/etl/input/sales_data.csv <<'CSV'
order_id,customer_id,date,product,quantity,unit_price
1001,501,2020-11-10,Laptop,2,799.99
1002,502,2021-01-05,Mouse,5,25.50
1003,503,2021-03-16,Keyboard,3,45.00
1004,504,2020-07-23,Monitor,1,189.99
1005,505,2021-12-30,Laptop,1,749.99
CSV

    # ------------------------------------------------------------------ #
    # Permissions                                                         #
    # ------------------------------------------------------------------ #
    # Read for everyone, execute (traverse) for directories, and write
    # access on the ETL workspace so the unprivileged student can create
    # output artefacts.
    chmod -R a+rX /home/user
    chmod -R a+w  /home/user/etl

%environment
    chmod 755 /home/user

    export PATH="/usr/local/bin:${PATH}"

%labels
    Author          "container-builder"
    Description     "Workspace for miniature ETL shell exercise; pytest pre-installed."

%runscript
    echo "ETL exercise container. Start your work in /home/user."
    exec /bin/bash "$@"