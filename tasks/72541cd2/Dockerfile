FROM ubuntu:22.04

# Labels
LABEL Author="autogenerated by ChatGPT"
LABEL Description="Initial workspace for API responses → CSV transformation task"

# Base system packages
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        jq \
        ca-certificates && \
    rm -rf /var/lib/apt/lists/*

# Python tooling – pytest for the grader
RUN pip3 install --no-cache-dir pytest

# Non-root user that the grader/agent will run as
RUN groupadd -g 1000 user || true && \
    useradd -m -u 1000 -g 1000 -s /bin/bash user || true

# Seed data: stubbed API responses
RUN mkdir -p /home/user/api_responses

# Create customers.json
RUN cat >/home/user/api_responses/customers.json <<'EOF'
[
  {"customer_id":1,"name":"Alice","country":"US"},
  {"customer_id":2,"name":"Bob","country":"CA"},
  {"customer_id":3,"name":"Charlie","country":"US"}
]
EOF

# Create orders.json
RUN cat >/home/user/api_responses/orders.json <<'EOF'
[
  {"order_id":101,"customer_id":1,"item":"Keyboard","quantity":2},
  {"order_id":102,"customer_id":1,"item":"Mouse","quantity":1},
  {"order_id":103,"customer_id":2,"item":"Monitor","quantity":1},
  {"order_id":104,"customer_id":3,"item":"Webcam","quantity":3}
]
EOF

# Create payments.json
RUN cat >/home/user/api_responses/payments.json <<'EOF'
[
  {"payment_id":5001,"order_id":101,"amount":40.00,"currency":"USD"},
  {"payment_id":5002,"order_id":102,"amount":25.00,"currency":"USD"},
  {"payment_id":5003,"order_id":103,"amount":200.00,"currency":"CAD"},
  {"payment_id":5004,"order_id":104,"amount":90.00,"currency":"USD"}
]
EOF

# Ensure correct ownership and a clean workspace
RUN chown -R 1000:1000 /home/user && \
    if [ -d /home/user/output ]; then rm -rf /home/user/output; fi

# Environment variables
ENV PATH="/home/user/.local/bin:$PATH"

# Set permissions on home directory
RUN chmod 755 /home/user

WORKDIR /home/user

# Help information as comments
# Container for the API → CSV transformation task.
# Switch to the 'user' account to begin your work.