Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ---------------------------------------------------------------------
    # Base system packages
    # ---------------------------------------------------------------------
    apt-get update && \
        apt-get install -y --no-install-recommends \
            python3 \
            python3-pip \
            jq \
            ca-certificates && \
        rm -rf /var/lib/apt/lists/*

    # ---------------------------------------------------------------------
    # Python tooling – pytest for the grader
    # ---------------------------------------------------------------------
    pip3 install --no-cache-dir pytest

    # ---------------------------------------------------------------------
    # Non-root user that the grader/agent will run as
    # ---------------------------------------------------------------------
    groupadd -g 1000 user || true
    useradd  -m -u 1000 -g 1000 -s /bin/bash user || true

    # ---------------------------------------------------------------------
    # Seed data: stubbed API responses
    # ---------------------------------------------------------------------
    mkdir -p /home/user/api_responses

    cat >/home/user/api_responses/customers.json <<'EOF'
[
  {"customer_id":1,"name":"Alice","country":"US"},
  {"customer_id":2,"name":"Bob","country":"CA"},
  {"customer_id":3,"name":"Charlie","country":"US"}
]
EOF

    cat >/home/user/api_responses/orders.json <<'EOF'
[
  {"order_id":101,"customer_id":1,"item":"Keyboard","quantity":2},
  {"order_id":102,"customer_id":1,"item":"Mouse","quantity":1},
  {"order_id":103,"customer_id":2,"item":"Monitor","quantity":1},
  {"order_id":104,"customer_id":3,"item":"Webcam","quantity":3}
]
EOF

    cat >/home/user/api_responses/payments.json <<'EOF'
[
  {"payment_id":5001,"order_id":101,"amount":40.00,"currency":"USD"},
  {"payment_id":5002,"order_id":102,"amount":25.00,"currency":"USD"},
  {"payment_id":5003,"order_id":103,"amount":200.00,"currency":"CAD"},
  {"payment_id":5004,"order_id":104,"amount":90.00,"currency":"USD"}
]
EOF

    # ---------------------------------------------------------------------
    # Ensure correct ownership and a clean workspace
    # ---------------------------------------------------------------------
    chown -R 1000:1000 /home/user

    # The output directory must NOT exist in the initial state
    if [ -d /home/user/output ]; then
        rm -rf /home/user/output
    fi

%environment
    chmod 755 /home/user

    # Ensure Python and user-local binaries are on PATH
    export PATH="/home/user/.local/bin:$PATH"

%runscript
    echo "Container for the API → CSV transformation task."
    echo "Switch to the 'user' account to begin your work:"
    echo "    apptainer exec --pwd /home/user $SINGULARITY_CONTAINER bash"

%labels
    Author="autogenerated by ChatGPT"
    Description="Initial workspace for API responses → CSV transformation task"