Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install python, pip and pytest dependencies
    apt-get update
    # Install Python and pip (python3 is pre-installed, but pip might not be)
    apt-get install -y --no-install-recommends python3 python3-pip
    # Install pytest via pip to ensure a recent version
    pip3 install --no-cache-dir pytest

    # -------------------------------------------------------------------------
    # Prepare the initial filesystem state required by the exercise
    # -------------------------------------------------------------------------

    # Create the compliance directory hierarchy
    mkdir -p /home/user/compliance

    # Populate the pre-existing audit file with the exact sanctioned content
    cat >/home/user/compliance/failed_logins.tsv <<'EOF'
username	ip_address	timestamp	attempts
alice	10.0.0.5	2023-08-01T12:01:22Z	3
bob	10.0.0.6	2023-08-01T12:02:17Z	7
carol	10.0.0.7	2023-08-01T12:04:03Z	5
dave	10.0.0.8	2023-08-01T12:05:55Z	10
EOF

    # Ensure sensible permissions so the non-root runtime user can read/write
    chmod 0755 /home/user /home/user/compliance
    chmod 0644 /home/user/compliance/failed_logins.tsv

%environment
    chmod 755 /home/user

    # Do not override $HOME; leave Apptainer defaults.
    export LC_ALL=C.UTF-8
    export PYTHONUNBUFFERED=1

%runscript
    echo "This container is set up for the 'account-lockout policy' exercise."
    echo "Invoke your shell or tooling as needed."