Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python, pip, pytest and supporting utilities
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        procps

    pip3 install --no-cache-dir pytest

    # Ensure the unprivileged working directory exists and is writable
    if ! id -u user >/dev/null 2>&1; then
        useradd -m -d /home/user -s /bin/bash user
    fi
    mkdir -p /home/user
    chmod 0777 /home/user

    # Guarantee a clean slate for the forthcoming exercise
    rm -rf /home/user/sre || true

    # Clean up APT cache to minimise image size
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    export PATH=/usr/local/bin:/usr/bin:/bin
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    echo "This container provides the base environment for the SRE heartbeat monitoring task."