Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    export DEBIAN_FRONTEND=noninteractive

    # Update package list and install Python + pip
    apt-get update -qq
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        procps \
        ca-certificates
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare the directory tree expected by the exercise
    # ------------------------------------------------------------------
    # Create /home and the working user's directory; make it writable by any uid
    mkdir -p /home/user
    chmod 0777 /home/user

    # Dataset tree
    DATASETS_ROOT="/home/user/datasets"
    mkdir -p "${DATASETS_ROOT}/experiment_alpha"
    mkdir -p "${DATASETS_ROOT}/experiment_beta/raw"

    # Create the dataset files with the exact contents/sizes required
    printf 'id,value\n1,42\n' > "${DATASETS_ROOT}/experiment_alpha/data1.csv"
    printf 'id,value\n2,84\n' > "${DATASETS_ROOT}/experiment_alpha/data2.csv"
    printf '{"status":"ok"}\n'  > "${DATASETS_ROOT}/experiment_beta/results.json"
    printf 'run1 done\n'       > "${DATASETS_ROOT}/experiment_beta/raw/run1.txt"

    # Ensure everything is world-readable
    chmod -R a+rX "${DATASETS_ROOT}"

    # Do NOT create /home/user/research_logs or any diagnostic log;
    # those are to be generated later by the learner.


%environment
    chmod 755 /home/user

    # Make sure Python points to python3
    export PYTHONIOENCODING=utf-8
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH


%labels
    Author "Autogenerated for life-science diagnostic exercise"

%help
    This container provides the starting environment for the diagnostic-log
    exercise.  It contains a small reference dataset under /home/user/datasets
    and has pytest pre-installed for automated grading.  No diagnostic logs are
    present; learners will generate them at runtime.