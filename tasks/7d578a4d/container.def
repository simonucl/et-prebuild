Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package index and install Python + pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install pytest for the test-runner
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------ #
    # Create the non-root user and its home directory
    # ------------------------------------------------------------------ #
    # Use UID/GID 1000 if they are free; ignore errors if they already exist
    groupadd -g 1000 user || true
    useradd  -m -u 1000 -g 1000 user || true

    # ------------------------------------------------------------------ #
    # Set up initial observability configuration
    # ------------------------------------------------------------------ #
    OBS_DIR="/home/user/observability"
    mkdir -p "${OBS_DIR}"

    # watchers.yaml (initial, unedited state)
    cat > "${OBS_DIR}/watchers.yaml" <<'YAML'
alerts:
  cpu_usage:
    enabled: true
    threshold: 85
  memory_usage:
    enabled: true
    threshold: 90
YAML

    # grafana.toml (initial, unedited state)
    cat > "${OBS_DIR}/grafana.toml" <<'TOML'
[auth]
disable_login_form = false

[users]
allow_sign_up  = true
default_theme  = "light"
TOML

    # Ensure the regular user owns its files
    chown -R 1000:1000 /home/user

    # Clean up apt cache to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Make sure Python binaries installed by pip are on PATH
    export PATH="$PATH:/usr/local/bin"

%labels
    Author "Apptainer Task Preparer"
    Description "Container providing initial state for observability configuration task."

%help
    This container sets up the initial file system state for the observability
    configuration challenge.  Two configuration files live in
    /home/user/observability with their original values, and pytest is
    installed so the autograder can verify the initial state.