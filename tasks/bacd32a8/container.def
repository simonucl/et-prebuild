Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Update package lists and install Python and pip
    apt-get update && \
        apt-get install -y --no-install-recommends python3 python3-pip && \
        rm -rf /var/lib/apt/lists/*

    # Install pytest for the autograder
    pip3 install --no-cache-dir pytest

    # Ensure the non-privileged user’s home directory exists and is writable
    mkdir -p /home/user
    chmod 777 /home/user

%environment
    chmod 755 /home/user

    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"
    export LC_ALL="C.UTF-8"
    export LANG="C.UTF-8"

%labels
    Author edge-computing-prep
    Description Base container for IoT edge mini-stack assignment – clean slate with pytest installed.