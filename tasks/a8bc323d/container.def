Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "Updating package lists and installing required packages..."
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        jq \
        python3 \
        python3-pip

    echo "Installing pytest via pip..."
    pip3 install --no-cache-dir pytest

    echo "Creating directory structure..."
    mkdir -p /home/user/storage
    mkdir -p /home/user/reports

    echo "Setting directory permissions to 0755..."
    chmod 0755 /home/user
    chmod 0755 /home/user/storage
    chmod 0755 /home/user/reports

    echo "Adding initial disks.json inventory..."
    cat > /home/user/storage/disks.json <<'EOF'
[
  { "name": "sda", "size_gb": 950 },
  { "name": "sdb", "size_gb": 1200 },
  { "name": "sdc", "size_gb": 500 }
]
EOF

    echo "Setting file permissions to 0644..."
    chmod 0644 /home/user/storage/disks.json

    echo "Cleanup apt caches..."
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure Python and pip are in PATH (usually already, but safe to export).
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
    export PYTHONUNBUFFERED=1

%labels
    Author "Container build for jq one-liner validation task"
    Description "Provides jq, pytest, and pre-populated /home/user environment for the agent."