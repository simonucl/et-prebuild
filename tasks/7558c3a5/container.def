Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Refresh APT metadata so that `apt-cache policy openssl` has package data
    apt-get update -y

    # Install Python and pip so we can add pytest for the grading harness
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install pytest (needed by the autograder)
    pip3 install --no-cache-dir pytest

    # Ensure the expected home directory for the student exists and is writable
    mkdir -p /home/user
    chmod 0777 /home/user

%environment
    chmod 755 /home/user

    # Make sure the standard local binary path is available
    export PATH="/usr/local/bin:${PATH}"