Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Update package index and install required system packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        openssh-client \
        python3 \
        python3-pip \
        ca-certificates \
        git
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Install Python testing utilities
    pip3 install --no-cache-dir pytest pyyaml

    # Create non-privileged user “user” with home directory /home/user
    if ! id -u user >/dev/null 2>&1; then
        useradd -m -s /bin/bash user
    fi

    # Ensure the home directory exists with sane permissions
    mkdir -p /home/user
    chown -R user:user /home/user
    chmod 755 /home/user

%environment
    # Default environment for the non-privileged user
    export HOME=/home/user
    export PATH=/usr/local/bin:/usr/local/sbin:/usr/bin:/usr/sbin:/bin:/sbin

%labels
    Author="DevSecOps Challenge Image"
    Description="Base image for SSH policy-as-code exercise with pytest pre-installed."