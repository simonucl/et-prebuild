FROM ubuntu:22.04

# Labels
LABEL Author="Generated by ChatGPT"
LABEL Description="Container for ML data validation task – seeds raw JSON files and installs pytest."

# Install required tools
RUN set -e && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3-pip \
        jq \
        ca-certificates && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Install pytest (and jsonschema – handy for the agent)
RUN pip3 install --no-cache-dir pytest jsonschema

# Prepare initial directory structure
RUN mkdir -p /home/user/ml_data/raw && \
    mkdir -p /home/user/ml_data/schema

# Create training_v1.json
RUN cat > /home/user/ml_data/raw/training_v1.json <<'EOF'
[
  {"text": "Hello world", "label": "greeting"},
  {"text": "Goodbye", "label": "farewell"},
  {"text": "How are you"},
  {"text": "What's up?", "label": "greeting"},
  {"text": "See you", "label": "farewell"}
]
EOF

# Create training_v2.json
RUN cat > /home/user/ml_data/raw/training_v2.json <<'EOF'
[
  {"text": "Buy now", "label": "advertisement"},
  {"label": "statement"},
  {"text": "Great job!", "label": "praise"},
  {"text": "Error sample"},
  {"text": "Thanks", "label": "gratitude"}
]
EOF

# Create record_schema.json
RUN cat > /home/user/ml_data/schema/record_schema.json <<'EOF'
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Training record",
  "type": "object",
  "properties": {
    "text": { "type": "string" },
    "label": { "type": "string" }
  },
  "required": ["text", "label"],
  "additionalProperties": false
}
EOF

# Ensure everything is world-readable
RUN chmod -R a+rX /home/user/ml_data

# Environment variables
ENV PATH="/usr/local/bin:/usr/bin:/bin:${PATH}"

# Set permissions on home directory
RUN chmod 755 /home/user

WORKDIR /home/user