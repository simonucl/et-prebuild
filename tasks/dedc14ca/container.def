Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install required tools
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3-pip \
        jq \
        ca-certificates \
        && apt-get clean && rm -rf /var/lib/apt/lists/*

    # Install pytest (and jsonschema – handy for the agent)
    pip3 install --no-cache-dir pytest jsonschema

    # ------------------------------------------------------------------
    # Prepare initial directory structure and seed data files
    # ------------------------------------------------------------------
    mkdir -p /home/user/ml_data/raw
    mkdir -p /home/user/ml_data/schema

    # training_v1.json
    cat > /home/user/ml_data/raw/training_v1.json <<'EOF'
[
  {"text": "Hello world", "label": "greeting"},
  {"text": "Goodbye", "label": "farewell"},
  {"text": "How are you"},
  {"text": "What's up?", "label": "greeting"},
  {"text": "See you", "label": "farewell"}
]
EOF

    # training_v2.json
    cat > /home/user/ml_data/raw/training_v2.json <<'EOF'
[
  {"text": "Buy now", "label": "advertisement"},
  {"label": "statement"},
  {"text": "Great job!", "label": "praise"},
  {"text": "Error sample"},
  {"text": "Thanks", "label": "gratitude"}
]
EOF

    # record_schema.json
    cat > /home/user/ml_data/schema/record_schema.json <<'EOF'
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Training record",
  "type": "object",
  "properties": {
    "text": { "type": "string" },
    "label": { "type": "string" }
  },
  "required": ["text", "label"],
  "additionalProperties": false
}
EOF

    # Ensure everything is world-readable
    chmod -R a+rX /home/user/ml_data

%environment
    chmod 755 /home/user

    export PATH="/usr/local/bin:/usr/bin:/bin:${PATH}"

%labels
    Author "Generated by ChatGPT"
    Description "Container for ML data validation task – seeds raw JSON files and installs pytest."