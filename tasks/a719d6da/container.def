Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Update package lists and install essential tools
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3-pip

    # Install pytest for the automated grader
    pip3 install --no-cache-dir pytest

    # Prepare a writable home directory for the unprivileged runtime user
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up APT caches to reduce image size
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure standard binary locations are in PATH
    export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:$PATH"

%runscript
    echo "Container for system-diagnostics assignment. Open a shell to begin."