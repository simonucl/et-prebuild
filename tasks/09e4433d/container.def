Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install Python + pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        && apt-get clean && rm -rf /var/lib/apt/lists/*

    # Install pytest for the evaluation framework
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare the directory structure and the sample manifest input file
    # ------------------------------------------------------------------
    BASE_DIR="/home/user/backup_test"
    INPUT_DIR="${BASE_DIR}/input"

    # Create directories with safe, world-readable permissions
    mkdir -p "${INPUT_DIR}"
    chmod 755 /home /home/user || true   # in case they don't already exist
    chmod 755 "${BASE_DIR}" "${INPUT_DIR}"

    MANIFEST="${INPUT_DIR}/manifest.log"

    # Create the manifest file with exact expected contents
    cat > "${MANIFEST}" <<'EOF'
2024-06-01 01:00:00 /var/www/html/index.html 2048 OK
2024-06-01 01:00:05 /var/log/syslog 1048576 OK
2024-06-01 01:00:10 /etc/passwd 4096 FAILED
2024-06-01 01:00:15 /home/user/data/report.pdf 8192 OK
2024-06-01 01:00:20 /home/user/secret/notes.txt 1234 FAILED
EOF

    # Ensure manifest permissions are exactly 0644
    chmod 644 "${MANIFEST}"

%labels
    chmod 755 /home/user

    Author backup-operator-exercise
    Description "Base image for backup manifest parsing task"

%help
This container provides the initial state for the backup manifest
exercise. It contains:
  • Python 3 with pytest pre-installed for automated grading.
  • The required manifest file located at
        /home/user/backup_test/input/manifest.log
    with correct contents and permissions.

Students are expected to create their output files under
    /home/user/backup_test/output/
without needing root privileges.

%environment
# No special environment variables are required for this task.

%runscript
exec "$@"