Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    ############################################################
    # 1) Install required system packages
    ############################################################
    apt-get update -y
    # sqlite3 (database CLI), gzip & coreutils (sha256sum is in coreutils),
    # python3 and pip (for pytest)
    apt-get install -y --no-install-recommends \
        sqlite3 \
        gzip \
        coreutils \
        python3 \
        python3-pip

    ############################################################
    # 2) Install pytest for the verification framework
    ############################################################
    pip3 install --no-cache-dir pytest

    ############################################################
    # 3) Create initial directory structure and database
    ############################################################
    # Create /home/user with wide permissions so the non-root
    # runtime user can write inside it (needed for the backup task).
    mkdir -p /home/user
    chmod 0777 /home/user

    # Create the data directory
    mkdir -p /home/user/data
    chmod 0755 /home/user/data

    # Build the SQLite database with the required schema & rows
    cat <<'SQL' | sqlite3 /home/user/data/sales.db
    PRAGMA journal_mode=WAL;
    CREATE TABLE customers(id INTEGER PRIMARY KEY, name TEXT, email TEXT);
    CREATE TABLE orders(id INTEGER PRIMARY KEY, customer_id INTEGER, amount REAL, created_at TEXT);
    INSERT INTO customers(id, name, email) VALUES
        (1, 'Alice', 'alice@example.com'),
        (2, 'Bob',   'bob@example.com');
    INSERT INTO orders(id, customer_id, amount, created_at) VALUES
        (1, 1, 123.45, '2023-01-10'),
        (2, 2,  99.99, '2023-01-11');
SQL

    # Ensure the database file is world-readable (needed for the read-only tests)
    chmod 0644 /home/user/data/sales.db

    ############################################################
    # 4) Clean up APT caches to keep the image small
    ############################################################
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Keep PATH sane; python & sqlite3 should already be in default PATH.
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%labels
    Author="Generated by AI"
    Description="Container for SQLite backup task with pytest pre-installed."

%help
    This Apptainer image provides the starting environment for the
    "SQLite Backup" task.  It contains:
      • An SQLite database at /home/user/data/sales.db
      • Python 3 with pytest
      • Command-line tools: sqlite3, gzip, sha256sum

    Students are expected to create the backup artefacts under
    /home/user/archive/2023-01-15 as described in the assignment.