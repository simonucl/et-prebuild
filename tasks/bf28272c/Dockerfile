FROM ubuntu:22.04

# Labels
LABEL Author="Generated by AI"
LABEL Description="Container for SQLite backup task with pytest pre-installed."

# Install required system packages
RUN set -e && \
    apt-get update -y && \
    apt-get install -y --no-install-recommends \
        sqlite3 \
        gzip \
        coreutils \
        python3 \
        python3-pip && \
    pip3 install --no-cache-dir pytest && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Create initial directory structure
RUN mkdir -p /home/user && \
    chmod 0777 /home/user && \
    mkdir -p /home/user/data && \
    chmod 0755 /home/user/data

# Build the SQLite database with the required schema & rows
RUN cat <<'SQL' | sqlite3 /home/user/data/sales.db
PRAGMA journal_mode=WAL;
CREATE TABLE customers(id INTEGER PRIMARY KEY, name TEXT, email TEXT);
CREATE TABLE orders(id INTEGER PRIMARY KEY, customer_id INTEGER, amount REAL, created_at TEXT);
INSERT INTO customers(id, name, email) VALUES
    (1, 'Alice', 'alice@example.com'),
    (2, 'Bob',   'bob@example.com');
INSERT INTO orders(id, customer_id, amount, created_at) VALUES
    (1, 1, 123.45, '2023-01-10'),
    (2, 2,  99.99, '2023-01-11');
SQL

# Ensure the database file is world-readable
RUN chmod 0644 /home/user/data/sales.db

# Set environment variables
ENV LC_ALL=C.UTF-8
ENV LANG=C.UTF-8

WORKDIR /home/user

# Help information (as comments):
# This container image provides the starting environment for the
# "SQLite Backup" task.  It contains:
#   • An SQLite database at /home/user/data/sales.db
#   • Python 3 with pytest
#   • Command-line tools: sqlite3, gzip, sha256sum
#
# Students are expected to create the backup artefacts under
# /home/user/archive/2023-01-15 as described in the assignment.