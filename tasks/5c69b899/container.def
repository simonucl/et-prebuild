Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install Python + pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare the initial data required by the assignment
    # ------------------------------------------------------------------
    mkdir -p /home/user/data

    # January sales
    cat <<'EOF' > /home/user/data/sales_january.csv
Date,Region,Product,Units,Unit_Price
2021-01-03,East,Gadget,10,19.99
2021-01-05,West,Widget,5,25.00
2021-01-10,East,Widget,7,25.00
EOF

    # February sales
    cat <<'EOF' > /home/user/data/sales_february.csv
Date,Region,Product,Units,Unit_Price
2021-02-12,North,Gadget,3,19.99
2021-02-15,East,Widget,9,25.00
2021-02-20,East,Gadget,4,19.99
EOF

    # Give non-root users read/write access to the prepared files
    chmod -R a+rwX /home/user

%environment
    chmod 755 /home/user

    # Keep PATH predictable and do not override HOME
    export PATH=/usr/local/bin:/usr/bin:/bin

%labels
    Author "Generated by ChatGPT – Apptainer task setup"
    Description "Container with initial CSV data and pytest installed for the Q1 East-region sales extraction task."

%help
    This container supplies the pristine starting state for the “East-region
    Q1 sales extraction” task.  It contains:
      • /home/user/data/sales_january.csv
      • /home/user/data/sales_february.csv
    plus Python and pytest for automated grading.