# syntax=docker/dockerfile:1
FROM ubuntu:22.04

# ------------------------------------------------------------------
# Labels (from %labels)
# ------------------------------------------------------------------
LABEL Author="Generated by ChatGPT – Apptainer task setup"
LABEL Description="Container with initial CSV data and pytest installed for the Q1 East-region sales extraction task."

# ------------------------------------------------------------------
# Post section: install dependencies and prepare data
# ------------------------------------------------------------------
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked --mount=type=cache,target=/var/lib/apt,sharing=locked --mount=type=cache,target=/root/.cache/pip set -e && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip && \
    pip3 install --no-cache-dir pytest && \
    rm -rf /var/lib/apt/lists/*

# Prepare initial data directory
RUN mkdir -p /home/user/data

# January sales data
RUN cat <<'EOF' > /home/user/data/sales_january.csv
Date,Region,Product,Units,Unit_Price
2021-01-03,East,Gadget,10,19.99
2021-01-05,West,Widget,5,25.00
2021-01-10,East,Widget,7,25.00
EOF

# February sales data
RUN cat <<'EOF' > /home/user/data/sales_february.csv
Date,Region,Product,Units,Unit_Price
2021-02-12,North,Gadget,3,19.99
2021-02-15,East,Widget,9,25.00
2021-02-20,East,Gadget,4,19.99
EOF

# Give non-root users read/write access to the prepared files
RUN chmod -R a+rwX /home/user && \
    chmod 755 /home/user

# ------------------------------------------------------------------
# Environment variables (from %environment)
# ------------------------------------------------------------------
ENV PATH=/usr/local/bin:/usr/bin:/bin

# ------------------------------------------------------------------
# Help (from %help)
# ------------------------------------------------------------------
# This container supplies the pristine starting state for the “East-region
# Q1 sales extraction” task. It contains:
#   • /home/user/data/sales_january.csv
#   • /home/user/data/sales_february.csv
# plus Python and pytest for automated grading.