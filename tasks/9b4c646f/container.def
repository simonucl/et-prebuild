Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update apt and install prerequisites
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        curl

    # Install pytest for the grading framework
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create the project directory structure and seed initial files
    # ------------------------------------------------------------------
    mkdir -p /home/user/project

    # package.json with initial version 1.2.3
    cat > /home/user/project/package.json <<'EOF'
{
  "name": "myapp",
  "version": "1.2.3",
  "description": "Sample app"
}
EOF

    # CHANGELOG.md with required pre-bump content
    cat > /home/user/project/CHANGELOG.md <<'EOF'
# Changelog

All notable changes to this project will be documented in this file.

## [Unreleased]

### Added
- Initial stub entries.

## [1.2.3] - 2023-08-01
### Added
- Previous stuff.
EOF

    # Ensure write permissions for the non-root runtime user
    chmod -R a+rw /home/user

%environment
    chmod 755 /home/user

    export PROJECT_DIR=/home/user/project
    export PATH=$PATH:/home/user/.local/bin

%runscript
    echo "Apptainer container for version-bump task."
    echo "Project directory: /home/user/project"
    exec "$@"