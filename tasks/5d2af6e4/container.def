Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package list and install Python & pip
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Create a non-privileged user `user` (UID 1000 / GID 1000)
    # ------------------------------------------------------------------
    if ! getent group 1000 >/dev/null; then
        groupadd -g 1000 user
    fi

    if ! id -u 1000 >/dev/null 2>&1; then
        useradd -m -u 1000 -g 1000 -s /bin/bash user
    fi

    # ------------------------------------------------------------------
    # Prepare initial filesystem state expected by the tests
    # ------------------------------------------------------------------
    # /home/user already exists because of `useradd -m`
    chown 1000:1000 /home/user
    chmod 755 /home/user

    # Create /home/user/new-certs with required permissions and contents
    mkdir -p /home/user/new-certs
    chown 1000:1000 /home/user/new-certs
    chmod 755 /home/user/new-certs

    # Create the initial certificate file (exactly 3 bytes: "abc")
    printf 'abc' > /home/user/new-certs/internal.pem
    chown 1000:1000 /home/user/new-certs/internal.pem
    chmod 644 /home/user/new-certs/internal.pem

%environment
    # Make sure Python and pip are on the path
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%runscript
    echo "Container for certificate-management task."
    echo "Switch to the non-privileged user with:  su - user"
    echo "Then perform the required operations."