Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update APT and install Python & pip
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the grading harness
    pip3 install --no-cache-dir pytest

    # -----------------------------------------------------------------
    # Prepare filesystem layout expected by the exercise’s test suite
    # -----------------------------------------------------------------
    # Create the user’s home directory hierarchy
    mkdir -p /home/user/backup

    # Ensure the backup directory is writable by any (non-root) user
    chmod 0777 /home/user/backup

    # Populate the initial input file with the exact specified content.
    cat > /home/user/backup/files_to_backup.txt <<'EOF'
/etc/hosts
/home/user/data/report1.csv
/etc/hosts
/var/log/syslog
/home/user/data/report2.csv
/var/log/syslog
EOF

    # Make the file world-readable (and writable if the agent wants to edit it)
    chmod 0666 /home/user/backup/files_to_backup.txt

%environment
    chmod 755 /home/user

    # Ensure Python and pip are in PATH for the agent
    export PATH="/usr/local/bin:$PATH"

%labels
    Author "Apptainer Build Script for Backup Manifest Task"