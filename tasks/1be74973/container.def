Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python, pip and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Prepare initial filesystem state expected by the automated tests
    # ------------------------------------------------------------------

    # Create the user and group referenced in the description (uid/gid 1000)
    groupadd -g 1000 user || true
    useradd  -u 1000 -g 1000 -d /home/user -s /bin/bash user || true

    # Create required directories
    mkdir -p /home/user/logs

    # Create sample application log with exact contents
cat << 'EOF' > /home/user/logs/app.log
[2024-06-01 10:00:00] INFO  AuthService - User john.doe logged in.
[2024-06-01 10:01:00] WARN  PaymentService - Timeout while processing transaction #872364.
[2024-06-01 10:02:15] ERROR InventoryService - NullPointerException at line 231.
[2024-06-01 10:03:42] DEBUG CacheService - Cache hit for key 192.168.1.15.
[2024-06-01 10:04:01] INFO  AuthService - User jane.smith logged out.
[2024-06-01 10:05:23] WARN  PaymentService - Retry attempt 1 for transaction #872365.
[2024-06-01 10:06:47] ERROR InventoryService - ArrayIndexOutOfBoundsException at line 78.
[2024-06-01 10:07:55] INFO  BillingService - Invoice #98234 generated successfully.
EOF

    # Set permissions as required by tests
    chmod 755 /home/user
    chmod 755 /home/user/logs
    chmod 644 /home/user/logs/app.log
    chown -R 1000:1000 /home/user

    # DO NOT create /home/user/logs/filtered here; it must be absent initially.

%environment
    export LC_ALL=C
    export PYTHONIOENCODING=UTF-8

%labels
    Author="Container build for log filtering task"
    Description="Provides initial state and pytest for automated evaluation."