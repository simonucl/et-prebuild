# Author="Generated by AI - Apptainer setup for diagnostics task"
# This container provides the starting environment for the diagnostics assignment.
# It includes:
#   • jq
#   • pytest (and jsonschema)
#   • Pre-populated /home/user/diagnostics/ directory with the required JSON files.

FROM ubuntu:22.04

RUN set -e && \
    apt-get update -y && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        jq \
        python3-pip && \
    pip3 install --no-cache-dir pytest jsonschema && \
    mkdir -p /home/user/diagnostics

RUN cat <<'EOF' > /home/user/diagnostics/raw_diagnostic.json
{
  "device_id": "router-4431",
  "uptime_seconds": 86400,
  "firmware_version": "v1.2.3",
  "interfaces": [
    {
      "name": "eth0",
      "rx_packets": 120000,
      "tx_packets": 118000,
      "status": "up"
    },
    {
      "name": "eth1",
      "rx_packets": 50000,
      "tx_packets": 52000,
      "status": "down"
    }
  ]
}
EOF

RUN cat <<'EOF' > /home/user/diagnostics/device_schema.json
{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "required": ["device_id", "uptime_seconds", "firmware_version", "interfaces"],
  "properties": {
    "device_id":       { "type": "string" },
    "uptime_seconds":  { "type": "integer", "minimum": 0 },
    "firmware_version":{ "type": "string" },
    "interfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "rx_packets", "tx_packets", "status"],
        "properties": {
          "name":       { "type": "string" },
          "rx_packets": { "type": "integer", "minimum": 0 },
          "tx_packets": { "type": "integer", "minimum": 0 },
          "status":     { "type": "string", "enum": ["up", "down"] }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
EOF

RUN chmod 755 /home/user && \
    chmod 755 /home/user/diagnostics && \
    chmod 644 /home/user/diagnostics/raw_diagnostic.json && \
    chmod 644 /home/user/diagnostics/device_schema.json && \
    rm -f /home/user/diagnostics/support_summary.log