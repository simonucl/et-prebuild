Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Basic tooling
    apt-get update && \
        apt-get install -y --no-install-recommends \
            python3 \
            python3-pip \
            jq \
        && apt-get clean && rm -rf /var/lib/apt/lists/*

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial repository state expected by the automated tests
    # ------------------------------------------------------------------
    mkdir -p /home/user/infra-observability
    cd /home/user/infra-observability

    # 1. VERSION
    echo '1.3.4' > VERSION

    # 2. package.json
    cat > package.json <<'EOF'
{
    "name": "infra-observability",
    "version": "1.3.4",
    "private": true,
    "description": "Internal dashboards and alerts"
}
EOF

    # 3. CHANGELOG.md
    cat > CHANGELOG.md <<'EOF'
<!-- Changelog follows keep-a-changelog style -->
## [1.3.4] – 2024-05-22
### Added
- Initial latency dashboard.

EOF

    # Make sure everything is writable by the runtime (non-root) user
    chmod -R a+rwX /home/user/infra-observability
    chmod 777 /home/user

%environment
    chmod 755 /home/user

    # Ensure user-level Python installs (if any) are on PATH
    export PATH="${PATH}:${HOME}/.local/bin"