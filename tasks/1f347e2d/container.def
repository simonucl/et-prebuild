Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "Updating apt cache and installing required packages..."
    apt-get update -qq
    # Python3 is pre-installed on ubuntu:22.04 but pip is not guaranteed
    apt-get install -y --no-install-recommends python3-pip
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    echo "Installing pytest for the validation framework..."
    pip3 install --no-cache-dir pytest

    echo "Creating initial directory structure and sample INI files..."
    mkdir -p /home/user/iot_configs
    chmod 755 /home/user
    chmod 755 /home/user/iot_configs

    cat >/home/user/iot_configs/device_alpha.ini <<'EOF'
[Network]
ip = 192.168.10.11
location = RoofTop

[Sensors]
enabled = temp,humidity,pressure

[System]
os = TinyLinux
last_maintained = 2023-05-10
EOF

    cat >/home/user/iot_configs/device_beta.ini <<'EOF'
[Network]
ip = 192.168.10.12
location = Warehouse55

[Sensors]
enabled = temp,vibration

[System]
os = TinyLinux
last_maintained = 2023-04-01
EOF

    cat >/home/user/iot_configs/device_gamma.ini <<'EOF'
[Network]
ip = 192.168.10.13
location = Dock

[Sensors]
enabled = temp,humidity,air_quality,co2

[System]
os = TinyLinux
last_maintained = 2022-12-15
EOF

    chmod 644 /home/user/iot_configs/device_*.ini

    echo "Initial container setup complete."

%environment
    # Keep the environment minimal but predictable.
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
    export PYTHONIOENCODING=UTF-8