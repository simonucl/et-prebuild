Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state for the credential-rotation task
    # ------------------------------------------------------------------
    mkdir -p /home/user/credentials

    # settings.yml with OLD_* values
    cat <<'EOF' > /home/user/credentials/settings.yml
aws:
  access_key_id: OLD_ACCESS_KEY
  secret_access_key: OLD_SECRET_KEY
database:
  user: dbuser
  password: verysecret
EOF

    # settings.toml with OLD_* values
    cat <<'EOF' > /home/user/credentials/settings.toml
[aws]
access_key_id = "OLD_ACCESS_KEY"
secret_access_key = "OLD_SECRET_KEY"

[database]
user = "dbuser"
password = "verysecret"
EOF

    # Ensure permissions are exactly 0644
    chmod 0644 /home/user/credentials/settings.yml
    chmod 0644 /home/user/credentials/settings.toml

%environment
    chmod 755 /home/user

    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
    export PYTHONUNBUFFERED=1