Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ------------------------------------------------------------------
    # Basic OS packages + Python tooling for the automated pytest suite
    # ------------------------------------------------------------------
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create the required directory structure and template files
    # ------------------------------------------------------------------
    mkdir -p /home/user/qa_envs/base
    mkdir -p /home/user/qa_envs/overrides
    mkdir -p /home/user/qa_envs/generated

    # -------- base/app_config.yml --------
    cat > /home/user/qa_envs/base/app_config.yml <<'EOF'
app:
  name: DemoApp
  version: "1.0.0"
  debug: false
database:
  host: localhost
  port: 5432
  username: demo
  password: demo123
EOF

    # -------- overrides/dev.yml --------
    cat > /home/user/qa_envs/overrides/dev.yml <<'EOF'
app:
  version: "1.1.0"
  debug: true
database:
  host: dev-db.internal
  port: 5433
  username: dev_user
  password: dev_pass
features:
  experimental: true
  logging: verbose
EOF

    # -------- overrides/test.yml --------
    cat > /home/user/qa_envs/overrides/test.yml <<'EOF'
app:
  version: "1.1.0"
database:
  host: test-db.internal
  port: 5434
  username: test_user
  password: test_pass
features:
  experimental: false
  logging: normal
EOF

    # -------- settings.toml --------
    cat > /home/user/qa_envs/settings.toml <<'EOF'
[build]
threads = 8
optimize = true

[qa]
environment = "multi"
EOF

    # ------------------------------------------------------------------
    # Permissions
    # ------------------------------------------------------------------
    # Make sure the future non-root agent can modify files and create new
    # artefacts under /home/user/qa_envs.
    chmod -R a+rwX /home/user/qa_envs

%labels
    chmod 755 /home/user

    Author QA-Container-Generator
    Description Initial environment for QA configuration merging task
    Version 1.0