Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    #!/bin/bash
    set -e

    # Basic utilities and Python tooling
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates

    # Install pytest for the grading suite
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create the non-root user expected by the task and tests
    # ------------------------------------------------------------------
    groupadd -g 1000 user || true
    useradd  -m -u 1000 -g 1000 user || true

    # ------------------------------------------------------------------
    # Prepare the initial directory structure & data file
    # ------------------------------------------------------------------
    install -d -m 0755 /home/user/capacity_data

    cat > /home/user/capacity_data/server_usage.csv <<'EOF'
server_id,cpu_usage_pct,mem_usage_pct
s1,45,67
s1,55,65
s2,80,70
s2,60,75
s3,30,40
EOF

    chmod 0644 /home/user/capacity_data/server_usage.csv

    # Ensure ownership so the running (non-root) user can write later
    chown -R 1000:1000 /home/user

%environment
    chmod 755 /home/user

    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH
    export HOME=/home/user

%runscript
    exec "$@"