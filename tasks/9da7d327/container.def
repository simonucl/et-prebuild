Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    #-----------------------------------------------------------------------
    # Install Python tooling and pytest (needed by the automated grader)
    #-----------------------------------------------------------------------
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get -y install --no-install-recommends \
        python3 \
        python3-pip

    pip3 install --no-cache-dir pytest

    # Clean up APT caches to keep image size small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    #-----------------------------------------------------------------------
    # Prepare initial filesystem state for the “service audit” task
    #-----------------------------------------------------------------------

    # Base directory
    mkdir -p /home/user/support_ticket/configs
    mkdir -p /home/user/support_ticket/report

    # Create app1.ini with the exact expected content
    cat > /home/user/support_ticket/configs/app1.ini <<'EOF'
[AuthService]
enabled=true
port=8080

[DataCollector]
enabled=true
; port intentionally omitted
EOF

    # Create app2.ini with the exact expected content
    cat > /home/user/support_ticket/configs/app2.ini <<'EOF'
[WebPortal]
enabled=true
port=8080

[Metrics]
enabled=false
port=9100
EOF

    #-----------------------------------------------------------------------
    # Permissions (agent runs unprivileged, so ensure readability)
    #-----------------------------------------------------------------------
    chmod 0755 /home/user
    chmod 0755 /home/user/support_ticket
    chmod 0755 /home/user/support_ticket/configs
    chmod 0755 /home/user/support_ticket/report

    chmod 0644 /home/user/support_ticket/configs/app1.ini
    chmod 0644 /home/user/support_ticket/configs/app2.ini

%environment
    chmod 755 /home/user

    # Ensure Python uses UTF-8 by default
    export PYTHONIOENCODING=UTF-8
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    echo "This container is prepared for the 'service audit' task."
    echo "Enter the shell to start working."
    exec /bin/bash