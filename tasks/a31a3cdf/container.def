Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Update package lists and install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # Create required directories and CSV file for the initial state
    mkdir -p /home/user/backups

    cat >/home/user/backups/backup_report.csv <<'EOF'
BackupID,Date,Status,SizeMB
BKP001,2023-07-01,OK,512
BKP002,2023-07-02,OK,514
BKP003,2023-07-03,FAILED,0
BKP004,2023-07-04,OK,518
BKP005,2023-07-05,OK,520
EOF

    # Ensure correct permissions so the non-root user (the student) can write in the directory
    chmod 777 /home/user/backups
    chmod 644 /home/user/backups/backup_report.csv

%environment
    chmod 755 /home/user

    # Keep output unbuffered for clearer logs
    export PYTHONUNBUFFERED=1

%runscript
    # Default action: drop into a shell
    exec /bin/bash "$@"