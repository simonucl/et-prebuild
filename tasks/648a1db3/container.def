Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install Python & pip
    apt-get update -y
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install pytest for the checker
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state expected by the tests
    # ------------------------------------------------------------------
    # Create the project directory structure
    mkdir -p /home/user/project/src

    # Create the initial main.py file with the required contents
    cat >/home/user/project/src/main.py <<'EOF'
#!/usr/bin/env python3
print("Hello from main!")
EOF

    # Make the script executable
    chmod +x /home/user/project/src/main.py

    # Ensure the student (non-root) user will be able to write inside /home/user
    chmod -R a+rwx /home/user

    # Clean up apt caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Leave $HOME untouched so Apptainer’s default binding behaviour applies
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    echo "Container for the symlink-task is ready."