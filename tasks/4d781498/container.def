Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update apt metadata and install Python along with venv support
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive \
    apt-get install -y --no-install-recommends \
        python3 \
        python3-venv \
        python3-pip \
        ca-certificates && \
    rm -rf /var/lib/apt/lists/*

    # Install pytest globally for the grading tests
    pip3 install --no-cache-dir pytest

    # Create a writable workspace for the student
    mkdir -p /home/user
    chmod 0777 /home/user

%environment
    chmod 755 /home/user

    # Make sure the standard python binaries are on PATH
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH