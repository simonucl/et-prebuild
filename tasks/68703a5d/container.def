Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Update package lists and install Python and required build tools
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 python3-venv python3-pip

    # Upgrade pip itself and install pytest for the grading harness
    python3 -m pip install --no-cache-dir --upgrade pip
    python3 -m pip install --no-cache-dir pytest

    # Ensure the /home/user directory exists and is writable by anybody
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up apt caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%labels
    chmod 755 /home/user

    Author  "Apptainer task setup"
    Description "Container for localization-env exercise; provides system Python, venv tools, and pytest."

%runscript
    echo "This container is prepared for the localization-env exercise."
    echo "Open a shell inside the container and follow the task instructions."