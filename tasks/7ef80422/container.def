Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # Install Python, pip, and pytest
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        tar \
        gzip
    pip3 install --no-cache-dir --upgrade pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare the initial filesystem state for the backup task
    # ------------------------------------------------------------------
    # Create source directory and populate the two text files
    mkdir -p /home/user/backup_src

    # file1.txt (ends with a single newline)
    cat > /home/user/backup_src/file1.txt <<'EOF'
Report id: FQ1-2024
Total revenue: $1,000,000
EOF

    # file2.txt (ends with a single newline)
    cat > /home/user/backup_src/file2.txt <<'EOF'
HR internal directory v2.3
Last updated: 2024-05-12
EOF

    # Ensure appropriate permissions so any non-root user can read & write
    chmod 777 /home/user/backup_src
    chmod 666 /home/user/backup_src/file1.txt /home/user/backup_src/file2.txt

%labels
    chmod 755 /home/user

    Author backup-task-builder
    Description "Apptainer image for the backup verification exercise with pytest pre-installed."