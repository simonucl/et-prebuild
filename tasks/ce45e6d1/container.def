Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Refresh package index and install Python tooling
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        python3 \
        python3-venv \
        python3-pip \
        python-is-python3

    # Provide a plain `python` command (Ubuntu only ships python3 by default)
    ln -sf /usr/bin/python3 /usr/local/bin/python

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial workspace expected by the exercise
    # ------------------------------------------------------------------
    mkdir -p /home/user/cloud_data

    cat > /home/user/cloud_data/cost_data.csv <<'EOF'
Service,Date,CostUSD
EC2,2023-07-01,25.50
S3,2023-07-01,5.25
RDS,2023-07-01,12.00
EC2,2023-07-02,30.75
S3,2023-07-02,4.75
RDS,2023-07-02,11.25
EC2,2023-07-03,28.00
S3,2023-07-03,6.00
EOF

    # Make sure the learner (runtime UID/GID) can freely write under /home/user
    chmod -R a+rwx /home/user

    # Clean up apt cache to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure standard binary paths are present
    export PATH=/usr/local/bin:/usr/local/sbin:/usr/bin:/usr/sbin:/bin:/sbin

%runscript
    echo "Apptainer container for the FinOps cost-analysis exercise."
    exec "$@"