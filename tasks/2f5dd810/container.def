Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "Updating package index and installing required packages..."
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install pytest for the learner’s verification tests
    pip3 install --no-cache-dir pytest

    echo "Creating non-root user with UID 1000 (username: user)..."
    # Create group and user only if they do not already exist
    if ! getent group 1000 >/dev/null; then
        groupadd -g 1000 user
    fi
    if ! id -u 1000 >/dev/null 2>&1; then
        useradd -m -u 1000 -g 1000 -s /bin/bash user
    fi

    # Ensure the home directory exists and is owned by the user
    mkdir -p /home/user
    chown -R 1000:1000 /home/user

    # Clean up APT caches to keep the image lean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Minimal PATH update to make sure pip-installed executables are found
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author="Generated by AI assistant"
    Description="Base image for the tiny internal HTTP service task. Contains Python3 and pytest, with a non-root user ready for the learner."