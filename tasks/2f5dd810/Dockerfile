FROM ubuntu:22.04

# %help (labels handled below)

RUN set -e && \
    echo "Updating package index and installing required packages..." && \
    apt-get update -y && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip && \
    pip3 install --no-cache-dir pytest && \
    echo "Creating non-root user with UID 1000 (username: user)..." && \
    if ! getent group 1000 >/dev/null; then groupadd -g 1000 user; fi && \
    if ! id -u 1000 >/dev/null 2>&1; then useradd -m -u 1000 -g 1000 -s /bin/bash user; fi && \
    mkdir -p /home/user && \
    chown -R 1000:1000 /home/user && \
    rm -rf /var/lib/apt/lists/*

RUN chmod 755 /home/user

ENV PATH=/usr/local/bin:/usr/bin:/bin:$PATH

LABEL Author="Generated by AI assistant"
LABEL Description="Base image for the tiny internal HTTP service task. Contains Python3 and pytest, with a non-root user ready for the learner."