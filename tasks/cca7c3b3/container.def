Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Update package lists and install Python + pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare the filesystem layout expected by the exercise
    # ------------------------------------------------------------------

    # Create the necessary directory tree with open permissions so the
    # (non-root) runtime user inside the container can write to it.
    mkdir -p /home/user/projects/ci_cd/config
    chmod -R 0777 /home /home/user /home/user/projects /home/user/projects/ci_cd

    # Place the legacy INI configuration file in its expected location.
    cat > /home/user/projects/ci_cd/config/build_settings.ini <<'EOF'
[build]
artifact_name=webapp
timeout=420
retries=3

[runtime]
python_version=3.10
entry_point=app:main

[notifications]
email=devops@example.com
EOF
    chmod 0644 /home/user/projects/ci_cd/config/build_settings.ini

%environment
    chmod 755 /home/user

    # Use Python 3 by default
    export PYTHONIOENCODING=utf-8
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8