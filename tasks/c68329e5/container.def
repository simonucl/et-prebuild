Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    ## Update apt index and install Python tooling
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    ## Create the required directory structure
    mkdir -p /home/user/audit_data

    ## Permissions:
    ## - /home/user must be writable by the unprivileged runtime user
    ## - /home/user/audit_data is read-only for others (0755)
    chmod 0777 /home/user
    chmod 0755 /home/user/audit_data

    ## Populate the mock_passwd file
    cat > /home/user/audit_data/mock_passwd <<'EOF'
root:x:0:0:root:/root:/bin/bash
daemon:x:1:1:daemon:/usr/sbin:/usr/sbin/nologin
alice:x:1000:1000:Alice:/home/alice:/bin/bash
bob:x:1001:1001:Bob:/home/bob:/bin/zsh
nobody:x:65534:65534:nobody:/nonexistent:/usr/sbin/nologin
john:x:1002:1002:John:/home/john:/bin/false
jane:x:1003:1003:Jane:/home/jane:/bin/bash
EOF
    chmod 0644 /home/user/audit_data/mock_passwd

%environment
    chmod 755 /home/user

    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author="OpenAI ChatGPT"
    Description="Container for compliance-audit shell task with pytest and initial mock_passwd."