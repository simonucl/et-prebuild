Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install Python, pip, pytest, and GNU time
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        time

    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state required by the exercise
    # ------------------------------------------------------------------

    # Create the user home hierarchy
    mkdir -p /home/user/datasets/raw

    # Write the exact raw CSV file (LF endings, newline after last line)
    cat <<'EOF' > /home/user/datasets/raw/sales.csv
id,region,sales
1,North,100
2,South,200
3,,150
4,East,
5,West,300
EOF

    # Ensure permissive permissions so the non-root agent can create new files
    chmod -R 777 /home/user

%environment
    chmod 755 /home/user

    # Keep default HOME; no overrides needed
    export LC_ALL=C.UTF-8

%labels
    Author MyCompany
    Description "Environment for CSV cleaning & benchmarking exercise"

%runscript
    echo "Container for CSV cleaning exercise. Open a shell to begin."