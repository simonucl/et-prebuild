Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author NetDiag-Container-Builder
    Description "Base container for the 'netdiag' task. Provides Python, pytest, and the standard networking / process‐control utilities required for grading."

%post
    set -e

    echo "Updating package lists..."
    apt-get update

    echo "Installing required packages..."
    # python3, pip, ping, ps and supporting utilities
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        iputils-ping \
        procps \
        locales

    echo "Generating locale to keep Python happy..."
    locale-gen en_US.UTF-8

    echo "Installing pytest via pip..."
    pip3 install --no-cache-dir pytest

    echo "Creating writable home directory for the learner..."
    mkdir -p /home/user
    chmod 0755 /home/user

    echo "Cleaning up APT caches to shrink container size..."
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8
    export PATH=/usr/local/bin:/usr/local/sbin:/usr/bin:/usr/sbin:/bin:/sbin

%runscript
    echo "This container is prepared for the 'netdiag' task."
    echo "Open a shell inside the container to begin working."