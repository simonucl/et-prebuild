Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Update package lists and install Python & pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y python3 python3-pip

    # Install pytest for the automated grader
    pip3 install --no-cache-dir pytest

    # Ensure the working directory for the student exists and is writable
    mkdir -p /home/user
    chmod 0777 /home/user

    # Minimal clean-up to keep image size small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%labels
    Author SRE-Firewall-Task
    Description "Base image for firewall staging assignment with pytest pre-installed."