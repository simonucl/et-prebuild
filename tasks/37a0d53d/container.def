Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Install Python and Pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python-is-python3
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial workspace expected by the grading tests
    # ------------------------------------------------------------------
    # Create project directory structure
    mkdir -p /home/user/project

    # Create VERSION file with exact required content
    printf '1.2.3\n' > /home/user/project/VERSION

    # Create CHANGELOG.md with exact required initial content
    printf '# Changelog\n\n## [1.2.3] - 2023-07-12\n### Added\n- Initial release.\n' \
        > /home/user/project/CHANGELOG.md

    # Ensure default permissions (directories 755, files 644)
    chmod 755 /home/user /home/user/project
    chmod 644 /home/user/project/VERSION /home/user/project/CHANGELOG.md

%labels
    Author="Task setup generated by AI"
    Description="Container for version bump task with initial project state and pytest installed"

%runscript
    exec "$@"