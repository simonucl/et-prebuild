FROM ubuntu:22.04

# Author: Task setup generated by AI
# Description: Container for version bump task with initial project state and pytest installed

ENV HOME=/home/user

RUN set -eux && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python-is-python3 && \
    pip3 install --no-cache-dir pytest && \
    mkdir -p /home/user/project && \
    printf '1.2.3\n' > /home/user/project/VERSION && \
    printf '# Changelog\n\n## [1.2.3] - 2023-07-12\n### Added\n- Initial release.\n' > /home/user/project/CHANGELOG.md && \
    chmod 755 /home/user /home/user/project && \
    chmod 644 /home/user/project/VERSION /home/user/project/CHANGELOG.md

CMD ["bash"]