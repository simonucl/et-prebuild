Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install required packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        openssh-client \
        ca-certificates
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the student and grader
    pip3 install --no-cache-dir pytest

    # Prepare writable home directory for the exercise
    mkdir -p /home/user
    chmod 0777 /home /home/user    # ensure the unprivileged runtime user can write

    # Make sure no artefacts from the final task exist at build time
    rm -rf /home/user/.ssh/microservice_rsa \
           /home/user/.ssh/microservice_rsa.pub \
           /home/user/micro_keys \
           /home/user/ssh_setup.log || true

%environment
    chmod 755 /home/user

    export LC_ALL=C
    export PYTHONUNBUFFERED=1

%labels
    Author "ChatGPT – Apptainer setup"
    Description "Base image for the micro-service SSH key exercise with pytest pre-installed."

%runscript
    exec "$@"