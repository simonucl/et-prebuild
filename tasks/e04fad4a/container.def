Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ------------------------------------------------------------------
    # Basic tooling
    # ------------------------------------------------------------------
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Prepare starting filesystem state for the exercise
    # ------------------------------------------------------------------
    # Create the expected user home and incoming certificate directory
    mkdir -p /home/user/certs_incoming

    # --- .meta files ---------------------------------------------------
    cat << 'EOF' > /home/user/certs_incoming/server_ok.meta
CN=api.example.com|CN=Example-CA|2023-06-01|2024-12-31
EOF

    cat << 'EOF' > /home/user/certs_incoming/server_soon.meta
CN=login.example.com|CN=Example-CA|2023-07-01|2024-07-01
EOF

    cat << 'EOF' > /home/user/certs_incoming/server_expired.meta
CN=legacy.example.com|CN=Legacy-CA|2022-05-01|2023-12-31
EOF

    # --- Dummy .crt files (PEM-looking placeholders) -------------------
    cat << 'EOF' > /home/user/certs_incoming/server_ok.crt
-----BEGIN CERTIFICATE-----
MIIDOk...dummy_ok
-----END CERTIFICATE-----
EOF

    cat << 'EOF' > /home/user/certs_incoming/server_soon.crt
-----BEGIN CERTIFICATE-----
MIIDOk...dummy_soon
-----END CERTIFICATE-----
EOF

    cat << 'EOF' > /home/user/certs_incoming/server_expired.crt
-----BEGIN CERTIFICATE-----
MIIDOk...dummy_expired
-----END CERTIFICATE-----
EOF

    # ------------------------------------------------------------------
    # Permissions
    # ------------------------------------------------------------------
    chmod -R a+rX /home/user
    # Attempt to give ownership to a non-root UID for convenience; ignore if uid 1000 is absent
    chown -R 1000:1000 /home/user || true

    # Ensure that the output directory does NOT exist yet (grader checks this)
    rm -rf /home/user/cert_analysis || true

%environment
    chmod 755 /home/user

    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    echo "Container for certificate analysis task."
    echo "Use apptainer exec ... to run your commands."

%labels
    Author ExampleBuilder
    Description "Prepared environment for certificate triage task with pytest installed."