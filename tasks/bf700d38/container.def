Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Update APT index and install required OS packages
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        cron \
        iputils-ping

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # Create a writable /home/user directory for the student
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up APT caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure a minimal, predictable environment
    export LC_ALL=C
    export PATH=/usr/local/bin:/usr/bin:/bin

%labels
    Author Network-Monitoring-Exercise
    Description "Base image for the network checks exercise (pytest included, clean initial state)"