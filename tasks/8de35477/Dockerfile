FROM ubuntu:22.04

# Help:
# This Apptainer image provides the initial filesystem state required for
# the “release manager” exercise. It already contains:
#   • /home/user/release/manifest.txt
#   • Two non-empty package archives in /home/user/packages/
#   • An empty /home/user/staging/ directory
# pytest is pre-installed for automated grading.

LABEL Author="Generated by OpenAI ChatGPT"
LABEL Description="Environment for release-manager pipeline task — includes pytest and preset filesystem state."

RUN set -e && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends python3 python3-pip && \
    pip3 install --no-cache-dir pytest

RUN mkdir -p /home/user/release && \
    mkdir -p /home/user/packages && \
    mkdir -p /home/user/staging

RUN cat <<'EOF' > /home/user/release/manifest.txt
app1-1.0.0.tar.gz
app2-2.1.0.tar.gz
app3-3.0.0.tar.gz
readme.txt
EOF

RUN echo "dummy data for app1" > /home/user/packages/app1-1.0.0.tar.gz && \
    echo "dummy data for app2" > /home/user/packages/app2-2.1.0.tar.gz

RUN find /home/user -type d -exec chmod 0777 {} + && \
    find /home/user -type f -exec chmod 0666 {} +