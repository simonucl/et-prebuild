Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ------------------------------------------------------------------
    # 1. Install Python and pytest
    # ------------------------------------------------------------------
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # 2. Create initial directory structure
    # ------------------------------------------------------------------
    mkdir -p /home/user/release
    mkdir -p /home/user/packages
    mkdir -p /home/user/staging

    # ------------------------------------------------------------------
    # 3. Create the manifest file with the exact required contents
    # ------------------------------------------------------------------
    cat > /home/user/release/manifest.txt <<'EOF'
app1-1.0.0.tar.gz
app2-2.1.0.tar.gz
app3-3.0.0.tar.gz
readme.txt
EOF

    # ------------------------------------------------------------------
    # 4. Seed the existing package archives with non-empty dummy data
    # ------------------------------------------------------------------
    echo "dummy data for app1" > /home/user/packages/app1-1.0.0.tar.gz
    echo "dummy data for app2" > /home/user/packages/app2-2.1.0.tar.gz

    # ------------------------------------------------------------------
    # 5. Ensure permissions allow non-root users to work in these paths
    # ------------------------------------------------------------------
    find /home/user -type d -exec chmod 0777 {} +
    find /home/user -type f -exec chmod 0666 {} +

%labels
    chmod 755 /home/user

    Author  "Generated by OpenAI ChatGPT"
    Description "Environment for release-manager pipeline task — includes pytest and preset filesystem state."

%help
    This Apptainer image provides the initial filesystem state required for
    the “release manager” exercise.  It already contains:
      • /home/user/release/manifest.txt
      • Two non-empty package archives in /home/user/packages/
      • An empty /home/user/staging/ directory
    pytest is pre-installed for automated grading.