Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    ########## 1. Install runtime dependencies ##########
    apt-get update && \
        apt-get install -y --no-install-recommends python3 python3-pip ca-certificates && \
        rm -rf /var/lib/apt/lists/*

    # pytest for the test harness
    pip3 install --no-cache-dir pytest

    ########## 2. Prepare initial workspace layout ##########
    mkdir -p /home/user/workspace/unorganized

    # secret.py
    cat > /home/user/workspace/unorganized/secret.py <<'EOF'
import os

# Application secret
SECRET_KEY="p@ssw0rd123"

print("Secret loaded")
EOF

    # config.js
    cat > /home/user/workspace/unorganized/config.js <<'EOF'
// Config file
const SECRET_KEY="xyz-999";
export default { key: SECRET_KEY };
EOF

    # readme.md
    cat > /home/user/workspace/unorganized/readme.md <<'EOF'
Temporary staging area for random project notes. Nothing special here.
EOF

    ########## 3. Relax permissions so the unprivileged user can work ##########
    chmod -R 777 /home/user

%environment
    chmod 755 /home/user

    # No HOME override; Apptainer will bind the host $HOME automatically.

%labels
    Author "Generated by ChatGPT"
    Description "Container for the 'Organize project files and generate a simple security-scan report' task."