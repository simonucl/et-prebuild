FROM ubuntu:22.04

# Help / metadata from %labels
LABEL Author="Generated by ChatGPT"
LABEL Description="Container for the 'Organize project files and generate a simple security-scan report' task."

RUN apt-get update && \
    apt-get install -y --no-install-recommends python3 python3-pip ca-certificates && \
    rm -rf /var/lib/apt/lists/*

RUN pip3 install --no-cache-dir pytest

RUN mkdir -p /home/user/workspace/unorganized

RUN cat > /home/user/workspace/unorganized/secret.py <<'EOF'
import os

# Application secret
SECRET_KEY="p@ssw0rd123"

print("Secret loaded")
EOF

RUN cat > /home/user/workspace/unorganized/config.js <<'EOF'
// Config file
const SECRET_KEY="xyz-999";
export default { key: SECRET_KEY };
EOF

RUN cat > /home/user/workspace/unorganized/readme.md <<'EOF'
Temporary staging area for random project notes. Nothing special here.
EOF

RUN chmod -R 777 /home/user

RUN chmod 755 /home/user