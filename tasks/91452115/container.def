Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Update package lists and install Python & pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        tzdata \
        locales

    # Install pytest for the checker
    pip3 install --no-cache-dir pytest

    # -----------------------------------------------------------------
    # Prepare the working directory structure and seed data for the task
    # -----------------------------------------------------------------

    # Create the user’s home directory hierarchy
    mkdir -p /home/user/disk_usage

    # Ensure correct directory permissions (755)
    chmod 755 /home/user
    chmod 755 /home/user/disk_usage

    # Create the raw_file_list.txt with the exact required content
    cat >/home/user/disk_usage/raw_file_list.txt <<'EOF'
.log
.tmp
.log
.bak
.log
.txt
.tmp
.csv
.csv
.txt
.log
.bak
.iso
.iso
.tmp
.log
.img
EOF

    # Set the file permissions to 644
    chmod 644 /home/user/disk_usage/raw_file_list.txt

    # Clean up apt caches to reduce image size
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    # Nothing special needed here; keep the default environment.
    export PATH=/usr/local/bin:/usr/bin:/bin

%labels
    Author  Your Name
    Description "Environment for disk-usage extension frequency task – includes pytest and pre-populated data."

%help
    This Apptainer image provides the starting environment for the
    "file-extension frequency summary" exercise.

    • Working directory: /home/user/disk_usage
    • Source file:       raw_file_list.txt (17 lines)
    • Task:              Generate extension_frequency.log as described.

    Pytest is pre-installed so the automated checker can validate both
    the initial state and the learner’s final solution.