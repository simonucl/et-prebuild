FROM ubuntu:22.04

# Help / labels from %help and %labels
LABEL Author="Generated by ChatGPT"
LABEL Description="Environment for network logging exercise; includes iproute2 and pytest, with a non-root user 'user'."

RUN set -e && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        iproute2 \
        python3-pip && \
    pip3 install --no-cache-dir pytest && \
    if ! getent group 1000 >/dev/null 2>&1; then groupadd -g 1000 user; fi && \
    if ! id -u 1000 >/dev/null 2>&1; then useradd -m -u 1000 -g 1000 -s /bin/bash user; fi && \
    mkdir -p /home/user && \
    chown 1000:1000 /home/user && \
    rm -rf /var/lib/apt/lists/*

RUN chmod 755 /home/user

ENV PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

# Default action: open an interactive shell as the non-privileged user.
CMD ["/bin/bash"]