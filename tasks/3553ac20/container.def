Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update APT metadata and install required packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        iproute2 \
        python3-pip

    # Install pytest for the runtime test-suite
    pip3 install --no-cache-dir pytest

    # Create a non-privileged user called “user” with home directory /home/user
    # UID/GID 1000 are conventional defaults; ignore if they already exist
    if ! getent group 1000 >/dev/null 2>&1; then
        groupadd -g 1000 user
    fi
    if ! id -u 1000 >/dev/null 2>&1; then
        useradd -m -u 1000 -g 1000 -s /bin/bash user
    fi

    # Ensure the home directory exists and has the correct ownership
    mkdir -p /home/user
    chown 1000:1000 /home/user

    # Clean up APT caches to keep the image small
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Standard PATH that includes sbin directories so the unprivileged user can
    # run `ip` and `ss` without specifying full paths.
    export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

%runscript
    # Default action: open an interactive shell as the non-privileged user.
    exec /bin/bash "$@"

%labels
    Author="Generated by ChatGPT"
    Description="Environment for network logging exercise; includes iproute2 and pytest, with a non-root user 'user'."