Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author ChatGPT
    Description "Environment for chat frequency task – provides raw dataset and pytest."

%post
    # Update package list and install Python + pip
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates && \
    pip3 install --no-cache-dir pytest && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Prepare filesystem layout expected by the automated grader
    # ------------------------------------------------------------------
    # Create /home/user and datasets directory
    mkdir -p /home/user/datasets

    # Make sure the student (non-root runtime user) can create files there
    chmod 0777 /home/user
    chmod 0777 /home/user/datasets

    # ------------------------------------------------------------------
    # Create the raw chat_samples.txt file with exact, eight-line content
    # ------------------------------------------------------------------
    cat > /home/user/datasets/chat_samples.txt <<'EOF'
Hello world, hello AI!
The AI world is vast.
Machine learning fuels the AI revolution.
Hello again, machine learning world.
AI and machine learning are related fields.
World of hello messages.
AI says hello to the world.
Learning about machine intelligence.
EOF

    # Set the required permissions (0644) on the raw data file
    chmod 0644 /home/user/datasets/chat_samples.txt

%environment
    chmod 755 /home/user

    # Default to Python 3 when the student invokes `python`
    export PYTHONIOENCODING=UTF-8
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%runscript
    echo "Container for the Chat Samples frequency task."
    echo "Invoke an interactive shell with:  apptainer exec <sif> /bin/bash"