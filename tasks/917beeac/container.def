Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package index and install Python + Pytest
    apt-get update -y && \
        apt-get install -y --no-install-recommends python3 python3-pip ca-certificates && \
        pip3 install --no-cache-dir pytest && \
        apt-get clean && rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Create initial filesystem state expected by the assessment tests
    # ------------------------------------------------------------------
    mkdir -p /home/user/source_data

    # customers.csv  (22 bytes)
    cat > /home/user/source_data/customers.csv <<'EOF'
id,name
1,Alice
2,Bob
EOF

    # orders.csv  (56 bytes – includes a deliberate blank line at the end)
    cat > /home/user/source_data/orders.csv <<'EOF'
order_id,customer_id,total
1001,1,250.00
1002,2,175.50

EOF

    # products.csv  (54 bytes)
    cat > /home/user/source_data/products.csv <<'EOF'
product_id,name,price
10,Widget,25.00
20,Gadget,40.00
EOF

    # Ensure the non-root runtime user can work within /home/user
    chmod -R a+rwx /home/user

%labels
    chmod 755 /home/user

    Author "Container prepared for ETL archiving exercise"