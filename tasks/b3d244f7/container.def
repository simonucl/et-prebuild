Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Ensure the base system is up-to-date and Python tooling is available
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Prepare the required directory structure and initial data files
    # ------------------------------------------------------------------
    # Create /home/user and make it writable for any UID that will run
    mkdir -p /home/user
    chmod 0777 /home/user

    # Create the site directory and make it writable
    mkdir -p /home/user/site
    chmod 0777 /home/user/site

    # Create the accounts.tsv file with exact content and permissions
    cat > /home/user/site/accounts.tsv <<'EOF'
101	alice	alice@example.com	admin
102	bob	bob@domain.com	editor
103	carol	carol@mail.net	viewer
104	dave	dave@site.org	editor
EOF
    chmod 0644 /home/user/site/accounts.tsv

%environment
    chmod 755 /home/user

    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8

%labels
    Author "Automatic container setup for coding task"
    Description "Provides initial state and pytest for the user_email.csv extraction exercise."