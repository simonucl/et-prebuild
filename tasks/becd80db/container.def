Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
Maintainer backup-task-setup

%post
    set -e

    # Update apt and install Python + pip
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install pytest for the test runner
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create the required initial filesystem hierarchy and files
    # ------------------------------------------------------------------

    # Ensure base home directory exists and is writable by any user so that
    # the unprivileged test/agent can create additional artefacts later on.
    mkdir -p /home/user
    chmod 0777 /home/user

    # Configuration directory and files
    mkdir -p /home/user/project/config

    cat >/home/user/project/config/app.conf <<'EOF'
[app]
version=1.2.3
name=ExampleApp
EOF

    cat >/home/user/project/config/db.conf <<'EOF'
[database]
host=localhost
port=5432
user=admin
pass=secret
EOF

    cat >/home/user/project/config/net.conf <<'EOF'
[network]
interface=eth0
address=192.168.1.100
EOF

    # Make sure everything inside /home/user is world-readable (but only the
    # agent will add writable paths such as /home/user/backups later).
    chmod -R a+rX /home/user

%environment
    chmod 755 /home/user

# No environment modifications required; keep default $HOME binding.

%runscript
exec "$@"