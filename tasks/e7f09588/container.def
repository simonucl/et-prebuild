Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # Update package lists and install required software
    apt-get update
    apt-get install -y --no-install-recommends \
        openssh-client \
        python3-pip

    # Install pytest for the grader
    pip install --no-cache-dir pytest

    # Create a writable home directory for the learner
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up APT caches to keep the image small
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Nothing special required here; keep default HOME binding.
    PATH=/usr/local/bin:/usr/local/sbin:/usr/bin:/usr/sbin:/bin:/sbin
    export PATH