Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    apt-get update -y
    # Minimal Python tooling for pytest
    apt-get install -y python3 python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create the demo repository in its required initial state.
    # ------------------------------------------------------------------
    mkdir -p /home/user/project/.github/workflows

    cat <<'EOF' > /home/user/project/.github/workflows/ci.yml
name: CI
on:
  push:
    branches: [ main ]
jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v2
      - name: Set up Node
        uses: actions/setup-node@v2
        with:
          node-version: '16'
EOF

    cat <<'EOF' > /home/user/project/pyproject.toml
[tool.poetry]
name = "demo"
version = "0.1.0"
description = "Demo project"
EOF

    # Ensure the files are writable by any non-root user that will run inside the
    # container.  Ownership is left as-is; world-writable bits guarantee access.
    chmod -R a+rw /home/user/project

%runscript
    chmod 755 /home/user

    echo "Container for CI/CD version-update exercise."
    echo "Edit the repository under /home/user/project as per the task instructions."