Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
Author TranslationTaskSetup
Description "Environment for translation report scripting task with pytest pre-installed."

%post
    set -e

    # Install Python and pytest
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip ca-certificates
    pip3 install --no-cache-dir pytest

    # Create project directory structure
    mkdir -p /home/user/project/i18n
    cd /home/user/project/i18n

    # template.pot
    cat > template.pot <<'EOF'
msgid ""
msgstr ""
"Project-Id-Version: Sample Project\n"
"Pot-Creation-Date: 2022-10-10 12:00+0000\n"
"Language: \n"

#: src/ui.c:10
msgid "Hello"
msgstr ""

#: src/ui.c:20
msgid "Goodbye"
msgstr ""

#: src/ui.c:30
msgid "Cancel"
msgstr ""
EOF

    # fr.po
    cat > fr.po <<'EOF'
msgid ""
msgstr ""
"Project-Id-Version: Sample Project\n"
"Language: fr\n"

#: src/ui.c:10
msgid "Hello"
msgstr "Bonjour"

#: src/ui.c:20
msgid "Goodbye"
msgstr ""

#: src/ui.c:30
msgid "Cancel"
msgstr ""
EOF

    # es.po
    cat > es.po <<'EOF'
msgid ""
msgstr ""
"Project-Id-Version: Sample Project\n"
"Language: es\n"

#: src/ui.c:10
msgid "Hello"
msgstr "Hola"

#: src/ui.c:20
msgid "Goodbye"
msgstr "Adiós"

#: src/ui.c:30
msgid "Cancel"
msgstr ""
EOF

    # Ensure correct permissions (readable and writable by the user, no exec bits)
    chmod 644 /home/user/project/i18n/*.po
    chmod 644 /home/user/project/i18n/template.pot

%environment
    chmod 755 /home/user

    # Ensure Python and pip are available on PATH
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%runscript
    echo "Container for translation report task. Run your commands within an interactive shell or via 'apptainer exec'."