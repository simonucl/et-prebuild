Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Install Python, pip and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # Clean up APT caches to keep image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Prepare initial filesystem state required for the assignment
    # ------------------------------------------------------------------

    # Ensure /home/user exists and is writable by non-root users so that
    # the learner can create new files/directories inside it.
    mkdir -p /home/user
    chmod 0777 /home/user

    # Create the scan_results directory and the predefined log file
    mkdir -p /home/user/scan_results
    cat > /home/user/scan_results/nmap_scan.log <<'EOF'
192.168.1.10:22/tcp Open VULNERABLE-OpenSSH CVE-2020-1234
192.168.1.12:80/tcp Closed
192.168.1.15:445/tcp Open VULNERABLE-SMBGhost CVE-2020-0796
10.0.0.5:3389/tcp Open Secure
172.16.0.9:22/tcp Open VULNERABLE-OpenSSH CVE-2021-28041
EOF

    # Set sensible permissions
    chmod 0755 /home/user/scan_results
    chmod 0644 /home/user/scan_results/nmap_scan.log

%environment
    chmod 755 /home/user

    # Nothing special required; keep default environment.

%labels
    Author PenTest Training Container
    Description Container for network-scan text-processing exercise

%runscript
    echo "This container is for the vulnerable-host extraction exercise."
    echo "Enter the shell and follow the instructions in the assignment."