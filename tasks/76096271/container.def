Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Update package list and install Python + pip
    apt-get update && \
    apt-get install -y --no-install-recommends python3 python3-pip && \
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare the initial filesystem state expected by the exercise
    # ------------------------------------------------------------------

    # Create required directories
    mkdir -p /home/user/projects/data_cleaning/raw_datasets
    mkdir -p /home/user/archive

    # Populate CSV files with the specified contents
    cat > /home/user/projects/data_cleaning/raw_datasets/sales_q1.csv <<'EOF'
id,amount
1,100
EOF

    cat > /home/user/projects/data_cleaning/raw_datasets/sales_q2.csv <<'EOF'
id,amount
2,200
EOF

    cat > /home/user/projects/data_cleaning/raw_datasets/customers.csv <<'EOF'
id,name
1,Alice
2,Bob
EOF

    # Ensure everything is writable by the non-root runtime user
    chmod -R a+rwX /home/user

%environment
    chmod 755 /home/user

    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8