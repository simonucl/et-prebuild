Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # Update package lists and install Python + pip
    apt-get update
    apt-get -y install --no-install-recommends python3 python3-pip

    # Install pytest for the automated checker
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state for the exercise
    # ------------------------------------------------------------------
    mkdir -p /home/user/backup

    # Create the full_backup.log with the exact required content
    cat > /home/user/backup/full_backup.log <<'EOF'
2024-06-01|00:15|37GB|OK
2024-06-02|00:17|40GB|OK
2024-06-03|00:20|38GB|FAIL
EOF

    # Set permissions
    chmod 0644 /home/user/backup/full_backup.log
    chmod 0755 /home/user
    chmod 0755 /home/user/backup

%runscript
    chmod 755 /home/user

    # Default runscript: just execute the given command inside the container
    exec "$@"