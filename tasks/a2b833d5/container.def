Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author network_logs_setup
    Description "Base container for network_logs assignment – ping available, pytest installed, correct initial filesystem state."

%post
    set -eux

    # Update package index and install minimal requirements
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        iputils-ping \
        python3-pip \
        ca-certificates \
        tzdata
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the grading framework
    pip3 install --no-cache-dir pytest

    # Create the /home/user directory (but NOT /home/user/network_logs)
    mkdir -p /home/user
    chmod 0777 /home/user   # Ensure any unprivileged runtime user can write here

%environment
    chmod 755 /home/user

    # Prepend pip’s installation path to PATH
    export PATH="/usr/local/bin:${PATH}"

%runscript
    echo "Container for the network_logs assignment. Use apptainer exec/run to start your work."