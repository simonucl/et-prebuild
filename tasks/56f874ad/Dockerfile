FROM ubuntu:22.04

# Labels
LABEL Author="Generated by ChatGPT"
LABEL Description="Container for the Distributed System re-organisation task with pytest pre-installed."

# Install Python and pytest
RUN set -e && \
    apt-get update && \
    apt-get install -y python3 python3-pip && \
    pip3 install --no-cache-dir pytest

# Set-up initial project directory structure
RUN mkdir -p /home/user/project/logs

# Create app.py
RUN cat <<"EOF" >/home/user/project/app.py
#!/usr/bin/env python3
"""
Sample application module for the distributed system project.
"""
def main():
    print("Hello from app.py")
if __name__ == "__main__":
    main()
EOF

# Create helper.py
RUN cat <<"EOF" >/home/user/project/helper.py
#!/usr/bin/env python3
"""
Helper utilities used by various nodes in the distributed system.
"""
def helper():
    return "helper"
EOF

# Create default.conf
RUN cat <<"EOF" >/home/user/project/default.conf
# Default configuration parameters
[network]
port = 8080
EOF

# Create run.sh
RUN cat <<"EOF" >/home/user/project/run.sh
#!/usr/bin/env bash
echo "Starting distributed system..."
EOF

RUN chmod +x /home/user/project/run.sh

# Create cluster_node_A.log
RUN cat <<"EOF" >/home/user/project/logs/cluster_node_A.log
2023-07-15T12:01:03Z;INFO;NodeA;Heartbeat OK
2023-07-15T12:01:10Z;ERROR;NodeA;Timeout contacting service registry
2023-07-15T12:02:11Z;WARN;NodeA;Slow response from cache
2023-07-15T12:03:45Z;ERROR;NodeA;Unhandled exception in worker thread
EOF

# Create cluster_node_B.log
RUN cat <<"EOF" >/home/user/project/logs/cluster_node_B.log
2023-07-15T12:00:02Z;WARN;NodeB;Clock skew detected
2023-07-15T12:01:59Z;ERROR;NodeB;Failed to replicate log entry
2023-07-15T12:04:00Z;WARN;NodeB;Retrying connection to NodeC
EOF

# Create cluster_node_C.log
RUN cat <<"EOF" >/home/user/project/logs/cluster_node_C.log
2023-07-15T12:00:30Z;INFO;NodeC;Startup complete
2023-07-15T12:02:47Z;WARN;NodeC;Low disk space
EOF

# Make everything under /home/user writable for the non-root runtime user
RUN chmod -R 777 /home/user

# Environment variables
ENV LC_ALL=C.UTF-8
ENV PYTHONIOENCODING=UTF-8

WORKDIR /home/user