Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Make sure basic locales and prerequisites are present
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -qq
    apt-get install -y --no-install-recommends python3 python3-pip ca-certificates
    pip3 install --no-cache-dir pytest

    # Create the expected /home/user directory and make it writable
    mkdir -p /home/user
    chmod 0777 /home/user   # allow the unprivileged runtime user to work here

    # Clean up apt cache to keep the image lean
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure python and pip are accessible
    export PATH=$PATH:/usr/local/bin

%runscript
    # Default command when the container is run without arguments
    exec /bin/bash

%labels
    Author="Generated by ChatGPT"
    Description="Environment for the provisioning task with pytest installed."