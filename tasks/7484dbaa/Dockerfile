# syntax=docker/dockerfile:1
FROM ubuntu:22.04

# Labels
LABEL Author="autogenerated" \
      Description="Container prepared for inventory housekeeping task with pytest pre-installed."

# --------------------------------------------------------------------
# Basic development tooling and Python dependencies
# --------------------------------------------------------------------
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked --mount=type=cache,target=/var/lib/apt,sharing=locked --mount=type=cache,target=/root/.cache/pip set -e && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates && \
    pip3 install --no-cache-dir pytest && \
    rm -rf /var/lib/apt/lists/*

# --------------------------------------------------------------------
# Create initial filesystem state expected by the test-suite
# 1. Directory /home/user and inventory sub-directory
# --------------------------------------------------------------------
RUN mkdir -p /home/user/inventory && \
    chmod 0755 /home/user && \
    chmod 0755 /home/user/inventory

# --------------------------------------------------------------------
# 2. Pre-populate servers.csv with the exact required contents
# --------------------------------------------------------------------
RUN cat > /home/user/inventory/servers.csv <<'EOF'
id,hostname,ip,env,region
1,web-01,10.0.0.11,prod,us-east
2,web-02,10.0.0.12,prod,us-east
3,api-01,10.0.1.21,staging,us-west
4,api-02,10.0.1.22,prod,eu-central
5,db-01,10.0.2.31,prod,us-east
6,db-02,10.0.2.32,staging,us-west
EOF

RUN chmod 0644 /home/user/inventory/servers.csv

# --------------------------------------------------------------------
# Environment setup (from %environment)
# --------------------------------------------------------------------
RUN chmod 0755 /home/user

# --------------------------------------------------------------------
# Help
# This container sets up the initial state for the inventory
# housekeeping exercise.
# --------------------------------------------------------------------