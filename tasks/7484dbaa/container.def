Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Basic development tooling
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 python3-pip ca-certificates

    pip3 install --no-cache-dir pytest

    #
    # Create initial filesystem state expected by the test-suite
    #
    # 1. Directory /home/user and inventory sub-directory
    #
    mkdir -p /home/user/inventory
    chmod 0755 /home/user
    chmod 0755 /home/user/inventory

    #
    # 2. Pre-populate servers.csv with the exact required contents
    #
    cat > /home/user/inventory/servers.csv <<'EOF'
id,hostname,ip,env,region
1,web-01,10.0.0.11,prod,us-east
2,web-02,10.0.0.12,prod,us-east
3,api-01,10.0.1.21,staging,us-west
4,api-02,10.0.1.22,prod,eu-central
5,db-01,10.0.2.31,prod,us-east
6,db-02,10.0.2.32,staging,us-west
EOF
    chmod 0644 /home/user/inventory/servers.csv

    #
    # Note: /home/user/inventory/process.log is intentionally NOT created
    # so that it can be either absent or empty, satisfying the initial
    # test expectations.
    #

%environment
    chmod 755 /home/user

    # Nothing to override here; rely on defaults.

%labels
    Author autogenerated
    Description Container prepared for inventory housekeeping task with pytest pre-installed.

%help
    This Apptainer image sets up the initial state for the inventory
    housekeeping exercise.