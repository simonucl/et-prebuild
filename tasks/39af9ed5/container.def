Bootstrap: localimage
From: ./ubuntu_22.04.sif

%environment
    # Ensure binaries installed with `pip --user` are reachable
    export PATH="/home/user/.local/bin:$PATH"

%post
    set -e

    # Basic package setup
    apt-get update
    # Install Python and required CLI utilities
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-setuptools \
        python3-wheel \
        coreutils \
        grep \
        dpkg
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the grading test-suite
    pip3 install --no-cache-dir pytest

    # Prepare writable home directory expected by the tests
    mkdir -p /home/user
    chmod 0777 /home/user

    # (Optional) add a passwd entry for the non-root user 'user'
    if ! grep -q "^user:" /etc/passwd; then
        echo "user:x:1001:1001:User,,,:/home/user:/bin/bash" >> /etc/passwd
    fi

%runscript
    chmod 755 /home/user

    # Default entry point just opens a shell
    exec bash -l