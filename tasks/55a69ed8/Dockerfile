# syntax=docker/dockerfile:1
FROM ubuntu:22.04

# Labels from Apptainer %labels
LABEL Author="Generated by ChatGPT"
LABEL Description="Container for benchmark logging exercise with pytest pre-installed"

# Install Python and pytest
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked --mount=type=cache,target=/var/lib/apt,sharing=locked --mount=type=cache,target=/root/.cache/pip set -e && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip && \
    pip3 install --no-cache-dir pytest && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Create required directory structure
RUN mkdir -p /home/user/tools

# Create legacy benchmark script
RUN cat >/home/user/tools/fake_benchmark.sh <<'EOF'
#!/usr/bin/env bash
echo -e "\treal: 0.12"
echo -e "\tuser: 0.03"
echo -e "\tsys: 0.01"
EOF

# Ensure the script and home directory are accessible
RUN chmod 755 /home/user/tools/fake_benchmark.sh && \
    chmod 755 /home/user

# Environment variables from Apptainer %environment
ENV PATH=/usr/local/bin:/usr/bin:/bin:$PATH

# Help:
# Container for benchmark logging exercise with pytest pre-installed