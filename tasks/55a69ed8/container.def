Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Create required directory structure and legacy benchmark script
    mkdir -p /home/user/tools

    cat >/home/user/tools/fake_benchmark.sh <<'EOF'
#!/usr/bin/env bash
echo -e "\treal: 0.12"
echo -e "\tuser: 0.03"
echo -e "\tsys: 0.01"
EOF

    # Ensure the script is executable
    chmod 755 /home/user/tools/fake_benchmark.sh

    # Make sure /home/user itself is accessible
    chmod 755 /home/user

%environment
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author="Generated by ChatGPT"
    Description="Container for benchmark logging exercise with pytest pre-installed"