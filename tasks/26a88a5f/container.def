Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # --------------------------------------------------------------------- #
    # Basic tooling                                                         #
    # --------------------------------------------------------------------- #
    apt-get update && \
    apt-get install -y --no-install-recommends python3-pip coreutils && \
    rm -rf /var/lib/apt/lists/*

    pip3 install --no-cache-dir pytest

    # --------------------------------------------------------------------- #
    # Prepare initial workspace layout                                      #
    # --------------------------------------------------------------------- #
    WORKSPACE_BASE="/home/user/ci_cd_workspace"

    # Create directory structure
    mkdir -p "${WORKSPACE_BASE}/build_artifacts" \
             "${WORKSPACE_BASE}/cache" \
             "${WORKSPACE_BASE}/logs" \
             "${WORKSPACE_BASE}/temp" \
             "${WORKSPACE_BASE}/scripts"

    # ----------------------- build_artifacts ----------------------------- #
    cd "${WORKSPACE_BASE}/build_artifacts"
    for i in $(seq -w 1 10); do
        dd if=/dev/zero of="artifact_${i}.bin" bs=102400 count=1 status=none
    done

    # --------------------------- cache ----------------------------------- #
    cd "${WORKSPACE_BASE}/cache"
    for i in $(seq -w 1 3); do
        dd if=/dev/zero of="layer_${i}.tgz" bs=1M count=1 status=none
    done

    # ---------------------------- logs ----------------------------------- #
    cd "${WORKSPACE_BASE}/logs"
    for i in $(seq -w 1 15); do
        dd if=/dev/zero of="log_${i}.txt" bs=20480 count=1 status=none
    done

    # ---------------------------- temp ----------------------------------- #
    cd "${WORKSPACE_BASE}/temp"
    for i in $(seq -w 1 5); do
        dd if=/dev/zero of="tmp_${i}.dat" bs=51200 count=1 status=none
    done

    # --------------------------- scripts --------------------------------- #
    cd "${WORKSPACE_BASE}/scripts"
    dd if=/dev/zero of="build.sh"  bs=5120 count=1 status=none
    dd if=/dev/zero of="deploy.sh" bs=5120 count=1 status=none

    # --------------------------------------------------------------------- #
    # Permissions (readable by any unprivileged user)                       #
    # --------------------------------------------------------------------- #
    chmod -R a+rX /home/user

%environment
    chmod 755 /home/user

    # Ensure Python user-base binaries (if any) are on PATH
    export PATH="$PATH:$HOME/.local/bin"

%labels
    Author      "Generated by ChatGPT"
    Description "Container providing preset CI/CD workspace and pytest for grading tasks."