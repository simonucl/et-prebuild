Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest for the test-runner
    apt-get update && \
        apt-get install -y --no-install-recommends python3 python3-pip && \
        pip3 install --no-cache-dir pytest && \
        apt-get clean && rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Create directory structure
    # ------------------------------------------------------------------
    mkdir -p /home/user/backup_test/source
    mkdir -p /home/user/backup_test/backup
    mkdir -p /home/user/backup_scripts
    mkdir -p /home/user/.config/systemd/user

    # ------------------------------------------------------------------
    # A) Source material
    # ------------------------------------------------------------------
    printf 'Important data v1\n' > /home/user/backup_test/source/important.txt

    # ------------------------------------------------------------------
    # C) Backup script
    # ------------------------------------------------------------------
    cat > /home/user/backup_scripts/backup_once.sh << 'EOF'
#!/bin/sh
SRC="/home/user/backup_test/source/important.txt"
DST="/home/user/backup_test/backup/important.txt"
LOG="/home/user/backup_scripts/backup.log"

# Ensure the destination directory exists
mkdir -p "$(dirname "$DST")"

# Copy the file (overwrite if it already exists)
cp "$SRC" "$DST"

# Append ISO-8601 timestamped log entry
date --iso-8601=seconds | awk '{printf "%s : Backed up important.txt\n", $0}' >> "$LOG"
    chmod 755 /home/user

EOF
    chmod 0755 /home/user/backup_scripts/backup_once.sh

    # ------------------------------------------------------------------
    # Run the backup script once so that the log entry and copy exist
    # ------------------------------------------------------------------
    /home/user/backup_scripts/backup_once.sh

    # ------------------------------------------------------------------
    # D) Cron specification
    # ------------------------------------------------------------------
    printf '17 2 * * * /home/user/backup_scripts/backup_once.sh\n' > \
        /home/user/backup_scripts/backup.cron

    # ------------------------------------------------------------------
    # E) systemd user units
    # ------------------------------------------------------------------
    cat > /home/user/.config/systemd/user/backup_once.service << 'EOF'
[Unit]
Description=One-off user backup

[Service]
Type=oneshot
ExecStart=/home/user/backup_scripts/backup_once.sh
EOF

    cat > /home/user/.config/systemd/user/backup_once.timer << 'EOF'
[Unit]
Description=Run user backup 5 minutes after boot

[Timer]
OnBootSec=5min
Unit=backup_once.service

[Install]
WantedBy=default.target
EOF

    # ------------------------------------------------------------------
    # Permissions (directories ≥755, systemd dir at least 700)
    # ------------------------------------------------------------------
    chmod -R a+rX /home/user/backup_test
    chmod -R a+rX /home/user/backup_scripts
    chmod 0700 /home/user/.config
    chmod -R a+rX /home/user/.config/systemd
    chmod 0700 /home/user/.config/systemd/user

%environment
    # Ensure /home/user is in PATH for convenience
    export PATH="/home/user/backup_scripts:$PATH"

%labels
    Author backup-operator-preparation
    Description "Container prepared for backup script exercise with cron and systemd unit files."

%help
    This Apptainer image contains all files necessary for the “backup-operator”
    exercise.  The backup script, cron entry, systemd service and timer units,
    as well as an initial backup and log entry, are pre-created in /home/user.