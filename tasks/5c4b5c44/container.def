Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ------------------------------------------------------------------
    # Install Python, pip and pytest (plus basic tooling)
    # ------------------------------------------------------------------
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Prepare initial directory structure and CSV file
    # ------------------------------------------------------------------
    mkdir -p /home/user/data
    chmod 777 /home/user          # allow the unprivileged runtime user to write inside /home/user
    chmod 755 /home/user/data

    # Create the employees.csv with exact required content (Unix newlines)
    cat > /home/user/data/employees.csv <<'EOF'
id,name,department,salary
1,John Smith,Engineering,90000
2,Jane Doe,Marketing,65000
3,Bob Johnson,Engineering,80000
4,Alice Davis,HR,60000
5,Charlie Brown,Engineering,72000
6,Eve Black,Engineering,68000
7,Frank White,Sales,70000
EOF

    chmod 644 /home/user/data/employees.csv

%environment
    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8

%labels
    Author "Generated by ChatGPT"
    Description "Apptainer image providing the initial filesystem state for the CSV filtering assignment."