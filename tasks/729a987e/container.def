Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    #!/bin/bash
    set -e

    ###############################
    # 1. Install required packages
    ###############################
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y python3 python3-pip
    pip3 install --no-cache-dir pytest

    ###############################
    # 2. Prepare initial filesystem
    ###############################
    # Create application directory and initial configuration file
    mkdir -p /home/user/myapp

    cat > /home/user/myapp/config.ini <<'EOF'
[service]
name=myapp
port=8080
debug=false
EOF

    # Make everything under /home/user writable for the non-root runtime user
    chmod -R a+rwX /home/user

%environment
    chmod 755 /home/user

    # Ensure that 'python' resolves to Python 3
    export PATH=/usr/local/bin:/usr/bin:/bin
    if ! command -v python >/dev/null 2>&1; then
        alias python=python3
    fi