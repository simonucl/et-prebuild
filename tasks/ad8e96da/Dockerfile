FROM ubuntu:22.04

# Author="Generated by OpenAI Assistant"
# Description="Ubuntu 22.04 base with Python, venv support and pytest pre-installed for compliance_project task."

RUN set -e && \
    echo "Updating APT package index..." && \
    apt-get update -y && \
    echo "Installing Python, pip, venv and other essentials..." && \
    DEBIAN_FRONTEND=noninteractive \
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-venv \
        ca-certificates \
        build-essential && \
    echo "Upgrading pip and installing pytest for system-level testing..." && \
    pip3 install --no-cache-dir --upgrade pip && \
    pip3 install --no-cache-dir pytest && \
    echo "Creating /home/user with write permissions for the unprivileged agent..." && \
    mkdir -p /home/user && \
    chmod 777 /home/user && \
    echo "Cleaning up APT caches to reduce image size..." && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /home/user

CMD ["sh", "-c", "echo 'Container is ready. Python version:' && python3 --version"]