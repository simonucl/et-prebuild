Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Install Python and pytest
    apt-get update -y && \
        apt-get install -y --no-install-recommends python3 python3-pip && \
        pip3 install --no-cache-dir pytest && \
        apt-get clean && \
        rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Create the CI workspace with the required structure and files
    # ------------------------------------------------------------------
    CI_ROOT="/home/user/ci_temp"

    # Directory tree
    mkdir -p "${CI_ROOT}/build1" \
             "${CI_ROOT}/build2" \
             "${CI_ROOT}/build3/nested"

    # build1
    printf "artifact build 1 – UNSAFE artefact\nUNSAFE\n" > "${CI_ROOT}/build1/artifact1.tmp"
    printf "This file should be kept as-is.\n"             > "${CI_ROOT}/build1/keep.txt"
    printf "Some harmless temporary notes.\n"              > "${CI_ROOT}/build1/notes.tmp"

    # build2
    printf "Debug information containing UNSAFE marker.\nUNSAFE\n" > "${CI_ROOT}/build2/debug.tmp"
    printf "Background noise tmp, safe.\n"                         > "${CI_ROOT}/build2/noise.tmp"
    printf "Regular build log.\n"                                  > "${CI_ROOT}/build2/other.log"

    # build3 / nested
    printf "Nested log file.\n"                                    > "${CI_ROOT}/build3/nested/inner.log"
    printf "Nested tmp with UNSAFE token.\nUNSAFE\n"               > "${CI_ROOT}/build3/nested/inner.tmp"

    # Ensure normal read permissions for all users
    chmod -R a+rX /home/user/ci_temp

%environment
    chmod 755 /home/user

    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author platform-engineer-task-setup
    Description "Container for CI temp cleanup exercise"

%runscript
    echo "This container is prepared for the CI cleanup exercise."
    echo "Use 'pytest' to run the pre-configured test suite."