Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update APT and install Python & pip
    apt-get update -y
    apt-get install -y --no-install-recommends python3 python3-pip

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial dataset
    # ------------------------------------------------------------------
    # Create directory structure
    mkdir -p /home/user/data/raw

    # Make sure the learner (non-root) can write inside /home/user/data
    chmod 0777 /home/user
    chmod 0777 /home/user/data
    chmod 0777 /home/user/data/raw

    # Populate the raw CSV with the exact required content
    cat > /home/user/data/raw/customers.csv <<'EOF'
id,name,age,country
1,Alice,31,US
2,Bob,25,CA
3,Charlie,35,UK
4,David,28,US
EOF
    chmod 0644 /home/user/data/raw/customers.csv

    # ------------------------------------------------------------------
    # Clean up APT caches to keep the image small
    # ------------------------------------------------------------------
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure Python and pip are in PATH
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author="Apptainer Task Prepper"
    Description="Environment for CSV cleaning task with initial raw data and pytest installed."