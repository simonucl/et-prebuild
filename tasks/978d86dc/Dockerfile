# From local SIF image: replaced with Ubuntu 22.04 base
FROM ubuntu:22.04

# --- Post section ---
RUN set -e && \
    echo "Updating APT and installing Python + pip..." && \
    apt-get update -y && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        tzdata

RUN pip3 install --no-cache-dir pytest

RUN mkdir -p /home/user/data && \
    chmod 0777 /home/user && \
    chmod 0777 /home/user/data

RUN cat <<'EOF' > /home/user/data/raw_survey.txt
Name | Age | Country | Income
Alice   | 29 | usa | 70000
Bob|34| Canada | 82000
   Charlie | NA | UK | NA
Diana| 42|usa|90000
Eve |27|Germany| 65000
Frank | 31 | USA | 72000
Grace| 25|  Canada|68000
Heidi|38|UK | NA
Ivan | 45 | germany| 87000
Judy|30|USA| 75000
EOF

RUN chmod 0644 /home/user/data/raw_survey.txt

RUN ln -sf /usr/bin/python3 /usr/local/bin/python

RUN apt-get clean && rm -rf /var/lib/apt/lists/*

# Fix permissions requested in %environment
RUN chmod 755 /home/user

# --- Environment variables ---
ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8
ENV PATH=/home/user/.local/bin:$PATH

# --- Labels ---
LABEL Author="Autogenerated for ML survey-cleaning task"
LABEL Description="Environment containing raw_survey.txt fixture and pytest installed"

# --- Help section ---
# This container provides the starting environment for the “messy survey data”
# cleaning task. It includes:
#   - Ubuntu 22.04 base system
#   - Python 3 + pytest for automated testing
#   - Pre-populated /home/user/data/raw_survey.txt fixture
# No task deliverables are present; the student is expected to create them.