Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "Updating APT and installing Python + pip..."
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        tzdata

    echo "Installing pytest (system-wide)…"
    pip3 install --no-cache-dir pytest

    echo "Creating /home/user and data directory..."
    mkdir -p /home/user/data
    chmod 0777 /home/user
    chmod 0777 /home/user/data

    echo "Populating raw_survey.txt fixture..."
    cat <<'EOF' > /home/user/data/raw_survey.txt
Name | Age | Country | Income
Alice   | 29 | usa | 70000
Bob|34| Canada | 82000
   Charlie | NA | UK | NA
Diana| 42|usa|90000
Eve |27|Germany| 65000
Frank | 31 | USA | 72000
Grace| 25|  Canada|68000
Heidi|38|UK | NA
Ivan | 45 | germany| 87000
Judy|30|USA| 75000
EOF
    chmod 0644 /home/user/data/raw_survey.txt

    echo "Creating convenience symlink so 'python' is available..."
    ln -sf /usr/bin/python3 /usr/local/bin/python

    echo "Cleaning up APT caches..."
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Minimal locale / path settings
    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8
    export PATH=/home/user/.local/bin:$PATH

%labels
    Author="Autogenerated for ML survey-cleaning task"
    Description="Environment containing raw_survey.txt fixture and pytest installed"

%help
    This container provides the starting environment for the “messy survey data”
    cleaning task.  It includes:
      • Ubuntu 22.04 base system
      • Python 3 + pytest for automated testing
      • Pre-populated /home/user/data/raw_survey.txt fixture
    No task deliverables are present; the student is expected to create them.