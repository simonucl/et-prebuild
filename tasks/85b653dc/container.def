Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    #!/bin/bash
    set -eux

    # Avoid interactive prompts during package installation
    export DEBIAN_FRONTEND=noninteractive

    # Update package lists and install required software
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        locales \
        tzdata \
        ca-certificates

    # Generate and enable the desired locale
    locale-gen en_US.UTF-8
    update-locale LANG=en_US.UTF-8

    # Create the non-root user expected by the exercise
    useradd -m -s /bin/bash user
    chown -R user:user /home/user

    # Install pytest for the automated grader
    pip3 install --no-cache-dir pytest

    # Clean up to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    export LANG=en_US.UTF-8
    export LC_ALL=en_US.UTF-8
    export PATH=/usr/local/bin:/usr/local/sbin:/usr/bin:/usr/sbin:/bin:/sbin

%labels
    Author="Exercise Preparation Bot"
    Description="Container for timezone conversion task; includes Python and pytest, plus a clean /home/user workspace."