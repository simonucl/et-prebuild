Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "Updating package index and installing Python + pip..."
    apt-get update -qq
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        && apt-get clean \
        && rm -rf /var/lib/apt/lists/*

    echo "Installing pytest via pip..."
    pip3 install --no-cache-dir --upgrade pip
    pip3 install --no-cache-dir pytest

    echo "Creating directory structure for the ERROR-counter task..."
    # Use permissive permissions so the non-root runtime user can write results.
    mkdir -p -m 0777 /home/user/tickets/logs
    mkdir -p -m 0777 /home/user/tickets/analysis

    echo "Populating the system.log file with predefined contents..."
    cat >/home/user/tickets/logs/system.log <<'EOF'
2023-04-18 10:15:23 INFO User login successful
2023-04-18 10:16:12 ERROR Database connection failed
2023-04-18 10:17:01 WARN Disk space low
2023-04-18 10:18:45 ERROR Timeout while fetching data
2023-04-18 10:20:10 INFO User logout
2023-04-18 10:22:05 ERROR Failed to send email
EOF

    # Ensure correct permissions for the log file: readable by all, immutable by default users
    chmod 0644 /home/user/tickets/logs/system.log

%environment
    chmod 755 /home/user

    # Guarantee Python and pip are on PATH
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%labels
    Author="Generated by ChatGPT – Apptainer task setup"
    Description="Container prepared for the ERROR counter one-liner task with pytest pre-installed."

%help
    This Apptainer image sets up the initial environment for the “ERROR counter”
    exercise. It pre-creates:
      • /home/user/tickets/logs/system.log      (with 3 ERROR lines)
      • /home/user/tickets/analysis/            (empty, writable)
    Pytest is installed for automatic grading.