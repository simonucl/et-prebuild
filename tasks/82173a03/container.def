Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package index and install Python as well as essential utilities
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # Create the unprivileged working directory expected by the assignment
    mkdir -p /home/user
    # Give broad write permissions so the non-root runtime user can create files
    chmod 0777 /home/user

    # Clean up apt caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure python and pip are on PATH
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author="Apptainer Task Prep"
    Description="Environment for system snapshot assignment (pytest included)"