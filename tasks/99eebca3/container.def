Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install Python and pip
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip

    # Install pytest for the testing framework
    python3 -m pip install --no-cache-dir pytest

    # Create /home/user with permissive permissions so the unprivileged
    # learner (whose UID is unknown at build-time) can create files/directories.
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up apt caches to keep the image lean
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%labels
    chmod 755 /home/user

    Author="Apptainer Exercise Builder"
    Description="Base image for cron-file creation exercise. Contains Python3 and pytest."

%help
    This container supplies the initial, pristine environment for the
    cron-file creation exercise.  It purposely does NOT include any of
    the artefacts that the learner must create (/home/user/cron, the
    *.cron file, or the status log).  Pytest is installed so the grading
    infrastructure can run its checks.