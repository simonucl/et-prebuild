Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3-pip \
        python3-setuptools \
        python3-wheel
    pip3 install --no-cache-dir pytest

    # Ensure the workspace directory exists and is writable by the unprivileged user
    mkdir -p /home/user
    chmod 0777 /home/user

%labels
    chmod 755 /home/user

    Author      ChatGPT
    Description Base image for MLOps benchmark exercise (pytest pre-installed)
    Version     1.0