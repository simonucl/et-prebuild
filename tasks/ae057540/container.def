Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python, pip and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state expected by the automated tests
    # ------------------------------------------------------------------

    # Create the directory hierarchy
    mkdir -p /home/user/projects/mobile-ci

    # Populate the CSV file with the exact ten lines required
    cat > /home/user/projects/mobile-ci/pipeline_runs.csv <<'EOF'
20231015-001;android;main;SUCCESS
20231015-002;android;main;FAILURE
20231015-003;ios;main;SUCCESS
20231015-004;ios;develop;FAILURE
20231015-005;ios;develop;SUCCESS
20231015-006;android;develop;SUCCESS
20231015-007;ios;develop;FAILURE
20231015-008;android;main;SUCCESS
20231015-009;android;main;SUCCESS
20231015-010;ios;develop;FAILURE
EOF

    # Ensure the student (non-root user at runtime) can write under /home/user
    chmod -R 0777 /home/user

%environment
    chmod 755 /home/user

    # Minimal locale settings to avoid potential warnings
    export LANG=C
    export LC_ALL=C

%labels
    Author  "Apptainer Build Automation"
    Description "Starter container for the mobile CI maintenance task"