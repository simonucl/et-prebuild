Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update APT and install Python tooling
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install pytest for the autograder
    pip3 install --no-cache-dir pytest

    # Ensure a writable home directory exists for the unprivileged user
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up APT caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH
    export HOME=/home/user

%labels
    Author="Task preparation script"
    Description="Ubuntu 22.04 base with pytest installed and a clean workspace for the YAML & TOML configuration management task."