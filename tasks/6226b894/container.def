Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package index and install required system packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        sqlite3 \
        ca-certificates

    # Install pytest for test execution inside the container
    pip3 install --no-cache-dir pytest

    # Create the required directory structure with write permissions
    mkdir -p /home/user/mlops
    chmod -R 0777 /home/user

%labels
    chmod 755 /home/user

    Author="Generated by ChatGPT"
    Description="Container with Python, sqlite3, and pytest; pre-creates /home/user/mlops for MLOps exercise."

%runscript
    exec "$@"