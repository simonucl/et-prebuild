# syntax=docker/dockerfile:1
FROM ubuntu:22.04

# Labels from Apptainer definition
LABEL Author="Generated by ChatGPT"
LABEL Description="Container with Python, sqlite3, and pytest; pre-creates /home/user/mlops for MLOps exercise."

# Install system packages and pytest, create directories and set permissions
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked --mount=type=cache,target=/var/lib/apt,sharing=locked --mount=type=cache,target=/root/.cache/pip set -e && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        sqlite3 \
        ca-certificates && \
    pip3 install --no-cache-dir pytest && \
    mkdir -p /home/user/mlops && \
    chmod -R 0777 /home/user && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Default command (equivalent to Apptainer %runscript exec "$@")
CMD ["/bin/bash"]