Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ---------------------------------------------------------------------- #
    # Create required directory structure
    # ---------------------------------------------------------------------- #
    mkdir -p /home/user/datasets
    mkdir -p /home/user/resources
    mkdir -p /home/user/outputs

    # ---------------------------------------------------------------------- #
    # Populate the sample dataset
    # ---------------------------------------------------------------------- #
    cat > /home/user/datasets/server_access.csv <<'EOF'
ip,timestamp,bytes_sent
192.0.2.1,2023-10-01T12:00:00Z,512
203.0.113.5,2023-10-01T12:01:00Z,1024
198.51.100.42,2023-10-01T12:02:00Z,2048
EOF

    # ---------------------------------------------------------------------- #
    # Populate the IP-to-hostname mapping file (tab-separated)
    # ---------------------------------------------------------------------- #
    cat > /home/user/resources/ip_hostname_map.txt <<'EOF'
192.0.2.1	api.internal.example
203.0.113.5	db01.internal.example
198.51.100.42	cache.internal.example
EOF

    # ---------------------------------------------------------------------- #
    # Install Python and pytest for the grading suite
    # ---------------------------------------------------------------------- #
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ---------------------------------------------------------------------- #
    # Ensure permissions allow the unprivileged runtime user to read the
    # inputs and write to the outputs directory.
    # ---------------------------------------------------------------------- #
    chmod 755 /home/user
    chmod -R 755 /home/user/datasets /home/user/resources
    chmod 777 /home/user/outputs

%environment
    # Nothing special required; rely on the runtime user's environment.

%runscript
    echo "Container for the hostname-enrichment task."
    echo "Input data is in /home/user/datasets and /home/user/resources."
    echo "Write your results to /home/user/outputs."