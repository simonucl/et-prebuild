Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Install Python and pytest
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest

    # Create non-root user `user`
    if ! getent group 1000 >/dev/null; then
        groupadd -g 1000 user
    fi
    if ! id -u 1000 >/dev/null 2>&1; then
        useradd -m -u 1000 -g 1000 -s /bin/bash user
    fi

    # Set up the initial directory structure and script required by the tests
    mkdir -p /home/user/ml_training/bin
    cat <<'EOF' > /home/user/ml_training/bin/prepare_data.sh
#!/usr/bin/env bash
echo "Preparing data"
EOF
    chmod +x /home/user/ml_training/bin/prepare_data.sh

    # Ensure ownership belongs to the non-root user
    chown -R 1000:1000 /home/user/ml_training

%environment
    chmod 755 /home/user

    # Preserve standard paths and ensure /usr/local/bin is included
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH