Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "=== Installing Python, pip and pytest ==="
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    echo "=== Creating initial directory structure for the exercise ==="
    # Create the user’s home directory (world–writable so the non-root agent can add files).
    mkdir -p /home/user
    chmod 0777 /home/user

    # Legacy tool staging
    mkdir -p /home/user/legacy/bin
    chmod 0755 /home/user/legacy
    chmod 0755 /home/user/legacy/bin

    cat >/home/user/legacy/bin/old_tool <<'EOF'
#!/usr/bin/env bash
echo "old_tool version v0.9.8-legacy"
EOF
    chmod 0755 /home/user/legacy/bin/old_tool

    echo "=== Clean-up apt caches ==="
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%labels
    chmod 755 /home/user

    Author  Your_Name
    Description   Container for legacy tool version audit exercise

%help
This container provides the initial state for the “legacy tool version audit”
exercise.  The tool is installed at /home/user/legacy/bin/old_tool, and pytest
is available for test execution.