Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package index and install required system packages
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-venv \
        python3-pip

    # Install pytest for the validation suites
    pip3 install --no-cache-dir pytest

    # Ensure a usable home directory exists and is writable by any user
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up APT caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Nothing to override; rely on Apptainer’s default HOME binding.

%labels
    Author "Apptainer setup for rollout venv task"
    Description "Ubuntu 22.04 image with Python, venv support, and pytest pre-installed."
    Version "1.0"

%help
    This container provides the baseline environment for the rollout-venv
    task.  Python, the venv module, and pytest are available.  No initial
    artefacts (virtual environment or setup.log) are created, so the task
    begins with a clean slate.