Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Refresh package index and install minimal tooling plus pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3-pip \
        procps \
        iproute2 \
        net-tools
    pip3 install --no-cache-dir pytest

    # Clean up APT caches to keep image lean
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Guarantee that /home/user/config_audit exists **at runtime** and is writable
    if [ ! -d "/home/user/config_audit" ]; then
        mkdir -p "/home/user/config_audit"
        chmod 700 "/home/user/config_audit"
    fi

    # Set sane locale defaults
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%labels
    Author "on-call configuration-manager exercise"

%help
    This container sets up the initial state for the configuration-audit task.
    It pre-installs pytest and ensures the directory /home/user/config_audit
    exists (owned by the invoking user) every time the container starts,
    while leaving the snapshot log file absent for the student to create.