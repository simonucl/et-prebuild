Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ---------------------------------------------------------------------
    # Basic tooling for the exercise & test-runner
    # ---------------------------------------------------------------------
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get -y install \
        python3 \
        python3-pip

    pip3 install --no-cache-dir pytest

    # ---------------------------------------------------------------------
    # Prepare initial directory structure and log file
    # ---------------------------------------------------------------------
    mkdir -p /home/user/logs

    cat > /home/user/logs/server_uptime.log <<'EOF'
2023-07-10T00:00:00Z OK 110
2023-07-10T00:05:00Z OK 105
2023-07-10T00:10:00Z DOWN -
2023-07-10T00:15:00Z OK 250
2023-07-10T00:20:00Z OK 700
2023-07-10T00:25:00Z DOWN -
2023-07-10T00:30:00Z OK 95
2023-07-10T00:35:00Z OK 900
2023-07-10T00:40:00Z OK 430
2023-07-10T00:45:00Z OK 510
2023-07-10T00:50:00Z DOWN -
2023-07-10T00:55:00Z OK 130
2023-07-10T01:00:00Z OK 140
2023-07-10T01:05:00Z DOWN -
2023-07-10T01:10:00Z OK 200
EOF

    # Ensure appropriate permissions (readable by non-root users)
    chmod 644 /home/user/logs/server_uptime.log

    # ---------------------------------------------------------------------
    # Clean up APT caches to keep the image small
    # ---------------------------------------------------------------------
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Add Python user-install location (if ever used) to PATH
    export PATH="$HOME/.local/bin:$PATH"

%labels
    Author="Generated by ChatGPT – Apptainer setup for SRE uptime exercise"

%help
    This container provides the initial state for the “server uptime” SRE
    exercise.  It contains:
      • /home/user/logs/server_uptime.log   (15 predefined lines)
    No report files are present; the student must create them.