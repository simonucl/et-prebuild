Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Update package index and install required utilities.
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        make \
        tar \
        python3 \
        python3-pip

    # Install pytest for the grading framework.
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create initial workspace expected by the grader.
    # ------------------------------------------------------------------
    mkdir -p /home/user/artifacts

    # Ensure the future, non-root runtime user has full write access.
    chmod 0777 /home/user
    chmod 0777 /home/user/artifacts

    # Seed the three required text files with their canonical contents.
    printf 'Meeting notes for Q1.\n'           > /home/user/artifacts/notes.txt
    printf 'v1.0 – initial release.\n'         > /home/user/artifacts/changelog.txt
    printf 'MIT License\n'                     > /home/user/artifacts/license.txt

    # Allow modification of the seed files by the unprivileged user.
    chmod 0666 /home/user/artifacts/*.txt

%environment
    chmod 755 /home/user

    # Keep PATH simple and include standard locations.
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%runscript
    # Default action: just exec whatever the caller wants.
    exec "$@"