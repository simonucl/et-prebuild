Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update and install minimal prerequisites
    apt-get update -y
    apt-get install -y --no-install-recommends python3-pip
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the grading suite
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create directory structure and populate the *raw* demo datasets
    # ------------------------------------------------------------------
    mkdir -p /home/user/datasets/raw
    mkdir -p /home/user/datasets/clean

    # transactions.csv  (7 lines: 1 header + 6 data rows)
    cat >/home/user/datasets/raw/transactions.csv <<'CSV'
transaction_id,date,amount,user_id,currency
1001,01/02/2022,23.5,501,USD
1002,2022-01-03,15.0,502,USD
1003,01-04-2022,12.99,,USD
1002,2022-01-03,15.0,502,USD
1004,04/01/2022,20,503,usd
1005,2022/01/05,7.5,504,USD
CSV

    # users.json  (array of 5 user records)
    cat >/home/user/datasets/raw/users.json <<'JSON'
[
 {"user_id":501,"name":"Alice","email":"alice@example.com"},
 {"user_id":502,"name":"Bob","email":"bob@example.com"},
 {"user_id":503,"name":"Charlie"},
 {"user_id":504,"name":"David","email":"david@example.com"},
 {"user_id":504,"name":"David Duplicate","email":"david@example.com"}
]
JSON

    # Make the "clean" directory writable by the non-root runtime user
    chmod -R 0777 /home/user/datasets/clean

%environment
    chmod 755 /home/user

    # Ensure Python and pip user-installed binaries are discoverable
    export PATH="$PATH:$HOME/.local/bin"

%labels
    Author      Data-Engineer-Bot
    Description "Container with raw demo datasets and pytest pre-installed."

%help
    This Apptainer container provides the raw datasets located at:
      /home/user/datasets/raw/

    A writable directory for cleaned outputs is located at:
      /home/user/datasets/clean/

    Pytest is pre-installed for the grading suite.