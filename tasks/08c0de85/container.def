Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update APT and install Python tooling
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial exercise state: /home/user/raw with four CSV files
    # ------------------------------------------------------------------
    mkdir -p /home/user/raw

    # 1. hostnames.csv
    cat >/home/user/raw/hostnames.csv <<'EOF'
HOSTNAME
server01
server02
db01
web02
proxy01
EOF

    # 2. os.csv
    cat >/home/user/raw/os.csv <<'EOF'
OS
Ubuntu 20.04
CentOS 8
Ubuntu 18.04
Debian 10
AlmaLinux 9
EOF

    # 3. patch_status.csv
    cat >/home/user/raw/patch_status.csv <<'EOF'
PATCH_STATUS
Compliant
Non-Compliant
Compliant
Compliant
Non-Compliant
EOF

    # 4. av_status.csv
    cat >/home/user/raw/av_status.csv <<'EOF'
AV_STATUS
Enabled
Disabled
Enabled
Enabled
Disabled
EOF

    # Permissions: directory world‐executable, files world‐readable
    chmod 755 /home/user /home/user/raw
    chmod 644 /home/user/raw/*.csv

%environment
    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8
    export PYTHONIOENCODING=utf-8

%labels
    Author Singularity-Prep
    Description "Initial state for compliance CSV merging task: raw data present, pytest installed."