Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install required utilities
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3-pip \
        iputils-ping

    # Install pytest for the grading suite
    pip3 install --no-cache-dir pytest

    # Ensure the working directory for the student exists and is writable
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%labels
    Author="Generated by ChatGPT"
    Description="Base image for connectivity-check task. Includes pytest and writable /home/user."