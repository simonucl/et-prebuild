Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install Python 3 + pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-setuptools

    # Install pytest for the validation framework
    pip3 install --no-cache-dir pytest

    # Create a writable /home/user directory for the exercise
    mkdir -p /home/user
    chmod 0777 /home/user

    # Minimal cleanup
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%runscript
    chmod 755 /home/user

    exec "$@"