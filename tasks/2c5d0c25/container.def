Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # Update package lists and install required system packages
    apt-get update
    apt-get install -y --no-install-recommends \
        python3-pip \
        cron

    # Install pytest for the exercise test-suite
    pip3 install --no-cache-dir pytest

    # Ensure the baseline /home/user directory exists and is writable
    mkdir -p /home/user
    chmod 0777 /home/user   # allow the unprivileged runtime user to write here

    # Clean up APT caches to keep the image lean
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    export LC_ALL=C.UTF-8
    export PATH=/usr/local/bin:/usr/bin:/bin

%runscript
    # Default runscript: just exec what was provided
    exec "$@"