Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ---------------------------------------------------------------------
    # Basic tooling
    # ---------------------------------------------------------------------
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        jq \
        ca-certificates
    pip3 install --no-cache-dir pytest jsonschema

    # ---------------------------------------------------------------------
    # Initial directory & file setup
    # ---------------------------------------------------------------------
    # Create the user home and credentials directory
    mkdir -p /home/user/credentials
    chmod 0777 /home/user /home/user/credentials || true   # ensure the learner can write

    # ---- creds.json (initial state) -------------------------------------
    cat > /home/user/credentials/creds.json <<'CREDS'
{
  "user": "service_account",
  "access_key": "AKIAOLD123456789",
  "secret_key": "oldSecretKeyValue",
  "rotation_date": "2022-01-15T10:00:00Z"
}
CREDS
    chmod 0666 /home/user/credentials/creds.json || true

    # ---- creds_schema.json ---------------------------------------------
    cat > /home/user/credentials/creds_schema.json <<'SCHEMA'
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Credentials Schema",
  "type": "object",
  "required": ["user", "access_key", "secret_key", "rotation_date"],
  "properties": {
    "user":          { "type": "string" },
    "access_key":    { "type": "string" },
    "secret_key":    { "type": "string" },
    "rotation_date": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
SCHEMA
    chmod 0644 /home/user/credentials/creds_schema.json

%labels
    chmod 755 /home/user

    Author "ChatGPT OpenAI"