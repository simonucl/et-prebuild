Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package list and install Python & pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates

    # Install pytest for the verification suite
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial on-disk state required by the exercise
    # ------------------------------------------------------------------
    # Create directories
    mkdir -p /home/user/provision

    # Populate the servers.list file with the exact required contents
    cat > /home/user/provision/servers.list <<'EOF'
web-1,10.1.1.10,ubuntu18
web-2,10.1.1.11,ubuntu18
db-1,10.1.2.20,centos7
cache-1,10.1.3.30,alpine3
msg-queue,10.1.4.40,debian10
EOF

    # Ensure permissive but safe permissions so the exercise can write later
    chmod 755 /home/user
    chmod 775 /home/user/provision
    chmod 644 /home/user/provision/servers.list

%environment
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author        ExampleAuthor
    Description   "Container for AWK/Sed host catalogue exercise with initial state prepared."