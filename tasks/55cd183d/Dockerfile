FROM ubuntu:22.04

# Labels
LABEL Author="Generated by ChatGPT"
LABEL Description="Environment for one-way sync workflow task with pytest pre-installed."

# Help information as comments
# This container sets up the required initial filesystem state for the
# repeatable one-way sync workflow exercise. Pytest is installed for the
# autograder.

# ------------------------------------------------------------------
# Install system packages and Python tooling
# ------------------------------------------------------------------
RUN set -e && \
    apt-get update -y && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 python3-pip rsync ca-certificates && \
    pip3 install --no-cache-dir pytest

# ------------------------------------------------------------------
# Create initial directory layout under /home/user
# ------------------------------------------------------------------
RUN mkdir -p /home/user/datasets/raw_data/exp1/.temp && \
    mkdir -p /home/user/datasets/raw_data/exp2 && \
    mkdir -p /home/user/remote/mirror/data && \
    mkdir -p /home/user/sync_logs

# ------------------------------------------------------------------
# Populate SOURCE files with exact contents
# ------------------------------------------------------------------

# exp1/results.csv
RUN cat > /home/user/datasets/raw_data/exp1/results.csv <<'EOF'
gene,expression
BRCA1,5.6
TP53,7.1
EOF

# exp1/notes.txt
RUN cat > /home/user/datasets/raw_data/exp1/notes.txt <<'EOF'
Reminder: remove outliers before publication.
EOF

# exp1/.temp/cache.tmp (binary 0xDE 0xAD 0xBE 0xEF)
RUN printf '\xDE\xAD\xBE\xEF' > /home/user/datasets/raw_data/exp1/.temp/cache.tmp

# exp2/data_part1.csv
RUN cat > /home/user/datasets/raw_data/exp2/data_part1.csv <<'EOF'
sample_id,value
S1,3.1
S2,2.9
EOF

# exp2/data_part2.csv
RUN cat > /home/user/datasets/raw_data/exp2/data_part2.csv <<'EOF'
sample_id,value
S3,4.2
S4,3.8
EOF

# exp2/.ignore (0-byte placeholder)
RUN : > /home/user/datasets/raw_data/exp2/.ignore

# ------------------------------------------------------------------
# Set permissive permissions so an unprivileged container user can
# create new files/directories as required by the assignment.
# ------------------------------------------------------------------
RUN chmod 0777 /home/user && \
    chmod 0777 /home/user/remote && \
    chmod -R 0777 /home/user/remote/mirror && \
    chmod 0777 /home/user/sync_logs

# Environment variables
ENV PATH=/usr/local/bin:/usr/bin:/bin:$PATH

# Set working directory
WORKDIR /home/user