Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "Updating APT package index and installing required tools…"
    apt-get update
    # Install networking diagnostics and Python tooling
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        iputils-ping \
        traceroute \
        dnsutils \
        python3 \
        python3-pip \
        ca-certificates

    # Clean up APT caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    echo "Installing pytest via pip…"
    pip3 install --no-cache-dir pytest

    echo "Preparing writable /home/user directory…"
    mkdir -p /home/user
    # Allow any non-root user to create sub-directories/files inside /home/user
    chmod 0777 /home/user

%environment
    chmod 755 /home/user

    export LC_ALL=C
    export LANG=C
    export PATH=/usr/local/bin:/usr/local/sbin:/usr/bin:/usr/sbin:/bin:/sbin

%labels
    Author      "Generated by ChatGPT"
    Description "Ubuntu 22.04 base image with networking tools and pytest pre-installed for the network-health snapshot assignment."