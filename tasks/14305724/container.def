Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    apt-get update && \
    apt-get install -y --no-install-recommends python3-pip && \
    pip3 install --no-cache-dir pytest && \
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Create the initial filesystem state expected by the test-suite
    # ------------------------------------------------------------------
    mkdir -p /home/user/db

    # Populate the original slow_query.log (exactly 14 lines, each LF-terminated)
cat > /home/user/db/slow_query.log <<'EOF'
SELECT * FROM orders WHERE status = 'pending';
SELECT id, name FROM customers WHERE country = 'US';
UPDATE inventory SET quantity = quantity - 1 WHERE product_id = 42;
SELECT * FROM orders WHERE status = 'pending';
SELECT * FROM orders WHERE status = 'pending';
UPDATE inventory SET quantity = quantity - 1 WHERE product_id = 42;
SELECT id, name FROM customers WHERE country = 'US';
DELETE FROM sessions WHERE last_active < NOW() - INTERVAL '30 days';
SELECT * FROM orders WHERE status = 'pending';
DELETE FROM sessions WHERE last_active < NOW() - INTERVAL '30 days';
SELECT * FROM orders WHERE status = 'pending';
SELECT id, name FROM customers WHERE country = 'US';
INSERT INTO audit_log (event, created_at) VALUES ('login', NOW());
SELECT * FROM orders WHERE status = 'pending';
EOF

    # Make sure the directory (and file) are writable by non-privileged users
    chmod -R a+rw /home/user/db

    # Do NOT create the artefacts that the agent must generate later
    # (/home/user/db/slow_query_frequency.tsv and slow_query_summary.log)

%environment
    chmod 755 /home/user

    export LANG=C
    export LC_ALL=C

%labels
    Author="Apptainer slow-query task container"

%help
This container sets up the initial state for the “slow query” SQL log
processing task.

Included:
  • /home/user/db/slow_query.log  – the 14-line source log
  • pytest                        – installed for the validation suite

The student / agent must create:
  • slow_query_frequency.tsv
  • slow_query_summary.log

Both inside /home/user/db.