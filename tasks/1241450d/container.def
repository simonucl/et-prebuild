Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    #!/bin/bash
    set -e

    # Install Python and tools required for the exercise and testing
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-venv

    # Install pytest for the automated grader
    pip3 install --no-cache-dir pytest

    # Create the datasets directory expected by the exercise
    mkdir -p /home/user/datasets

    # Ensure the learner (non-root at runtime) can freely write to /home/user/*
    chmod -R 0777 /home/user

    # Clean up APT caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
    export PYTHONUNBUFFERED=1

%labels
    Author "Apptainer Exercise Preparer"
    Description "Base container for research_env virtual-environment exercise."