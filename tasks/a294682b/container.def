Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    ## Install Python3-pip and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3-pip
    pip3 install --no-cache-dir pytest

    ## ------------------------------------------------------------------ ##
    ## Create initial directory structure and daily log files             ##
    ## ------------------------------------------------------------------ ##
    # Base directory for the exercise
    mkdir -p /home/user/backups/daily

    # Ensure correct permissions:
    #   - /home/user : readable/executable by everyone
    #   - /home/user/backups : writable so the learner (non-root) can create
    #     the 'summary' directory later on.
    chmod 755 /home/user
    chmod 777 /home/user/backups
    chmod 755 /home/user/backups/daily

    ## Create the three daily log files with exact contents
    cat > /home/user/backups/daily/backup_report_2023-08-01.log << 'EOF'
db.sql 20480 9f8b1e2d 2023-08-01
home.tar 512000 c3d8fab1 2023-08-01
etc.cfg 120 1a2b3c4d 2023-08-01
EOF

    cat > /home/user/backups/daily/backup_report_2023-08-02.log << 'EOF'
db.sql 20560 af4c9d11 2023-08-02
home.tar 513024 0ddce8ef 2023-08-02
etc.cfg 125 ee44aa55 2023-08-02
EOF

    cat > /home/user/backups/daily/backup_report_2023-08-03.log << 'EOF'
db.sql 20640 bb88cc77 2023-08-03
home.tar 514048 2376abdc 2023-08-03
etc.cfg 130 ddd77711 2023-08-03
EOF

    # Ensure the files are readable by everyone
    chmod 644 /home/user/backups/daily/backup_report_2023-08-*.log

    ## Do NOT create /home/user/backups/summary/ or any output artefacts.
    ## ------------------------------------------------------------------ ##

%environment
    # Nothing special needed; keep user HOME untouched
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%labels
    Author Backup-Training-Setup
    Description "Environment for backup consolidation task with initial daily logs."

%help
    This Apptainer image provides the starting filesystem state for the
    "backup consolidation" exercise.  Three daily log files are present in
    /home/user/backups/daily/; the /home/user/backups/summary/ directory has
    deliberately NOT been created so the learner can generate required
    outputs there.  Pytest is installed for automated grading.