Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Maintainer cpu-hog-prep
    Description "Environment for the CPU-hog performance-snapshot exercise"

%post
    set -eux

    # Basic tools and Python environment
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 python3-pip procps ca-certificates
    pip3 install --no-cache-dir --upgrade pip
    pip3 install --no-cache-dir pytest

    # Prepare working directory and helper script
    mkdir -p /home/user
    chmod 0777 /home/user     # allow the unprivileged runtime user to write here

    cat >/home/user/cpu_hog.sh <<'EOF'
#!/usr/bin/env bash
# Very small infinite loop to eat CPU
while true; do :; done
EOF
    chmod 0755 /home/user/cpu_hog.sh

    # Ensure the perf_logs directory does NOT exist in the pristine image
    rm -rf /home/user/perf_logs

%environment
    chmod 755 /home/user

    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH