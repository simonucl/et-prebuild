Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "Updating package index and installing Python tooling..."
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    echo "Installing pytest for the grading suite..."
    pip3 install --no-cache-dir pytest

    echo "Creating initial deployment configuration directory and files..."
    mkdir -p /home/user/deployment_configs
    chmod 755 /home/user/deployment_configs

    cat > /home/user/deployment_configs/service_alpha.conf <<'EOF'
ServiceName: AlphaAPI
Version: 1.3.7
Environment: staging
Status: READY
EOF

    cat > /home/user/deployment_configs/service_beta.conf <<'EOF'
ServiceName: BetaWorker
Version: 3.2.4
Environment: production
Status: LIVE
EOF

    cat > /home/user/deployment_configs/service_gamma.conf <<'EOF'
ServiceName: GammaDB
Version: 0.9.12
Environment: staging
Status: READY
EOF

    cat > /home/user/deployment_configs/service_delta.conf <<'EOF'
ServiceName: DeltaUI
Version: 2.1.0
Environment: staging
Status: IN_TEST
EOF

    chmod 644 /home/user/deployment_configs/*.conf

%environment
    # Preserve default HOME and add Python to PATH just in case
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author release-manager-task
    Description "Container with initial deployment configuration files and pytest pre-installed for grading."

%help
    This container sets up the initial state required for the “release-manager”
    programming task. It installs pytest and places four .conf files in
    /home/user/deployment_configs/ exactly as expected by the automated tests.