Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update -y
    apt-get install -y python3 python3-pip
    pip3 install --no-cache-dir pytest

    # Prepare initial pipeline log files expected by the tests
    mkdir -p /home/user/pipeline/logs

    printf "[2023-01-01 00:00:01] ERROR Pipeline crashed at step 3\n" \
        > /home/user/pipeline/logs/error.log
    printf "[2023-01-01 00:00:00] INFO  Pipeline started\n" \
        > /home/user/pipeline/logs/pipeline.log

    # Ensure the unprivileged runtime user can read/write these files
    chmod -R a+rwX /home/user

%environment
    chmod 755 /home/user

    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH
    export PYTHONUNBUFFERED=1

%labels
    Author On-call Support Engineer
    Description Initial state for diagnostics-collection task