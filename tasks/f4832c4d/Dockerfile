FROM ubuntu:22.04

# Help section
# This container provides the starting point for the log-processing task.
# It includes:
#   • /home/user/project/logs/day1_access.log (5 lines)
#   • /home/user/project/logs/day2_access.log (5 lines)
# Both logs match the exact specification in the assignment.
# The reports directory is intentionally absent.
# Pytest is installed so the grading suite can run inside the container.

LABEL Author="autogenerated"
LABEL Description="Environment for Apache access-log column-extraction task. Logs pre-seeded; pytest installed."

ENV PYTHONIOENCODING=utf-8

RUN set -e && \
    apt-get update -y && \
    apt-get install -y --no-install-recommends python3 python3-pip ca-certificates && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

RUN pip3 install --no-cache-dir pytest

RUN mkdir -p /home/user/project/logs && \
    chmod -R 0777 /home/user

RUN cat > /home/user/project/logs/day1_access.log <<'EOF'
192.168.1.10 - - [15/Sep/2023:10:00:00 +0000] "GET /index.html HTTP/1.1" 200 1043 "-" "Mozilla/5.0"
172.16.0.3 - - [15/Sep/2023:10:02:47 +0000] "POST /login HTTP/1.1" 302 560 "-" "Mozilla/5.0"
93.184.216.34 - - [15/Sep/2023:10:03:12 +0000] "GET /images/logo.png HTTP/1.1" 304 0 "-" "Mozilla/5.0"
192.0.2.44 - - [15/Sep/2023:10:05:55 +0000] "GET /about HTTP/1.1" 200 2048 "-" "Mozilla/5.0"
203.0.113.5 - - [15/Sep/2023:10:07:23 +0000] "GET /contact HTTP/1.1" 404 512 "-" "Mozilla/5.0"
EOF

RUN cat > /home/user/project/logs/day2_access.log <<'EOF'
192.168.1.10 - - [16/Sep/2023:10:00:00 +0000] "GET /index.html HTTP/1.1" 200 1100 "-" "Mozilla/5.0"
172.16.0.3 - - [16/Sep/2023:10:02:47 +0000] "POST /login HTTP/1.1" 200 580 "-" "Mozilla/5.0"
93.184.216.34 - - [16/Sep/2023:10:03:12 +0000] "GET /images/logo.png HTTP/1.1" 304 0 "-" "Mozilla/5.0"
192.0.2.44 - - [16/Sep/2023:10:05:55 +0000] "GET /about HTTP/1.1" 503 2100 "-" "Mozilla/5.0"
203.0.113.5 - - [16/Sep/2023:10:07:23 +0000] "GET /contact HTTP/1.1" 200 540 "-" "Mozilla/5.0"
EOF

RUN if grep -q $'\r' /home/user/project/logs/day1_access.log || \
       grep -q $'\r' /home/user/project/logs/day2_access.log; then \
        echo "Detected CR characters in log files; aborting build." && exit 1; \
    fi

RUN chmod 755 /home/user