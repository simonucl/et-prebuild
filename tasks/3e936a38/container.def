Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package index and install required tools
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        jq \
        net-tools \
        procps \
        ca-certificates
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the automated test harness
    pip3 install --no-cache-dir pytest

    # Ensure the expected home directory exists and is writable
    mkdir -p /home/user
    chmod 0777 /home/user

    # Guarantee a clean starting point for the assignment
    rm -rf /home/user/compliance_audit || true

%environment
    chmod 755 /home/user

    # Keep a predictable, standard PATH
    export PATH=/usr/local/bin:/usr/local/sbin:/usr/bin:/usr/sbin:/bin:/sbin

%labels
    Author="Generated by AI"
    Description="Container for compliance-audit assignment – includes pytest and a clean /home/user environment"