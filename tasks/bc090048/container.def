Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Update package lists and install Python + pip
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare the required directory structure and files for the task
    # ------------------------------------------------------------------
    mkdir -p /home/user/config_backups

    # 1. Configuration backup files with exact contents (no trailing LF)
    printf 'abc' > /home/user/config_backups/fw01.conf
    printf 'hello world' > /home/user/config_backups/sw02.conf
    : > /home/user/config_backups/rtr03.conf    # create empty file

    # 2. Authoritative reference CSV (must end with a single LF)
    cat > /home/user/config_backups/reference_checksums.csv <<'EOF'
FILENAME,SHA256
fw01.conf,ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad
sw02.conf,b94d27b9934d3e08a52e52d7da7dabfac484efe37a5380ee9088f7ace2efcde9
rtr03.conf,e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855
EOF

    # Ensure correct permissions so the non-root user inside the sandbox can read them
    chmod 755 /home/user
    chmod 755 /home/user/config_backups
    chmod 644 /home/user/config_backups/*

%environment
    # Nothing to override; keep default HOME binding.

%labels
    Author check-sums task setup
    Description "Prepares initial state for checksum verification exercise"

%help
    This container image sets up the initial filesystem state required for the
    checksum verification coding task and includes pytest so that the automated
    grader can validate both the initial state and the student’s solution.