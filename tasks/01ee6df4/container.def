Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # ---------------------------------------------------------------------
    # Core packages and pytest
    # ---------------------------------------------------------------------
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates
    pip3 install --no-cache-dir pytest
    rm -rf /var/lib/apt/lists/*

    # ---------------------------------------------------------------------
    # Create initial directory layout and seed log file
    # ---------------------------------------------------------------------
    mkdir -p /home/user/logs
    chmod 0755 /home/user
    chmod 0755 /home/user/logs

    # Access log (30 lines, LF endings, permissions 0644)
    cat > /home/user/logs/access.log << 'EOF'
192.168.1.10 - - [10/Oct/2023:13:55:36 +0000] "GET /index.html HTTP/1.1" 200 1024
192.168.1.11 - - [10/Oct/2023:13:55:37 +0000] "GET /about.html HTTP/1.1" 200 2048
