Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Non-interactive apt operations
    export DEBIAN_FRONTEND=noninteractive

    # Basic tooling and Python + pytest
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        locales
    pip3 install --no-cache-dir pytest

    # Create a normal user that matches the exercise assumptions
    if ! id -u 1000 &>/dev/null; then
        useradd -m -u 1000 -s /bin/bash user
    fi

    # Prepare the required directory and UTF-16LE source file
    mkdir -p /home/user/scan_outputs

    python3 - << 'PY'
import pathlib, sys
content = (
    "Open port: 22/ssh\n"
    "Deprecated protocol: SSLv3 detected\n"
    "Vulnerability: CVE-2023-1234\n"
)
path = pathlib.Path("/home/user/scan_outputs/vuln_scan_utf16le.txt")
# utf-16 writes with a BOM; on little-endian systems it becomes UTF-16LE + BOM.
path.write_text(content, encoding="utf-16")
PY

    # Reasonable permissions (readable by the ordinary user)
    chmod 644 /home/user/scan_outputs/vuln_scan_utf16le.txt

%environment
    chmod 755 /home/user

    # Ensure Python and pip are on PATH for the learner
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%labels
    Author task-prep-generator
    Description "Environment for UTF-16LE -> UTF-8 conversion exercise with pytest pre-checks"