Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Install Python, pip, pytest, and iptables tooling
    apt-get update -y
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        iptables

    pip3 install --no-cache-dir pytest

    # Create an unprivileged user 'user' with a home directory at /home/user
    useradd -m -s /bin/bash user

    # Ensure the user owns its home directory
    chown -R user:user /home/user

    # Clean up APT caches to reduce image size
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure Python is on PATH (usually already is, but explicitly set for safety)
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author="Task Preparer"
    Description="Base image for firewall artefact-creation task. Contains Python, pytest, and iptables; no firewall artefacts are pre-created."

%help
    This Apptainer image provides the minimal environment required for the
    student to carry out the firewall artefact task.  It intentionally
    contains NO pre-created firewall directories or files.