Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update APT metadata and install Python & pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # Ensure a neutral working home is present but **do not** create any
    # of the task-specific artefacts.  The tests require they be absent.
    mkdir -p /home/user

    # Clean up APT caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Make sure Python and user-installed binaries are on the PATH
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"