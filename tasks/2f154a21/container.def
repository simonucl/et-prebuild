Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # Install Python and pytest
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial directory structure and baseline files for testing
    # ------------------------------------------------------------------
    mkdir -p /home/user/tinyftp
    mkdir -p /home/user/logs

    # tinyftp configuration (initial state)
    cat > /home/user/tinyftp/tinyftp.conf <<'EOF'
# tinyftp configuration
port=2121
log-level=INFO
EOF

    # Pre-populated mixed-level log
    cat > /home/user/logs/tinyftp.log <<'EOF'
2023-09-01 12:00:00 INFO: Server started on port 2121
2023-09-01 12:01:00 DEBUG: Connection from 192.168.1.10 accepted
2023-09-01 12:02:00 ERROR: Failed login attempt for user 'john'
2023-09-01 12:03:00 DEBUG: Connection closed for 192.168.1.10
2023-09-01 12:04:00 INFO: Server status: OK
EOF

    # Make sure the normal (non-root) user will be able to write here
    chmod -R a+rwX /home/user

%environment
    chmod 755 /home/user

    # Keep Python happy with UTF-8 everywhere
    export PYTHONIOENCODING=UTF-8

%labels
    Author tinyftp-initial-state