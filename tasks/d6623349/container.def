Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Update package index and install required tools
    apt-get update -y
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        jq \
        ca-certificates

    # Install pytest and jsonschema via pip (latest versions)
    pip3 install --no-cache-dir pytest jsonschema

    # ------------------------------------------------------------------
    # Create initial directory structure and populate required JSON files
    # ------------------------------------------------------------------
    MON_DIR="/home/user/monitoring"
    mkdir -p "${MON_DIR}"

    # --- alert-schema.json ---
    cat > "${MON_DIR}/alert-schema.json" << 'EOF'
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["id", "service", "severity", "timestamp"],
  "properties": {
    "id":        { "type": "string" },
    "service":   { "type": "string" },
    "severity":  { "type": "string",
                   "enum": ["low", "medium", "high", "critical"] },
    "timestamp": { "type": "string",
                   "format": "date-time" }
  },
  "additionalProperties": false
}
EOF

    # --- alerts.json ---
    cat > "${MON_DIR}/alerts.json" << 'EOF'
[
  {
    "id": "a1",
    "service": "auth",
    "severity": "high",
    "timestamp": "2023-09-12T10:33:00Z"
  },
  {
    "id": "a2",
    "service": "billing",
    "severity": "critical",
    "timestamp": "2023-09-12T10:35:27Z"
  },
  {
    "id": 100,
    "service": "db",
    "severity": "urgent",
    "timestamp": "not a date"
  }
]
EOF

    # Ensure correct permissions (readable, non-executable)
    chmod -R a+r "${MON_DIR}"

    # Remove apt caches to reduce image size
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%labels
    chmod 755 /home/user

    Author      Monitoring-Platform Task Preparer
    Description "Environment with initial JSON files, pytest, jsonschema, and jq for the monitoring-platform assignment."