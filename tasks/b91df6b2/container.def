Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "Updating package index and installing dependencies..."
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        time \
        parallel \
        jq \
        ca-certificates

    echo "Installing pytest via pip..."
    pip3 install --no-cache-dir pytest

    echo "Creating baseline directory structure and files..."
    # Ensure /home/user exists
    mkdir -p /home/user

    # Create policy_tests directories
    mkdir -p /home/user/policy_tests/scripts

    # Create compute.sh with executable workload
    cat >/home/user/policy_tests/scripts/compute.sh <<'EOF'
#!/usr/bin/env bash
# Very small CPU-bound workload (~0.5-1s)
for i in $(seq 1 150000); do
  : $((i * i))
done
EOF
    chmod 755 /home/user/policy_tests/scripts/compute.sh

    # Create policy.conf with required thresholds
    cat >/home/user/policy_tests/policy.conf <<'EOF'
MAX_RUNTIME_MS=1500
MAX_MEMORY_KB=300000
EOF
    chmod 644 /home/user/policy_tests/policy.conf

    # Ensure write permissions for future artefacts
    chmod -R a+rwx /home/user/policy_tests

    echo "Cleaning up apt caches to reduce image size..."
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    echo "Container for Policy-as-Code Performance Benchmark."
    echo "Everything is prepared under /home/user/policy_tests."
    echo "Invoke your benchmark scripts from the host environment."