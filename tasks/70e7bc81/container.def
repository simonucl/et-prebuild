Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package index and install required system packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        glpk-utils \
        python3-pip \
        ca-certificates

    # Install pytest for the grading suite
    pip3 install --no-cache-dir pytest

    # Create the working directory and populate the LP file
    mkdir -p /home/user
    cat > /home/user/storage_problem.lp <<'EOF'
Minimize
 obj: x1 + 2 x2 + 3 x3
Subject To
 c1: x1 + x2 + x3 >= 10
Bounds
 0 <= x1 <= 4
 0 <= x2 <= 5
 0 <= x3 <= 7
Generals
 x1 x2 x3
End
EOF

    # Ensure readable permissions
    chmod 644 /home/user/storage_problem.lp

%environment
    chmod 755 /home/user

    # Nothing required here; we intentionally leave $HOME untouched so that
    # Apptainer binds the caller's home directory as usual.
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%labels
    Author "Container Build Script for Storage LP Task"
    Version "1.0"
    Description "Provides initial state (LP file, glpsol, pytest) for the student storage LP assignment."