Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ------------------------------------------------------------------
    # Install system packages
    # ------------------------------------------------------------------
    apt-get update && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        sqlite3 \
        ca-certificates \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Python tooling
    # ------------------------------------------------------------------
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare filesystem layout expected by the tests
    # ------------------------------------------------------------------
    mkdir -p /home/user/legacy
    mkdir -p /home/user/new

    # Make sure the agent (non-root at runtime) can read/write here
    chmod -R 777 /home/user

    # ------------------------------------------------------------------
    # Create the legacy SQLite database with required schema & data
    # ------------------------------------------------------------------
    sqlite3 /home/user/legacy/legacy.db <<'SQL'
    CREATE TABLE customers_old (
        id    INTEGER PRIMARY KEY,
        name  TEXT,
        email TEXT
    );
    INSERT INTO customers_old (id, name, email) VALUES
        (1,'Alice Smith','alice@example.com'),
        (2,'Bob Jones','bob@example.com'),
        (3,'Charlie Brown','charlie@example.com');
SQL

    # Ensure the DB is writable by the runtime user
    chmod 666 /home/user/legacy/legacy.db

%environment
    chmod 755 /home/user

    # Keep output unbuffered and locale predictable
    export PYTHONUNBUFFERED=1
    export LC_ALL=C

%labels
    Author="Container prep script"
    Description="Initial environment for SQLite migration task with pytest installed."