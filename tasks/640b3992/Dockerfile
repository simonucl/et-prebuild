# syntax=docker/dockerfile:1
FROM ubuntu:22.04

# ------------------------------------------------------------------
# Basic utilities and Python testing framework
# ------------------------------------------------------------------
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked --mount=type=cache,target=/var/lib/apt,sharing=locked --mount=type=cache,target=/root/.cache/pip set -e && \
    apt-get update && \
    apt-get install -y --no-install-recommends \
        rsync \
        python3-pip && \
    pip3 install --no-cache-dir pytest && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# ------------------------------------------------------------------
# Create non-root user “user” with home directory /home/user
# ------------------------------------------------------------------
RUN useradd -m -u 1000 -s /bin/bash user || true

# ------------------------------------------------------------------
# Set up the required directory tree and dataset files
# ------------------------------------------------------------------
RUN set -e && \
    DATASETS_BASE="/home/user/datasets" && \
    SRC_DIR="${DATASETS_BASE}/original" && \
    BACKUP_DIR="${DATASETS_BASE}/backup" && \
    mkdir -p "${SRC_DIR}/images" && \
    mkdir -p "${BACKUP_DIR}" && \
    printf 'a,1,2\n'                 > "${SRC_DIR}/experiment1.csv" && \
    printf 'b,3,4\n'                 > "${SRC_DIR}/experiment2.csv" && \
    printf '# Experiments Dataset\n' > "${SRC_DIR}/readme.md" && \
    printf 'PNG_DUMMY_A\n'           > "${SRC_DIR}/images/plot_A.png" && \
    printf 'PNG_DUMMY_B\n'           > "${SRC_DIR}/images/plot_B.png"

# ------------------------------------------------------------------
# Permissions: allow the runtime (non-root) user to read/write as needed
# ------------------------------------------------------------------
RUN chown -R 1000:1000 /home/user && \
    chmod 777 /home/user/datasets && \
    chmod 777 /home/user/datasets/backup

# ------------------------------------------------------------------
# Runtime environment setup (from %environment)
# ------------------------------------------------------------------
RUN chmod 755 /home/user

# ------------------------------------------------------------------
# Labels
# ------------------------------------------------------------------
LABEL Author="Generated by AI – Apptainer task scaffold for dataset sync"