Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # 1. Install Python and pytest ------------------------------------------------
    apt-get update && \
        apt-get install -y --no-install-recommends python3 python3-pip && \
        apt-get clean && \
        rm -rf /var/lib/apt/lists/*

    pip3 install --no-cache-dir pytest

    # 2. Prepare the initial filesystem state -------------------------------------
    # Ensure the /home/user directory tree exists and is world-writable so the
    # unprivileged agent can create additional files and directories.
    mkdir -p /home/user/restores/2024-06-10

    # Create the daily_filelist.log with the exact required content
    cat <<'EOF' > /home/user/restores/2024-06-10/daily_filelist.log
docs/finance/report1.pdf
docs/hr/policy.docx
media/photos/img001.jpg
docs/finance/report1.pdf
media/photos/img002.jpg
docs/finance/report1.pdf
media/photos/img001.jpg
docs/hr/policy.docx
scripts/backup.sh
scripts/backup.sh
scripts/backup.sh
media/photos/img002.jpg
media/photos/img002.jpg
EOF

    # 3. Set liberal permissions so the non-root user inside the container can
    #    read/write as needed during testing.
    chmod -R a+rwx /home/user

%environment
    chmod 755 /home/user

    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
    export PYTHONUNBUFFERED=1