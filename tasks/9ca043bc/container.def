Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # --------------------------------------------------------------------- #
    # 1. Install required packages and pytest
    # --------------------------------------------------------------------- #
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        locales

    # Generate minimal UTF-8 locale so Python does not complain
    locale-gen en_US.UTF-8

    # Install pytest for the runtime user
    pip3 install --no-cache-dir pytest

    # --------------------------------------------------------------------- #
    # 2. Create initial dataset directory and CSV files
    # --------------------------------------------------------------------- #
    DATA_DIR="/home/user/datasets"
    mkdir -p "${DATA_DIR}"

    # sales_Q1.csv
    cat > "${DATA_DIR}/sales_Q1.csv" <<'EOF'
id,category,amount
1,Electronics,120
2,Furniture,300
3,Electronics,80
4,Toys,25
5,Books,15
6,Electronics,200
7,Books,20
EOF

    # sales_Q2.csv
    cat > "${DATA_DIR}/sales_Q2.csv" <<'EOF'
id,category,amount
1,Toys,30
2,Furniture,150
3,Electronics,220
4,Toys,40
5,Books,18
6,Kitchen,80
7,Electronics,130
EOF

    # Ensure the dataset directory and its files are readable by any user.
    chmod 755 /home/user
    chmod -R 755 "${DATA_DIR}"

%environment
    export LC_ALL=en_US.UTF-8
    export LANG=en_US.UTF-8
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Maintainer "Generated by ChatGPT"
    Description "Container with pre-populated sales CSV datasets and pytest installed for assessment."

%runscript
    echo "This container is intended for an educational task."
    echo "Datasets are located in /home/user/datasets."
    echo "Use this container as the execution environment for the assignment."