# Maintainer: Generated by ChatGPT
# Description: Container with pre-populated sales CSV datasets and pytest installed for assessment.

FROM ubuntu:22.04

ENV LC_ALL=en_US.UTF-8
ENV LANG=en_US.UTF-8
ENV PATH=/usr/local/bin:/usr/bin:/bin:$PATH

RUN set -e && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        locales && \
    locale-gen en_US.UTF-8 && \
    pip3 install --no-cache-dir pytest

RUN mkdir -p /home/user/datasets

RUN cat > /home/user/datasets/sales_Q1.csv <<'EOF'
id,category,amount
1,Electronics,120
2,Furniture,300
3,Electronics,80
4,Toys,25
5,Books,15
6,Electronics,200
7,Books,20
EOF

RUN cat > /home/user/datasets/sales_Q2.csv <<'EOF'
id,category,amount
1,Toys,30
2,Furniture,150
3,Electronics,220
4,Toys,40
5,Books,18
6,Kitchen,80
7,Electronics,130
EOF

RUN chmod 755 /home/user && chmod -R 755 /home/user/datasets

CMD echo "This container is intended for an educational task." && \
    echo "Datasets are located in /home/user/datasets." && \
    echo "Use this container as the execution environment for the assignment."