Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author automation_task_builder
    Description "Environment for the 'quarterly_rollup' Unix-workflow exercise"

%post
    set -e

    export DEBIAN_FRONTEND=noninteractive

    # ---------------------------------------------------------------------
    # Install Python 3 and pytest
    # ---------------------------------------------------------------------
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates
    pip3 install --no-cache-dir pytest

    # ---------------------------------------------------------------------
    # Create the required directory tree and seed CSV files
    # ---------------------------------------------------------------------
    mkdir -p /home/user/source_data
    mkdir -p /home/user/workflows          # DO NOT create quarterly_rollup here

    # Ensure write permission for the non-root user that will run inside
    # the container (uid == host uid).  Using 0777 avoids unknown uid issues.
    chmod 0777 /home/user
    chmod 0777 /home/user/workflows

    # ------------------ sales_q1.csv -------------------------------------
    cat >/home/user/source_data/sales_q1.csv <<'EOF'
Date,Region,Product,Units,Revenue
2024-01-10,North,Widget,120,2400
2024-02-12,South,Gadget,85,1700
2024-03-08,East,Thingamajig,60,1200
EOF

    # ------------------ sales_q2.csv -------------------------------------
    cat >/home/user/source_data/sales_q2.csv <<'EOF'
Date,Region,Product,Units,Revenue
2024-04-11,North,Widget,130,2600
2024-05-15,South,Gadget,90,1800
2024-06-18,East,Thingamabob,70,1400
EOF

    # Secure the source_data directory while still allowing read access.
    chmod 0755 /home/user/source_data
    chmod 0644 /home/user/source_data/sales_q*.csv

%environment
    chmod 755 /home/user

    # Ensure python and pip are on the PATH
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

# No %runscript section needed; the testing harness will use `apptainer exec`
# directly.