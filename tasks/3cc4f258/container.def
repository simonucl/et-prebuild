Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update and install required packages
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip jq
    rm -rf /var/lib/apt/lists/*

    # Python testing utilities
    pip3 install --no-cache-dir pytest jsonschema

    # Create the unprivileged user and its home
    useradd -m -s /bin/bash user

    # Populate initial hardening data
    install -d -m 0755 /home/user/hardening

    cat >/home/user/hardening/config.json <<'EOF'
{
  "system": "webserver",
  "ssh": {
    "permitRootLogin": "no",
    "passwordAuthentication": "no"
  },
  "firewall": {
    "portsOpen": [22, 80, 443]
  }
}
EOF

    cat >/home/user/hardening/schema.json <<'EOF'
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["system", "ssh", "firewall"],
  "properties": {
    "system": { "type": "string" },
    "ssh": {
      "type": "object",
      "required": ["permitRootLogin", "passwordAuthentication"],
      "properties": {
        "permitRootLogin": {
          "type": "string",
          "enum": ["yes", "no"]
        },
        "passwordAuthentication": {
          "type": "string",
          "enum": ["yes", "no"]
        }
      },
      "additionalProperties": false
    },
    "firewall": {
      "type": "object",
      "required": ["portsOpen"],
      "properties": {
        "portsOpen": {
          "type": "array",
          "items": { "type": "integer" }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
EOF

    # Ensure ownership for the regular user
    chown -R user:user /home/user

%environment
    chmod 755 /home/user

    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%labels
    Author   hardening-task
    Version  v1.0
    Purpose  "Initial state for JSON hardening exercise"