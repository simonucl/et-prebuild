Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install Python + pytest
    apt-get update -y
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest

    ############################################################
    # Prepare initial filesystem state for the cron-policy task
    ############################################################

    # Create the /home/user hierarchy expected by the tests
    mkdir -p /home/user/policies
    mkdir -p /home/user/cron
    mkdir -p /home/user/logs

    # Weekly maintenance cron line (baseline)
    WEEKLY_LINE="0 0 * * 0 /home/user/scripts/weekly_maintenance.sh"

    # Create policy file containing ONLY the weekly job
    echo "${WEEKLY_LINE}" > /home/user/policies/allowed_cron_jobs.txt

    # Create effective crontab file containing ONLY the weekly job
    echo "${WEEKLY_LINE}" > /home/user/cron/enforced_user_crontab

    # Set permissions so the non-root runtime user can modify as required
    chmod 0777 /home/user /home/user/policies /home/user/cron /home/user/logs
    chmod 0666 /home/user/policies/allowed_cron_jobs.txt
    chmod 0666 /home/user/cron/enforced_user_crontab

    # NOTE:  Do NOT create /home/user/backup directory or the compliance
    #        report file; these must be absent at container start.

%labels
    chmod 755 /home/user

    Author "ChatGPT DevSecOps Container Builder"
    Description "Container for cron-policy assessment task (includes pytest)"

%help
    This container provides the baseline filesystem and pytest installation
    required for the cron-policy exercise.