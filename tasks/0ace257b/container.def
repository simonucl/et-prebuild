BootStrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Install required packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        curl \
        ca-certificates
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the grading harness
    pip3 install --no-cache-dir pytest

    # Prepare initial filesystem state
    mkdir -p /home/user/project

    # Create the English source JSON without a trailing newline
    printf '{"greeting":"Hello","farewell":"Goodbye"}' \
        > /home/user/project/translations_en.json

    # Ensure the student (non-root) can write to the project area
    chmod -R 0777 /home/user/project
    chmod 0777 /home/user

%labels
    chmod 755 /home/user

    Author localization-task-setup
    Description "Container prepared for the localization engineer task with initial English JSON and pytest installed."