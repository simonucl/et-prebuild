FROM ubuntu:22.04

# Labels
LABEL Author="Auto-generated by ChatGPT"
LABEL Description="Container with pre-populated MLOps experiment data and pytest installed."

# Help comment:
# This container provides the initial workspace for the MLOps experiment
# summarization task.  It already includes:
#   • /home/user/mlops/experiments/EXP001
#   • /home/user/mlops/experiments/EXP002
#   • /home/user/mlops/experiments/EXP003
# each populated with the exact files expected by the grading tests.
# Pytest is installed for test execution.

# System packages
RUN set -e && \
    apt-get update && \
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        git && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Python tooling
RUN pip3 install --no-cache-dir pytest

# Create initial workspace expected by the grader
RUN mkdir -p /home/user/mlops/experiments/EXP001 \
             /home/user/mlops/experiments/EXP002 \
             /home/user/mlops/experiments/EXP003

# EXP001 files
RUN cat > /home/user/mlops/experiments/EXP001/metrics.txt << 'EOF'
Accuracy: 0.9321
Loss: 0.1278
EOF

RUN cat > /home/user/mlops/experiments/EXP001/params.yaml << 'EOF'
model: ResNet50
lr: 0.001
batch_size: 32
EOF

RUN cat > /home/user/mlops/experiments/EXP001/artifact_list.txt << 'EOF'
2023-08-21
checkpoint.pt
tensorboard/
EOF

# EXP002 files
RUN cat > /home/user/mlops/experiments/EXP002/metrics.txt << 'EOF'
Accuracy: 0.8876
Loss: 0.2345
EOF

RUN cat > /home/user/mlops/experiments/EXP002/params.yaml << 'EOF'
model: EfficientNetB0
lr: 0.0005
batch_size: 64
augment: true
EOF

RUN cat > /home/user/mlops/experiments/EXP002/artifact_list.txt << 'EOF'
2023-08-22
checkpoint.pt
tensorboard/
EOF

# EXP003 files
RUN cat > /home/user/mlops/experiments/EXP003/metrics.txt << 'EOF'
Accuracy: 0.9458
Loss: 0.0987
EOF

RUN cat > /home/user/mlops/experiments/EXP003/params.yaml << 'EOF'
model: ViT-B16
lr: 0.0001
batch_size: 16
patch_size: 16
epochs: 30
EOF

RUN cat > /home/user/mlops/experiments/EXP003/artifact_list.txt << 'EOF'
2023-08-25
checkpoint.pt
tensorboard/
EOF

# Ensure every directory and file is accessible/writable by the non-root user
RUN chmod -R a+rwX /home/user

# Environment variables
ENV PYTHONUNBUFFERED=1
ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8

WORKDIR /home/user