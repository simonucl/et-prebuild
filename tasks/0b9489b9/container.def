Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ------------------------------------------------------------------
    # System packages
    # ------------------------------------------------------------------
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        git
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Python tooling
    # ------------------------------------------------------------------
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create initial workspace expected by the grader
    # ------------------------------------------------------------------
    BASE_DIR="/home/user/mlops/experiments"
    mkdir -p "${BASE_DIR}/EXP001" "${BASE_DIR}/EXP002" "${BASE_DIR}/EXP003"

    # ----------------------------- EXP001 -----------------------------
    cat > "${BASE_DIR}/EXP001/metrics.txt" << 'EOF'
Accuracy: 0.9321
Loss: 0.1278
EOF

    cat > "${BASE_DIR}/EXP001/params.yaml" << 'EOF'
model: ResNet50
lr: 0.001
batch_size: 32
EOF

    cat > "${BASE_DIR}/EXP001/artifact_list.txt" << 'EOF'
2023-08-21
checkpoint.pt
tensorboard/
EOF

    # ----------------------------- EXP002 -----------------------------
    cat > "${BASE_DIR}/EXP002/metrics.txt" << 'EOF'
Accuracy: 0.8876
Loss: 0.2345
EOF

    cat > "${BASE_DIR}/EXP002/params.yaml" << 'EOF'
model: EfficientNetB0
lr: 0.0005
batch_size: 64
augment: true
EOF

    cat > "${BASE_DIR}/EXP002/artifact_list.txt" << 'EOF'
2023-08-22
checkpoint.pt
tensorboard/
EOF

    # ----------------------------- EXP003 -----------------------------
    cat > "${BASE_DIR}/EXP003/metrics.txt" << 'EOF'
Accuracy: 0.9458
Loss: 0.0987
EOF

    cat > "${BASE_DIR}/EXP003/params.yaml" << 'EOF'
model: ViT-B16
lr: 0.0001
batch_size: 16
patch_size: 16
epochs: 30
EOF

    cat > "${BASE_DIR}/EXP003/artifact_list.txt" << 'EOF'
2023-08-25
checkpoint.pt
tensorboard/
EOF

    # ------------------------------------------------------------------
    # Ensure every directory and file is accessible/writable by the
    # non-root user that will run inside the container.
    # ------------------------------------------------------------------
    chmod -R a+rwX /home/user

%environment
    chmod 755 /home/user

    export PYTHONUNBUFFERED=1
    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8

%labels
    Author="Auto-generated by ChatGPT"
    Description="Container with pre-populated MLOps experiment data and pytest installed."

%help
    This container provides the initial workspace for the MLOps experiment
    summarization task.  It already includes:
      • /home/user/mlops/experiments/EXP001
      • /home/user/mlops/experiments/EXP002
      • /home/user/mlops/experiments/EXP003
    each populated with the exact files expected by the grading tests.
    Pytest is installed for test execution.