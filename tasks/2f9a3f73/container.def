Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Update package index and install Python + pip
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip

    # Install pytest for the forthcoming test suites
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------ #
    # Prepare the required directory tree and the initial CSV dataset
    # ------------------------------------------------------------------ #
    mkdir -p /home/user/project/data

    cat > /home/user/project/data/users.csv << 'EOF'
id,name,email,status
1,John Doe,john@example.com,active
2,Jane Smith,jane@sample.com,inactive
3,Bob Lee,bob@domain.com,active
4,Alice Kay,alice@website.org,pending
EOF

    # Ensure the student (non-root runtime UID) can write inside /home/user
    chmod -R a+rwX /home/user

    # Clean up apt caches to keep the image lean
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Nothing special needed; inherit host $HOME and default PATH
    export PYTHONIOENCODING=UTF-8

%runscript
    echo "Container for the 'active users' exercise. Execute your commands inside an interactive shell."
    exec /bin/bash "$@"

%help
    This Apptainer image provides the initial environment for the
    "active users" CSV/JSON processing exercise.

    Key pre-created artefact:
      /home/user/project/data/users.csv  (sample dataset)

    pytest is installed so that the supplied test suites can be run.