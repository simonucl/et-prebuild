Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install required packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        openssh-client \
        ca-certificates
    pip3 install --no-cache-dir pytest

    # Prepare writable home and .ssh directories for the (non-root) runtime user
    mkdir -p /home/user/.ssh
    chmod 0777 /home/user
    chmod 0777 /home/user/.ssh

    # Provide the predefined key in authorized_keys (if the exercise needs it)
    cat <<'EOF' > /home/user/.ssh/authorized_keys
ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIB3j6Lm9vDGf/oldexamplekey== dev@old
EOF
    chmod 0666 /home/user/.ssh/authorized_keys

%runscript
    chmod 755 /home/user

    exec "$@"