Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python, pip, and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state for the task
    # ------------------------------------------------------------------
    mkdir -p /home/user/localpkgs/bash
    mkdir -p /home/user/localpkgs/coreutils

    # Create version files with exact contents (newline-terminated)
    printf "5.1.16\n" > /home/user/localpkgs/bash/version.txt
    printf "8.32\n" > /home/user/localpkgs/coreutils/version.txt

    # Ensure readable permissions for the unprivileged run-time user
    chmod -R 0755 /home/user

%environment
    chmod 755 /home/user

    # Ensure standard paths are available
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

%labels
    Author "Container Preparer"
    Description "Environment for local-only package bundles task with pytest pre-installed."