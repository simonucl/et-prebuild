Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Prepare initial filesystem state expected by the assessment tests
    # ------------------------------------------------------------------
    # 1. Create /home/user/secrets directory hierarchy
    mkdir -p /home/user/secrets
    chmod 755 /home/user
    chmod 755 /home/user/secrets

    # 2. Populate /home/user/secrets/credentials.csv with exact content
    cat > /home/user/secrets/credentials.csv <<'EOF'
app_name,username,password,last_rotated
billing-service,bill-user,B!llPass123,2022-12-01
auth-service,auth-user,Aut#2020,2023-04-15
reporting-service,rep-user,Rep0rt!,2022-11-20
legacy-api,legacy-user,L3gacyPwd,2022-01-10
EOF

    # 3. Set permissive read permissions for the grader
    chmod 644 /home/user/secrets/credentials.csv

%labels
    Author Credential-Rotation-Setup
    Description "Base container for credential-rotation exercise. Provides initial secrets directory and installs pytest."

%environment
    # Ensure python points to python3
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"
    if [ -x /usr/bin/python3 ]; then
        ln -sf /usr/bin/python3 /usr/local/bin/python || true
    fi