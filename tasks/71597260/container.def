Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install Python tooling
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3-pip \
        iproute2 \
    && rm -rf /var/lib/apt/lists/*

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # Prepare the expected home directory
    mkdir -p /home/user
    chmod 777 /home/user     # Writable by the unprivileged runtime user

    # Ensure the task-specific directory is absent at build time
    rm -rf /home/user/pt_scan

%labels
    chmod 755 /home/user

    Author "Generated by ChatGPT"
    Description "Container for penetration-testing reconnaissance task with pytest pre-installed."