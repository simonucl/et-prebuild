# syntax=docker/dockerfile:1
FROM ubuntu:22.04

# %post
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked --mount=type=cache,target=/var/lib/apt,sharing=locked set -e && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3-pip \
        iproute2 && \
    rm -rf /var/lib/apt/lists/*

RUN --mount=type=cache,target=/root/.cache/pip pip3 install --no-cache-dir pytest

RUN mkdir -p /home/user && \
    chmod 777 /home/user

RUN rm -rf /home/user/pt_scan

# Adjust permissions as specified in labels section
RUN chmod 755 /home/user

# %labels
LABEL Author="Generated by ChatGPT"
LABEL Description="Container for penetration-testing reconnaissance task with pytest pre-installed."