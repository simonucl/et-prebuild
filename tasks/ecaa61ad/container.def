Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ------------------------------------------------------------------
    # Install Python tooling and pytest
    # ------------------------------------------------------------------
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare the required directory structure and JSON fixtures
    # ------------------------------------------------------------------
    mkdir -p /home/user/api_responses

    cat > /home/user/api_responses/response_1.json <<'EOF'
{
  "id": 101,
  "status": "OK",
  "latency_ms": 234
}
EOF

    cat > /home/user/api_responses/response_2.json <<'EOF'
{
  "id": 102,
  "status": "FAIL",
  "latency_ms": 678
}
EOF

    cat > /home/user/api_responses/response_3.json <<'EOF'
{
  "id": 103,
  "status": "OK",
  "latency_ms": 345
}
EOF

    # Ensure non-root users can read the files
    chmod 644 /home/user/api_responses/response_*.json

%environment
    chmod 755 /home/user

    # Keep Python output unbuffered for ease of debugging
    export PYTHONUNBUFFERED=1

%labels
    Author        apptainer-setup
    Description   Base image for API integration test assignment with pytest pre-installed.