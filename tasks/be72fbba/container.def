Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install required packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        python3 \
        python3-pip \
        diffutils \
        patch

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare the initial file system state expected by the test-suite
    # ------------------------------------------------------------------
    mkdir -p /home/user/audit
    chmod 0777 /home/user/audit    # Allow the unprivileged test user to write here

    # Baseline configuration snapshot
    cat > /home/user/audit/server.cfg.orig <<'EOF'
# Server configuration
Port=8080
EnableSSH=false
MaxUsers=10
EOF

    # Newly scanned configuration snapshot
    cat > /home/user/audit/server.cfg.new <<'EOF'
# Server configuration
Port=2222
EnableSSH=true
MaxUsers=20
Logging=verbose
EOF

    # Readable by all; originals should not need to be modified by the agent
    chmod 0644 /home/user/audit/server.cfg.orig /home/user/audit/server.cfg.new

%labels
    chmod 755 /home/user

    Author "Security Audit Task Maintainer"
    Description "Ubuntu 22.04 base image pre-loaded with audit configs and pytest."