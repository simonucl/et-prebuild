Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install required packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        sqlite3
    pip3 install --no-cache-dir pytest

    # Prepare the working directory
    mkdir -p /home/user
    chmod 777 /home/user   # make sure the runtime user can write here

    # Create and populate the SQLite database
    sqlite3 /home/user/app_release.db <<'SQL'
PRAGMA journal_mode=OFF;
CREATE TABLE IF NOT EXISTS releases(
    id      INTEGER PRIMARY KEY AUTOINCREMENT,
    version TEXT    NOT NULL UNIQUE,
    status  TEXT    NOT NULL
);
DELETE FROM releases;
INSERT INTO releases(version, status) VALUES ('v1.0.0', 'deployed');
INSERT INTO releases(version, status) VALUES ('v1.1.0', 'deployed');
SQL

    # Ensure the database is writable by the non-root runtime user
    chmod 666 /home/user/app_release.db

    # Guarantee the confirmation file does not exist at build time
    rm -f /home/user/release_log.csv

%environment
    chmod 755 /home/user

    export PATH="/usr/local/bin:/usr/bin:/bin"

%runscript
    echo "Release-manager exercise container."
    echo "Run 'bash' to start an interactive shell."
    exec /bin/bash