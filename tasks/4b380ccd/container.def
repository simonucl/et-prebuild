Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # --- Install Python tooling ------------------------------------------------
    apt-get update && \
        apt-get install -y --no-install-recommends python3-pip && \
        apt-get clean && rm -rf /var/lib/apt/lists/*

    pip3 install --no-cache-dir pytest

    # --- Set up initial filesystem state for the task -------------------------
    # Ensure base directory exists
    mkdir -p /home/user

    # Create audit directories
    mkdir -p /home/user/audit/reports

    # Create the official 2024 compliance report with EXACT contents
    cat > /home/user/audit/reports/annual_2024.txt <<'EOF'
Compliance Report 2024
All systems passed baseline checks.
EOF

    # Permissions: make directories writable by the non-root user
    chmod 0777 /home/user/audit
    chmod 0777 /home/user/audit/reports
    chmod 0666 /home/user/audit/reports/annual_2024.txt

%labels
    chmod 755 /home/user

    Author compliance-task-image