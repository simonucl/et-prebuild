Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package index and install required utilities
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends \
        locales \
        tzdata \
        python3 \
        python3-pip \
        tar

    # Generate the locales needed by the exercise
    echo "en_US.UTF-8 UTF-8" >> /etc/locale.gen
    echo "fr_FR.UTF-8 UTF-8" >> /etc/locale.gen
    locale-gen
    update-locale LANG=en_US.UTF-8

    # Install pytest (latest available from PyPI)
    pip3 install --no-cache-dir pytest

    # Prepare the writable home directory expected by the grader
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up APT caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Minimal environment so Python and locale work out of the box
    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8
    export PYTHONUNBUFFERED=1

%runscript
    echo "This container is prepared for the backup-and-restore exercise."
    echo "Start an interactive shell with:  apptainer exec <image> /bin/bash"