Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    #!/bin/bash
    set -e

    # Update package index and install required software
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 python3-pip cron tar

    # Install pytest for the test harness
    pip install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create the non-privileged user expected by the exercise
    # ------------------------------------------------------------------
    useradd -m -s /bin/bash user

    # ------------------------------------------------------------------
    # Prepare the mandatory directory skeleton
    # ------------------------------------------------------------------
    install -d -m 755 /home/user/datasets/raw
    install -d -m 755 /home/user/datasets/backups
    chown -R user:user /home/user/datasets

    # ------------------------------------------------------------------
    # Clean up APT caches to keep the image small
    # ------------------------------------------------------------------
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Make Python output unbuffered (helpful for debugging)
    export PYTHONUNBUFFERED=1

%labels
    Author  "Course Automation"
    Version "1.0"
    Description "Base image for the daily compressed backup exercise with pytest pre-installed."