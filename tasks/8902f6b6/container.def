Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # Install Python and pytest
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest

    # Create the non-root user expected by the exercise
    if ! id -u 1000 >/dev/null 2>&1; then
        useradd -m -u 1000 -s /bin/bash user
    fi

    # Build the required directory tree and seed the input CSVs
    mkdir -p /home/user/automation/input

    cat > /home/user/automation/input/servers.csv <<'EOF'
id,name,ip,location
srv01,alpha,10.0.0.1,us-east
srv02,beta,10.0.0.2,us-west
srv03,gamma,10.0.0.3,eu-central
EOF

    cat > /home/user/automation/input/metrics.csv <<'EOF'
metric_id,server_id,cpu,mem,disk
m001,srv01,55,68,70
m002,srv02,35,40,50
m003,srv03,60,52,80
EOF

    # Ensure the new user owns the exercise data
    chown -R 1000:1000 /home/user/automation || true

    # Clean up apt caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Make user-installed Python tools (if any) visible on PATH
    export PATH="/home/user/.local/bin:$PATH"