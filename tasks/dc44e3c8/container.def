Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install required packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        sqlite3 \
        python3 \
        python3-pip

    # Install the latest pytest via pip
    pip3 install --no-cache-dir --upgrade pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state for the migration exercise
    # ------------------------------------------------------------------
    mkdir -p /home/user

    # Create the legacy SQLite database with the prescribed schema & data
    sqlite3 /home/user/observability.db <<'SQL'
    PRAGMA journal_mode=WAL;
    CREATE TABLE metrics (id INTEGER PRIMARY KEY, name TEXT, value REAL);
    INSERT INTO metrics VALUES
      (1,'cpu_usage',0.75),
      (2,'mem_usage',0.60),
      (3,'disk_io',123.45);
SQL

    # Ensure permissive permissions so the non-root agent can read/write
    chmod -R a+rwX /home/user

%labels
    chmod 755 /home/user

    Author "Apptainer Task Preparer"
    Description "Container providing initial state for SQLite migration task with pytest installed."

%environment
    # Keep default HOME; no override needed
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8