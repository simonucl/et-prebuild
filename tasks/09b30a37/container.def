Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "Updating package index and installing Python & pip..."
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    echo "Installing pytest for the grader..."
    pip3 install --no-cache-dir pytest

    echo "Creating required directory structure and fixture log file..."
    mkdir -p /home/user/logs

    cat >/home/user/logs/event_stream.txt <<'EOF'
2024-06-01 10:00:00,INFO,UserLogin
2024-06-01 10:00:02,ERROR,PaymentFailure
2024-06-01 10:00:05,INFO,PageView
2024-06-01 10:00:07,WARNING,CacheMiss
2024-06-01 10:00:10,INFO,PageView
2024-06-01 10:00:12,ERROR,PaymentFailure
2024-06-01 10:00:15,ERROR,DBTimeout
2024-06-01 10:00:18,INFO,UserLogout
2024-06-01 10:00:20,WARNING,CacheMiss
2024-06-01 10:00:22,INFO,UserLogin
EOF

    # Ensure permissions are broad enough for the unprivileged runtime user
    chmod -R 0755 /home/user

%labels
    chmod 755 /home/user

    Author  AutomationWorkflowSetup
    Description  Base image for log-level counting task. Creates initial log file and installs pytest.

%runscript
    echo "Container ready. Review the task instructions and proceed in the shell."