Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install Python & pip
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the grading suite
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare the initial filesystem state required for the exercise
    # ------------------------------------------------------------------
    # 1. Create the reports directory tree and populate it with files.
    mkdir -p /home/user/reports/summary

    printf "Q1 financial summary\n" > /home/user/reports/report1.txt
    printf "Q2 financial summary\n" > /home/user/reports/report2.txt
    printf "Q3 details\n"             > /home/user/reports/summary/quarter3.txt

    # 2. Set permissive permissions on /home/user so the unprivileged
    #    runtime user can create new items such as /home/user/backups.
    chmod 0777 /home/user

    # Reasonable permissions for the pre-existing content
    chmod 0755 /home/user/reports /home/user/reports/summary
    chmod 0644 /home/user/reports/report1.txt \
               /home/user/reports/report2.txt \
               /home/user/reports/summary/quarter3.txt

%labels
    chmod 755 /home/user

    Author BackupTaskSetup
    Description "Container with initial state for the backup administrator exercise"

%runscript
    echo "Container for the backup administrator exercise.  Start a shell to begin."