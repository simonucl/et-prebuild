Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare the required filesystem layout and initial dataset
    # ------------------------------------------------------------------
    # Create home directory structure
    mkdir -p /home/user/datasets
    chmod 755 /home/user
    chmod 755 /home/user/datasets

    # Create the original CSV with duplicate rows
    cat <<'EOF' > /home/user/datasets/sugar_levels.csv
patient_id,glucose_mg_dl,timestamp
P001,110,2023-07-01 09:00
P002,145,2023-07-01 09:05
P001,110,2023-07-01 09:00
P003,90,2023-07-01 09:10
P002,145,2023-07-01 09:05
P004,130,2023-07-01 09:15
EOF
    chmod 644 /home/user/datasets/sugar_levels.csv

%environment
    # Keep a sensible PATH; do not override HOME.
    export PATH=/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin

%labels
    Author="Generated by ChatGPT"
    Description="Container for the deduplication terminal command task with pytest pre-installed."

%help
    This container provides the initial dataset and environment required
    for the deduplication task. Execute your single-line shell command to
    create /home/user/datasets/sugar_levels_dedup.csv as specified.