Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update && \
    apt-get install -y --no-install-recommends python3 python3-pip && \
    rm -rf /var/lib/apt/lists/*

    pip3 install --no-cache-dir pytest

    # Prepare the workspace and the required input file
    mkdir -p /home/user/audit_workspace

    cat > /home/user/audit_workspace/permissions_dump.txt <<'EOF'
-rw-r--r-- 1 alice auditors 1337 Jun 10 10:24 config.yml
-rwxr-xr-x 1 bob auditors 4096 Jun  5 09:12 run.sh
-rw-rw-r-- 1 carol auditors 2048 May 30 14:00 notes.txt
-rw-r--r-- 1 dave auditors 5120 Apr 21 08:45 backup.tar
-rwxrwxrwx 1 eve auditors   64 Jun 11 11:11 dangerous.sh
EOF

    # Ensure the non-root user running inside the container can write here
    chmod -R 0777 /home/user/audit_workspace

%environment
    chmod 755 /home/user

    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8