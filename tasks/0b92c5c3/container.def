Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ---------------------------------------------------------------------
    # 1. Base OS packages and Python tooling
    # ---------------------------------------------------------------------
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # ---------------------------------------------------------------------
    # 2. Seed directories and raw log files
    # ---------------------------------------------------------------------
    mkdir -p /home/user/profiling/raw_logs

    # run1.log ------------------------------------------------------------
    cat >/home/user/profiling/raw_logs/run1.log <<'EOF'
{"timestamp":"2023-06-01T10:00:00Z","cpu":10.5,"mem":104857}
{"timestamp":"2023-06-01T10:00:05Z","cpu":25.0,"mem":209715}
{"timestamp":"2023-06-01T10:00:10Z","cpu":30.5,"mem":157286}
EOF

    # run2.log ------------------------------------------------------------
    cat >/home/user/profiling/raw_logs/run2.log <<'EOF'
{"timestamp":"2023-06-01T11:00:00Z","cpu":50.0,"mem":262144}
{"timestamp":"2023-06-01T11:00:05Z","cpu":65.0,"mem":524288}
{"timestamp":"2023-06-01T11:00:10Z","cpu":55.0,"mem":393216}
{"timestamp":"2023-06-01T11:00:15Z","cpu":70.0,"mem":458752}
EOF

    # run3.log ------------------------------------------------------------
    cat >/home/user/profiling/raw_logs/run3.log <<'EOF'
{"timestamp":"2023-06-01T12:00:00Z","cpu":15.0,"mem":131072}
{"timestamp":"2023-06-01T12:00:05Z","cpu":20.0,"mem":196608}
{"timestamp":"2023-06-01T12:00:10Z","cpu":25.0,"mem":262144}
{"timestamp":"2023-06-01T12:00:15Z","cpu":18.0,"mem":327680}
{"timestamp":"2023-06-01T12:00:20Z","cpu":22.0,"mem":393216}
EOF

    # ---------------------------------------------------------------------
    # 3. Permissions — allow the non-root runtime user to create artefacts
    # ---------------------------------------------------------------------
    chmod 777 /home/user
    chmod 777 /home/user/profiling
    chmod 755 /home/user/profiling/raw_logs
    chmod 644 /home/user/profiling/raw_logs/*.log

    # ---------------------------------------------------------------------
    # 4. Clean up APT cache to keep the image small
    # ---------------------------------------------------------------------
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%labels
    Author "Container setup for profiling task – generated by ChatGPT"