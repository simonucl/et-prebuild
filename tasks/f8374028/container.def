Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # ------------------------------------------------------------------
    # 1. Install Python and pytest
    # ------------------------------------------------------------------
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # 2. Create required directory structure and Markdown files
    # ------------------------------------------------------------------
    mkdir -p /home/user/docs/source

    # intro.md ---------------------------------------------------------
    cat >/home/user/docs/source/intro.md <<'EOF'
# Introduction
This project contains example Markdown documentation.

Some more prose that is irrelevant for this task.
EOF

    # setup.md ---------------------------------------------------------
    cat >/home/user/docs/source/setup.md <<'EOF'
# Setup
Follow these steps to prepare your environment.

# Installation
Run the installation script after cloning the repository.
EOF

    # usage.md ---------------------------------------------------------
    cat >/home/user/docs/source/usage.md <<'EOF'
# Usage
After installation, you can run the program as follows:
EOF

    # duplicateHeading.md ---------------------------------------------
    cat >/home/user/docs/source/duplicateHeading.md <<'EOF'
# Introduction
This is a duplicate heading introduced on purpose.
EOF

    # ------------------------------------------------------------------
    # 3. Permissions (readable by unprivileged users)
    # ------------------------------------------------------------------
    chmod -R a+r /home/user/docs/source
    find /home/user/docs/source -type d -exec chmod a+rx {} +

%labels
    chmod 755 /home/user

    Author example@example.com
    Description "Environment for Markdown heading aggregation task."

%help
    This container provides the initial filesystem and software (Python + pytest)
    needed for the Markdown heading aggregation exercise.