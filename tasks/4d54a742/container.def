Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Install Python and pytest
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Prepare initial filesystem state required by the grading tests
    # ------------------------------------------------------------------
    # Ensure /home/user exists and is writable by the runtime (non-root) user
    mkdir -p /home/user
    chmod 777 /home/user

    # Create the source_data directory and the canonical iris.csv file
    mkdir -p /home/user/source_data
    cat > /home/user/source_data/iris.csv <<'EOF'
sepal_length,sepal_width,petal_length,petal_width,species
5.1,3.5,1.4,0.2,setosa
7.0,3.2,4.7,1.4,versicolor
6.3,3.3,6.0,2.5,virginica
EOF

    # Apply the required initial permissions
    chmod 644 /home/user/source_data/iris.csv
    chmod 755 /home/user/source_data

%environment
    # Minimal environment setup
    export LC_ALL=C
    export PATH=/usr/local/bin:/usr/bin:/bin

%runscript
    # Default runscript: pass control to whatever command the user supplied
    exec "$@"