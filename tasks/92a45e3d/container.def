Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package index and install Python + pip
    apt-get update -y
    apt-get install -y --no-install-recommends python3 python3-pip

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state for the exercise
    # ------------------------------------------------------------------
    # Create the required directory hierarchy for log files
    mkdir -p /home/user/capacity/logs

    # Populate the three log files with exact placeholder contents
    printf 'APP_LOG_SAMPLE\n' > /home/user/capacity/logs/app.log
    printf 'DB_LOG_SAMPLE\n'  > /home/user/capacity/logs/db.log
    printf 'SYS_LOG_SAMPLE\n' > /home/user/capacity/logs/sys.log

    # Set sensible permissions:
    #   - /home/user/capacity must be writable so the unprivileged
    #     agent can create the backup/ directory during the task.
    chmod 777 /home/user/capacity

    #   - The logs directory and files should be readable.
    chmod 755 /home/user/capacity/logs
    chmod 644 /home/user/capacity/logs/*.log

    # Ensure /home/user itself is accessible
    chmod 755 /home/user

%environment
    # Nothing to override; default environment is fine
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    echo "Container for 'Lightweight on-call log backup' exercise."
    echo "Open a shell with: apptainer exec <image>.sif /bin/bash"