FROM ubuntu:22.04

# Labels
LABEL Author="Generated by ChatGPT – Apptainer task setup"
LABEL Description="Container image that sets up the initial state for the 'Synchronise a release bundle' task and includes pytest for testing."

# ------------------------------------------------------------------
# Basic tools and Python + pytest
# ------------------------------------------------------------------
RUN apt-get update -qq && \
    DEBIAN_FRONTEND=noninteractive \
    apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    ca-certificates \
    build-essential \
    git \
    passwd && \
    pip3 install --no-cache-dir pytest && \
    rm -rf /var/lib/apt/lists/*

# ------------------------------------------------------------------
# Create non-privileged user "user"
# ------------------------------------------------------------------
RUN if ! id -u user >/dev/null 2>&1; then \
        useradd -m -s /bin/bash -u 1000 user; \
    fi

# ------------------------------------------------------------------
# Prepare initial workspace expected by the task
# ------------------------------------------------------------------
# Source release bundle
RUN mkdir -p /home/user/project && \
    printf '<h1>Welcome</h1>\n' > /home/user/project/index.html && \
    printf 'console.log("version 1.0.0");\n' > /home/user/project/app.js && \
    printf 'version: 1.0.0\n' > /home/user/project/config.yaml

# "Remote" servers – empty application directories
RUN mkdir -p /home/user/remote_servers/web01/var/www/app && \
    mkdir -p /home/user/remote_servers/web02/var/www/app

# Give ownership of everything under /home/user to the non-privileged user
RUN chown -R 1000:1000 /home/user && \
    chmod 755 /home/user

# Environment variables
ENV PATH="/home/user/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:$PATH"

# Set working directory
WORKDIR /home/user

# Switch to non-privileged user
USER user

# Default command
CMD ["/bin/bash"]