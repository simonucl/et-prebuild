Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    pip3 install --no-cache-dir pytest

    # Create a non-root user with UID 1000 whose home is /home/user.
    # If the UID is already taken (e.g., by an existing user), skip creation.
    if ! id -u user >/dev/null 2>&1; then
        groupadd -g 1000 user || true
        useradd  -m -u 1000 -g 1000 -s /bin/bash user || true
    fi

    # Ensure the directory exists and has safe permissions (owner: rwx, group/other: rx)
    mkdir -p /home/user
    chmod 755 /home/user

%environment
    # Keep whatever $HOME the runtime sets, but put /home/user on PATH for convenience.
    export PATH="/home/user:$PATH"

%runscript
    exec /bin/bash

%labels
    Author      Compliance-Apprentice-Container
    Description Container for firewall documentation exercise with pytest pre-installed