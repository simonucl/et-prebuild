Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ------------------------------------------------------------------
    # Base tooling
    # ------------------------------------------------------------------
    apt-get update -y
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Directory structure for the task
    # ------------------------------------------------------------------
    mkdir -p /home/user/app/logs
    mkdir -p /home/user/backup

    # ------------------------------------------------------------------
    # Seed log files with exact ground-truth contents
    # ------------------------------------------------------------------
    cat > /home/user/app/logs/app-2023-05-30.log <<'EOF'
2023-05-30 10:00:00 INFO  Service started
2023-05-30 10:05:00 WARN  Cache miss
2023-05-30 10:10:00 ERROR Failed to connect to database
2023-05-30 10:15:00 INFO  Service running
2023-05-30 10:20:00 ERROR Timeout while reading from queue
EOF

    cat > /home/user/app/logs/app-2023-05-31.log <<'EOF'
2023-05-31 09:00:00 INFO  Daily job started
2023-05-31 09:05:00 ERROR Null pointer exception
2023-05-31 09:10:00 WARN  Low disk space
2023-05-31 09:15:00 ERROR Failed to send email
2023-05-31 09:20:00 INFO  Daily job finished
EOF

    cat > /home/user/app/logs/app-2023-06-01.log <<'EOF'
2023-06-01 08:00:00 INFO  Service started
2023-06-01 08:10:00 INFO  Health check passed
EOF

    cat > /home/user/app/logs/app-2023-06-02.log <<'EOF'
2023-06-02 11:00:00 INFO  Service started
2023-06-02 11:05:00 ERROR Simulated June error
EOF

    # ------------------------------------------------------------------
    # Permissions
    #   • Log files: read-only for everyone (0644) – they only need to be read.
    #   • backup directory: writable for everyone so the non-root agent can work.
    # ------------------------------------------------------------------
    chmod 0644 /home/user/app/logs/*.log
    chmod 0755 /home/user/app/logs
    chmod 0777 /home/user/backup
    chmod 0777 /home/user      # ensure /home/user itself is writable

    echo "Build complete – environment ready for May-2023 log archiving task."

%environment
    chmod 755 /home/user

    # Make sure Python and Pip are on PATH
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%labels
    Author "Autogenerated for May-2023 log-archiving task"
    Description "Container with pre-seeded logs and pytest installed."

%help
    This container provides the initial filesystem state required for the
    “May-2023 application log archiving” exercise.