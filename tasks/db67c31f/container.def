Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Set up initial filesystem state required by the grading harness
    # ------------------------------------------------------------------

    # Create the user home hierarchy
    mkdir -p /home/user/data
    mkdir -p /home/user/backup

    # Populate /home/user/data with the expected files
    cat > /home/user/data/report.txt <<'EOF'
Quarterly report Q3 2023
EOF

    cat > /home/user/data/config.cfg <<'EOF'
max_connections=100
EOF

    # Ensure correct permissions:
    #  - /home/user/data : readable
    #  - /home/user/backup : writable by non-root users and empty
    chmod 0755 /home/user
    chmod 0755 /home/user/data
    chmod 0777 /home/user/backup
    chmod 0644 /home/user/data/report.txt /home/user/data/config.cfg

%environment
    chmod 755 /home/user

    # Keep a sensible PATH
    export PATH=/usr/local/bin:/usr/local/sbin:/usr/bin:/usr/sbin:/bin:/sbin

%labels
    Author backup-task-builder
    Description "Initial state for backup automation task – includes pytest and predefined data/backup directories."