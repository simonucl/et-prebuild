Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install required system packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        python3 \
        python3-pip \
        sqlite3

    # Install pytest for the grader
    python3 -m pip install --no-cache-dir pytest

    # ---------------------------------------------------------------------
    # Prepare filesystem layout expected by the tests and the student agent
    # ---------------------------------------------------------------------
    # Create the /home/user hierarchy
    mkdir -p /home/user/vuln_scans

    # Reasonable permissions:
    #   /home/user            : readable/executable by everyone
    #   /home/user/vuln_scans : writable so the unprivileged user can add CSV
    chmod 0755 /home/user
    chmod 0777 /home/user/vuln_scans

    # ---------------------------------------------------------------------
    # Create and populate the SQLite database with the exact fixture data
    # ---------------------------------------------------------------------
    cat <<'SQL' | sqlite3 /home/user/vuln_scans/scan_results.db
PRAGMA foreign_keys=OFF;
BEGIN TRANSACTION;
CREATE TABLE vulnerabilities(
    id       INTEGER PRIMARY KEY,
    host     TEXT,
    port     INTEGER,
    service  TEXT,
    severity TEXT,
    cvss     REAL
);
INSERT INTO vulnerabilities (id, host, port, service, severity, cvss) VALUES
    (1,'192.168.1.10',22,'ssh','HIGH',9.0),
    (2,'192.168.1.10',80,'http','MEDIUM',6.5),
    (3,'192.168.1.11',445,'smb','HIGH',8.6),
    (4,'192.168.1.12',21,'ftp','LOW',3.7);
COMMIT;
SQL

    # Make sure the DB is readable by any unprivileged user
    chmod 0644 /home/user/vuln_scans/scan_results.db

%environment
    chmod 755 /home/user

    # No changes necessary; keep default HOME binding and environment.

%labels
    Author="Generated by ChatGPT"
    Description="Environment for penetration-testing CSV export exercise with pytest installed."

%help
    This Apptainer container sets up the directory /home/user/vuln_scans with a
    pre-populated SQLite database (scan_results.db).  Students must issue a
    single-line shell command that exports the HIGH-severity findings to
    /home/user/vuln_scans/high_vulns.csv as specified in the assignment.