FROM ubuntu:22.04

# Labels
LABEL Author="Generated by ChatGPT"
LABEL Description="Environment for penetration-testing CSV export exercise with pytest installed."

# Install required system packages
RUN set -e && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        python3 \
        python3-pip \
        sqlite3

# Install pytest for the grader
RUN python3 -m pip install --no-cache-dir pytest

# Create the /home/user hierarchy
RUN mkdir -p /home/user/vuln_scans && \
    chmod 0755 /home/user && \
    chmod 0777 /home/user/vuln_scans

# Create and populate the SQLite database with the exact fixture data
RUN cat <<'SQL' | sqlite3 /home/user/vuln_scans/scan_results.db
PRAGMA foreign_keys=OFF;
BEGIN TRANSACTION;
CREATE TABLE vulnerabilities(
    id       INTEGER PRIMARY KEY,
    host     TEXT,
    port     INTEGER,
    service  TEXT,
    severity TEXT,
    cvss     REAL
);
INSERT INTO vulnerabilities (id, host, port, service, severity, cvss) VALUES
    (1,'192.168.1.10',22,'ssh','HIGH',9.0),
    (2,'192.168.1.10',80,'http','MEDIUM',6.5),
    (3,'192.168.1.11',445,'smb','HIGH',8.6),
    (4,'192.168.1.12',21,'ftp','LOW',3.7);
COMMIT;
SQL

# Make sure the DB is readable by any unprivileged user
RUN chmod 0644 /home/user/vuln_scans/scan_results.db

# Set working directory
WORKDIR /home/user