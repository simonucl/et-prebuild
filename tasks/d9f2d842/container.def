Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author database-exercise
    Description "Initial state for Database Dumps Cleanup task"

%post
    set -e

    # Update package list and install Python + Pytest
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create working directory structure expected by the exercise
    # ------------------------------------------------------------------
    # Ensure /home and /home/user exist
    mkdir -p /home/user

    # Make /home/user writable for the unprivileged runtime user
    chmod 0777 /home/user

    # Create the required starting directory and SQL files
    mkdir -p /home/user/db_dumps

    cat > /home/user/db_dumps/customers.sql <<'EOF'
-- Dump of table customers
INSERT INTO customers (id, name, email) VALUES
(1, 'Alice Smith', 'alice@example.com'),
(2, 'Bob Jones', 'bob@example.com');
EOF

    cat > /home/user/db_dumps/orders.sql <<'EOF'
-- Dump of table orders
INSERT INTO orders (id, customer_id, order_total) VALUES
(1, 1, 99.99),
(2, 2, 149.49);
EOF

    cat > /home/user/db_dumps/inventory.sql <<'EOF'
-- Dump of table inventory
INSERT INTO inventory (id, product_name, quantity) VALUES
(1, 'Widget', 500),
(2, 'Gadget', 300);
EOF

    # Set read/write permissions so the exercise participant can manipulate files
    chmod -R a+rwX /home/user/db_dumps

%runscript
    chmod 755 /home/user

    echo "Container for Database Dumps Cleanup exercise."
    echo "Navigate to /home/user to begin the task."