Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Update package lists and install required OS packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        openssh-client \
        jq \
        python3-pip

    # Install pytest for the testing harness
    pip3 install --no-cache-dir pytest

    # Create base user directory expected by the tests (write-able by any UID)
    mkdir -p /home/user
    chmod 0777 /home/user

%environment
    chmod 755 /home/user

    # Do not override $HOME; just ensure common tools are on PATH
    export PATH=/usr/local/bin:/usr/local/sbin:/usr/bin:/usr/sbin:/bin:/sbin

%labels
    Author devsecops-container-builder
    Description "Base image for the SSH-key-as-code exercise – contains openssh-client, jq, and pytest."

%runscript
    echo "This container is intended for automated testing of the SSH-key-as-code exercise."