Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update APT index and install required system packages
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        sqlite3 \
        ca-certificates \
        tzdata
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # Ensure that /home/user exists (the grader expects this path)
    mkdir -p /home/user
    chmod 0755 /home/user

%labels
    chmod 755 /home/user

    Author  Apptainer Task Setup
    Description  Base image for IoT edge-computing SQLite exercise with pytest installed.

%runscript
    echo "This container is prepared for the IoT edge SQLite exercise."
    echo "Use the shell to begin working:  apptainer exec <image>.sif /bin/bash"

%environment
    # Make sure Python 3 is the default python command if not already
    if [ -x /usr/bin/python3 ] && [ ! -e /usr/bin/python ]; then
        export PATH="/usr/bin:$PATH"
        alias python=python3
    fi

    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8