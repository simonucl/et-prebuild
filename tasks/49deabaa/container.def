Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
Author System

%post
    set -e

    echo "Updating apt cache and installing required packages..."
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates

    echo "Installing pytest via pip..."
    pip3 install --no-cache-dir pytest

    echo "Creating neutral workspace at /home/user ..."
    mkdir -p /home/user
    # Make sure every (non-root) test runner can create files inside /home/user
    chmod 0777 /home/user

    # Clean up APT caches to keep image size small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Do not override HOME; Apptainer will bind the caller's $HOME.
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    echo "Container for systemd-timer task. Open a shell with: apptainer exec <image> /bin/bash"