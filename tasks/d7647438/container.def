Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest for the validation suite
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
    && rm -rf /var/lib/apt/lists/*

    pip3 install --no-cache-dir pytest

    # ---------------------------------------------------------------------
    # Prepare initial project state
    # ---------------------------------------------------------------------
    # Create the required directory structure and CSV file
    mkdir -p /home/user/project/data

    cat >/home/user/project/data/users.csv <<'EOF'
id,first_name,last_name,email
1,Jane,Doe,jane.doe@example.com
2,John,Smith,john.smith@example.com
3,Alice,Brown,alice.brown@example.com
EOF

    # Set safe permissions: readable by anyone, writable by owner
    chmod 0644 /home/user/project/data/users.csv
    chmod 0755 /home/user /home/user/project /home/user/project/data

%labels
    chmod 755 /home/user

    Maintainer "Container prep for CSV → JSON exercise"
    Description "Initial environment with users.csv and pytest installed."