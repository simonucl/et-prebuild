Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # Update package lists
    apt-get update

    # Install Python tooling and pytest
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-setuptools \
        python3-wheel \
        python3-pytest

    # Make sure the newest pip & pytest are available via /usr/local/bin/pytest
    pip3 install --no-cache-dir --upgrade pip
    pip3 install --no-cache-dir --upgrade pytest

    # Create a non-root “human” user with UID 1000 so tests can find it
    if ! getent group user >/dev/null; then
        groupadd -g 1000 user
    fi
    if ! id -u user >/dev/null 2>&1; then
        useradd -m -u 1000 -g 1000 -s /bin/bash user
    fi

    # Ensure the home directory exists and is world-readable/executable
    chmod 755 /home/user

    # Clean up APT caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    # Ensure pip-installed tools (e.g., pytest) are in the default PATH
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author      "AI-generated"
    Description "Ubuntu 22.04 with pytest and a UID>=1000 user for assignment testing."