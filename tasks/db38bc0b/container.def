Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # --- Install Python and pytest -------------------------------------------------
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # --- Create the snapshot directory structure -----------------------------------
    SNAPSHOT_ROOT="/home/user/compliance_snapshot"
    mkdir -p "${SNAPSHOT_ROOT}/etc"

    # /etc/timezone
    echo 'America/New_York' > "${SNAPSHOT_ROOT}/etc/timezone"

    # /etc/locale.conf
    {
        echo 'LANG="en_US.UTF-8"'
        echo 'LC_TIME="en_DK.UTF-8"'
    } > "${SNAPSHOT_ROOT}/etc/locale.conf"

    # AUDIT_REFERENCE
    echo '2024-04-01T12:00:00Z' > "${SNAPSHOT_ROOT}/AUDIT_REFERENCE"

    # --- Set permissions so the unprivileged user can read everything --------------
    chmod -R a+rX "${SNAPSHOT_ROOT}"

%help
    chmod 755 /home/user

This container includes:
• A pre-populated compliance snapshot under /home/user/compliance_snapshot
  required for the “time-zone / locale audit” exercise.
• pytest, installed system-wide, so automated tests can be executed.