Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author security_task_builder
    Description "Base image for security remediation task – prepares vulnerable webapp and installs pytest"

%post
    set -e

    echo "##### Install required OS packages #####"
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        tzdata
    pip3 install --no-cache-dir pytest

    echo "##### Create non-privileged user 'user' #####"
    groupadd -g 1000 user
    useradd  -m -u 1000 -g 1000 -s /bin/bash user

    echo "##### Build vulnerable web application tree #####"
    install  -d -m 0755 /home/user/webapp
    install  -d -m 0777 /home/user/webapp/scripts
    install  -d -m 0755 /home/user/webapp/config

    # index.php (0644)
    cat >/home/user/webapp/index.php <<'PHP'
<?php
echo "Hello, world!\n";
?>
PHP
    chmod 0644 /home/user/webapp/index.php

    # scripts/deploy.sh (0777 – intentionally insecure)
    cat >/home/user/webapp/scripts/deploy.sh <<'SH'
#!/usr/bin/env bash
echo "Deploying application..."
SH
    chmod 0777 /home/user/webapp/scripts/deploy.sh

    # config/settings.ini (0644) with insecure setting
    echo "disable-auth = true" >/home/user/webapp/config/settings.ini
    chmod 0644 /home/user/webapp/config/settings.ini

    # Obsolete identical backup (0644)
    cp /home/user/webapp/config/settings.ini /home/user/webapp/config/settings.ini.bak
    chmod 0644 /home/user/webapp/config/settings.ini.bak

    echo "##### Ensure ownership #####"
    chown -R user:user /home/user

    echo "##### Cleanup APT cache #####"
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    export PYTHONUNBUFFERED=1
    export PATH=/home/user/.local/bin:$PATH

%runscript
    # Default runscript keeps whatever command is supplied, useful for pytest execution.
    exec "$@"