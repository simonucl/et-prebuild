Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ------------------------------------------------------------
    # Basic tooling: python3, pip and pytest for the test harness
    # ------------------------------------------------------------
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------
    # Prepare initial filesystem state expected by the tests
    # ------------------------------------------------------------
    # Create directory tree
    mkdir -p /home/user/incoming_batches/batchA
    mkdir -p /home/user/incoming_batches/batchB
    mkdir -p /home/user/verification_logs

    # Set directory permissions (0755)
    chmod 0755 /home/user
    chmod 0755 /home/user/incoming_batches
    chmod 0755 /home/user/incoming_batches/batchA
    chmod 0755 /home/user/incoming_batches/batchB
    chmod 0755 /home/user/verification_logs

    # Create empty data files (0644)
    touch /home/user/incoming_batches/batchA/alpha.txt
    touch /home/user/incoming_batches/batchA/bravo.txt
    touch /home/user/incoming_batches/batchB/charlie.txt
    touch /home/user/incoming_batches/batchB/delta.txt

    chmod 0644 /home/user/incoming_batches/batchA/alpha.txt
    chmod 0644 /home/user/incoming_batches/batchA/bravo.txt
    chmod 0644 /home/user/incoming_batches/batchB/charlie.txt
    chmod 0644 /home/user/incoming_batches/batchB/delta.txt

    # Create the checksum manifest with exact content and newline endings
    cat > /home/user/incoming_batches/expected_sha256.txt <<'EOF'
e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855  batchA/alpha.txt
e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855  batchA/bravo.txt
e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855  batchB/charlie.txt
e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855  batchB/delta.txt
EOF
    chmod 0644 /home/user/incoming_batches/expected_sha256.txt

%environment
    chmod 755 /home/user

    export PATH=/usr/local/bin:/usr/bin:/bin

%labels
    Author "Auto-generated by ChatGPT"
    Description "Container prepared for a storage integrity verification task; includes pytest and the required initial dataset."