Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # Install Python and pytest
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Prepare the initial filesystem state expected by the exercise
    # ------------------------------------------------------------------
    mkdir -p /home/user/helpdesk/logs
    chmod 755 /home/user/helpdesk/logs

    cat > /home/user/helpdesk/logs/2023-Sept-Audit.log << 'EOF'
2023-09-01 00:00:01 Start of audit
2023-09-01 00:05:47 Audit completed
EOF
    chmod 644 /home/user/helpdesk/logs/2023-Sept-Audit.log

%environment
    export PYTHONDONTWRITEBYTECODE=1
    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8