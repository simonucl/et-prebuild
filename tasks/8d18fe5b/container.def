Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Basic development utilities
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install pytest for the grading infrastructure
    pip3 install --no-cache-dir pytest

    # Ensure a writable home for the non-root user who will run the exercise
    mkdir -p /home/user
    # Make it writable by any UID that might execute inside the container
    chmod 0777 /home/user

    # Clean up
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%labels
    Author mlops-exercise-container
    Description "Base image for MLOps symbolic-link exercise – clean filesystem, pytest pre-installed."