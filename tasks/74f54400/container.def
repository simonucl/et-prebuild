Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state expected by the automated tests
    # ------------------------------------------------------------------
    # Create the profiling directory and populate it with the required
    # “.perf” files.  All paths and file contents must match exactly.
    mkdir -p /home/user/profiling

    cat > /home/user/profiling/cpu_usage.perf <<'EOF'
# Profiling Report - CPU Usage
Timestamp: 2020-11-20T10:00:00Z
AvgCPU: 73.4%
EOF

    cat > /home/user/profiling/mem_usage.perf <<'EOF'
# Profiling Report - Memory Usage
Timestamp: 2020-11-20T10:00:00Z
AvgMem: 512MB
EOF

    cat > /home/user/profiling/io_usage.perf <<'EOF'
# Profiling Report - Disk I/O
Timestamp: 2020-11-20T10:00:00Z
AvgIO: 120MB/s
EOF

    # Permissions: make sure the future non-root agent can work inside
    # /home/user (they will need to create /home/user/archives later).
    chmod 777 /home/user
    chmod 755 /home/user/profiling
    chmod 644 /home/user/profiling/*.perf

%environment
    # Use the system Python as default
    export PYTHONIOENCODING=utf-8
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%labels
    Author example
    Description "Container for profiling backup task – provides initial .perf files and pytest"