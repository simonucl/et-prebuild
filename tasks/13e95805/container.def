Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Basic tooling
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the grading suite
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create non-root user “user” with home directory /home/user
    # ------------------------------------------------------------------
    useradd -m -s /bin/bash user

    # ------------------------------------------------------------------
    # Prepare initial filesystem state for the exercise
    # ------------------------------------------------------------------
    # Backup directories
    mkdir -p /home/user/backups/2024-05-01
    mkdir -p /home/user/backups/2024-06-01

    # Convenience symlink that (initially) points to the older backup
    ln -s /home/user/backups/2024-05-01 /home/user/backup_latest

    # Ensure appropriate permissions so the runtime user can modify /home/user
    chown -R user:user /home/user
    chmod -R a+rwx /home/user   # writable by anyone inside the container

%environment
    chmod 755 /home/user

    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    exec /bin/bash "$@"