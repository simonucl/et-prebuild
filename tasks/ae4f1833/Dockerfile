FROM ubuntu:22.04

# Labels
LABEL Author="Generated by ChatGPT"
LABEL Description="Environment for AWS key-rotation optimisation exercise with pytest pre-installed."

# Install Python, pip and pytest (plus PuLP for the user's script)
RUN set -e && \
    apt-get update -y && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip && \
    pip3 install --no-cache-dir pytest pulp && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Create the required directory hierarchy under /home/user
RUN mkdir -p /home/user/resources && \
    chmod 0755 /home/user/resources && \
    mkdir -p /home/user && \
    chmod 0777 /home/user

# Create the initial CSV file with exact required content & mode
RUN cat > /home/user/resources/credentials_2024Q2.csv <<'EOF'
user_id,access_key,created,expires
u101,AKIA111111,2024-01-15,2024-06-10
u102,AKIA222222,2024-02-10,2024-04-30
u103,AKIA333333,2024-01-20,2024-05-15
u104,AKIA444444,2024-03-01,2024-04-20
u105,AKIA555555,2024-02-18,2024-07-01
u106,AKIA666666,2024-02-25,2024-04-18
u107,AKIA777777,2024-01-30,2024-04-25
EOF

RUN chmod 0644 /home/user/resources/credentials_2024Q2.csv

# Environment variables
ENV PATH="/home/user/.local/bin:$PATH"

# Set working directory
WORKDIR /home/user

# Default command
CMD ["echo", "This container is set up for the AWS key-rotation exercise."]