Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Update package list and install Python + pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare the initial filesystem state expected by the assignment
    # ------------------------------------------------------------------

    # Create the user home directory and the input file
    mkdir -p /home/user
    cat > /home/user/network_snapshot.txt <<'EOF'
10.0.0.5 22/tcp ssh OpenSSH 7.4
10.0.0.5 80/tcp http Apache 2.4.6
10.0.0.6 21/tcp ftp vsftpd 2.3.4 (VULNERABLE)
10.0.0.7 445/tcp smb Samba 3.0.20 (VULNERABLE)
10.0.0.8 443/tcp https OpenSSL 1.0.1 (Heartbleed)
10.0.0.9 3306/tcp mysql MySQL 5.5
EOF

    # Set secure, readable permissions
    chmod 755 /home/user
    chmod 644 /home/user/network_snapshot.txt

    # Ensure that no output artefacts/directories exist yet
    rm -rf /home/user/pen_test || true

%labels
    Author="Autogenerated container for pen-test optimisation challenge"

%help
    This Apptainer image provides the pristine starting environment for the
    performance-optimised vulnerability extraction task. It supplies the
    input file /home/user/network_snapshot.txt and installs pytest for the
    automated grading suite.