Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # Update package lists
    apt-get update

    # Install Python and development essentials
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-setuptools \
        ca-certificates \
        coreutils \
        util-linux

    # Install pytest for the grading suite
    pip3 install --no-cache-dir pytest

    # Create the /home/user directory with permissive write access
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up APT caches to keep the image lean
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure standard binary locations are in PATH
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%runscript
    # Default runscript just executes the given command
    exec "$@"