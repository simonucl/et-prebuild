Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ------------------------------------------------------------------ #
    # 1. Install Python tooling and pytest
    # ------------------------------------------------------------------ #
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------ #
    # 2. Create initial filesystem expected by the task
    # ------------------------------------------------------------------ #
    # Directories
    mkdir -p /home/user/reports
    mkdir -p /home/user/finops/latest

    # Report file with exact, line-terminated content
    cat >/home/user/reports/2023-Q3-cloud-costs.csv <<'EOF'
Account,Service,Cost (USD)
000123456789,EC2,1043.57
000123456789,S3,132.18
EOF

    # ------------------------------------------------------------------ #
    # 3. Permissions
    # ------------------------------------------------------------------ #
    # Allow the (non-root) runtime user full access to the finops workspace
    chmod 755 /home/user
    chmod 755 /home/user/reports
    chmod 644 /home/user/reports/2023-Q3-cloud-costs.csv
    chmod 777 /home/user/finops
    chmod 777 /home/user/finops/latest

%labels
    Author "Autogenerated definition for FinOps quarterly report task"