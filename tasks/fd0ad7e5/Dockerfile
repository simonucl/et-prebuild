FROM ubuntu:22.04

# Author "Autogenerated definition for FinOps quarterly report task"

RUN set -e && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip && \
    pip3 install --no-cache-dir pytest

RUN set -e && \
    mkdir -p /home/user/reports && \
    mkdir -p /home/user/finops/latest

RUN cat >/home/user/reports/2023-Q3-cloud-costs.csv <<'EOF'
Account,Service,Cost (USD)
000123456789,EC2,1043.57
000123456789,S3,132.18
EOF

RUN chmod 755 /home/user && \
    chmod 755 /home/user/reports && \
    chmod 644 /home/user/reports/2023-Q3-cloud-costs.csv && \
    chmod 777 /home/user/finops && \
    chmod 777 /home/user/finops/latest