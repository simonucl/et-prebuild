Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python 3, pip and pytest
    apt-get update -qq
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    ###############
    # File system #
    ###############
    # Base project path
    BASE="/home/user/projects/api_integration"

    # Create mandatory directory hierarchy
    mkdir -p "${BASE}/releases/v1"
    mkdir -p "${BASE}/releases/v2"
    mkdir -p "${BASE}/releases/v2/libs"          # libs inside v2
    mkdir -p "${BASE}/shared/config"
    mkdir -p "${BASE}/shared/libs"

    # Root-level libs directory (must be a real directory) with sub-folders v1 and v2
    mkdir -p "${BASE}/libs/v1"
    mkdir -p "${BASE}/libs/v2"

    # Create a dangling symlink for current_release (points to non-existent v3 -> dangling)
    ln -sf "${BASE}/releases/v3" "${BASE}/current_release"

    # Ensure the parent home directory exists
    mkdir -p /home/user
    chmod -R 0755 /home/user

%environment
    chmod 755 /home/user

    # Keep default $HOME binding behaviour; no overrides required
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    echo "Container for API integration deployment task. Pytest is installed."
    exec "$@"

%labels
    Author IntegrationTaskSetup
    Description Initial environment for API integration symbolic-link exercise.