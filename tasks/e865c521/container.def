Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install required packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        git \
        python3-pip \
        ca-certificates
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create initial project layout expected by the exercise
    # ------------------------------------------------------------------
    mkdir -p /home/user/projects/optimize_app
    cd /home/user/projects/optimize_app

    # Initialise an empty Git repository
    git init

    # Baseline solver_config.yaml (must match tests EXACTLY, incl. newline)
    cat > solver_config.yaml <<'EOF'
solver:
  name: "glpk"
  tolerance: 1e-6
  max_iterations: 1000
  verbose: false
EOF

    # Initial commit
    git config --local user.name  "Builder"
    git config --local user.email "builder@example.com"
    git add solver_config.yaml
    git commit -m "chore: initial GLPK config"

    # ------------------------------------------------------------------
    # Ensure the runtime (non-root) user can freely modify the workspace
    # ------------------------------------------------------------------
    chmod -R a+rwx /home/user

%labels
    chmod 755 /home/user

    Author  optimization-setup-bot
    Description "Base image for optimise_app exercise – contains initial Git repository"

%help
    This container sets up the starting state for the “optimise_app” exercise.
    A Git repository is prepared in /home/user/projects/optimize_app with a
    baseline solver_config.yaml.  Pytest is installed for running the automated
    checks.