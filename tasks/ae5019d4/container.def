Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update -y && \
    apt-get install -y python3 python3-pip && \
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial project structure and seed files for the learner
    # ------------------------------------------------------------------
    mkdir -p /home/user/projects/observability/grafana

    # dashboard.yaml (original 7-line file)
    cat > /home/user/projects/observability/grafana/dashboard.yaml <<'EOF'
title: "Service Overview"
panels:
  - id: 1
    title: "CPU Usage"
    datasource: "Prometheus"
    targets:
      - expr: "rate(node_cpu_seconds_total[5m])"
EOF

    # alerting.toml (alerting disabled)
    cat > /home/user/projects/observability/alerting.toml <<'EOF'
[alerting]
enabled = false
EOF

    # Ensure the student (non-root) can freely modify everything under /home/user
    chmod -R a+rwX /home/user

%labels
    chmod 755 /home/user

    Author observability-task-setup

%help
    This container sets up the initial state for the observability editing task
    and includes pytest for automated evaluation.