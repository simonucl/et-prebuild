Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update APT and install Python + PyPI to get pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare the curation staging area with the three solver “archives”
    # ------------------------------------------------------------------
    mkdir -p /home/user/curation/binaries

    # Create each placeholder archive with the exact required content
    printf 'CBC binary placeholder v2.10.5\n'  > /home/user/curation/binaries/cbc-2.10.5-linux-x86_64.tar.gz
    printf 'GLPK binary placeholder v5.0\n'    > /home/user/curation/binaries/glpk-5.0-linux-x86_64.tar.gz
    printf 'SCIP binary placeholder v8.0.3\n'  > /home/user/curation/binaries/scip-8.0.3-linux-x86_64.tar.gz

    # Ensure directories are accessible and files are readable
    chmod 755 /home /home/user /home/user/curation /home/user/curation/binaries
    chmod 644 /home/user/curation/binaries/*.tar.gz

%labels
    chmod 755 /home/user

    Author="Auto-generated container for optimisation-solver curation task"