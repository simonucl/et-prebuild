FROM ubuntu:22.04

# Labels
LABEL Author="Generated by ChatGPT"
LABEL Description="Container for backup checklist exercise with initial state and pytest installed"

# Install Python and pytest
RUN apt-get update && \
    apt-get install -y --no-install-recommends python3 python3-pip && \
    rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir pytest

# ------------------------------------------------------------------
# Prepare initial filesystem state expected by the grading harness
# ------------------------------------------------------------------
# Ensure base home directory exists
RUN mkdir -p /home/user

# Create configuration directory and file
RUN mkdir -p /home/user/db_backup/conf

RUN cat > /home/user/db_backup/conf/backup.ini <<'EOF'
[primary]
db_name = customer_orders
host = db-primary.local
port = 5432
last_full_backup = 2023-06-01 00:00:00

[secondary]
db_name = analytics
host = db-secondary.local
port = 5433
last_full_backup = 2023-06-01 02:00:00
EOF

# Set reasonable permissions
RUN chmod 755 /home/user && \
    chmod -R 755 /home/user/db_backup && \
    chmod 644 /home/user/db_backup/conf/backup.ini

# Environment variables
ENV PATH=/usr/local/bin:/usr/bin:/bin:$PATH

# Help information (as comments):
# This container image provides the initial environment for the
# backup-checklist exercise. It contains:
#   - Python 3 and pytest for test execution
#   - The configuration file at /home/user/db_backup/conf/backup.ini
# Students must create /home/user/db_backup/reports/backup_checklist.log
# according to the exercise instructions.