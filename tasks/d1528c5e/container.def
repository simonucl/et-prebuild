Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Install Python and pytest
    apt-get update && \
        apt-get install -y --no-install-recommends python3 python3-pip && \
        rm -rf /var/lib/apt/lists/*
    pip install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state expected by the grading harness
    # ------------------------------------------------------------------
    # Ensure base home directory exists
    mkdir -p /home/user

    # Create configuration directory and file
    mkdir -p /home/user/db_backup/conf

    cat > /home/user/db_backup/conf/backup.ini <<'EOF'
[primary]
db_name = customer_orders
host = db-primary.local
port = 5432
last_full_backup = 2023-06-01 00:00:00

[secondary]
db_name = analytics
host = db-secondary.local
port = 5433
last_full_backup = 2023-06-01 02:00:00
EOF

    # Set reasonable permissions
    chmod 755 /home/user
    chmod -R 755 /home/user/db_backup
    chmod 644 /home/user/db_backup/conf/backup.ini

%environment
    # Ensure Python and pip are on PATH
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author="Generated by ChatGPT"
    Description="Container for backup checklist exercise with initial state and pytest installed"

%help
    This Apptainer image provides the initial environment for the
    backup-checklist exercise.  It contains:
      • Python 3 and pytest for test execution
      • The configuration file at /home/user/db_backup/conf/backup.ini
    Students must create /home/user/db_backup/reports/backup_checklist.log
    according to the exercise instructions.