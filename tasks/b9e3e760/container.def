Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python tooling and pytest
    apt-get update
    apt-get install -y --no-install-recommends python3-pip
    pip3 install --no-cache-dir pytest

    # Create a non-root user for the exercise
    useradd -m -s /bin/bash user

    # -----------------------------------------------------------------
    # Prepare the initial mock DNS data (read-only file, 0644)
    # -----------------------------------------------------------------
    mkdir -p /home/user/mock_dns
    cat <<'EOF' > /home/user/mock_dns/hosts_mapping
backup1.example.com 192.168.10.11
backup2.example.com 192.168.10.12
db1.internal.local 10.0.0.21
db2.internal.local 10.0.0.22
EOF
    chmod 0644 /home/user/mock_dns/hosts_mapping

    # Ensure the container’s non-root user (and any caller) can work
    chown -R user:user /home/user
    chmod 0777 /home/user      # world-writable so any UID can create restore_tests

%environment
    chmod 755 /home/user

    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8