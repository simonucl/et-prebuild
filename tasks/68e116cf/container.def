Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Maintainer Automation-Workflow-Container
    Description Base image for the “automation-workflow” assignment (Python & pytest pre-installed)

%post
    set -e

    # Update package lists and install required system packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        tzdata \
        locales

    # Install pytest for the test harness
    pip3 install --no-cache-dir pytest

    # Prepare a writable home directory expected by the assignment
    mkdir -p /home/user
    chmod 0777 /home/user   # make it writable for any unprivileged runtime user

    # Clean up APT caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Minimal PATH setup (do NOT override $HOME)
    export PATH=/usr/local/bin:/usr/bin:/bin

%runscript
    # Default action: start an interactive shell
    exec /bin/bash "$@"