Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # --------------------------------------------------------------------
    # Install required software
    # --------------------------------------------------------------------
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        rsync \
        ca-certificates \
        curl
    pip3 install --no-cache-dir pytest

    # --------------------------------------------------------------------
    # Create non-root user `user`
    # --------------------------------------------------------------------
    useradd -m -s /bin/bash user

    # --------------------------------------------------------------------
    # Prepare the initial remote storage area with placeholder files
    # --------------------------------------------------------------------
    REMOTE_BASE=/home/user/remote_storage
    mkdir -p "${REMOTE_BASE}/images/dogs"
    mkdir -p "${REMOTE_BASE}/images/cats"
    mkdir -p "${REMOTE_BASE}/labels"

    # Images (placeholder text files)
    echo "DOG1_PLACEHOLDER"  > "${REMOTE_BASE}/images/dogs/dog1.jpg"
    echo "DOG2_PLACEHOLDER"  > "${REMOTE_BASE}/images/dogs/dog2.jpg"
    echo "CAT1_PLACEHOLDER"  > "${REMOTE_BASE}/images/cats/cat1.jpg"

    # CSV label files
    cat << 'EOF' > "${REMOTE_BASE}/labels/dog_labels.csv"
id,label
1,bulldog
2,poodle
EOF

    cat << 'EOF' > "${REMOTE_BASE}/labels/cat_labels.csv"
id,label
1,siamese
2,maine_coon
EOF

    # --------------------------------------------------------------------
    # Ensure `user` owns everything under /home/user
    # --------------------------------------------------------------------
    chown -R user:user /home/user

%environment
    chmod 755 /home/user

    # Add Python to PATH for convenience
    PATH="/usr/local/bin:/usr/bin:/bin:${PATH}"

%runscript
    exec /bin/bash "$@"

%labels
    Author  ml-initial-state-preparer
    Description Container with initial filesystem state for ML artefact sync task.