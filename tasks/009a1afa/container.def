Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Use non-interactive frontend for apt
    export DEBIAN_FRONTEND=noninteractive

    # Update package lists and install Python + pip
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install pytest for the forthcoming tests
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare directory structure and the solver log required by tests
    # ------------------------------------------------------------------
    mkdir -p /home/user/experiments/opt_solver

    # Make everything under /home/user writable by whoever runs the container
    chmod -R 0777 /home/user

    # Create the solver_run.log with exact expected content (LF endings)
    cat > /home/user/experiments/opt_solver/solver_run.log <<'EOF'
iteration,objective,elapsed_sec
1,12.34,0.5
2,7.89,1.0
3,5.67,1.5
4,4.56,2.0
5,4.12,2.5
final,4.12,2.5
EOF

    # Ensure the log file itself is writable
    chmod 666 /home/user/experiments/opt_solver/solver_run.log

%environment
    chmod 755 /home/user

    # Nothing special needed here; rely on image defaults.
    export PYTHONIOENCODING=UTF-8

%runscript
    # Default action when the container is executed without arguments
    exec "$@"

%labels
    Author="Generated by ChatGPT for MLOps solver-log task"
    Description="Container provides initial state (solver_run.log) and pytest for assessment."