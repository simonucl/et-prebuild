Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    ## 1. Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    ## 2. Create initial workspace for the agent
    mkdir -p /home/user/app

    ## requirements_old.txt
    cat >/home/user/app/requirements_old.txt <<'EOF'
requests==2.25.0
numpy==1.18.0
pandas==1.1.0
EOF

    ## requirements_new.txt
    cat >/home/user/app/requirements_new.txt <<'EOF'
requests==2.31.0
numpy==1.24.0
pandas==2.0.3
EOF

    ## Ensure appropriate permissions (read-write for owner, read for group/others)
    chmod 644 /home/user/app/requirements_old.txt /home/user/app/requirements_new.txt

    ## 3. Make sure update_logs directory does NOT exist at build time
    rm -rf /home/user/update_logs

    ## 4. General permissions on /home/user
    chmod 755 /home/user
    chmod 755 /home/user/app

%environment
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"
    export LC_ALL=C.UTF-8
    export PYTHONIOENCODING=UTF-8

%labels
    Author agent-prep
    Description "Environment for dependency-comparison task, includes pytest and initial requirement files."