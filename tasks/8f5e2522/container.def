Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python, pip, and pytest
    apt-get update && \
        DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
            python3 \
            python3-pip \
            coreutils && \
        apt-get clean && rm -rf /var/lib/apt/lists/*

    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state for the student/agent
    # ------------------------------------------------------------------
    mkdir -p /home/user/data

    # Tight permissions (read/write/execute for user only)
    chmod 700 /home/user
    chmod 700 /home/user/data

    # Create the raw training file with exact required content
    cat > /home/user/data/raw_train.tsv <<'EOF'
label	sepal_length	sepal_width	petal_length
Iris-setosa	5.1	3.5	1.4
Iris-versicolor	7.0	3.2	4.7
Iris-virginica	6.3	3.3	6.0
EOF

    # Readable by user, no execute bit
    chmod 644 /home/user/data/raw_train.tsv

%environment
    chmod 755 /home/user

    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8