Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ------------------------------------------------------------------
    # 1. Install required system packages and Python dependencies
    # ------------------------------------------------------------------
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends \
        sqlite3 \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # 2. Prepare initial filesystem layout and legacy SQLite database
    # ------------------------------------------------------------------
    # Create directory structure
    mkdir -p /home/user/security_scans
    chmod 0777 /home/user
    chmod 0777 /home/user/security_scans

    # Build the legacy database with the required schema and rows
    sqlite3 /home/user/security_scans/scan_results_v1.db <<'SQL'
    CREATE TABLE vulnerabilities (
        id   INTEGER PRIMARY KEY,
        host TEXT,
        port INTEGER,
        vuln TEXT
    );
    INSERT INTO vulnerabilities (id, host, port, vuln) VALUES
        (1, '192.168.0.5', 22,  'OpenSSH 7.2p2 outdated'),
        (2, '192.168.0.18', 445, 'SMB v1 enabled'),
        (3, '10.0.0.7', 80,  'Apache 2.2 directory listing');
SQL
    chmod 0666 /home/user/security_scans/scan_results_v1.db

%environment
    chmod 755 /home/user

    # Ensure Python user installs (if any) go to a writeable location
    export PYTHONUSERBASE=/tmp/.pyusr
    export PATH="$PYTHONUSERBASE/bin:$PATH"
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8