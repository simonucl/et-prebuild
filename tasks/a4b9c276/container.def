Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Update package index and install Python plus pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        bash
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the forthcoming automated checks
    pip3 install --no-cache-dir pytest

    ##############
    # Pre-task file system scaffolding expected by the grader
    ##############

    # 1. Ensure the generic home directory exists
    mkdir -p /home/user
    chmod 0777 /home/user        # allow the non-root test user to write later

    # 2. Provide a default .bashrc that *does not* yet source the dotenv file
    if [ -f /etc/skel/.bashrc ]; then
        cp /etc/skel/.bashrc /home/user/.bashrc
    else
        cat >/home/user/.bashrc <<'EOB'
# ~/.bashrc – default initial content for Apptainer test container
# (Intentionally left minimal; will be extended by the backup-automation task.)
EOB
    fi

    # Make the file world-writable so whatever UID runs inside the container
    # can append its sourcing line without root privileges.
    chmod 0666 /home/user/.bashrc

%environment
    chmod 755 /home/user

    # Nothing special; we purposely do NOT source the future dotenv file here
    # so that the learner handles it.

%runscript
    # Default runscript does nothing special; provide a shell for convenience.
    exec /bin/bash

%help
    This container supplies a minimal Ubuntu 22.04 environment with pytest
    installed and a predefined /home/user/.bashrc file that does *not* yet
    source any dotenv file.  It establishes the initial conditions required
    for the PostgreSQL-backup automation task’s automated grading.