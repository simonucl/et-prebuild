Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Ensure required packages are present
    apt-get update -y
    apt-get install -y python3 python3-pip tar
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state for the learner
    # ------------------------------------------------------------------
    mkdir -p /home/user/source_release
    mkdir -p /home/user/package
    mkdir -p /home/user/testing_area

    # Create the staged micro-service source files
    cat >/home/user/source_release/app.py <<'PY'
#!/usr/bin/env python3
print("Hello, CI/CD!")
PY

    cat >/home/user/source_release/requirements.txt <<'REQ'
requests==2.31.0
REQ

    # Make the script executable (not strictly required, but conventional)
    chmod 755 /home/user/source_release/app.py

%environment
    export LC_ALL=C.UTF-8
    export PYTHONIOENCODING=UTF-8

%labels
    Author="Generated by ChatGPT"
    Description="CI/CD packaging challenge base image with pytest pre-installed"

%post
# End of file