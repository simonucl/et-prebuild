FROM ubuntu:22.04

# Help / metadata from %labels
LABEL Author="Generated by ChatGPT"
LABEL Description="CI/CD packaging challenge base image with pytest pre-installed"

# Environment variables from %environment
ENV LC_ALL=C.UTF-8
ENV PYTHONIOENCODING=UTF-8

# Install required packages and pytest
RUN set -e && \
    apt-get update -y && \
    apt-get install -y python3 python3-pip tar && \
    pip3 install --no-cache-dir pytest

# Create directories
RUN mkdir -p /home/user/source_release && \
    mkdir -p /home/user/package && \
    mkdir -p /home/user/testing_area

# Create app.py
RUN cat <<'PY' >/home/user/source_release/app.py
#!/usr/bin/env python3
print("Hello, CI/CD!")
PY

# Create requirements.txt
RUN cat <<'REQ' >/home/user/source_release/requirements.txt
requests==2.31.0
REQ

# Make script executable
RUN chmod 755 /home/user/source_release/app.py