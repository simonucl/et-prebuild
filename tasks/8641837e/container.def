Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Ensure non-interactive apt operations
    export DEBIAN_FRONTEND=noninteractive

    # Update package index and install Python tooling
    apt-get update
    apt-get install -y --no-install-recommends python3-pip

    # Install pytest for the grading harness
    pip3 install --no-cache-dir pytest

    # Create a writable /home/user directory for the student
    mkdir -p /home/user
    chmod 0777 /home/user   # world-writable so the unprivileged runtime UID can write

    # Guarantee a clean starting state for the exercise
    rm -rf /home/user/audit_reports || true

    # Clean up apt caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
    export PYTHONUNBUFFERED=1

%runscript
    exec "$@"

%labels
    Author      "Autogenerated for compliance-audit task"
    Description "Base image prepared for daily disk-usage audit exercise. Contains pytest and a clean /home/user workspace."