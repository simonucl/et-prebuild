# Converted from Apptainer definition file
FROM ubuntu:22.04

# Begin help text from %labels section
# Author: Autogenerated for compliance-audit task
# Description: Base image prepared for daily disk-usage audit exercise. Contains pytest and a clean /home/user workspace.

ENV LC_ALL=C.UTF-8
ENV LANG=C.UTF-8
ENV PYTHONUNBUFFERED=1

RUN set -e && \
    export DEBIAN_FRONTEND=noninteractive && \
    apt-get update && \
    apt-get install -y --no-install-recommends python3-pip && \
    pip3 install --no-cache-dir pytest && \
    mkdir -p /home/user && \
    chmod 0777 /home/user && \
    rm -rf /home/user/audit_reports || true && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

RUN chmod 755 /home/user

CMD ["sh", "-c", "exec \"$@\"", "--"]