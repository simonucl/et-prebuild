Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author backup-permissions-exercise
    Description "Environment for the database-backup permission hardening task"

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # Install Python and pytest
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Prepare the initial (insecure) filesystem state expected by tests
    # ------------------------------------------------------------------
    mkdir -p /home/user/db_backups

    # Make sure the agent can write inside /home/user
    chmod 0777 /home/user

    # Insecure starting permissions for the backup directory and file
    chmod 0777 /home/user/db_backups
    echo "TESTDATA" > /home/user/db_backups/production.db
    chmod 0664 /home/user/db_backups/production.db

%environment
    chmod 755 /home/user

    # Keep Python output unbuffered for easier debugging
    export PYTHONUNBUFFERED=1