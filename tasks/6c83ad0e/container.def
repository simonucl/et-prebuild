Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package index and install Python + pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state expected by the grading tests
    # ------------------------------------------------------------------

    # Create the directory tree
    mkdir -p /home/user/network/logs

    # Make sure the student (non-root) user will be able to write here.
    # We cannot know the exact UID at runtime, so give write permission
    # to everyone on the directories (tests only require writability,
    # not specific permissions).
    chmod 0777 /home/user /home/user/network /home/user/network/logs

    # Create the UTF-16 LE (with BOM) input file exactly as specified.
    python3 - <<'PY'
import os, codecs, stat, textwrap

dir_path = "/home/user/network/logs"
file_path = os.path.join(dir_path, "connection_report_utf16le.txt")

lines = [
    "2023-07-21 10:12:05 192.168.1.10 OK\r\n",
    "2023-07-21 10:14:27 192.168.1.11 FAILED\r\n",
    "2023-07-21 10:15:32 192.168.1.12 OK\r\n",
    "2023-07-21 10:17:43 192.168.1.13 FAILED\r\n",
]

with open(file_path, "wb") as fb:
    # Write UTF-16 LE BOM
    fb.write(codecs.BOM_UTF16_LE)
    # Encode each line as UTF-16 LE and write them
    for line in lines:
        fb.write(line.encode("utf-16-le"))

# Permissions: 0644 (rw-r--r--) — accepted by the tests
os.chmod(file_path, 0o644)
PY

%environment
    chmod 755 /home/user

    # Nothing special required; keep default environment.

%labels
    Author Connection-Report-Task Builder
    Description Initial container setup for “connection-health report” exercise.

%help
    This Apptainer image sets up the initial state for the
    connection-health report conversion task and includes pytest for
    automated grading.