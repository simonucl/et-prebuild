Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Update package index and install required system packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-venv \
        ca-certificates

    # Install pytest for the validation suite
    pip3 install --no-cache-dir pytest

    # Ensure a writable home for the future unprivileged agent
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up apt caches to keep image size small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Basic PATH setup; do NOT touch $HOME
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%runscript
    # Default action: start a shell
    exec /bin/bash