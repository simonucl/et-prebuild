Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package index and install Python + build essentials
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-venv \
        python3-pip \
        build-essential \
        ca-certificates

    # Upgrade pip and install pytest (needed by the test harness)
    python3 -m pip install --no-cache-dir --upgrade pip
    python3 -m pip install --no-cache-dir pytest

    # Prepare writable workspace for the unprivileged user inside the container
    mkdir -p /home/user
    chmod 0777 /home/user     # ensure any UID can write here

    # Clean up apt caches to keep image lean
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure standard binary locations are in PATH
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author="Apptainer Task Preparation"
    Description="Base image for API integration virtual-environment creation task"

%runscript
    echo "Container for API integration task. Run your commands inside this shell."
    exec /bin/bash "$@"