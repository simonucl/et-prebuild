Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update APT and install required packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        sqlite3 \
        python3 \
        python3-pip

    # Install pytest for the assessment framework
    pip3 install --no-cache-dir pytest

    # ---------------------------------------------------------------------
    # Create the directory structure expected by the task
    # ---------------------------------------------------------------------
    mkdir -p /home/user/data
    mkdir -p /home/user/migration

    # Make sure the student (non-root) process can create new files later
    chmod -R 777 /home/user

    # ---------------------------------------------------------------------
    # Create the legacy SQLite database with the exact schema and rows
    # ---------------------------------------------------------------------
    sqlite3 /home/user/data/legacy.db <<'SQL'
    PRAGMA journal_mode = OFF;
    PRAGMA synchronous  = OFF;

    CREATE TABLE employees(
        id      INTEGER PRIMARY KEY,
        name    TEXT,
        salary  INTEGER
    );

    INSERT INTO employees(id, name, salary) VALUES
        (1, 'Alice',   72000),
        (2, 'Bob',     68000),
        (3, 'Charlie', 65000);
SQL

    # Ensure world-readable permissions on the legacy DB
    chmod 644 /home/user/data/legacy.db

%environment
    chmod 755 /home/user

    # Ensure python and sqlite3 are on PATH
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%labels
    Author  "Generated by ChatGPT – Apptainer task preparer"
    Description "Environment primed with a legacy SQLite database for migration exercise."

%runscript
    echo "Container for SQLite migration task. Open a shell with 'apptainer exec -it <image> /bin/bash'."