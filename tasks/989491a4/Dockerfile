FROM ubuntu:22.04

# Author: Generated by ChatGPT – Apptainer task preparer
# Description: Environment primed with a legacy SQLite database for migration exercise.
# Runscript: Container for SQLite migration task. Open a shell with 'apptainer exec -it <image> /bin/bash'.

RUN set -e && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        sqlite3 \
        python3 \
        python3-pip && \
    rm -rf /var/lib/apt/lists/*

RUN pip3 install --no-cache-dir pytest

RUN mkdir -p /home/user/data && \
    mkdir -p /home/user/migration && \
    chmod -R 777 /home/user

RUN sqlite3 /home/user/data/legacy.db <<'SQL'
PRAGMA journal_mode = OFF;
PRAGMA synchronous  = OFF;

CREATE TABLE employees(
    id      INTEGER PRIMARY KEY,
    name    TEXT,
    salary  INTEGER
);

INSERT INTO employees(id, name, salary) VALUES
    (1, 'Alice',   72000),
    (2, 'Bob',     68000),
    (3, 'Charlie', 65000);
SQL

RUN chmod 644 /home/user/data/legacy.db

RUN chmod 755 /home/user

ENV PATH="/usr/local/bin:/usr/bin:/bin:$PATH"