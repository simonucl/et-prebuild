Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Basic utilities and Python tooling
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        make \
        ca-certificates

    pip3 install --no-cache-dir pytest

    # ---------------------------------------------------------------------
    # Create the unprivileged user and project seed directory structure
    # ---------------------------------------------------------------------
    useradd -m -s /bin/bash user || true   # ignore if already present

    PROJECT_ROOT=/home/user/project
    RAW_DIR=${PROJECT_ROOT}/data/raw

    mkdir -p "${RAW_DIR}"

    # ---------------------------------------------------------------------
    # Seed raw CSV files with the exact starter data expected by the tests
    # ---------------------------------------------------------------------
    cat > "${RAW_DIR}/customers.csv" <<'EOF'
id,name,email
1,Alice,alice@example.com
2,Bob,
3,,charlie@example.com
4,David,david@example.com
EOF

    cat > "${RAW_DIR}/transactions.csv" <<'EOF'
tid,customer_id,amount
1001,1,23.50
1002,2,
1003,3,100.00
1004,4,55.25
EOF

    # ---------------------------------------------------------------------
    # Set liberal permissions so the non-root runtime user can modify content
    # ---------------------------------------------------------------------
    chmod -R 0777 /home/user

%environment
    chmod 755 /home/user

    # Nothing to override; keep the caller's $HOME binding intact.
    export PYTHONIOENCODING=UTF-8

%runscript
    # Drop into a shell by default
    exec /bin/bash "$@"