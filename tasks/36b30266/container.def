Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author      task-prep
    Description Base image for the “artifact-manager” exercise—sets up Python,
                pytest, and the required /home/user directory (without the
                task’s log file).

%post
    set -e

    # Update package lists and install minimal Python environment.
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install pytest for the test harness.
    pip3 install --no-cache-dir pytest

    # Create the home directory expected by the tests.
    mkdir -p /home/user
    chmod 0755 /home/user

    # Ensure the exercise log file is NOT present at build time.
    rm -f /home/user/artifact_dns_check.log

    # Clean up APT cache to reduce image size.
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Do not modify $HOME; Apptainer will pass the host’s value through.
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"