Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -ex

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create the initial backup directory structure expected by the tests
    # ------------------------------------------------------------------
    mkdir -p /home/user/daily_backup/docs
    mkdir -p /home/user/daily_backup/images
    mkdir -p /home/user/daily_backup/data
    mkdir -p /home/user/reference

    # docs/report.txt
    cat >/home/user/daily_backup/docs/report.txt <<'EOF'
----------------------------
Quarterly Financial Report
Q1 Revenue: $1,200,000
Q1 Profit: $250,000
----------------------------
EOF

    # images/logo.png  (7-byte ASCII text “PNGDATA” + newline)
    printf 'PNGDATA\n' >/home/user/daily_backup/images/logo.png

    # data/data.csv
    cat >/home/user/daily_backup/data/data.csv <<'EOF'
id,value
1,alpha
2,beta
3,gamma
EOF

    # ------------------------------------------------------------------
    # Generate reference SHA-256 digests (relative paths, two-space separator)
    # ------------------------------------------------------------------
    cd /home/user/daily_backup
    sha256sum docs/report.txt images/logo.png data/data.csv \
        > /home/user/reference/sha256sums.txt
    cd /

    # Ensure world-readability so the non-root runtime user can access files
    chmod -R a+rX /home/user

%environment
    chmod 755 /home/user

    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author backup-verification-engineer
    Description "Environment for backup integrity verification task – includes staged files and reference SHA-256 sums."