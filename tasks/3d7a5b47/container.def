Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "Updating package list and installing Python tooling..."
    apt-get update -y
    # Basic Python environment (includes venv module) and build helpers
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-venv \
        python3-pip \
        python3-setuptools \
        python3-wheel

    # Upgrade pip to a reasonably recent version
    python3 -m pip install --no-cache-dir --upgrade pip

    # Install pytest so the grader can execute its test-suite
    python3 -m pip install --no-cache-dir pytest

    # Prepare writable working directory for the future “user”
    mkdir -p /home/user
    chmod 0777 /home/user   # allow whichever UID runs the container to write

    # Clean up apt cache to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure the default python and pip point to python3
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH
    export PYTHONIOENCODING=utf-8

%labels
    Author="Generated for credential-rotation exercise"
    Description="Baseline image with Python, pytest, and writable /home/user"

%runscript
    echo "This container provides the tooling required for the credential-rotation exercise."
    echo "Invoke an interactive shell with:  apptainer exec <image.sif> /bin/bash"