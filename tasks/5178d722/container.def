Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update apt cache and install Python tooling
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest

    # ---------------------------------------------------------------------
    # Prepare the working directory structure and the pre-seeded key-pair
    # ---------------------------------------------------------------------
    # Ensure the /home/user tree exists and is writable by any unprivileged
    # user that the grader might employ.
    mkdir -p /home/user
    chmod 0777 /home/user   # allow subsequent write access by the agent

    # Create the preseed directory that already contains the key-pair
    mkdir -p /home/user/preseed
    chmod 0755 /home/user/preseed

    # Private key
    printf 'myprivatekey\n' > /home/user/preseed/id_ed25519
    chmod 0644 /home/user/preseed/id_ed25519

    # Public key
    printf 'ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIG15cHVibGlja2V5 user@training\n' \
        > /home/user/preseed/id_ed25519.pub
    chmod 0644 /home/user/preseed/id_ed25519.pub

    # Clean up APT caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%help
    chmod 755 /home/user

    Container for the “SSH-key installation & Kubernetes-Secret” task.
    Pre-seeded keys are available under /home/user/preseed/.
    Pytest is installed for the grader’s test-suite.