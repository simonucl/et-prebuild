Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # Create a regular user with home directory
    useradd -m -s /bin/bash user || true

    # ------------------------------------------------------------------ #
    # Initialise the required backup data set for the exercise
    # ------------------------------------------------------------------ #
    mkdir -p /home/user/backups
    chmod 0777 /home/user/backups      # permissions must be 0777 initially

    # Empty backup files
    : > /home/user/backups/db.sql
    : > /home/user/backups/photos.tar.gz

    # Reference checksum manifest
    cat > /home/user/backups/sha256sums.txt <<'EOF'
e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855  db.sql
aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa  photos.tar.gz
EOF
    chmod 0666 /home/user/backups/sha256sums.txt  # manifest permissions 0666

    # Ensure ownership belongs to the non-root user
    chown -R user:user /home/user

    # Clean up APT cache to keep the image lean
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8
    export PATH=/usr/local/bin:/usr/bin:/bin

%labels
    Author="auto-generated"
    Description="Apptainer image for backup audit exercise (initial state)"