Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author autogenerated
    Description Base image for query optimization exercise. Provides Python, pip, venv tools and pytest. Leaves /home/user empty so that the learner can create the required artefacts during the exercise.

%post
    set -e

    # Update apt repositories and install required system packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-venv \
        ca-certificates \
        build-essential

    # Install pytest globally (used by the grading test-suite)
    python3 -m pip install --no-cache-dir --upgrade pip
    python3 -m pip install --no-cache-dir pytest

    # Ensure a writable home for the exercise
    mkdir -p /home/user
    chmod 777 /home/user   # Make it writable for any unprivileged container user

    # Clean up apt caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Make sure “python” points to python3
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"
    if [ -x /usr/bin/python3 ] && [ ! -e /usr/bin/python ]; then
        ln -s /usr/bin/python3 /usr/bin/python
    fi

%runscript
    echo "Container for the SQL query optimisation exercise."
    echo "Start an interactive shell (e.g., 'apptainer exec <img> bash') to begin."