FROM ubuntu:22.04

# Labels
LABEL Author="autogenerated"
LABEL Description="Base image for query optimization exercise. Provides Python, pip, venv tools and pytest. Leaves /home/user empty so that the learner can create the required artefacts during the exercise."

# Update apt repositories and install required system packages
RUN set -e && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-venv \
        ca-certificates \
        build-essential && \
    # Install pytest globally (used by the grading test-suite)
    python3 -m pip install --no-cache-dir --upgrade pip && \
    python3 -m pip install --no-cache-dir pytest && \
    # Ensure a writable home for the exercise
    mkdir -p /home/user && \
    chmod 777 /home/user && \
    # Clean up apt caches to keep the image small
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Create symlink for python command if it doesn't exist
RUN if [ -x /usr/bin/python3 ] && [ ! -e /usr/bin/python ]; then \
        ln -s /usr/bin/python3 /usr/bin/python; \
    fi

# Environment variables
ENV PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

# Set working directory
WORKDIR /home/user

# Default command
CMD ["bash", "-c", "echo 'Container for the SQL query optimisation exercise.' && echo 'Start an interactive shell to begin.' && exec bash"]