Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    #-----------------------------------------------------------------
    # Install system packages and Python tooling
    #-----------------------------------------------------------------
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        locales \
        ca-certificates
    pip3 install --no-cache-dir pytest

    # Generate a UTF-8 locale to silence potential locale warnings
    locale-gen en_US.UTF-8

    #-----------------------------------------------------------------
    # Prepare initial filesystem state for the exercise
    #-----------------------------------------------------------------
    # Create the required directory hierarchy and CSV source file
    mkdir -p /home/user/backups
    cat > /home/user/backups/servers_2023-10-15.csv <<'CSVEOF'
id,hostname,ip
1,web01,192.168.1.10
2,db01,192.168.1.20
CSVEOF

    # The archive directory may exist (allowed by the tests) but must not yet
    # contain the JSON output.  We create the directory and an EMPTY log file.
    mkdir -p /home/user/backups/archive
    : > /home/user/backups/archive/archive.log   # zero-byte placeholder

    #-----------------------------------------------------------------
    # Make sure the non-privileged user can read/write where needed
    #-----------------------------------------------------------------
    chmod -R a+rwX /home/user

%environment
    chmod 755 /home/user

    # Ensure UTF-8 locale inside the container
    export LC_ALL=en_US.UTF-8
    export LANG=en_US.UTF-8
    export LANGUAGE=en_US.UTF-8

%labels
    Author Unknown
    Description "Environment for CSV→JSON archiving task with pytest pre-installed."

%help
    This Apptainer container provides the initial filesystem state and all
    dependencies (Python + pytest) required for the “backup administrator”
    coding exercise.