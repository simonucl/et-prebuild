Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        procps
    pip3 install --no-cache-dir pytest

    # Prepare writable home for the exercise participant
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up APT cache to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%labels
    chmod 755 /home/user

    Author DeploymentExercise
    Description "Base image for the deployment-logs task with pytest pre-installed."

%environment
    # Ensure Python is on PATH (it already is, but make it explicit)
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH