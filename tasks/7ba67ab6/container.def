Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------------------
    # Set up initial filesystem state required for the exercise
    # ------------------------------------------------------------------------------

    # Create the directory that will hold CI/CD configuration files
    mkdir -p /home/user/cicd
    # Make it writable so the learner (non-root inside container) can create files
    chmod 0777 /home/user/cicd

    # Create the pristine pipeline.ini with the exact expected contents
    cat > /home/user/cicd/pipeline.ini << 'EOF'
[metadata]
project_name = Nebula
build_number = 42

[deploy]
envs = dev,staging,prod
strategy = rolling

[notifications]
slack = true
email = false
EOF
    # Ensure sensible permissions
    chmod 0644 /home/user/cicd/pipeline.ini

%environment
    chmod 755 /home/user

    # Minimal locale settings
    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8

%labels
    Author    "Your Name"
    Description "Apptainer image for CI/CD INI parsing task with pytest pre-installed."