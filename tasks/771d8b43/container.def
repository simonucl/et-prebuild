Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Ensure package index is up-to-date and install required software
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        sqlite3 \
        python3-pip \
        ca-certificates
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the grading suite
    python3 -m pip install --no-cache-dir --upgrade pip
    python3 -m pip install --no-cache-dir pytest

    # Create the home directory expected by the tests
    mkdir -p /home/user
    # Grant write permissions to non-root runtime users
    chmod 0777 /home/user

%environment
    chmod 755 /home/user

    export PATH=/usr/local/bin:$PATH
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8