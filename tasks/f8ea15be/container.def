Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python tooling and pytest
    apt-get update
    apt-get install -y --no-install-recommends python3-pip
    pip3 install --no-cache-dir pytest

    # -----------------------------------------------------------------------------
    # Prepare initial filesystem state for the “string-service” exercise
    # -----------------------------------------------------------------------------
    mkdir -p /home/user/string-service/config
    mkdir -p /home/user/string-service/logs

    # Initial configuration
    echo 'LOCALE="en_US"' > /home/user/string-service/config/env.conf

    # Empty log file
    : > /home/user/string-service/logs/translation_update.log

    # Make sure the unprivileged runtime user can modify the files
    chmod 777 /home/user/string-service \
              /home/user/string-service/config \
              /home/user/string-service/logs
    chmod 666 /home/user/string-service/config/env.conf \
              /home/user/string-service/logs/translation_update.log

%environment
    chmod 755 /home/user

    # No special environment variables are needed.