Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install required tools
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        iputils-ping \
        iproute2

    # Upgrade pip and install pytest
    python3 -m pip install --no-cache-dir --upgrade pip
    python3 -m pip install --no-cache-dir pytest

    # Ensure the baseline home directory expected by the tests exists
    mkdir -p /home/user
    # Make it writable for any non-root user who will run the exercise
    chmod 0777 /home/user

    # Clean apt caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8
    export PATH=/usr/local/bin:${PATH}

%labels
    Author="Generated by ChatGPT"
    Description="Container for the first-pass connectivity report exercise with pytest pre-installed."