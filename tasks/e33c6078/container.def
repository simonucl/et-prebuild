Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author "ChatGPT - Automatic build file"
    Description "Environment pre-loaded with capacity-planner sample INI data and pytest."

%post
    set -e

    # ------------------------------------------------------------------
    # Install required system packages
    # ------------------------------------------------------------------
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        locales \
        tzdata
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Install Python testing framework
    # ------------------------------------------------------------------
    pip3 install --no-cache-dir --upgrade pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare directory structure and starter data files
    # ------------------------------------------------------------------
    DATA_DIR="/home/user/capacity_planner/data"
    mkdir -p "${DATA_DIR}"

    # server01.ini ------------------------------------------------------
    cat > "${DATA_DIR}/server01.ini" <<'EOF'
[2024-08-01]
CPU=55
Memory=6820
Disk=120

[2024-08-02]
CPU=60
Memory=7000
Disk=118

[2024-08-03]
CPU=58
Memory=6950
Disk=117
EOF

    # server02.ini ------------------------------------------------------
    cat > "${DATA_DIR}/server02.ini" <<'EOF'
[2024-08-01]
CPU=70
Memory=12000
Disk=250

[2024-08-02]
CPU=75
Memory=11850
Disk=249

[2024-08-03]
CPU=73
Memory=11900
Disk=248
EOF

    # server03.ini ------------------------------------------------------
    cat > "${DATA_DIR}/server03.ini" <<'EOF'
[2024-08-01]
CPU=30
Memory=4000
Disk=80

[2024-08-02]
CPU=28
Memory=3950
Disk=79

[2024-08-03]
CPU=27
Memory=3900
Disk=78
EOF

    # ------------------------------------------------------------------
    # Ensure appropriate permissions (readable by any user)
    # ------------------------------------------------------------------
    chmod 755 /home /home/user /home/user/capacity_planner /home/user/capacity_planner/data || true
    chmod 644 "${DATA_DIR}"/*.ini

    # Do NOT create summary output or marker files; these will be
    # generated by the student/agent at runtime.

%environment
    chmod 755 /home/user

    export PYTHONUNBUFFERED=1
    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8

%runscript
    echo "Container for capacity-planner task. Execute your scripts inside."