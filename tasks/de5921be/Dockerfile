FROM ubuntu:22.04

# Labels
LABEL Author="Singularity Task Setup"
LABEL Description="Container image prepared for the large log alert monitoring task."

############################
# 1. Install dependencies  #
############################
RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        tzdata && \
    rm -rf /var/lib/apt/lists/*

# Install pytest for the grading test-suite
RUN pip3 install --no-cache-dir pytest

############################
# 2. Prepare initial data  #
############################
# Directory structure
RUN mkdir -p /home/user/monitoring/logs

# Create the three log files with the exact sizes required by the tests
RUN truncate -s 2000000 /home/user/monitoring/logs/access.log && \
    truncate -s 500000 /home/user/monitoring/logs/error.log && \
    truncate -s 1200000 /home/user/monitoring/logs/debug.log

# Permissions (readable by non-root users)
RUN chmod 755 /home && \
    chmod 755 /home/user && \
    chmod 755 /home/user/monitoring && \
    chmod 755 /home/user/monitoring/logs && \
    chmod 644 /home/user/monitoring/logs/*.log

# NOTE:
# * Do NOT create /home/user/monitoring/alerts or the CSV report here—
#   they must be generated by the student's solution.

# Ensure python is available via `python` as well
ENV PATH=/usr/local/bin:$PATH

RUN if [ -x /usr/bin/python3 ] && [ ! -e /usr/bin/python ]; then \
        ln -s /usr/bin/python3 /usr/bin/python; \
    fi

WORKDIR /home/user