Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    ############################
    # 1. Install dependencies  #
    ############################
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        tzdata

    # Install pytest for the grading test-suite
    pip3 install --no-cache-dir pytest

    ############################
    # 2. Prepare initial data  #
    ############################
    # Directory structure
    mkdir -p /home/user/monitoring/logs

    # Create the three log files with the exact sizes required by the tests
    truncate -s 2000000 /home/user/monitoring/logs/access.log   # 2,000,000 bytes
    truncate -s  500000 /home/user/monitoring/logs/error.log    #   500,000 bytes
    truncate -s 1200000 /home/user/monitoring/logs/debug.log    # 1,200,000 bytes

    # Permissions (readable by non-root users)
    chmod 755 /home
    chmod 755 /home/user
    chmod 755 /home/user/monitoring
    chmod 755 /home/user/monitoring/logs
    chmod 644 /home/user/monitoring/logs/*.log

    # NOTE:
    # * Do NOT create /home/user/monitoring/alerts or the CSV report here—
    #   they must be generated by the student’s solution.

%environment
    # Ensure python is available via `python` as well
    export PATH=/usr/local/bin:$PATH
    if [ -x /usr/bin/python3 ] && [ ! -e /usr/bin/python ]; then
        ln -s /usr/bin/python3 /usr/bin/python
    fi

%labels
    Author      Singularity Task Setup
    Description Container image prepared for the “large log alert” monitoring task.