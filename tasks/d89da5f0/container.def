Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive

    # Basic packages and Python tooling
    apt-get update -y
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        tzdata \
        locales \
        ca-certificates

    # Generate the en_US.UTF-8 locale required by the exercise
    sed -i 's/^# *en_US.UTF-8 UTF-8/en_US.UTF-8 UTF-8/' /etc/locale.gen
    locale-gen

    # Upgrade pip and install pytest for the test-harness
    pip3 install --no-cache-dir --upgrade pip
    pip3 install --no-cache-dir pytest

    # Create a non-root user 'user' with home directory /home/user
    groupadd -g 1000 user
    useradd -m -u 1000 -g 1000 -s /bin/bash user
    chown -R 1000:1000 /home/user

    # Clean up APT cache to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    export LANG=en_US.UTF-8
    export LC_ALL=en_US.UTF-8
    export LANGUAGE=en_US:en