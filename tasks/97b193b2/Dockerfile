FROM ubuntu:22.04

# Labels
LABEL Author="Autogenerated Definition"
LABEL Description="Environment prepared for the status-code summary task with pytest pre-installed."

# Post installation
RUN set -e && \
    echo "Updating apt and installing Python + pytest ..." && \
    apt-get update -y && \
    apt-get install -y python3 python3-pip && \
    pip3 install --no-cache-dir pytest && \
    echo "Creating directory structure and pre-populating access log ..." && \
    mkdir -p /home/user/projects/site/logs

# Populate the access log with the exact eight lines specified
RUN cat > /home/user/projects/site/logs/access.log << 'EOF'
127.0.0.1 - - [10/Jun/2023:14:32:10 +0000] "GET /index.html HTTP/1.1" 200 1024 "-" "Mozilla/5.0"
127.0.0.1 - - [10/Jun/2023:14:32:12 +0000] "POST /api/login HTTP/1.1" 302 512 "-" "Mozilla/5.0"
127.0.0.1 - - [10/Jun/2023:14:32:15 +0000] "GET /dashboard HTTP/1.1" 200 2048 "-" "Mozilla/5.0"
127.0.0.1 - - [10/Jun/2023:14:32:18 +0000] "GET /nonexistent HTTP/1.1" 404 256 "-" "Mozilla/5.0"
127.0.0.1 - - [10/Jun/2023:14:32:20 +0000] "GET /index.html HTTP/1.1" 200 1024 "-" "Mozilla/5.0"
127.0.0.1 - - [10/Jun/2023:14:32:25 +0000] "GET /images/logo.png HTTP/1.1" 200 20480 "-" "Mozilla/5.0"
127.0.0.1 - - [10/Jun/2023:14:32:30 +0000] "GET /api/data HTTP/1.1" 500 128 "-" "Mozilla/5.0"
127.0.0.1 - - [10/Jun/2023:14:32:35 +0000] "GET /contact HTTP/1.1" 200 1536 "-" "Mozilla/5.0"
EOF

# Ensure everything under /home/user is writable
RUN chmod -R 0777 /home/user && \
    echo "Initial setup complete."

# Environment variables
ENV PYTHONIOENCODING=utf-8

# Set working directory
WORKDIR /home/user

# Default command
CMD ["/bin/bash"]