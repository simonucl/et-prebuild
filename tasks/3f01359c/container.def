Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial project structure expected by the automated tests
    # ------------------------------------------------------------------
    mkdir -p /home/user/project/i18n

    # Unsorted French JSON delivered by the localization engineer
    cat > /home/user/project/i18n/fr.json <<'JSON_EOF'
{
  "CancelButton": "Annuler",
  "AddButton": "Ajouter",
  "DeleteDialogTitle": "Supprimer l’élément ?",
  "EditLabel": "Modifier",
  "SaveSuccess": "Enregistré avec succès"
}
JSON_EOF

    # Make sure the student (non-root at runtime) can create new files
    chmod 777 /home/user/project /home/user/project/i18n
    chmod 666 /home/user/project/i18n/fr.json

%environment
    chmod 755 /home/user

    # No special environment variables are needed for this task
    :