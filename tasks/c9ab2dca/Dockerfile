FROM ubuntu:22.04

# Labels
LABEL Author="Autogenerated for restore exercise"
LABEL Description="Environment for find+xargs restore task with pytest pre-installed"

# Environment variables
ENV PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

# Update APT and install Python + pip
RUN set -e && \
    echo "Updating APT and installing Python + pip..." && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip && \
    pip3 install --no-cache-dir pytest && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Create directory structure under /home/user
RUN echo "Creating directory structure under /home/user ..." && \
    mkdir -p /home/user && \
    chmod 755 /home/user

# Backup repository with date-stamped sub-directories
RUN for day in 2023-07-14 2023-07-15; do \
        mkdir -p "/home/user/backup_repo/daily_backups/${day}/files"; \
    done

# 2023-07-14 backups
RUN printf "server=alpha\nport=8080\n" \
        > /home/user/backup_repo/daily_backups/2023-07-14/files/config1.cfg.bak && \
    printf "CREATE TABLE test1 (id INTEGER);\n" \
        > /home/user/backup_repo/daily_backups/2023-07-14/files/data1.sql.bak && \
    printf "Backup note for July 14\n" \
        > /home/user/backup_repo/daily_backups/2023-07-14/files/notes.txt.bak

# 2023-07-15 backups
RUN printf "server=beta\nport=9090\n" \
        > /home/user/backup_repo/daily_backups/2023-07-15/files/config2.cfg.bak && \
    printf "CREATE TABLE test2 (id INTEGER);\n" \
        > /home/user/backup_repo/daily_backups/2023-07-15/files/data2.sql.bak

# Extra non-backup files (ignored by tests)
RUN head -c 1024 </dev/urandom \
        > /home/user/backup_repo/daily_backups/2023-07-14/files/random.tmp && \
    echo "This is a readme." \
        > /home/user/backup_repo/daily_backups/2023-07-15/files/readme.md

# Make sure everything is world-readable
RUN chmod -R a+rX /home/user/backup_repo

# Empty restore test directory (must exist but contain nothing)
# Allow the non-root container user to write here
RUN mkdir -p /home/user/restore_test && \
    chmod 777 /home/user/restore_test

# Set working directory
WORKDIR /home/user

# Default command
CMD ["/bin/bash", "-c", "echo 'Container for restore exercise. Launch an interactive shell with:' && echo '    docker exec -it <container> /bin/bash' && echo 'pytest is available for running the verification suite.'"]