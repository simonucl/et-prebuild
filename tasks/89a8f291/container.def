Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package list and install required software
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        file \
        locales

    # Generate a UTF-8 locale so tools like `file` behave consistently
    locale-gen en_US.UTF-8

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # --------------------------------------------------------------------- #
    # Prepare initial exercise state
    # --------------------------------------------------------------------- #

    # Create the required directory hierarchy
    mkdir -p /home/user/projects/cicd

    # Populate the legacy Windows-1252 file
    cat <<'EOF' | iconv -f UTF-8 -t windows-1252 > /home/user/projects/cicd/legacy_config_win1252.txt
# Build configuration – ACME CI/CD
BUILD_SERVER=alpha
DEPLOY_TARGET=production
CURRENCY=€
EOF

    # Ensure the directory tree is readable by any non-root user
    chmod -R a+rX /home/user

%labels
    chmod 755 /home/user

    Author      legacy-config-exercise
    Description "Environment for the legacy config encoding conversion task"

%runscript
    echo "Container for the legacy config encoding exercise."
    echo "Switch to /home/user/projects/cicd and begin your work."
    exec "$@"

%environment
    export LC_ALL=en_US.UTF-8
    export LANG=en_US.UTF-8