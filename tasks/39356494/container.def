Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ------------------------------------------------------------------
    # Install Python and pytest
    # ------------------------------------------------------------------
    apt-get update && \
        DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
            python3 \
            python3-pip \
            python3-setuptools && \
        pip3 install --no-cache-dir pytest && \
        apt-get clean && \
        rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Create initial project layout expected by the grader
    # ------------------------------------------------------------------
    mkdir -p /home/user/my_project/src
    mkdir -p /home/user/my_project/test
    mkdir -p /home/user/my_project/notes/tmp

    # Required files
    touch /home/user/my_project/src/old.tmp
    touch /home/user/my_project/src/main.c
    touch /home/user/my_project/test/data.tmp
    touch /home/user/my_project/debug.log
    touch /home/user/my_project/notes/tmp/info.tmp

    # ------------------------------------------------------------------
    # Permissions: make everything inside /home/user writable so the
    # non-root student user can create/move files during evaluation.
    # ------------------------------------------------------------------
    chmod -R 0777 /home/user

%environment
    chmod 755 /home/user

    # Ensure Python is on PATH (default in Ubuntu, but explicit is safer)
    export PATH="/usr/local/bin:/usr/bin:/bin"