Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # ------------------------------------------------------------------
    # Install Python tooling required for the grading harness
    # ------------------------------------------------------------------
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Prepare initial filesystem state expected by the tests
    # ------------------------------------------------------------------
    mkdir -p /home/user/project/config

    # build.cfg  (64 bytes, Windows-1252, CRLF)
    printf 'project_name=AwesomeApp\r\nversion=1.2.3\r\nmaintainer=DevOps Team\r\n' \
        > /home/user/project/config/build.cfg

    # deploy.cfg (52 bytes, Windows-1252, CRLF)
    printf 'deploy_env=production\r\nservers=5\r\nstrategy=rolling\r\n' \
        > /home/user/project/config/deploy.cfg

    # test.cfg   (44 bytes, Windows-1252, CRLF)
    printf 'tests_enabled=true\r\ntimeout=300\r\nretries=2\r\n' \
        > /home/user/project/config/test.cfg

    # ------------------------------------------------------------------
    # Permissions – allow non-root container users to read/write/execute
    # ------------------------------------------------------------------
    chmod 777 /home/user /home/user/project /home/user/project/config
    chmod 666 /home/user/project/config/*.cfg

%labels
    chmod 755 /home/user

    Author encoding-conversion-task-preparer