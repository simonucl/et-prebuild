Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python tooling
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-venv \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

    # Install pytest (required by the autograder)
    pip3 install --no-cache-dir pytest==8.1.1

    # Prepare a writable workspace for the unprivileged test user
    mkdir -p /home/user
    chmod 0777 /home/user

%environment
    chmod 755 /home/user

    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH
    export PYTHONDONTWRITEBYTECODE=1

%labels
    Author "Container build automation"
    Description "Apptainer image for the package-requirements normalisation exercise."

%runscript
    # Default runscript: just execute whatever the caller asked for
    exec "$@"