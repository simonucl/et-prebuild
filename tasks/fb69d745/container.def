Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    #--------------------------------------------------------------
    # Basic tooling
    #--------------------------------------------------------------
    apt-get update && \
        apt-get install -y --no-install-recommends \
            python3 \
            python3-pip \
            python3-setuptools && \
        rm -rf /var/lib/apt/lists/*

    pip3 install --no-cache-dir pytest

    #--------------------------------------------------------------
    # Prepare initial filesystem state for the task
    #--------------------------------------------------------------
    mkdir -p /home/user/dashboards

    # Required JSON dashboard files
    cat > /home/user/dashboards/prometheus_k8s_legacy.json <<'EOF'
{"title":"Prometheus K8s Legacy","version":1}
EOF

    cat > /home/user/dashboards/grafana_overview_legacy.json <<'EOF'
{"title":"Grafana Overview Legacy","version":1}
EOF

    cat > /home/user/dashboards/service_latency.json <<'EOF'
{"title":"Service Latency","version":2}
EOF

    # README file
    cat > /home/user/dashboards/readme.md <<'EOF'
These dashboards are managed by the observability team.
EOF

    # Leave archive directory and cleanup log uncreated;
    # they must be generated by the student’s solution.

    #--------------------------------------------------------------
    # Make sure the non-root runtime user can modify everything
    #--------------------------------------------------------------
    chmod -R 0777 /home/user

%help
    chmod 755 /home/user

This container supplies the starting filesystem state for the
“dashboard spring-cleaning” task as well as pytest for test execution.

%runscript
exec "$@"