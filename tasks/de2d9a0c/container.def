Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "Updating package index and installing Python tooling..."
    apt-get update -qq
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3-pip \
        ca-certificates

    echo "Installing pytest for the verification suite..."
    pip3 install --no-cache-dir pytest

    echo "Creating initial file system state for the incident-responder task..."

    # Create the user home directory tree that the task expects.
    mkdir -p /home/user/cluster_logs
    chmod 755 /home/user
    chmod 755 /home/user/cluster_logs

    # --- node1.log ---
    cat >/home/user/cluster_logs/node1.log <<'EOF'
INFO service started
ERROR failed to connect db
WARN retrying
ERROR timeout
EOF

    # --- node2.log ---
    cat >/home/user/cluster_logs/node2.log <<'EOF'
INFO service started
INFO healthcheck pass
INFO user login
ERROR disk full
ERROR disk full
ERROR disk full
EOF

    # --- node3.log ---
    cat >/home/user/cluster_logs/node3.log <<'EOF'
INFO service started
WARN memory usage high
INFO request processed
EOF

    # Ensure the log files are readable by non-root users.
    chmod 644 /home/user/cluster_logs/node*.log

    echo "Initial state prepared."

%environment
    # No HOME overrides – let Apptainer bind the host's HOME automatically.
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    echo "Container for the incident-responder task."
    echo "Invoke your commands with 'apptainer exec' as needed."