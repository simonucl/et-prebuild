# syntax=docker/dockerfile:1
FROM ubuntu:22.04

# Author: Apptainer Task Builder
LABEL Author="Apptainer Task Builder"

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked --mount=type=cache,target=/var/lib/apt,sharing=locked set -e && \
    apt-get update && \
    apt-get install -y --no-install-recommends python3 python3-pip && \
    rm -rf /var/lib/apt/lists/*

RUN --mount=type=cache,target=/root/.cache/pip pip3 install --no-cache-dir pytest

# ------------------------------------------------------------------
# Prepare the DBA environment expected by the test harness
# ------------------------------------------------------------------

# Create home directory
RUN mkdir -p /home/user

# 1. ~/.env_dba with required exports
RUN cat > /home/user/.env_dba <<'EOF'
export PGDATABASE="salesdb"
export PGUSER="analyst"
export PGTZ="UTC"
export PGOPTIONS="-c work_mem=64MB -c shared_buffers=256MB"
EOF

RUN chmod 0644 /home/user/.env_dba

# 2. ~/.bashrc ending with the mandatory snippet
RUN cat > /home/user/.bashrc <<'EOF'
# .bashrc generated by build script

# >>> DBA ENV START >>>
if [ -f ~/.env_dba ]; then
    . ~/.env_dba
fi
# <<< DBA ENV END <<<
EOF

RUN chmod 0644 /home/user/.bashrc

# 3. db_tuning directory
RUN mkdir -p /home/user/db_tuning && \
    chmod 0755 /home/user/db_tuning

# 4. optimize_queries.log with exact content
RUN cat > /home/user/db_tuning/optimize_queries.log <<'EOF'
========== BEFORE ==========
Seq Scan on sales (cost=0.00..431.00 rows=24000 width=12)

========== TUNING_STEPS ==========
1. Created index: CREATE INDEX idx_sales_date ON sales(order_date);
2. Adjusted work_mem to 64MB.
3. Enabled indexscan with: SET enable_seqscan = off;

========== AFTER ==========
Index Scan using idx_sales_date on sales (cost=0.43..123.00 rows=24000 width=12)
EOF

RUN chmod 0644 /home/user/db_tuning/optimize_queries.log

# Environment setup
RUN chmod 755 /home/user

ENV PATH="/usr/local/bin:/usr/bin:/bin:${PATH}"