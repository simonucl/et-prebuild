Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ------------------------------------------------------------------
    # 1. Install Python and pytest (via pip, guarantees latest pytest)
    # ------------------------------------------------------------------
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 python3-pip ca-certificates
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # 2. Create the required directory structure and raw sensor log
    # ------------------------------------------------------------------
    # Ensure the /home/user hierarchy exists with sensible permissions
    mkdir -p /home/user/data
    chmod 755 /home/user
    chmod 755 /home/user/data

    # Create the sensor log with the exact expected 10 lines
    cat > /home/user/data/sensor_readings_2023.log <<'EOF'
2023-06-01T00:00:01Z SENSOR_ID=alpha STATUS=OK   TEMP=24.5C HUM=45%
2023-06-01T00:30:01Z SENSOR_ID=alpha STATUS=FAIL TEMP=0.0C  HUM=0%
2023-06-01T01:00:01Z SENSOR_ID=beta  STATUS=OK   TEMP=23.1C HUM=47%
2023-06-01T01:30:01Z SENSOR_ID=beta  STATUS=FAIL TEMP=-5.0C HUM=0%
2023-06-01T02:00:01Z SENSOR_ID=gamma STATUS=OK   TEMP=22.8C HUM=44%
2023-06-01T02:30:01Z SENSOR_ID=gamma STATUS=OK   TEMP=22.9C HUM=44%
2023-06-01T03:00:01Z SENSOR_ID=alpha STATUS=OK   TEMP=24.7C HUM=45%
2023-06-01T03:30:01Z SENSOR_ID=beta  STATUS=OK   TEMP=23.4C HUM=47%
2023-06-01T04:00:01Z SENSOR_ID=gamma STATUS=FAIL TEMP=-10.0C HUM=0%
2023-06-01T04:30:01Z SENSOR_ID=alpha STATUS=OK   TEMP=24.6C HUM=46%
EOF
    chmod 644 /home/user/data/sensor_readings_2023.log

%environment
    # Keep environment minimal; do NOT override $HOME.
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%labels
    Author="Autogenerated for sensor-log task"
    Description="Container providing raw sensor log and pytest for student exercises."

%help
    This Apptainer image contains the raw sensor log at
      /home/user/data/sensor_readings_2023.log
    along with pytest for automated grading.