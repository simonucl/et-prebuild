Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install required packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        iputils-ping
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Prepare working directory and prerequisite file
    mkdir -p /home/user
    printf '8.8.8.8\n1.1.1.1\n192.0.2.1\n' > /home/user/ip_list.txt
    chmod 644 /home/user/ip_list.txt
    chmod 777 /home/user   # Allow the learner to create the report file

%environment
    chmod 755 /home/user

    export PYTHONIOENCODING=UTF-8