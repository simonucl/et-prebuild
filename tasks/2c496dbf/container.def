Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install required software
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        curl \
        ca-certificates
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the hidden test suite
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial repository state expected by the tests
    # ------------------------------------------------------------------
    # Create the user home and artifact directory
    mkdir -p /home/user/artifacts
    chmod 755 /home/user
    chmod 755 /home/user/artifacts

    # Create the two binary files with the exact required content
    printf 'WIDGET\n' >  /home/user/artifacts/widget-1.0.0.bin
    printf 'GADGET\n' >  /home/user/artifacts/gadget-2.1.3.bin

    # Ensure file permissions are world-readable
    chmod 444 /home/user/artifacts/widget-1.0.0.bin
    chmod 444 /home/user/artifacts/gadget-2.1.3.bin

%environment
    # Ensure Python and pip are on PATH
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author    "Container Build Script for Artifact Repository Task"

%runscript
    echo "This container sets up the initial state for the artifact repository task."
    echo "Use 'apptainer exec <image> /bin/bash' to start working on the exercise."