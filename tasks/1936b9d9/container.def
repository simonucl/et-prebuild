Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install required packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 python3-pip sqlite3 \
        && apt-get clean && rm -rf /var/lib/apt/lists/*

    # Install pytest for the grading test-suite
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state expected by the automated tests
    # ------------------------------------------------------------------

    # Ensure /home/user exists and is writable by any user inside the
    # container (the runtime UID is unknown a-priori).
    mkdir -p /home/user
    chmod 0777 /home/user

    # Create microservices directory (read-only is fine for tests)
    mkdir -p /home/user/microservices
    chmod 0755 /home/user/microservices

    # Build the pre-populated SQLite database
    SQLITE_DB=/home/user/microservices/logs.db
    sqlite3 "${SQLITE_DB}" <<'SQL_EOF'
    PRAGMA journal_mode = OFF;
    CREATE TABLE services (
        id     INTEGER PRIMARY KEY,
        name   TEXT    NOT NULL,
        status TEXT    NOT NULL
    );

    INSERT INTO services (id, name, status) VALUES
        (1, 'auth-api',     'running'),
        (2, 'payments-api', 'stopped'),
        (3, 'user-api',     'running'),
        (4, 'metrics',      'running'),
        (5, 'gateway',      'stopped');
    SQL_EOF

    # Set database permissions: readable by everyone, not writable by others
    chmod 0644 "${SQLITE_DB}"

    # NOTE:
    # The directory /home/user/output **must not** exist at build time.
    # The student's solution will create it during execution.
    :

%environment
    chmod 755 /home/user

    # Keep environment minimal; rely on inherited $HOME.
    export LC_ALL=C.UTF-8
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

%labels
    Author "Container Prep Utility"
    Description "Environment for SQLite counting task (includes pytest and test DB)"