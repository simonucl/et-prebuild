Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ---------------------------------------------------------------------
    # Install Python tooling required for the test harness
    # ---------------------------------------------------------------------
    apt-get update -y
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest

    # ---------------------------------------------------------------------
    # Prepare the initial filesystem state expected by the grader
    # ---------------------------------------------------------------------
    # Create the user’s home and downloads directories
    mkdir -p /home/user/downloads

    # Create the three placeholder “binary” files with the exact byte-sizes
    # specified in the task description.
    printf "alpha-1.0 binary\n"   > /home/user/downloads/alpha-1.0.jar    # 17 bytes
    printf "bravo-2.1 package\n"  > /home/user/downloads/bravo-2.1.rpm    # 18 bytes
    printf "charlie-3.4 package\n" > /home/user/downloads/charlie-3.4.deb # 20 bytes

    # Provide an empty .bashrc so the learner can append to it later.
    touch /home/user/.bashrc

    # Make sure the learner (who will not have root) can write under /home/user
    chmod -R 0777 /home/user

%environment
    chmod 755 /home/user

    # Do not set any task-related variables; keep the environment clean
    export LC_ALL=C.UTF-8
    export PATH=/usr/local/bin:/usr/bin:/bin

%labels
    Author example
    Description Initial state for artifact-curation exercise (with pytest pre-installed)

%help
    This container prepares the starting environment for the “artifact curation”
    exercise.  It installs pytest and seeds /home/user/downloads with the three
    placeholder binaries that the learner is expected to manage.