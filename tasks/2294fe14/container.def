Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # Create required directory and input file with correct contents
    mkdir -p /home/user/performance
    cat <<'EOF' > /home/user/performance/running_containers.txt
redis
nginx
metrics_collector
auth_service
EOF

    # Adjust permissions so the non-root runtime user can work within the directory
    chmod 0777 /home/user/performance
    chmod 0666 /home/user/performance/running_containers.txt

%environment
    chmod 755 /home/user

    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%runscript
    echo "Container for the running-containers counting task. No default action."