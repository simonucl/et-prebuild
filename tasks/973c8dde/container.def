Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # --------------------------------------------------------------------- #
    # 1. Install system packages and Python tooling
    # --------------------------------------------------------------------- #
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        locales \
        ca-certificates
    # Minimal locale so UTF-8 operations work reliably
    sed -i 's/^# *\(en_US.UTF-8\)/\1/' /etc/locale.gen
    locale-gen

    # Upgrade pip and install pytest (required by the grading engine)
    python3 -m pip install --no-cache-dir --upgrade pip
    python3 -m pip install --no-cache-dir pytest

    # --------------------------------------------------------------------- #
    # 2. Create the initial workspace expected by the assignment
    # --------------------------------------------------------------------- #
    mkdir -p /home/user/project/translations

    # English source strings
    cat > /home/user/project/translations/en_US.csv <<'EOF'
greeting,Hello
farewell,Goodbye
ask_name,What is your name?
thank_you,Thank you
welcome,Welcome
EOF

    # Spanish (in-progress) translations
    cat > /home/user/project/translations/es_ES.csv <<'EOF'
greeting,Hola
farewell,Adiós
thank_you,Gracias
EOF

    # Ensure the non-root runtime user can read (and if desired, write) these files
    chmod -R a+rwX /home/user/project

%labels
    chmod 755 /home/user

    Author          ExampleAuthor
    Description     Base image for the localization transformation task

%help
    This Apptainer image sets up the initial workspace for the localization
    transformation exercise.  It pre-installs Python, pytest, and places the two
    required source CSV files under:
        /home/user/project/translations/