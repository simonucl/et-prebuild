Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    #------------------------------------------------------------------
    # Base tooling
    #------------------------------------------------------------------
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        python3 \
        python3-pip \
        --no-install-recommends

    pip3 install --no-cache-dir pytest

    #------------------------------------------------------------------
    # Prepare initial task data
    #------------------------------------------------------------------
    mkdir -p /home/user/configs
    mkdir -p /home/user/changes

    # registration.csv  (semicolon-separated, with trailing newline)
    cat > /home/user/configs/registration.csv <<'EOF'
server_id;location;role;maint_window
srv01;us-east;web;Sun 01:00
srv02;us-west;db;Mon 02:00
srv03;eu-central;cache;Tue 03:00
EOF

    # firmware_versions.tsv  (tab-separated, with trailing newline)
    cat > /home/user/changes/firmware_versions.tsv <<'EOF'
server_id	version	release_date
srv01	1.2.4	2024-01-21
srv02	1.4.7	2024-02-10
srv03	1.3.2	2024-02-28
EOF

    #------------------------------------------------------------------
    # Permissions: ensure the runtime user (non-root) can work freely
    #------------------------------------------------------------------
    chmod -R a+rwx /home/user

%environment
    chmod 755 /home/user

    # Keep environment minimal; do not override $HOME
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8