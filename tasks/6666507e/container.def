Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author  YourName
    Purpose "Container for the init-PID audit assignment"

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # Basic utilities and Python
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates

    # Install pytest for the grading suite
    pip3 install --no-cache-dir pytest

    # Create non-root user expected by the test harness (UID 1000, home /home/user)
    groupadd -g 1000 user
    useradd  -m -u 1000 -g 1000 -s /bin/bash user
    chown -R 1000:1000 /home/user

    # Clean up APT cache to keep image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%runscript
    echo "This container is ready for the init-PID audit assignment."
    echo "Open a shell with:  apptainer exec <image> /bin/bash"