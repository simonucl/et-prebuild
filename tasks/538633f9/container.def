Bootstrap: localimage
From: ./ubuntu_22.04.sif

%help
Container for the “capacity-planner” encryption task.
Pre-populates the CSV data file and installs the tools (GnuPG, pytest, etc.)
that the student/agent will need.

%post
    set -e

    echo "Updating package index and installing required packages ..."
    apt-get update -y
    # Install GnuPG for encryption plus Python + Pytest for the test harness
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        gnupg \
        python3 \
        python3-pip

    # Install the latest pytest via pip to avoid any version-mismatch issues
    python3 -m pip install --no-cache-dir --upgrade pip
    python3 -m pip install --no-cache-dir pytest

    echo "Creating initial directory structure and CSV file ..."
    # Create /home/user path (make writable for any UID running inside container)
    mkdir -p /home/user/capacity_tasks
    chmod 0777 /home/user
    chmod 0777 /home/user/capacity_tasks

    # Write the CSV file with the exact required content (4 lines, each ending with '\n')
    cat > /home/user/capacity_tasks/resource_usage.csv << 'EOF'
timestamp,cpu_usage_percent,memory_usage_mb
2024-06-01T00:00:00Z,32,2048
2024-06-01T01:00:00Z,45,3072
2024-06-01T02:00:00Z,29,1984
EOF

    # Ensure proper default permissions: readable & writable by the user
    chmod 0644 /home/user/capacity_tasks/resource_usage.csv

    echo "Container setup complete."

%environment
    chmod 755 /home/user

    # No environment variables are strictly required for the task,
    # but we expose a hint that GPG is available.
    export GPG_TTY=$(tty || true)

%runscript
    echo "This container prepares the initial state for the capacity-planner exercise."
    echo "Execute your solution inside the container as needed."