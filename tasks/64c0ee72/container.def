Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Update package lists and install Python & pytest
    apt-get update -y && \
    apt-get install -y python3 python3-pip && \
    python3 -m pip install --no-cache-dir pytest && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Create the demo project exactly as described in the task statement
    # ------------------------------------------------------------------
    mkdir -p /home/user/projects/app

    # /home/user/projects/app/main.py
    cat >/home/user/projects/app/main.py <<'EOF'
# Sample app
def login():
    # TODO: improve security
    password = "12345"
EOF

    # /home/user/projects/app/utils.py
    cat >/home/user/projects/app/utils.py <<'EOF'
# utility
secret_key = "abcde"
def helper():
    pass
EOF

    # Ensure the agent (non-root at runtime) can create new directories/files
    chmod -R a+rwX /home/user

%environment
    chmod 755 /home/user

    # Keep the default HOME; no override required
    export PYTHONUNBUFFERED=1

%labels
    Author task-setup
    Description "Environment for quick security-keyword sweep task"