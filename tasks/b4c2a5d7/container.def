Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update and install Python + pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 python3-pip \
        ca-certificates \
        grep coreutils
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the grading framework
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare the initial filesystem state expected by the grading tests
    # ------------------------------------------------------------------

    # Create required directories
    mkdir -p /home/user/reports/policy

    # Populate the initial vulnerability report
    cat > /home/user/reports/vuln_report.csv <<'EOF'
CVE_ID,SEVERITY,DESCRIPTION,AFFECTED_PACKAGE
CVE-2023-1111,MEDIUM,OpenSSL minor issue,openssl
CVE-2023-2222,CRITICAL,Kernel privilege escalation,linux-kernel
CVE-2023-3333,LOW,Typo in man page,man-db
CVE-2023-4444,CRITICAL,Remote code execution,libssh
CVE-2023-5555,HIGH,Potential DoS in zlib,zlib
EOF

    # Ensure write permissions for the non-root runtime user
    chmod -R 0777 /home/user

%environment
    chmod 755 /home/user

    # Make sure python3 is the default python
    export PYTHONIOENCODING=UTF-8
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH