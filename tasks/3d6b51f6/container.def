Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install Python 3, pip, and pytest
    apt-get update
    apt-get install -y python3 python3-pip
    pip3 install --no-cache-dir pytest

    # Create the user workspace and sample file
    mkdir -p /home/user
    chmod 0777 /home/user

    # Create the required sample_images.txt with exact content
    # (no trailing newline after the second line)
    printf 'raw_image_01.jpg\nraw_image_02.jpg' > /home/user/sample_images.txt
    chmod 0666 /home/user/sample_images.txt

%environment
    chmod 755 /home/user

    # Ensure Python and pip are on PATH
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author "Auto-generated for workflow setup task"

%runscript
    echo "Container for workflow setup task. Use as base runtime image."