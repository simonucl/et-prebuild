Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install required packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        curl \
        python3-pip

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # -----------------------------------------------------------------
    # Prepare the initial filesystem state for the task
    # -----------------------------------------------------------------
    mkdir -p /home/user

    cat >/home/user/mock_api_response.json <<'EOF'
{
  "original_query": "SELECT * FROM employees",
  "optimized_query": "SELECT id, name, department FROM employees",
  "cost_reduction_percent": 37
}
EOF

    # Permissions: allow any runtime user to create the log file
    chmod 644 /home/user/mock_api_response.json
    chmod 777 /home/user

%environment
    chmod 755 /home/user

    export PATH="$PATH:/home/user/.local/bin"

%labels
    Author task-prep
    Description "Container for curl file-copy smoke-test task"