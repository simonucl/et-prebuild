Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update apt and install Python & build essentials
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        gnupg \
        coreutils \
        gawk \
        sed
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state required by the exercise
    # ------------------------------------------------------------------
    # 1. Create the directory structure
    mkdir -p /home/user/logs

    # 2. Create the raw telemetry file with exact, byte-perfect content
    cat >/home/user/logs/resource_usage_2023-08-04.log <<'EOF'
2023-08-04 00:00:00 CPU=17% MEM=2048MB NET_IN=120kB/s NET_OUT=80kB/s
2023-08-04 06:00:00 CPU=65% MEM=4096MB NET_IN=512kB/s NET_OUT=340kB/s
2023-08-04 12:00:00 CPU=89% MEM=8192MB NET_IN=1024kB/s NET_OUT=840kB/s
2023-08-04 18:00:00 CPU=4% MEM=1024MB NET_IN=12kB/s NET_OUT=8kB/s
2023-08-04 23:59:59 CPU=52% MEM=6144MB NET_IN=256kB/s NET_OUT=210kB/s
EOF

    # Ensure correct permissions (readable by all, writable by user)
    chmod 644 /home/user/logs/resource_usage_2023-08-04.log

    # 3. Create placeholder parent directory for future output (empty for now)
    mkdir -p /home/user/output
    chmod 755 /home/user/output

    # Clean up apt cache to reduce image size
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

# No runscript is required; the learner will execute commands interactively