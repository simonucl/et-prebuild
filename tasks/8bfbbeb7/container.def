Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    ########################################
    # Basic tooling and Python + pytest
    ########################################
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        python3 \
        python3-pip \
        --no-install-recommends
    pip3 install --no-cache-dir pytest

    # Make sure the command `python` exists
    ln -sf /usr/bin/python3 /usr/local/bin/python

    ########################################
    # Create initial filesystem state
    ########################################
    # Home directory for the (runtime) user
    mkdir -p /home/user
    chmod 0777 /home/user   # allow the unprivileged runtime user to create files

    # ETL data directories
    mkdir -p /home/user/etl_data/raw
    mkdir -p /home/user/etl_data/processed
    mkdir -p /home/user/etl_data/temp

    chmod 0755 /home/user/etl_data
    chmod 0755 /home/user/etl_data/raw
    chmod 0755 /home/user/etl_data/processed
    chmod 0755 /home/user/etl_data/temp

    # Create files with exact byte sizes
    truncate -s 1024 /home/user/etl_data/raw/raw_1.csv
    truncate -s 2048 /home/user/etl_data/raw/raw_2.csv
    truncate -s 4096 /home/user/etl_data/processed/processed_2023-01.parquet
    truncate -s 512  /home/user/etl_data/temp/temp_abc.tmp

    # Set file permissions (world-readable)
    chmod 0644 /home/user/etl_data/raw/raw_1.csv
    chmod 0644 /home/user/etl_data/raw/raw_2.csv
    chmod 0644 /home/user/etl_data/processed/processed_2023-01.parquet
    chmod 0644 /home/user/etl_data/temp/temp_abc.tmp

%environment
    chmod 755 /home/user

    # Ensure standard binary locations are in PATH
    export PATH=/usr/local/bin:/usr/local/sbin:/usr/bin:/usr/sbin:/bin:/sbin

%labels
    Author "Generated by AI assistant"
    Description "Apptainer image for ETL disk-usage exercise with predefined data and pytest installed."

%help
    This container sets up the initial state for the ETL disk-usage task.
    It installs Python 3, pytest, and creates /home/user/etl_data with the
    required files and exact byte sizes so that automated grading can begin.