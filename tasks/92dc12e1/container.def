Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Minimal Python tooling for the task and tests
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # Prepare a writable home for the non-root agent without creating the task artefacts
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up apt caches to keep the image lean
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure standard binary locations are in PATH
    export PATH=/usr/local/bin:/usr/local/sbin:/usr/sbin:/usr/bin:/sbin:/bin

%labels
    Author="Apptainer Task Builder"
    Description="Container for the dotenv workspace cleanup task with pytest pre-installed."