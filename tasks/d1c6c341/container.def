Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "Updating APT package index and installing prerequisites..."
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        python3 \
        python3-pip \
        python3-venv \
        --no-install-recommends

    echo "Cleaning up APT caches..."
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    echo "Installing pytest for runtime use..."
    pip3 install --no-cache-dir pytest

    echo "Ensuring /home/user exists and is writable..."
    mkdir -p /home/user
    chmod 0777 /home/user

%environment
    chmod 755 /home/user

    # Keep the standard PATH; nothing else needs to be set here.
    export PATH=/usr/local/bin:/usr/bin:/bin

%labels
    Author Automation-Workflow Setup
    Description Base image prepared for workflow-automation task (Python3, venv support, pytest pre-installed)

%help
    This container provides:
      • Python 3 with the stdlib "venv" module
      • pytest (installed system-wide)
      • A writable /home/user directory (permissions 0777)
    Students can create virtual environments and other artefacts under /home/user without requiring root privileges.