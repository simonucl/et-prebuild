Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
Author YourName
Description Container image for "disk space summary" task – prepares /home layout and installs pytest.

%post
    set -e

    # Update package lists and install Python + pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-setuptools \
        python3-wheel \
        ca-certificates \
        gnupg \
        curl

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create the required users, groups and directory structure
    # ------------------------------------------------------------------
    # Add primary group and user with UID/GID 1000 so tests referring to
    # the “user” account work even inside the container.
    groupadd -g 1000 user
    useradd  -u 1000 -g 1000 -s /bin/bash -m -d /home/user user

    # Ensure /home/user exists and has correct ownership
    mkdir -p /home/user
    chown -R 1000:1000 /home/user
    chmod 755 /home/user

    # Create at least one additional directory under /home so the test
    # suite has more than just /home/user to inspect.
    mkdir -p /home/guest
    chmod 755 /home/guest
    # Populate /home/guest with some sample data to give it a non-trivial size.
    dd if=/dev/urandom of=/home/guest/random.bin bs=1M count=5
    chown -R 0:0 /home/guest   # owned by root but world-readable

    # Make sure no pre-created report file exists.
    rm -f /home/user/disk_space_summary.txt

    # Clean up apt caches to keep image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    # Preserve default PATH and locale settings
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    echo "Container for disk-space summary task. Use it as a base image; no default action."