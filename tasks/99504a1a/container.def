Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package index and install Python + pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install pytest for the grading framework
    pip3 install --no-cache-dir pytest

    # Create the required home directory for the learner
    mkdir -p /home/user
    chmod 755 /home/user

    # Clean up to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    # Ensure Python and common binary paths are available
    export PATH=/usr/local/bin:/usr/bin:/bin

%labels
    Author="Apptainer QA Exercise"
    Description="Base image for the QA firewall task – includes Python, pip, and pytest."