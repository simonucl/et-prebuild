Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Basic tooling
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        && apt-get clean && rm -rf /var/lib/apt/lists/*

    # Install pytest for the checker
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state expected by the task/test suite
    # ------------------------------------------------------------------

    # Ensure /home/user exists
    mkdir -p /home/user
    chmod 755 /home/user

    # Create logs directory with required permissions
    mkdir -p /home/user/logs
    chmod 755 /home/user/logs

    # Create restore.log with the exact required content
    cat > /home/user/logs/restore.log <<'EOF'
2023-09-10 12:45:27 | INFO  | Restore started for backup set ID=BK20230910A
2023-09-10 12:46:00 | WARN  | Missing incremental file inc-20230909-02.delta
2023-09-10 12:46:05 | INFO  | Attempting partial restore
2023-09-10 12:47:10 | ERROR | Restore failed with code ERR42
2023-09-10 12:47:45 | INFO  | Clean-up finished
2023-09-11 08:10:32 | INFO  | Restore started for backup set ID=BK20230911A
2023-09-11 08:10:55 | WARN  | File changed during restore: /var/lib/data/app.db
2023-09-11 08:12:23 | ERROR | Restore aborted due to checksum mismatch
2023-09-11 08:13:00 | INFO  | Sending failure report email
EOF

    # Set correct permissions on the log file
    chmod 644 /home/user/logs/restore.log

%environment
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    echo "Container for 'restore log alert view' task. Open a shell to work on the exercise."
    exec "$@"