Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # Update package index and install required packages
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        libnss-systemd \
        ca-certificates

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # Create the homework directory with wide-open permissions so the
    # unprivileged learner can create the report file.
    mkdir -p /home/user
    chmod 0777 /home/user

    # Ensure the local hostname always resolves via NSS “myhostname”
    if ! grep -qE 'hosts:.*myhostname' /etc/nsswitch.conf; then
        sed -i 's/^\(hosts:.*\)/\1 myhostname/' /etc/nsswitch.conf
    fi

    # Clean up APT caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure the PATH includes where pip puts executables
    export PATH=/usr/local/bin:/usr/bin:/bin

%runscript
    echo "Container for DNS report task. Use 'apptainer exec ...' to run commands inside."