Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Maintainer task-prep
    Description "Initial filesystem and tooling for syslog log-filter exercise"

%post
    set -eux

    # Refresh apt and install Python tooling
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates

    # Install pytest so the grader can run its suites
    pip3 install --no-cache-dir --upgrade pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create the required directory structure and seed sample log file
    # ------------------------------------------------------------------
    HOME_DIR="/home/user"
    LOG_DIR="${HOME_DIR}/logs"

    # Create home directory if it does not yet exist
    mkdir -p "${LOG_DIR}"

    # Ensure write permissions for the unprivileged runtime user
    chmod 0777 "${LOG_DIR}"

    # Populate syslog_sample.log with the exact fixture lines
    cat > "${LOG_DIR}/syslog_sample.log" <<'EOF'
2023-08-25 10:02:15 server1 sshd[1234]: INFO User root logged in
2023-08-25 10:03:10 server1 sshd[1234]: WARN Failed password attempt for user dev
2023-08-25 10:05:42 server1 app[5678]: ERROR Could not connect to database [code=DBCONN01]
2023-08-25 10:06:00 server1 kernel: INFO CPU temperature normal
2023-08-25 10:07:18 server1 app[5678]: ERROR Timeout while reading socket [code=SOCKTIME02]
2023-08-25 10:08:22 server1 app[5678]: WARN Deprecated API usage detected
2023-08-25 10:09:30 server1 backup[9012]: INFO Backup completed successfully
EOF

    # Set correct permissions: readable by everyone, but unwritable by others
    chmod 0644 "${LOG_DIR}/syslog_sample.log"

    # Make sure no artefact files exist yet
    rm -f "${LOG_DIR}/filtered_syslog.log" "${LOG_DIR}/summary.log" || true

%environment
    chmod 755 /home/user

    # Ensure Python user base binaries (if any) are on PATH
    export PATH="${HOME}/.local/bin:${PATH}"

%runscript
    echo "Container for syslog filtering exercise. Execute your commands inside an interactive shell."
    exec /bin/bash

%help
    This Apptainer image sets up the initial state required for the
    "syslog filter and summary" shell-task exercise.  The file
    /home/user/logs/syslog_sample.log is provided, and the student is
    expected to create filtered_syslog.log and summary.log inside the same
    directory using standard shell utilities. Pytest is installed so that
    the automated grader can run its tests.