Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author timezone_debug_setup
    Description "Base image for the timezone_debug exercise – contains Python, pytest and a writable /home/user."

%post
    set -e

    # Update apt cache and install required packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        python3 \
        python3-pip \
        locales \
        tzdata \
        ca-certificates

    # Ensure UTF-8 locale is generated (needed by many tools)
    sed -i 's/^# *\(en_US.UTF-8 UTF-8\)/\1/' /etc/locale.gen
    locale-gen

    # Install pytest for the grading suite
    pip3 install --no-cache-dir pytest

    # Prepare a writable home directory expected by the tests
    mkdir -p /home/user
    chmod 0777 /home/user   # allow the unprivileged runtime user to write here

    # Clean up apt caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Keep HOME untouched (Apptainer will bind the host home), but
    # ensure tools default to a UTF-8 locale inside the container.
    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8

%runscript
    echo "Container for the timezone_debug exercise.  Use 'apptainer exec' or 'apptainer shell' to work inside."