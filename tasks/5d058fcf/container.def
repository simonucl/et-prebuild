Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "Updating package lists and installing required system packages..."
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        sqlite3 \
        python3 \
        python3-pip

    echo "Installing pytest via pip..."
    pip3 --no-cache-dir install pytest

    echo "Creating the iris SQLite database..."
    mkdir -p /home/user/ml
    chmod 755 /home/user
    chmod 755 /home/user/ml

    cat <<'SQL' | sqlite3 /home/user/ml/iris.db
    PRAGMA journal_mode=WAL;
    CREATE TABLE iris (
        sepal_length REAL,
        sepal_width  REAL,
        petal_length REAL,
        petal_width  REAL,
        species      TEXT
    );

    INSERT INTO iris VALUES (5.0, 3.4, 1.5, 0.1, 'setosa');
    INSERT INTO iris VALUES (5.1, 3.5, 1.4, 0.2, 'setosa');
    INSERT INTO iris VALUES (4.9, 3.0, 1.4, 0.2, 'setosa');
    INSERT INTO iris VALUES (6.0, 2.2, 5.0, 1.5, 'versicolor');
    INSERT INTO iris VALUES (6.3, 2.9, 5.6, 1.8, 'virginica');
    SQL

    chmod 644 /home/user/ml/iris.db

    echo "Cleaning up apt caches..."
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    # Ensure Python user base binary directory is in PATH (for pip-installed tools)
    export PATH="$HOME/.local/bin:$PATH"

%runscript
    echo "Container for Iris minimum-petal-width exercise."
    echo "Use the sqlite3 CLI to query /home/user/ml/iris.db as described in the assignment."