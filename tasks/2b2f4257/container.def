Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Update package lists and install required system packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        iputils-ping \
        ca-certificates

    # Install pytest for the grader/agent
    pip3 install --no-cache-dir pytest

    # Ensure the required home directory exists and is write-able
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up apt caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Basic, predictable PATH and locale
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export LC_ALL=C
    export LANG=C

%labels
    Author="Generated by OpenAI – FinOps Loopback Latency Task"
    Description="Base image with ping, Python, and pytest installed; prepared for loopback latency assignment."

%help
    This container image provides:
      • iputils-ping for network diagnostics
      • Python 3 and pytest for automated grading
      • A writable /home/user directory required by the assignment