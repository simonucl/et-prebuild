# Help: This container provides ping, Python 3, pytest, and a writable /home/user directory

FROM ubuntu:22.04

# Post section
RUN set -eux && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        iputils-ping \
        ca-certificates && \
    pip3 install --no-cache-dir pytest && \
    mkdir -p /home/user && \
    chmod 0777 /home/user && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Environment section
ENV PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
ENV LC_ALL=C
ENV LANG=C

# Labels
LABEL Author="Generated by OpenAI – FinOps Loopback Latency Task"
LABEL Description="Base image with ping, Python, and pytest installed; prepared for loopback latency assignment."