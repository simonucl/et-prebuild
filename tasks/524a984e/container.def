Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update && \
        apt-get install -y --no-install-recommends python3 python3-pip ca-certificates && \
        rm -rf /var/lib/apt/lists/*

    pip3 install --no-cache-dir pytest

    # -----------------------------------------------------------------
    # Create the experiment directory tree and populate artefact files
    # -----------------------------------------------------------------
    mkdir -p /home/user/experiments/exp_alpha
    mkdir -p /home/user/experiments/exp_beta
    mkdir -p /home/user/experiments/exp_gamma

    # -------- exp_alpha --------
    cat > /home/user/experiments/exp_alpha/metrics.csv <<'EOF'
epoch,accuracy,loss
1,0.8071,0.6722
2,0.8983,0.3399
3,0.9234,0.1123
EOF

    cat > /home/user/experiments/exp_alpha/config.yaml <<'EOF'
model: resnet18
learning_rate: 0.001
epochs: 3
EOF

    # -------- exp_beta --------
    cat > /home/user/experiments/exp_beta/metrics.csv <<'EOF'
epoch,accuracy,loss
1,0.7550,0.7109
2,0.8662,0.4012
3,0.9111,0.1278
EOF

    cat > /home/user/experiments/exp_beta/config.yaml <<'EOF'
model: mobilenetv2
optimizer: adam
learning_rate: 0.0005
epochs: 3
EOF

    # -------- exp_gamma --------
    cat > /home/user/experiments/exp_gamma/metrics.csv <<'EOF'
epoch,accuracy,loss
1,0.8744,0.5080
2,0.9327,0.2414
3,0.9570,0.0931
EOF

    cat > /home/user/experiments/exp_gamma/config.yaml <<'EOF'
model: efficientnet_b0
epochs: 3
learning_rate: 0.002
EOF

    # Ensure world-readable permissions so the non-root runtime user can access them
    chmod -R a+rX /home/user

%environment
    chmod 755 /home/user

    export PYTHONUNBUFFERED=1