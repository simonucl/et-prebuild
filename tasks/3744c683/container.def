Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends python3 python3-pip
    pip install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Set up initial workspace expected by the tests
    # ------------------------------------------------------------------
    mkdir -p /home/user/research_datasets/climate_data
    mkdir -p /home/user/research_datasets/ocean_salinity
    mkdir -p /home/user/research_datasets/star_catalog

    # Data placeholder files ---------------------------------------------------
    touch /home/user/research_datasets/climate_data/data.csv
    touch /home/user/research_datasets/ocean_salinity/salinity.csv
    touch /home/user/research_datasets/star_catalog/stars.parquet

    # meta.json files ----------------------------------------------------------
    cat > /home/user/research_datasets/climate_data/meta.json <<'EOF'
{
  "description": "Daily world surface temperature readings.",
  "rows": 36500,
  "columns": 8
}
EOF

    cat > /home/user/research_datasets/ocean_salinity/meta.json <<'EOF'
{
  "description": "Global ocean surface salinity measurements.",
  "rows": 54000,
  "columns": 6
}
EOF

    cat > /home/user/research_datasets/star_catalog/meta.json <<'EOF'
{
  "description": "Stellar positions and magnitudes from deep-sky survey.",
  "rows": 112000,
  "columns": 12
}
EOF

    # Ensure everything under /home/user is world-readable/executable so the
    # non-root runtime user can access it.
    chmod -R a+rX /home/user

%environment
    chmod 755 /home/user

    # Make sure Python is on PATH
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%runscript
    # Default action: drop into a shell
    exec bash "$@"