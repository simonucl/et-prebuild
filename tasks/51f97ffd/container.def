Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author      ExampleAuthor
    Description Initial filesystem and tooling for “Bring MegaCRM back online” exercise.

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # --- Install Python and pytest -------------------------------------------------
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # --- Create initial directory structure ---------------------------------------
    mkdir -p /home/user/app/config
    mkdir -p /home/user/app/certs
    # NOTE: The logs directory is intentionally *not* created; its presence is
    # optional for the initial-state tests.

    # --- Seed legacy configuration files ------------------------------------------
    cat > /home/user/app/config/settings.yml <<'EOF'
app:
  name: MegaCRM
  version: "2.3.0"
maintenance_mode: false
limits:
  max_users: 500
  max_connections: 80
EOF

    cat > /home/user/app/config/database.toml <<'EOF'
[database]
engine = "postgresql"
host = "localhost"
port = 5432
name = "megacrm"
user = "legacy_user"
password = "changeme"
EOF

    # --- Stub certificate file required by tests ----------------------------------
    touch /home/user/app/certs/db-client.pem

    # --- Relax permissions so non-root users can modify everything ----------------
    chmod -R a+rwx /home/user

%environment
    chmod 755 /home/user

    # Do not override $HOME; only ensure custom binaries remain in PATH.
    export PATH=$PATH:/usr/local/bin

%runscript
    # Default action: launch an interactive shell.
    exec /bin/bash "$@"