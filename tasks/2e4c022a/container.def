Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    apt-get update
    # Install jq for JSON processing and Python tooling for pytest
    apt-get install -y --no-install-recommends \
        jq \
        python3-pip

    # Clean up apt cache to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the validation tests
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state for the exercise
    # ------------------------------------------------------------------
    # Create the required directory structure
    mkdir -p /home/user/backups
    chmod 755 /home/user
    chmod 755 /home/user/backups

    # Create the initial metadata.json file with exact contents
    cat > /home/user/backups/metadata.json <<'EOF'
[
  {"id":"bkp-001","timestamp":"2023-10-01T02:00:00Z","size":2048,"status":"completed"},
  {"id":"bkp-002","timestamp":"2023-10-02T02:00:00Z","status":"failed"},
  {"id":"bkp-003","timestamp":"2023-10-03T02:00:00Z","size":4096,"status":"completed"},
  {"id":"bkp-004","timestamp":"2023-10-04T02:00:00Z","size":1024}
]
EOF
    chmod 644 /home/user/backups/metadata.json

    # Ensure that the output files the learner must create do NOT exist
    rm -f /home/user/backups/validation_report.json
    rm -f /home/user/backup_validation.log

%environment
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%labels
    Author          "Generated by AI"
    Description     "Container for backup validation exercise. Provides initial JSON data and tooling (jq, pytest)."

%help
    This container sets up the initial environment for the backup-validation
    exercise. It includes:
      • /home/user/backups/metadata.json (the input data)
      • Tools: jq, pytest

    The learner must create:
      • /home/user/backups/validation_report.json
      • /home/user/backup_validation.log