# Converted from Apptainer definition file
FROM ubuntu:22.04

# Help text
# This container sets up the initial environment for the backup-validation exercise.
# It includes:
#   • /home/user/backups/metadata.json (the input data)
#   • Tools: jq, pytest
# The learner must create:
#   • /home/user/backups/validation_report.json
#   • /home/user/backup_validation.log

ENV LC_ALL=C.UTF-8
ENV LANG=C.UTF-8

RUN set -e && \
    apt-get update && \
    apt-get install -y --no-install-recommends \
        jq \
        python3-pip && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

RUN pip3 install --no-cache-dir pytest

RUN mkdir -p /home/user/backups && \
    chmod 755 /home/user && \
    chmod 755 /home/user/backups

RUN cat > /home/user/backups/metadata.json << 'EOF'
[
  {"id":"bkp-001","timestamp":"2023-10-01T02:00:00Z","size":2048,"status":"completed"},
  {"id":"bkp-002","timestamp":"2023-10-02T02:00:00Z","status":"failed"},
  {"id":"bkp-003","timestamp":"2023-10-03T02:00:00Z","size":4096,"status":"completed"},
  {"id":"bkp-004","timestamp":"2023-10-04T02:00:00Z","size":1024}
]
EOF

RUN chmod 644 /home/user/backups/metadata.json

RUN rm -f /home/user/backups/validation_report.json && \
    rm -f /home/user/backup_validation.log

LABEL Author="Generated by AI"
LABEL Description="Container for backup validation exercise. Provides initial JSON data and tooling (jq, pytest)."