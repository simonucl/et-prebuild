Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    ############################################################
    # 1. Install system packages and pytest
    ############################################################
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    python3 -m pip install --no-cache-dir --upgrade pip
    python3 -m pip install --no-cache-dir pytest

    ############################################################
    # 2. Create initial filesystem expected by the tests
    ############################################################
    # Create user home directory tree
    mkdir -p /home/user/db
    mkdir -p /home/user/logs

    # Ensure directory permissions are exactly 0755
    chmod 0755 /home/user
    chmod 0755 /home/user/db
    chmod 0755 /home/user/logs

    # Create the initial PostgreSQL configuration file
    cat >/home/user/db/postgresql.conf <<'EOF'
# PostgreSQL configuration file
# Memory settings
work_mem = 4MB
# End
EOF

    # Set correct permissions for the configuration file
    chmod 0644 /home/user/db/postgresql.conf

%environment
    chmod 755 /home/user

    # Make sure /home/user is in PATH for any helper scripts (if added later)
    export PATH="$PATH:/home/user"

%runscript
    exec /bin/bash "$@"

%test
    # Basic sanity check that pytest is importable (not the full task tests)
    python3 - <<'PY'
import pytest, sys
print("pytest version:", pytest.__version__)
PY