Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Update package lists and install required system packages
    apt-get update
    # iproute2 supplies `ip`, iputils-ping supplies `ping`. `libc-bin`
    # (for `getent`) is already present in the base image but we include it
    # explicitly for clarity. `python3` and `pip` are needed for pytest.
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        iproute2 \
        iputils-ping \
        libc-bin

    # Clean up apt caches to keep image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Upgrade pip and install pytest for the grading framework
    pip3 install --no-cache-dir --upgrade pip pytest

    # Ensure a writable home directory for the non-root user that will run
    # inside the container.  Do NOT create any task-specific paths here.
    mkdir -p /home/user
    chmod 0777 /home/user

%environment
    chmod 755 /home/user

    # Ensure Python and standard locations are on PATH
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"
    export PYTHONUNBUFFERED="1"

%help
    Base image for the “Nightly Build Network Diagnostic” task.
    - Contains python3 and pytest for automated grading.
    - Provides standard networking tools: hostname, uname, ip, ping, getent.
    - Leaves /home/user/build_net_diag/ **absent** so the learner starts from a
      clean slate.