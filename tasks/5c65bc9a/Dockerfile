# syntax=docker/dockerfile:1
FROM ubuntu:22.04

# ------------------------------------------------------------------
# %post section
# ------------------------------------------------------------------
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked --mount=type=cache,target=/var/lib/apt,sharing=locked --mount=type=cache,target=/root/.cache/pip set -eux && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3-pip \
        python3-setuptools \
        dnsutils \
        ca-certificates && \
    pip3 install --no-cache-dir pytest && \
    if ! getent group 1000 >/dev/null; then \
        groupadd -g 1000 user; \
    fi && \
    if ! id -u 1000 >/dev/null 2>&1; then \
        useradd -m -u 1000 -g 1000 -s /bin/bash user; \
    fi && \
    mkdir -p /home/user && \
    chown 1000:1000 /home/user && \
    chmod 0755 /home/user

RUN cat >/home/user/custom_hosts <<'EOF'
10.20.1.15 db.internal.example.com
10.20.1.20 api.internal.example.com
EOF

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked --mount=type=cache,target=/var/lib/apt,sharing=locked chown 1000:1000 /home/user/custom_hosts && \
    chmod 0644 /home/user/custom_hosts && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# ------------------------------------------------------------------
# %environment section
# ------------------------------------------------------------------
ENV PATH=/usr/local/bin:/usr/local/sbin:/usr/bin:/usr/sbin:/bin:/sbin

# ------------------------------------------------------------------
# %labels section
# ------------------------------------------------------------------
LABEL Author="Generated by ChatGPT - Apptainer setup for DNS triage task"

# ------------------------------------------------------------------
# %help section
# ------------------------------------------------------------------
# This container provides the starting environment for the
# "DNS & Hostname Resolution Triage for an Internal Outage" exercise.
# The user 'user' (uid 1000) has a custom hosts file at
# /home/user/custom_hosts pre-populated with two host mappings.
# Pytest is installed so the grading harness can validate the initial state.