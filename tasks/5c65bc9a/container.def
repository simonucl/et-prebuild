Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Update package lists and install required OS packages
    apt-get update
    # Python tooling for pytest, and dnsutils for `dig`
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3-pip \
        python3-setuptools \
        dnsutils \
        ca-certificates

    # Install pytest for the grading harness
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create an unprivileged user `user` with home directory /home/user
    # UID/GID 1000 is conventional but not strictly required; adjust if
    # already taken in the base image.
    # ------------------------------------------------------------------
    if ! getent group 1000 >/dev/null; then
        groupadd -g 1000 user
    fi
    if ! id -u 1000 >/dev/null 2>&1; then
        useradd -m -u 1000 -g 1000 -s /bin/bash user
    fi

    # Ensure home directory exists with correct permissions
    mkdir -p /home/user
    chown 1000:1000 /home/user
    chmod 0755 /home/user

    # ------------------------------------------------------------------
    # Prepare the initial state file for the exercise
    # (/home/user/custom_hosts with the two given mappings)
    # ------------------------------------------------------------------
    cat >/home/user/custom_hosts <<'EOF'
10.20.1.15 db.internal.example.com
10.20.1.20 api.internal.example.com
EOF

    # Set ownership and mode
    chown 1000:1000 /home/user/custom_hosts
    chmod 0644 /home/user/custom_hosts

    # Clean up apt caches to keep image size small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure Python and user-installed binaries are on PATH
    export PATH=/usr/local/bin:/usr/local/sbin:/usr/bin:/usr/sbin:/bin:/sbin

%labels
    Author "Generated by ChatGPT - Apptainer setup for DNS triage task"

%help
    This container provides the starting environment for the
    "DNS & Hostname Resolution Triage for an Internal Outage" exercise.
    The user 'user' (uid 1000) has a custom hosts file at
    /home/user/custom_hosts pre-populated with two host mappings.
    Pytest is installed so the grading harness can validate the initial state.