Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package index and install Python/pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install pytest for the grading harness
    pip3 install --no-cache-dir pytest

    # Create a writable home directory for the unprivileged runtime user
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up apt caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
    export PYTHONDONTWRITEBYTECODE=1

%labels
    Author perf_lab_singularity_setup
    Description "Base container for perf_lab exercise – provides Python, pytest, and a writable /home/user directory."