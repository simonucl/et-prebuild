Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Update APT and install Python + pip
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest

    # ---------------------------------------------------------------------
    # Create required directory structure and INI files
    # ---------------------------------------------------------------------
    mkdir -p /home/user/system_configs
    chmod 755 /home/user
    chmod 755 /home/user/system_configs

    # webapp.ini
    cat > /home/user/system_configs/webapp.ini <<'EOF'
[server]
port = 8080
enable_debug = true

[security]
secret_key = abc123
allowed_hosts = localhost,example.com
EOF

    # db.ini
    cat > /home/user/system_configs/db.ini <<'EOF'
[database]
port = 1234
username = appuser
password = S3cur3Pass!

[options]
debug_mode = false
EOF

    # cache.ini
    cat > /home/user/system_configs/cache.ini <<'EOF'
[cache]
port = 6379
enable_debug = false

[auth]
secret_key = veryverysecuresecret
EOF

    chmod 644 /home/user/system_configs/*.ini

    # Ensure the incident_logs directory does NOT exist initially
    rm -rf /home/user/incident_logs

%environment
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH