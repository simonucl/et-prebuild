Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author auditbot-prep
    Description "Base image for 2023-Q4 Network Diagnostics exercise. Installs tooling and pytest; intentionally leaves audit directory absent."

%post
    set -e

    # Refresh package lists and install required utilities
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        iputils-ping \
        traceroute \
        iproute2 \
        ca-certificates \
        curl \
        gnupg \
        coreutils

    # Clean up apt caches to keep image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Install pytest via pip (system-wide)
    pip3 install --no-cache-dir pytest

    # Ensure a writable home directory for the non-root runtime user
    mkdir -p /home/user
    chmod 0755 /home/user

%environment
    chmod 755 /home/user

    # Make sure Python user installs go to /usr/local (already in PATH) and
    # stdout/stderr are unbuffered for consistent audit logs.
    export PYTHONUNBUFFERED=1

%runscript
    echo "Container for the 2023-Q4 Network Diagnostics exercise."
    echo "Invoke an interactive shell to begin:  apptainer exec <image.sif> /bin/bash"