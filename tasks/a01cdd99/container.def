Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "Installing Python and pytest..."
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    echo "Preparing staged packages directory..."
    # Create the expected directory hierarchy
    mkdir -p /home/user/preloaded_packages

    # Make /home/user writable for the non-root user that will execute the tasks
    chmod 0777 /home/user

    # Create the two empty, pre-staged package files
    touch /home/user/preloaded_packages/sensor_utils-1.2.3.tar.gz
    touch /home/user/preloaded_packages/edge_comm-0.9.8.tar.gz
    chmod 0644 /home/user/preloaded_packages/*.tar.gz

%environment
    chmod 755 /home/user

    # Keep environment minimal; HOME will be provided by Apptainer runtime
    export PYTHONUNBUFFERED=1

%runscript
    echo "IoT deployment exercise container. Happy hacking!"