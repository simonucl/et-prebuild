Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    ## 1. Install required packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        curl \
        python3-pip \
        ca-certificates
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    ## 2. Install pytest for the test harness
    pip3 install --no-cache-dir pytest

    ## 3. Create the non-root user expected by the exercise
    if ! id -u user >/dev/null 2>&1; then
        useradd -m -s /bin/bash user
    fi

    ## 4. Prepare the metrics fixture directory and file
    METRICS_DIR="/home/user/observability/metrics"
    mkdir -p "${METRICS_DIR}"

    cat <<'EOF' > "${METRICS_DIR}/exporter_stats.txt"
up 1
scrape_duration_seconds 0.005
scrape_samples_post_metric_relabeling 15
EOF

    ## 5. Ensure correct ownership and permissions
    chown -R user:user /home/user
    chmod 755 /home/user
    chmod -R 755 /home/user/observability
    chmod 644 "${METRICS_DIR}/exporter_stats.txt"

%labels
    Author      observability-task-generator
    Description Container for Prometheus curl metrics validation kata

%environment
    # No special environment variables needed; keep defaults.