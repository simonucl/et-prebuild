Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update APT index and install Python plus pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates

    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Set up the initial filesystem state expected by the exercise tests
    # ------------------------------------------------------------------
    LOG_DIR="/home/user/projects/logs"
    mkdir -p "${LOG_DIR}"

    # Create the raw_events.log file with the exact required content
    cat > "${LOG_DIR}/raw_events.log" << 'EOF'
EVENT|2023-09-01T10:12:45Z|alice|LOGIN_SUCCESS
EVENT|2023-09-01T10:15:01Z|bob|LOGIN_FAILURE
EVENT|2023-09-01T10:17:22Z|alice|FILE_UPLOAD
EVENT|2023-09-01T10:20:55Z|carol|LOGIN_SUCCESS
EVENT|2023-09-01T10:25:30Z|bob|LOGIN_SUCCESS
EVENT|2023-09-01T10:30:05Z|alice|LOGIN_SUCCESS
EVENT|2023-09-01T10:35:47Z|dave|FILE_DELETE
EVENT|2023-09-01T10:40:18Z|carol|LOGIN_FAILURE
EVENT|2023-09-01T10:45:00Z|bob|LOGIN_SUCCESS
EVENT|2023-09-01T10:50:10Z|alice|LOGIN_FAILURE
EOF

    # Ensure permissive permissions so the non-root runtime user can write
    chmod 0777 "${LOG_DIR}"
    chmod 0666 "${LOG_DIR}/raw_events.log"

    # The two CSV files must NOT exist at build time; ensure they are absent
    rm -f "${LOG_DIR}/login_success_events.csv" \
          "${LOG_DIR}/login_success_counts.csv"

%environment
    chmod 755 /home/user

    # Make sure python and pip are on PATH for convenience
    export PATH="/usr/bin:$PATH"
    export PYTHONIOENCODING=UTF-8
    export LC_ALL=C.UTF-8

%labels
    Author automation-workflow-specialist
    Description "Environment for log-processing command-line exercise with pytest pre-installed."

%help
    This Apptainer image provides the starting filesystem layout and tools
    needed for the 'log to CSV' exercise. Pytest is installed for the test
    harness, and the raw log file is populated under /home/user/projects/logs/.