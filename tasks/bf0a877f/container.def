Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Update package index and install necessary packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates

    # Install pytest for the grading framework
    pip3 install --no-cache-dir pytest

    # Create a writable home directory for the unprivileged user
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up APT caches to reduce image size
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure standard paths and Python behaviour
    export PYTHONUNBUFFERED=1
    export PATH="/usr/local/bin:/usr/bin:/bin:${PATH}"

%labels
    Author QA-Prep-Container
    Description "Apptainer image for process & PID management exercise with pytest pre-installed."