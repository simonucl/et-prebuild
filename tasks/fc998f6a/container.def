Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    export DEBIAN_FRONTEND=noninteractive

    # ------------------------------------------------------------------
    # Install Python and pytest
    # ------------------------------------------------------------------
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create initial filesystem layout for the task
    # ------------------------------------------------------------------
    # Backup directory with real database files
    mkdir -p /home/user/backups/full_2023_10_01/data
    echo "cust_data_v1"  > /home/user/backups/full_2023_10_01/data/customer.db
    echo "order_data_v1" > /home/user/backups/full_2023_10_01/data/orders.db
    echo "inv_data_v1"   > /home/user/backups/full_2023_10_01/data/inventory.db

    # Project directory with one good, one broken, one missing symlink
    mkdir -p /home/user/project/data_link
    cd /home/user/project/data_link

    # Good symlink (already correct)
    ln -s ../../backups/full_2023_10_01/data/customer.db customer.db

    # Broken symlink (points to September backup that does not exist)
    ln -s ../../backups/full_2023_09_01/data/orders.db orders.db

    # inventory.db symlink intentionally absent

    # ------------------------------------------------------------------
    # Permissions: allow the non-root runtime user to modify /home/user/project
    # ------------------------------------------------------------------
    chmod -R a+rwX /home/user/project
    chmod -R a+rX  /home/user/backups

%environment
    chmod 755 /home/user

    # Ensure python is available as `python`
    export PYTHONIOENCODING=UTF-8
    if [ -x /usr/bin/python3 ]; then
        alias python=/usr/bin/python3
    fi

%labels
    Author symlink-task-builder
    Description "Container for symlink integrity task with pytest pre-installed."

%help
    This Apptainer image contains the initial state for the symbolic-link
    repair task. pytest is installed for automated grading.