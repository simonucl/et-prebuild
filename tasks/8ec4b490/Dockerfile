FROM ubuntu:22.04

# Help / description
# Author: Generated by ChatGPT
# Description: Apptainer image for task DNS-0001 (localhost IPv4/IPv6 verification)

ENV PATH="/usr/local/bin:/usr/bin:/bin:${PATH}"

RUN set -e && \
    apt-get update && \
    apt-get install -y --no-install-recommends python3 python3-pip && \
    pip3 install --no-cache-dir pytest

RUN mkdir -p /home/user/network_data

RUN cat >/home/user/network_data/hosts_sample <<'EOF'
127.0.0.1 localhost
::1 localhost ip6-localhost ip6-loopback
EOF

RUN chmod 755 /home/user && \
    chmod 755 /home/user/network_data && \
    chmod 644 /home/user/network_data/hosts_sample

RUN apt-get clean && rm -rf /var/lib/apt/lists/*