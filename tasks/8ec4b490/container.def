Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install Python & pip
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state for the DNS-0001 ticket
    # ------------------------------------------------------------------
    # 1. Create required directories
    mkdir -p /home/user/network_data

    # 2. Populate hosts_sample with the exact required contents
    cat >/home/user/network_data/hosts_sample <<'EOF'
127.0.0.1 localhost
::1 localhost ip6-localhost ip6-loopback
EOF

    # 3. Set permissions so the (non-root) runtime user can read/write
    chmod 755 /home/user
    chmod 755 /home/user/network_data
    chmod 644 /home/user/network_data/hosts_sample

    # Clean up APT caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    # Ensure standard paths are available
    export PATH="/usr/local/bin:/usr/bin:/bin:${PATH}"

%labels
    Author      "Generated by ChatGPT"
    Description "Apptainer image for task DNS-0001 (localhost IPv4/IPv6 verification)"