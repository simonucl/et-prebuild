Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ------------------------------------------------------------------
    # Basic OS packages and Python tooling
    # ------------------------------------------------------------------
    apt-get update -y && \
        DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
            python3-pip \
        && apt-get clean && rm -rf /var/lib/apt/lists/*

    # Install pytest for the grading framework
    pip3 install --no-cache-dir --upgrade pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create initial filesystem state for the assignment
    # ------------------------------------------------------------------
    # Make /home/user and /home/user/logs with liberal permissions so the
    # unprivileged runtime user can create additional files/directories.
    mkdir -p /home/user/logs
    chmod 0777 /home/user
    chmod 0777 /home/user/logs

    # ------------------------------------------------------------------
    # Populate the three log files with exact required contents
    # (each line ends with a single '\n', including the final line).
    # ------------------------------------------------------------------

    cat > /home/user/logs/node1.log <<'EOF'
[2024-04-24 12:00:00] INFO  Starting training epoch 1
[2024-04-24 12:00:01] ERROR Loss became NaN
[2024-04-24 12:00:02] ERROR Gradient explosion detected
[2024-04-24 12:00:03] INFO  Retrying with smaller learning rate
EOF

    cat > /home/user/logs/node2.log <<'EOF'
[2024-04-24 12:00:00] INFO  Starting training epoch 1
[2024-04-24 12:00:05] ERROR Out of memory
[2024-04-24 12:00:06] INFO  Swapped to CPU memory
EOF

    cat > /home/user/logs/node3.log <<'EOF'
[2024-04-24 12:00:00] INFO  Starting training epoch 1
[2024-04-24 12:00:04] ERROR Gradient explosion detected
[2024-04-24 12:00:05] ERROR Gradient explosion detected
[2024-04-24 12:00:06] INFO  Adjusting gradient clipping
EOF

    # Ensure the files are world-readable/writable by the runtime user
    chmod 0666 /home/user/logs/node*.log

%labels
    chmod 755 /home/user

    Author="Generated by ChatGPT"
    Description="Container for log-processing Apptainer task – includes initial log files and pytest."

%help
    This container provides the initial environment for the distributed-training
    log debugging task.  The three log files are pre-seeded in /home/user/logs/,
    and pytest is installed for automated grading.