Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update base image and install required packages
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        jq \
        ca-certificates

    # Install pytest for the evaluation framework
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare filesystem layout and initial artefacts for the IoT task
    # ------------------------------------------------------------------
    mkdir -p /home/user/iot/deployment
    mkdir -p /home/user/iot/logs

    # Create the initial device_status.json file
    cat > /home/user/iot/deployment/device_status.json <<'EOF'
[
  {
    "device_id": "edge-therm-01",
    "status": "online",
    "ip": "192.168.10.21"
  },
  {
    "device_id": "edge-therm-02",
    "status": "offline",
    "ip": "192.168.10.22"
  },
  {
    "device_id": "edge-therm-03",
    "status": "online",
    "ip": "192.168.10.23"
  },
  {
    "device_id": "edge-therm-04",
    "status": "maintenance",
    "ip": "192.168.10.24"
  },
  {
    "device_id": "edge-therm-05",
    "status": "offline",
    "ip": "192.168.10.25"
  }
]
EOF

    # Create a minimal (but valid) Draft-07 JSON Schema file
    cat > /home/user/iot/deployment/device_status_schema.json <<'EOF'
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Device Status Schema",
  "type": "object",
  "properties": {
    "device_id": { "type": "string" },
    "status":     { "type": "string" },
    "ip":         { "type": "string", "format": "ipv4" }
  },
  "required": ["device_id", "status", "ip"],
  "additionalProperties": false
}
EOF

    # Ensure the regular (non-root) user at runtime can write where needed
    chmod -R 777 /home/user/iot

    # Clean up apt caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8