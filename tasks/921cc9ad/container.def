Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Update package lists and install needed utilities
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        curl \
        iproute2 \
        lsof \
        ca-certificates \
        tar
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the test-harness
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial exercise artefacts
    # ------------------------------------------------------------------
    # Create backup directory structure
    mkdir -p /home/user/backup

    # Create the exact HTML file expected in the tarball
    cat > /tmp/index.html <<'EOF'
<html>
<body>
<h1>Backup Restore Successful</h1>
</body>
</html>
EOF

    # Package it into site_backup.tar.gz with path "index.html"
    tar -czf /home/user/backup/site_backup.tar.gz -C /tmp index.html

    # Remove temporary working file
    rm /tmp/index.html

    # Ensure write permissions for the runtime (non-root) user
    # The exercises will need to create additional files/directories here.
    chmod 1777 /home/user
    chmod -R a+rX /home/user/backup
    chmod -R a+rw /home/user/backup

%environment
    chmod 755 /home/user

    # Keep a sane PATH; do NOT modify HOME so that Apptainer binds the host one.
    export PATH=$PATH

%labels
    Author  restore-task-image
    Description "Environment for static website restore exercise with pytest pre-installed."