Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author localization-task-setup
    Description "Initial environment for localisation compilation exercise"

%post
    set -eux

    # ------------------------------------------------------------------ #
    # Basic tooling and Python test dependencies                         #
    # ------------------------------------------------------------------ #
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        python3 \
        python3-pip \
        gettext      # provides msgmerge, msgfmt, etc.

    python3 -m pip install --no-cache-dir pytest

    # ------------------------------------------------------------------ #
    # Create directory skeleton                                           #
    # ------------------------------------------------------------------ #
    install -d -m 755 /home/user
    install -d -m 755 /home/user/localization/source
    install -d -m 755 /home/user/localization/project/po
    # Logs directory must exist and be empty but writable by the runtime user
    install -d -m 777 /home/user/localization/logs

    # ------------------------------------------------------------------ #
    # Populate template POT file                                          #
    # ------------------------------------------------------------------ #
    cat > /home/user/localization/source/messages.pot <<'EOF'
msgid ""
msgstr ""
"Project-Id-Version: Demo 1.1\n"
"Content-Type: text/plain; charset=UTF-8\n"
"Plural-Forms: nplurals=2; plural=(n != 1);\n"

#: hello.c:10
msgid "Hello"
msgstr ""

#: bye.c:11
msgid "Good-bye"
msgstr ""
EOF
    # Fixed mtime for potential downstream checks
    touch -d "@1700000000" /home/user/localization/source/messages.pot
    chmod 644 /home/user/localization/source/messages.pot

    # ------------------------------------------------------------------ #
    # Populate initial PO files                                           #
    # ------------------------------------------------------------------ #
    cat > /home/user/localization/project/po/en.po <<'EOF'
msgid ""
msgstr ""
"Project-Id-Version: Demo 1.0\n"
"Language: en\n"

#: hello.c:10
msgid "Hello"
msgstr "Hello"
EOF

    cat > /home/user/localization/project/po/fr.po <<'EOF'
msgid ""
msgstr ""
"Project-Id-Version: Demo 1.0\n"
"Language: fr\n"

#: hello.c:10
msgid "Hello"
msgstr "Bonjour"
EOF

    cat > /home/user/localization/project/po/es.po <<'EOF'
msgid ""
msgstr ""
"Project-Id-Version: Demo 1.0\n"
"Language: es\n"

#: hello.c:10
msgid "Hello"
msgstr "Hola"
EOF

    # Make PO files world-writable so the non-root runtime user can update them
    chmod 666 /home/user/localization/project/po/*.po

%environment
    chmod 755 /home/user

    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    echo "Apptainer image prepared for localisation task. Execute your build script inside the container."