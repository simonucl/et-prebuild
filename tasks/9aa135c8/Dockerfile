FROM ubuntu:22.04

# Update apt index and install Python tooling
RUN set -e && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        python3 \
        python3-venv \
        python3-pip \
        --no-install-recommends && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Upgrade pip/setuptools/wheel and install pytest
RUN pip3 install --no-cache-dir --upgrade pip setuptools wheel && \
    pip3 install --no-cache-dir pytest

# Create writable home directory
RUN mkdir -p /home/user && \
    chown -R 1000:1000 /home/user || true && \
    chmod 0775 /home/user

# Environment settings
ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8

# Additional environment command from %environment
RUN chmod 755 /home/user

# Labels
LABEL Author="Generated by ChatGPT – Apptainer template for credential rotation task"