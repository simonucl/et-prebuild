Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update apt index and install Python tooling
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        python3 \
        python3-venv \
        python3-pip \
        --no-install-recommends
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Upgrade pip/setuptools/wheel inside the base layer and install pytest
    pip3 install --no-cache-dir --upgrade pip setuptools wheel
    pip3 install --no-cache-dir pytest

    # Create a writable home directory for the non-privileged user that
    # the autograder will run as.  Do NOT create the exercise-specific
    # directories so that initial-state tests pass.
    mkdir -p /home/user
    # Make it group-writable and, if possible, give UID 1000 ownership.
    chown -R 1000:1000 /home/user || true
    chmod 0775 /home/user

%environment
    chmod 755 /home/user

    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8

%labels
    Author "Generated by ChatGPT – Apptainer template for credential rotation task"