Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # Update package lists and install required tools
    apt-get update
    apt-get install -y --no-install-recommends \
        jq \
        python3-pip

    # Clean up apt caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the verification suite
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare the working directory and the machine-generated file
    # ------------------------------------------------------------------
    # Create /home/user with liberal permissions so the non-root runtime
    # user can write the validation log there.
    mkdir -p /home/user
    chmod 0777 /home/user

    # Create the JSON inventory file with the exact required contents.
    cat > /home/user/disk_inventory.json << 'EOF'
[
  {
    "mount": "/",
    "size_gb": 100,
    "used_gb": 60,
    "available_gb": 40,
    "percent_used": 60
  },
  {
    "mount": "/home",
    "size_gb": 500,
    "used_gb": 300,
    "available_gb": 200,
    "percent_used": 60
  },
  {
    "mount": "/var",
    "size_gb": 50,
    "used_gb": 25,
    "available_gb": 25,
    "percent_used": 50
  }
]
EOF
    chmod 0644 /home/user/disk_inventory.json

%environment
    chmod 755 /home/user

    # Nothing special needed; leave HOME untouched so the runtime user
    # retains their host $HOME.

%labels
    Author "Generated by ChatGPT – Apptainer task setup"
    Description "Container for jq one-liner validation task with pytest pre-installed"

%help
    This Apptainer image sets up the initial state for the “jq one-liner”
    disk inventory validation exercise. It provides:
      • /home/user/disk_inventory.json with valid sample data
      • jq and pytest installed
    The runtime (non-root) user will create /home/user/disk_validation.log
    during task execution.