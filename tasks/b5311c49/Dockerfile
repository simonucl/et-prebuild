# syntax=docker/dockerfile:1
# Author: Generated by ChatGPT – Apptainer task setup
# Description: Container for jq one-liner validation task with pytest pre-installed
# Help:
# This image sets up the initial state for the “jq one-liner” disk inventory validation exercise.
# It provides:
#   - /home/user/disk_inventory.json with valid sample data
#   - jq and pytest installed
# The runtime (non-root) user will create /home/user/disk_validation.log during task execution.

FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked --mount=type=cache,target=/var/lib/apt,sharing=locked set -e && \
    apt-get update && \
    apt-get install -y --no-install-recommends \
        jq \
        python3-pip && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

RUN --mount=type=cache,target=/root/.cache/pip pip3 install --no-cache-dir pytest

RUN mkdir -p /home/user && chmod 0777 /home/user

RUN cat > /home/user/disk_inventory.json << 'EOF'
[
  {
    "mount": "/",
    "size_gb": 100,
    "used_gb": 60,
    "available_gb": 40,
    "percent_used": 60
  },
  {
    "mount": "/home",
    "size_gb": 500,
    "used_gb": 300,
    "available_gb": 200,
    "percent_used": 60
  },
  {
    "mount": "/var",
    "size_gb": 50,
    "used_gb": 25,
    "available_gb": 25,
    "percent_used": 50
  }
]
EOF

RUN chmod 0644 /home/user/disk_inventory.json && chmod 755 /home/user