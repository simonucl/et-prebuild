Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial project state expected by the automated tests
    # ------------------------------------------------------------------
    mkdir -p /home/user/project

    # config.yaml (initial state with maintenance set to false)
    cat > /home/user/project/config.yaml <<'EOF'
server:
  host: "0.0.0.0"
  port: 8080
feature_flags:
  maintenance: false
  beta: true
EOF

    # settings.toml (initial state with maintenance set to false)
    cat > /home/user/project/settings.toml <<'EOF'
[database]
host = "localhost"
port = 5432
user = "webapp"
maintenance = false
EOF

    # Ensure the student can modify these files/directories later
    chmod 777 /home/user/project
    chmod 666 /home/user/project/config.yaml /home/user/project/settings.toml

%environment
    chmod 755 /home/user

    # Keep locale sane
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    # Default action is to drop into a shell
    exec "${@:-/bin/bash}"