BootStrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Basic build utilities and Python tooling
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        tar \
        gzip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state for the exercise
    # ------------------------------------------------------------------
    # Required directory tree
    mkdir -p /home/user/backups/daily
    mkdir -p /home/user/archives
    mkdir -p /home/user/backup_logs

    # Create the three SQL dump files with placeholder content
    echo "-- users data dump"    > /home/user/backups/daily/users.sql
    echo "-- orders data dump"   > /home/user/backups/daily/orders.sql
    echo "-- products data dump" > /home/user/backups/daily/products.sql

    # Ensure the student (non-root runtime user) can read/write here
    chmod -R 0777 /home/user

%environment
    chmod 755 /home/user

    # Keep a sane PATH; do not override HOME
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin