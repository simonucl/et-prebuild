Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update apt index and install Python and pip
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Upgrade pip tooling and install pytest
    python3 -m pip install --no-cache-dir --upgrade pip setuptools wheel
    python3 -m pip install --no-cache-dir pytest

    # Ensure the canonical home directory expected by the tests exists
    mkdir -p /home/user
    chmod 0777 /home/user   # allow the run-time (non-root) user to write here

%environment
    chmod 755 /home/user

    # Minimal environment setup; do NOT touch $HOME
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%runscript
    exec /bin/bash "$@"