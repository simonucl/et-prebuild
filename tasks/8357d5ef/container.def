Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update apt and install Python + pip
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install pytest for the grader test-suite
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create the required directory tree and data files
    # ------------------------------------------------------------------
    mkdir -p /home/user/datasets/images
    mkdir -p /home/user/datasets/texts
    mkdir -p /home/user/datasets/videos

    # images/img.bin → 2 048 000 bytes
    dd if=/dev/zero of=/home/user/datasets/images/img.bin bs=1000 count=2048 status=none

    # texts/story.txt → 1 048 576 bytes
    dd if=/dev/zero of=/home/user/datasets/texts/story.txt bs=1024 count=1024 status=none

    # videos/clip.mkv → 5 242 880 bytes
    dd if=/dev/zero of=/home/user/datasets/videos/clip.mkv bs=1024 count=5120 status=none

    # Ensure all files and directories are readable by non-root users
    chmod -R a+rX /home/user/datasets
    # (leave write-permissions off to mimic read-only dataset area)

    # Clean up package lists to keep image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure Python and pip are on PATH
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%runscript
    echo "This container sets up the environment for the disk-usage reporting task."