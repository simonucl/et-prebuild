Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # Update package lists and install Python plus pip
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

    # Install pytest for the test harness
    pip3 install --no-cache-dir pytest

    # Prepare the initial directory structure and source file
    mkdir -p /home/user/deploy
    chmod 0777 /home/user /home/user/deploy   # ensure write access for the unprivileged runtime user

    # Create targets.txt with the required content and trailing newline
    cat >/home/user/deploy/targets.txt <<'EOF'
web-01
web-02
api-01
db-01
EOF
    chmod 0666 /home/user/deploy/targets.txt  # writable by the invoking user

%environment
    chmod 755 /home/user

    # Keep the default HOME that Apptainer sets/binds; no changes needed here
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%labels
    Author "Apptainer Task Setup"
    Description "Environment for the deploy targets transformation exercise with pytest installed."

%runscript
    echo "Container for deploy targets transformation exercise."