Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Minimal Python tooling for running pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # Create the expected home directory for the non-root user that will execute the tasks.
    mkdir -p /home/user
    chmod 0777 /home/user   # Make it writable for whoever runs inside the container.

    # Clean up apt caches to keep the image small.
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Make sure python and pip are accessible.
    export PATH="/usr/local/bin:/usr/bin:${PATH}"

%labels
    Author monitoring-task-preparer
    Description "Base image for the monitoring scripting exercise—pytest installed, clean initial state."
    Version v1.0