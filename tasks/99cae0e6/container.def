Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update apt cache and install Python and pip
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # Create a non-privileged user that owns /home/user
    useradd -m -s /bin/bash user
    chown -R user:user /home/user

    # Clean up apt caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Do not override HOME; Apptainer will bind the host $HOME automatically
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%runscript
    # Default command when the container is executed without arguments
    exec /bin/bash "$@"

%labels
    Author      edge-computing-exercise
    Description "Environment for heartbeat log exercise with pytest preinstalled."