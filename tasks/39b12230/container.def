Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Ensure basic tooling is available
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        openssh-client

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # Create the baseline home directory structure expected by the grader
    mkdir -p /home/user
    chmod 0777 /home/user     # make it writable by the non-root runtime user

    # Clean up APT caches to keep image lean
    apt-get clean
    rm -rf /var/lib/apt/lists/*


%environment
    chmod 755 /home/user

    # Keep a predictable PATH; do not alter $HOME
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"


%runscript
    # Default action: open an interactive shell
    exec /bin/bash -l "$@"