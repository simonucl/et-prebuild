Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    apt-get update && \
    apt-get install -y python3 python3-pip && \
    pip3 install --no-cache-dir pytest

    # Create default non-root user and its home if they do not already exist
    if ! id -u user >/dev/null 2>&1; then
        useradd -m -u 1000 user
    fi
    mkdir -p /home/user
    chown -R 1000:1000 /home/user

%environment
    chmod 755 /home/user

    export PATH=/home/user/.local/bin:$PATH

%labels
    Author OpenAI-ChatGPT
    Description "Apptainer image for the load-average logging one-liner task."

%runscript
    echo "Container ready. Drop into a shell."
    exec /bin/bash "$@"