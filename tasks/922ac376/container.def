Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update apt cache and install Python + pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        && apt-get clean && rm -rf /var/lib/apt/lists/*

    # Install pytest for the grading framework
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state expected by the grading tests
    # ------------------------------------------------------------------

    # Create the /home/user hierarchy
    mkdir -p /home/user/remote_repo
    chmod 755 /home/user
    chmod 755 /home/user/remote_repo

    # Create the expected Kubernetes manifest files inside remote_repo
    cat > /home/user/remote_repo/nginx-deployment.yaml <<'EOF'
apiVersion: apps/v1
kind: Deployment
metadata:
  name: nginx-deployment
spec:
  replicas: 3
  selector:
    matchLabels:
      app: nginx
  template:
    metadata:
      labels:
        app: nginx
    spec:
      containers:
      - name: nginx
        image: nginx:1.21
        ports:
        - containerPort: 80
EOF

    cat > /home/user/remote_repo/nginx-service.yaml <<'EOF'
apiVersion: v1
kind: Service
metadata:
  name: nginx-service
spec:
  selector:
    app: nginx
  ports:
  - protocol: TCP
    port: 80
    targetPort: 80
  type: ClusterIP
EOF

    chmod 644 /home/user/remote_repo/nginx-deployment.yaml /home/user/remote_repo/nginx-service.yaml

    # Ensure the target directory and log file do NOT exist at build time
    rm -rf /home/user/k8s-manifests || true
    rm -f /home/user/sync.log || true

%environment
    # Ensure python3 and pip are in PATH
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%labels
    Author DevOpsChallenge
    Description "Container prepared for Kubernetes manifest synchronisation task; includes pytest and pre-populated remote_repo."