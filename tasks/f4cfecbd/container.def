Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ------------------------------------------------------------
    # Install Python tooling required by the automated test suite
    # ------------------------------------------------------------
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------
    # Create the directory structure for the incident-response task
    # ------------------------------------------------------------
    mkdir -p /home/user/services/inventory-app/config
    mkdir -p /home/user/services/inventory-app/runtime
    mkdir -p /home/user/incident_logs

    # Ensure directory permissions are exactly 0755
    chmod 0755 /home/user \
               /home/user/services \
               /home/user/services/inventory-app \
               /home/user/services/inventory-app/config \
               /home/user/services/inventory-app/runtime \
               /home/user/incident_logs

    # ------------------------------------------------------------
    # Populate configuration and status files with initial content
    # ------------------------------------------------------------
    cat > /home/user/services/inventory-app/config/env.conf <<'EOF'
APP_ENV=production
PORT=4000
EOF

    echo "running on 4000" > /home/user/services/inventory-app/runtime/service.status

    # ------------------------------------------------------------
    # Create the mock service helper script
    # ------------------------------------------------------------
    cat > /home/user/services/inventory-app/mock_service.sh <<'EOSH'
#!/usr/bin/env bash
# very small helper: writes to service.status
set -e
RUNTIME_DIR="$(dirname "$0")/runtime"
STATUS_FILE="${RUNTIME_DIR}/service.status"
CONFIG_FILE="$(dirname "$0")/config/env.conf"

if [[ "$1" == "start" ]]; then
    source "${CONFIG_FILE}"
    echo "running on ${PORT}" > "${STATUS_FILE}"
elif [[ "$1" == "stop" ]]; then
    echo "stopped" > "${STATUS_FILE}"
else
    echo "Usage: $0 {start|stop}"
    exit 1
fi
EOSH

    # ------------------------------------------------------------
    # Set correct permissions for files
    # ------------------------------------------------------------
    chmod 0755 /home/user/services/inventory-app/mock_service.sh
    chmod 0644 /home/user/services/inventory-app/config/env.conf
    chmod 0644 /home/user/services/inventory-app/runtime/service.status

    # Guarantee a trailing newline in service.status (safety)
    sed -i -e '$a\' /home/user/services/inventory-app/runtime/service.status

%environment
    chmod 755 /home/user

    # Add inventory-app directory to PATH for convenience
    export PATH="${PATH}:/home/user/services/inventory-app"

%labels
    Author      On-call Ops Automation
    Description Baseline image for the “inventory-app” incident-response task