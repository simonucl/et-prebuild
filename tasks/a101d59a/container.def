Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # Install Python and pytest
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Prepare the filesystem expected by the grading tests
    # ------------------------------------------------------------------
    # Create required directories
    mkdir -p /home/user/data/csvs

    # Set safe directory permissions
    chmod 0755 /home
    chmod 0755 /home/user
    chmod 0755 /home/user/data
    chmod 0755 /home/user/data/csvs

    # ------------------------------------------------------------------
    # Create the three pre-seeded CSV files with EXACT contents & sizes
    # ------------------------------------------------------------------
    cat > /home/user/data/csvs/sales_2021_q1.csv <<'EOF'
Region,Product,Units
North,Widget,100
South,Gadget,150
East,Widget,200
EOF

    cat > /home/user/data/csvs/sales_2021_q2.csv <<'EOF'
Region,Product,Units
West,Widget,120
North,Gadget,110
South,Widget,90
East,Gadget,130
EOF

    cat > /home/user/data/csvs/sales_2021_q3.csv <<'EOF'
Region,Product,Units
North,Widget,140
West,Gadget,160
EOF

    # Ensure correct file permissions
    chmod 0644 /home/user/data/csvs/sales_2021_q1.csv
    chmod 0644 /home/user/data/csvs/sales_2021_q2.csv
    chmod 0644 /home/user/data/csvs/sales_2021_q3.csv

%environment
    chmod 755 /home/user

    # Ensure Python is the default interpreter name expected by many tools
    export PYTHONIOENCODING=utf-8
    export LC_ALL=C.UTF-8

%labels
    Author="Automated build for disk-usage analysis task"
    Description="Base image containing pre-seeded quarterly sales CSV files and pytest"