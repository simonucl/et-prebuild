Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    #------------------------------------------------------------------
    # Basic OS packages and Python tooling
    #------------------------------------------------------------------
    apt-get update -y
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    #------------------------------------------------------------------
    # Create initial dataset required by the assignment
    #------------------------------------------------------------------
    # Directory layout:
    #   /home/user/datasets/
    #       images/img1.jpg  -> "fake image data 1\n"
    #       images/img2.jpg  -> "fake image data 2\n"
    #       labels/img1.txt  -> "label for image 1\n"
    #       labels/img2.txt  -> "label for image 2\n"
    #
    install -d -m 0755 /home/user/datasets/images
    install -d -m 0755 /home/user/datasets/labels

    # Create files with the precise 18-byte contents
    printf "fake image data 1\n" > /home/user/datasets/images/img1.jpg
    printf "fake image data 2\n" > /home/user/datasets/images/img2.jpg
    printf "label for image 1\n" > /home/user/datasets/labels/img1.txt
    printf "label for image 2\n" > /home/user/datasets/labels/img2.txt

    # Set permissions to 0644 as specified
    chmod 0644 /home/user/datasets/images/img1.jpg
    chmod 0644 /home/user/datasets/images/img2.jpg
    chmod 0644 /home/user/datasets/labels/img1.txt
    chmod 0644 /home/user/datasets/labels/img2.txt

    #------------------------------------------------------------------
    # Prepare /home/user/backups directory (empty; for student output)
    #------------------------------------------------------------------
    install -d -m 0755 /home/user/backups

%environment
    chmod 755 /home/user

    # Ensure Python and commands are on the PATH
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author YourName
    Description "Environment for image-classification dataset backup task"

%help
    This container provides the initial cleaned dataset and a Python/pytest
    environment so that students can work on the backup & manifest task
    described in the assignment.