Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update apt database and install Python & pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install pytest for the runtime tests
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial task resources
    # ------------------------------------------------------------------
    # Create the directory structure for the DNS-log assignment
    mkdir -p /home/user/logs

    # Create the sample DNS traffic log with exact, newline-terminated lines
    cat >/home/user/logs/dns_traffic.log <<'EOF'
2023-03-01T12:00:01Z example.com 93.184.216.34
2023-03-01T12:00:02Z example.com 93.184.216.34
2023-03-01T12:00:03Z localhost 127.0.0.1
2023-03-01T12:00:04Z example.net 93.184.216.34
2023-03-01T12:00:05Z example.com 93.184.216.35
2023-03-01T12:00:06Z example.net 93.184.216.34
EOF

    # Ensure readability for non-root users
    chmod -R 0755 /home/user

%environment
    chmod 755 /home/user

    # Make sure Python and pip are on PATH
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%runscript
    echo "Container for the DNS log-analysis task.  Open a shell with:"
    echo "   apptainer exec <image>.sif /bin/bash"