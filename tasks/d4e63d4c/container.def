Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # Install Python and pytest
    apt-get update && \
        apt-get install -y --no-install-recommends python3 python3-pip ca-certificates && \
        rm -rf /var/lib/apt/lists/*

    pip3 install --no-cache-dir pytest

    # Set up initial filesystem state for the exercise
    mkdir -p /home/user/pentest

    cat >/home/user/pentest/.targets.env <<'EOF'
TARGET_A=192.168.1.10
TARGET_B=10.0.0.5
PORTS=22,80,443
EOF

    # Correct permissions so the non-root runtime user can read them
    chmod 755 /home/user
    chmod 755 /home/user/pentest
    chmod 644 /home/user/pentest/.targets.env

%environment
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH