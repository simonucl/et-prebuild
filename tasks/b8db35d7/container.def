Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Ensure the basic home directory expected by the exercise exists and is writable
    mkdir -p /home/user
    chmod 0777 /home/user

    # Install Python and PyPI so we can add pytest for the test-runner
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install pytest via pip (keeps the package list small)
    pip3 install --no-cache-dir pytest

    # Clean up APT caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Make sure “python3” is on PATH and the default python points to it
    export PATH=/usr/local/bin:/usr/bin:/bin
    if [ ! -e /usr/bin/python ] && [ -e /usr/bin/python3 ]; then
        ln -s /usr/bin/python3 /usr/local/bin/python || true
    fi

%labels
    Author="Apptainer Automated Build"
    Description="Environment for bash-package.log helper-utilities exercise – Ubuntu 22.04 with pytest pre-installed."