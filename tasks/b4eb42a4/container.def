Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
  set -e

  echo "Updating package index and installing required tools..."
  apt-get update -y
  DEBIAN_FRONTEND=noninteractive apt-get install -y \
      python3 \
      python3-pip \
      jq \
      --no-install-recommends
  apt-get clean
  rm -rf /var/lib/apt/lists/*

  echo "Installing pytest via pip..."
  pip3 install --no-cache-dir pytest

  echo "Creating initial directory structure and draft release files..."
  mkdir -p /home/user/releases/input

  cat <<'EOF' > /home/user/releases/input/release-a.json
{
  "version": "v1",
  "services": [
    { "name": "auth",    "image": "registry.example.com/auth:1.2.3",    "replicas": 2 },
    { "name": "billing", "image": "registry.example.com/billing:3.4.5", "replicas": 1 }
  ]
}
EOF

  cat <<'EOF' > /home/user/releases/input/release-b.json
{
  "version": "v2",
  "services": [
    { "name": "auth",   "image": "registry.example.com/auth:1.2.4",   "replicas": 3 },
    { "name": "search", "image": "registry.example.com/search:2.1.0", "replicas": 2 }
  ]
}
EOF

  # Ensure world-readable permissions so non-root users can read the files.
  chmod 755 /home/user /home/user/releases /home/user/releases/input
  chmod 644 /home/user/releases/input/release-a.json /home/user/releases/input/release-b.json

  echo "Initial container setup complete."

%labels
  Author release-manager-task
  Description "Container prepared for the release-manager terminal assignment."

%help
  This container provides:
    • jq
    • Python 3 with pytest
    • Pre-populated draft release descriptors in /home/user/releases/input/
  No output artefacts have been created yet.