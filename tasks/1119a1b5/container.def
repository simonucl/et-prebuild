Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    #----------------------------
    # Basic tooling and pytest
    #----------------------------
    apt-get update
    apt-get install -y --no-install-recommends python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    #----------------------------
    # Prepare initial filesystem
    #----------------------------
    # Ensure /home/user exists
    mkdir -p /home/user/network_configs
    chmod 755 /home/user
    chmod 755 /home/user/network_configs

    # Create router.cfg with exact reference content (final newline included)
    cat > /home/user/network_configs/router.cfg <<'EOF'
!
version 15.2
hostname TestRouter
interface GigabitEthernet0/0
 ip address 192.168.1.1 255.255.255.0
 no shutdown
!
end
EOF

    # Generate the correct SHA-256 checksum file (one line + newline)
    sha256sum /home/user/network_configs/router.cfg | awk '{print $1}' > /home/user/network_configs/router.cfg.sha256

    # Permissions
    chmod 644 /home/user/network_configs/router.cfg
    chmod 644 /home/user/network_configs/router.cfg.sha256

%environment
    export PYTHONUNBUFFERED=1

%labels
    Author "Apptainer Task Setup"
    Description "Initial state for router checksum verification exercise"