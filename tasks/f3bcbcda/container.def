BootStrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package index and install required packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        sqlite3 \
        ca-certificates

    # Install pytest for the grading framework
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create the initial data directory structure and database
    # ------------------------------------------------------------------
    mkdir -p /home/user/ml_data
    chmod 755 /home/user
    chmod 755 /home/user/ml_data

    # Build the SQLite database with the required schema and rows
    sqlite3 /home/user/ml_data/training.db <<'SQL_EOF'
    CREATE TABLE training_samples (
        id INTEGER PRIMARY KEY,
        text TEXT,
        label INTEGER
    );
    INSERT INTO training_samples (id,text,label) VALUES
        (1,'hello world',0),
        (2,'goodbye world',1),
        (3,'test sample',0);
    SQL_EOF

    # Set the correct permissions
    chmod 644 /home/user/ml_data/training.db

    # Give ownership to uid 1000 (the typical non-root user inside
    # the container runtime).  The tests only require permission bits,
    # not ownership, but this allows the unprivileged agent to create
    # new files/directories within /home/user/ml_data.
    chown -R 1000:1000 /home/user || true

    # Clean up apt caches to minimize image size
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    # Ensure Python is available via `python` as well as `python3`
    if [ -x /usr/bin/python3 ] && [ ! -e /usr/bin/python ]; then
        ln -s /usr/bin/python3 /usr/bin/python
    fi

%labels
    Author Machine-Learning Task Setup
    Description Sets up initial state for ML CSV export task with SQLite DB