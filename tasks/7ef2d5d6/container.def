Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update apt cache and install Python + pip
    apt-get update -qq
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        && apt-get clean && rm -rf /var/lib/apt/lists/*

    # Install pytest for the forthcoming test suites
    pip3 install --no-cache-dir --upgrade pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state for the “Acme-Payments” exercise
    # ------------------------------------------------------------------
    # 1. Writable firewall directory
    mkdir -p /home/user/firewall
    chmod 0777 /home/user/firewall       # ensure the unprivileged user can write

    # 2. Base rules file (read-only to the learner)
    cat > /home/user/firewall/base.rules <<'EOF'
*filter
:INPUT DROP [0:0]
:FORWARD DROP [0:0]
:OUTPUT ACCEPT [0:0]
-A INPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
-A INPUT -i lo -j ACCEPT
COMMIT
EOF
    chmod 0644 /home/user/firewall/base.rules   # world-readable, not writable by others

    # 3. Writable release log directory
    mkdir -p /home/user/release_logs
    chmod 0777 /home/user/release_logs

%environment
    chmod 755 /home/user

    # Ensure python and pip are on PATH (should already be, but explicit for safety)
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%labels
    Author Acme-Payments Task Setup
    Description Container image pre-configured for the “Acme-Payments” firewall exercise.
    Maintainer example@example.com

%runscript
    exec /bin/bash -l "$@"