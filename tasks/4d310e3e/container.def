Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and tooling
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-setuptools \
        ca-certificates
    pip3 install --no-cache-dir pytest

    # Create a writable home directory for the non-privileged user that will
    # run the tasks/tests.  World-writable with the sticky bit ensures any UID
    # can create files inside it without interfering with others.
    mkdir -p /home/user
    chmod 1777 /home/user

    # Clean up APT caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure the path to pip-installed tools is available
    export PATH=/usr/local/bin:$PATH

%runscript
    # Default command when the container is executed without arguments
    exec "$@"

%labels
    Author="Generated by ChatGPT"
    Description="Environment for the backup_daemon enablement task with pytest installed."