Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Basic development tools
    apt-get update -y
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest

    # Create directory structure
    mkdir -p /home/user/docs/raw

    # ------------------------------------------------------------------
    # Write initial Markdown drafts with exact, byte-perfect content.
    # Trailing spaces are significant—DO NOT remove them.
    # ------------------------------------------------------------------

    cat > /home/user/docs/raw/installation.md <<'EOF'
# Installation
To install the **AwesomeApp**, follow these steps:
1. Download the package. [TODO] 
2. Run the installer.
It will guide you through the setup.  
EOF

    cat > /home/user/docs/raw/usage.md <<'EOF'
# Usage Guide
After installation, you can start AwesomeApp via terminal:
$ awesomeapp start
For advanced options, consult the manual. [TODO]  
EOF

    cat > /home/user/docs/raw/changelog.md <<'EOF'
# Changelog
## v1.0.1
- Fixed minor bugs.  
## v1.0.0
- Initial release. [TODO]
EOF

    # Make /home/user writable for the non-root runtime user
    chmod -R a+rwX /home/user

%environment
    chmod 755 /home/user

    # Nothing to override; leave HOME as provided by Apptainer at runtime.
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8