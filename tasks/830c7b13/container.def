Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # Update APT index and install required packages
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        sqlite3 \
        ca-certificates

    # Install pytest for the test harness
    pip3 install --no-cache-dir pytest

    # Prepare a writable home for the runtime (non-root) user
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up APT caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%help
    This container supplies the tooling required for the “SQLite provisioning demo” task:
      • sqlite3 CLI
      • Python 3 and pytest (for the autograder)

    The provisioning directory /home/user/provisioning/db is intentionally *absent*
    so that the learner can create it during their solution.