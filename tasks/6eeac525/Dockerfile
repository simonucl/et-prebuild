# syntax=docker/dockerfile:1
FROM ubuntu:22.04

# Labels converted from %labels
LABEL Author="Autogenerated for ETL ERROR count task" \
      Description="Container with predefined log file and directory structure for educational task." \
      Maintainer="ChatGPT Apptainer Builder"

# Help text converted from %help
# This image sets up the initial environment for an ETL log–parsing assignment.
# It provides:
#   • Directories:
#         /home/user/etl/logs
#         /home/user/etl/reports
#     (both with 0755 permissions)
#   • Pre-populated log file:
#         /home/user/etl/logs/pipeline.log  (0644 perms)
#   • Python 3 and pytest pre-installed for automated grading.

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked --mount=type=cache,target=/var/lib/apt,sharing=locked set -e && \
    echo "Updating package index and installing Python tooling..." && \
    apt-get update -qq && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

RUN --mount=type=cache,target=/root/.cache/pip echo "Installing pytest for the evaluation framework..." && \
    pip3 install --no-cache-dir pytest

RUN echo "Creating directory structure for the ETL task..." && \
    mkdir -p /home/user/etl/logs && \
    mkdir -p /home/user/etl/reports && \
    chmod 755 /home/user && \
    chmod 755 /home/user/etl && \
    chmod 755 /home/user/etl/logs && \
    chmod 755 /home/user/etl/reports

RUN echo "Populating the pipeline.log file with ground-truth content..." && \
    cat > /home/user/etl/logs/pipeline.log <<'EOF'
[2023-05-12 08:00:01] INFO  Start extraction
[2023-05-12 08:00:02] ERROR Source connection failure
[2023-05-12 08:05:31] INFO  Retrying extraction
[2023-05-12 08:05:45] INFO  Extraction succeeded
[2023-05-12 08:06:00] INFO  Start transformation
[2023-05-12 08:06:12] ERROR Null value encountered
[2023-05-12 08:07:00] INFO  Transformation succeeded
[2023-05-12 08:07:15] INFO  Start load
[2023-05-12 08:07:45] ERROR Constraint violation on load
[2023-05-12 08:08:02] INFO  Load finished
EOF

RUN chmod 644 /home/user/etl/logs/pipeline.log

# Environment setup converted from %environment
ENV PATH=/usr/local/bin:/usr/bin:/bin

RUN if [ ! -e /usr/bin/python ] && [ -e /usr/bin/python3 ]; then \
        ln -s /usr/bin/python3 /usr/bin/python; \
    fi