Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ------------------------------------------------------------------
    # 1. Base OS packages
    # ------------------------------------------------------------------
    apt-get update && \
    apt-get install -y --no-install-recommends \
        sqlite3 \
        python3 \
        python3-pip && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # 2. Python testing framework
    # ------------------------------------------------------------------
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # 3. Create directory structure and populate the audit database
    # ------------------------------------------------------------------
    mkdir -p /home/user/audit_data

    sqlite3 /home/user/audit_data/compliance.db <<'SQL'
    PRAGMA foreign_keys = OFF;
    BEGIN TRANSACTION;

    /* Table definition */
    CREATE TABLE system_access (
        id          INTEGER PRIMARY KEY,
        username    TEXT NOT NULL,
        access_time TEXT NOT NULL,
        result      TEXT NOT NULL
    );

    /* Pre-loaded rows */
    INSERT INTO system_access (id, username, access_time, result) VALUES
        (1, 'alice',   '2024-05-20 09:10:00', 'SUCCESS'),
        (2, 'bob',     '2024-06-02 14:55:00', 'FAIL'),
        (3, 'charlie', '2024-06-10 07:32:12', 'FAIL'),
        (4, 'dan',     '2024-06-15 15:45:30', 'FAIL'),
        (5, 'erin',    '2024-05-18 22:11:09', 'FAIL');

    COMMIT;
SQL

    # Permissions so that the non-root runtime user can read the DB
    chmod 644 /home/user/audit_data/compliance.db
    chmod 755 /home/user/audit_data

    # ------------------------------------------------------------------
    # 4. Prepare (empty) output directory for the agent’s future work
    # ------------------------------------------------------------------
    mkdir -p /home/user/audit_logs
    chmod 755 /home/user/audit_logs

%environment
    # No special environment variables required.

%labels
    Author      "Generated by ChatGPT"
    Description "Apptainer image for the SQLite audit compliance task"