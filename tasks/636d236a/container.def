Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Basic development tools
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install pytest for the grading harness
    pip3 install --no-cache-dir pytest

    # Create an unprivileged user `user` with UID/GID 1000 and a home directory
    groupadd -g 1000 user
    useradd  -m -u 1000 -g 1000 -s /bin/bash user

    # Clean up APT caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure pip-installed CLI tools are in PATH
    export PATH="/usr/local/bin:$PATH"

%runscript
    # Default action: start an interactive shell
    exec /bin/bash