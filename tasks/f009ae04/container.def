Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author experiment_setup
    Description "Container that provides the initial experimental workspace and pytest for grading."

%post
    set -eux

    # Update package index and install Python tooling
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3-pip \
        python3-setuptools \
        python3-wheel

    # Install pytest for the grading suite
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create initial filesystem state expected by the grader
    # ------------------------------------------------------------------
    mkdir -p /home/user/experiments/exp1
    mkdir -p /home/user/experiments/exp2
    mkdir -p /home/user/experiments/exp3

    # -------- exp1 --------
    cat > /home/user/experiments/exp1/log.txt << 'EOF'
[INFO] Training started at 2023-08-30 10:00:00
epoch=1 accuracy=0.72 loss=0.85
epoch=2 accuracy=0.80 loss=0.65
epoch=3 accuracy=0.82 loss=0.63
[INFO] Finished 3 epochs
Final accuracy: 0.83
Final loss: 0.61
EOF

    cat > /home/user/experiments/exp1/metrics.csv << 'EOF'
epoch,accuracy,loss
1,0.72,0.85
2,0.80,0.65
3,0.82,0.63
EOF

    # -------- exp2 --------
    cat > /home/user/experiments/exp2/log.txt << 'EOF'
[INFO] Training started at 2023-08-30 10:02:00
epoch=1 accuracy=0.78 loss=0.70
epoch=2 accuracy=0.83 loss=0.60
epoch=3 accuracy=0.87 loss=0.54
[INFO] Finished 3 epochs
Final accuracy: 0.88
Final loss: 0.52
EOF

    cat > /home/user/experiments/exp2/metrics.csv << 'EOF'
epoch,accuracy,loss
1,0.78,0.70
2,0.83,0.60
3,0.87,0.54
EOF

    # -------- exp3 --------
    cat > /home/user/experiments/exp3/log.txt << 'EOF'
[INFO] Training started at 2023-08-30 10:05:00
epoch=1 accuracy=0.68 loss=0.90
epoch=2 accuracy=0.74 loss=0.80
epoch=3 accuracy=0.77 loss=0.73
[INFO] Finished 3 epochs
Final accuracy: 0.79
Final loss: 0.73
EOF

    cat > /home/user/experiments/exp3/metrics.csv << 'EOF'
epoch,accuracy,loss
1,0.68,0.90
2,0.74,0.80
3,0.77,0.73
EOF

    # Ensure correct permissions (directories 0755, files 0644)
    find /home/user/experiments -type d -exec chmod 755 {} +
    find /home/user/experiments -type f -exec chmod 644 {} +

%environment
    chmod 755 /home/user

    # Expose pip-installed binaries
    export PATH=/usr/local/bin:$PATH

%runscript
    echo "This container is prepared for the experiment summarization task."
    echo "Execute your solution inside the container shell."