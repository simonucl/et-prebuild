Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    #--------------------------------------------------
    # Install Python and pytest for the validation suite
    #--------------------------------------------------
    apt-get update -y
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest

    #--------------------------------------------------
    # Create the filesystem layout expected by the tests
    #--------------------------------------------------
    # Base home directory
    mkdir -p /home/user
    chmod 0755 /home/user

    # Repos and logs directories
    mkdir -p /home/user/repos
    mkdir -p /home/user/logs
    chmod 0755 /home/user/repos
    chmod 0755 /home/user/logs

    #--------------------------------------------------
    # Populate source files with exact content and permissions
    #--------------------------------------------------
    cat > /home/user/repos/packages_a.txt << 'EOF'
build;sha256;size
coreutils;f1c2d3e4;1200K
openssl;abcd1234;3400K
nginx;9876abcd;2500K
EOF

    cat > /home/user/repos/packages_b.txt << 'EOF'
project;version;maintainer
coreutils;9.3;gnu
openssl;3.1.1;openssl
nginx;1.25.0;nginx
EOF

    chmod 0644 /home/user/repos/packages_a.txt
    chmod 0644 /home/user/repos/packages_b.txt

    # Ensure correct ownership (non-root users will execute the tasks)
    chown -R 1000:1000 /home/user || true

%environment
    chmod 755 /home/user

    # Ensure Python is on PATH
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%labels
    Author="Generated by ChatGPT"
    Description="Environment for the artifact-repository curator task with pytest preinstalled."

%help
    This Apptainer image provides the initial filesystem state and Python tooling
    required to run the automated checks for the “artifact-repository curator” task.