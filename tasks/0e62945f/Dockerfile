FROM ubuntu:22.04

# Help:
# This Apptainer image provides the initial filesystem state and Python tooling
# required to run the automated checks for the “artifact-repository curator” task.

LABEL Author="Generated by ChatGPT"
LABEL Description="Environment for the artifact-repository curator task with pytest preinstalled."

RUN set -e && \
    apt-get update -y && \
    apt-get install -y --no-install-recommends python3 python3-pip && \
    pip3 install --no-cache-dir pytest && \
    mkdir -p /home/user && \
    chmod 0755 /home/user && \
    mkdir -p /home/user/repos && \
    mkdir -p /home/user/logs && \
    chmod 0755 /home/user/repos && \
    chmod 0755 /home/user/logs

RUN cat > /home/user/repos/packages_a.txt << 'EOF'
build;sha256;size
coreutils;f1c2d3e4;1200K
openssl;abcd1234;3400K
nginx;9876abcd;2500K
EOF

RUN cat > /home/user/repos/packages_b.txt << 'EOF'
project;version;maintainer
coreutils;9.3;gnu
openssl;3.1.1;openssl
nginx;1.25.0;nginx
EOF

RUN chmod 0644 /home/user/repos/packages_a.txt && \
    chmod 0644 /home/user/repos/packages_b.txt && \
    chown -R 1000:1000 /home/user || true && \
    chmod 755 /home/user

ENV PATH=/usr/local/bin:/usr/bin:/bin:$PATH
ENV LC_ALL=C.UTF-8
ENV LANG=C.UTF-8