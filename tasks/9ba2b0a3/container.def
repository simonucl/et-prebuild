Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Update package index and install Python/pip
    apt-get update -y && \
        apt-get install -y --no-install-recommends python3 python3-pip && \
        apt-get clean && rm -rf /var/lib/apt/lists/*

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare directory structure and permissions expected by the tests
    # ------------------------------------------------------------------
    mkdir -p /home/user/apps/logs/old
    mkdir -p /home/user/output

    # Make sure every directory in the path is accessible to an arbitrary
    # (non-root) runtime UID that Apptainer may map in.
    chmod 0777 /home /home/user /home/user/apps /home/user/apps/logs \
               /home/user/apps/logs/old /home/user/output

    # ------------------------------------------------------------------
    # Create the log files with the exact byte sizes required
    # (content itself is irrelevant for the tests, only size & mtime)
    # ------------------------------------------------------------------
    truncate -s 614400 /home/user/apps/logs/app1.log
    truncate -s 307200 /home/user/apps/logs/app2.log
    truncate -s 819200 /home/user/apps/logs/old/old.log

    # ------------------------------------------------------------------
    # Set modification times so that they are at least 3 or 5 days old
    # relative to the moment the container is built.  This guarantees
    # they will satisfy the “≥ 2 days” check at test time.
    # ------------------------------------------------------------------
    touch -d '3 days ago' /home/user/apps/logs/app1.log
    touch -d '3 days ago' /home/user/apps/logs/app2.log
    touch -d '5 days ago' /home/user/apps/logs/old/old.log

    # Ensure the files are readable (and not executable)
    chmod 0666 /home/user/apps/logs/app1.log \
               /home/user/apps/logs/app2.log \
               /home/user/apps/logs/old/old.log

%labels
    chmod 755 /home/user

    Author "Generated by ChatGPT – Apptainer task bootstrap"

%environment
    # Nothing special needed; inherit host HOME and PATH
    export PYTHONUNBUFFERED=1