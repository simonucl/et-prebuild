FROM ubuntu:22.04

# Help / labels from Apptainer file
# Author "Generated by ChatGPT – Apptainer task bootstrap"

RUN apt-get update -y && \
    apt-get install -y --no-install-recommends python3 python3-pip && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

RUN pip3 install --no-cache-dir pytest

RUN mkdir -p /home/user/apps/logs/old && \
    mkdir -p /home/user/output

RUN chmod 0777 /home /home/user /home/user/apps /home/user/apps/logs /home/user/apps/logs/old /home/user/output

RUN truncate -s 614400 /home/user/apps/logs/app1.log && \
    truncate -s 307200 /home/user/apps/logs/app2.log && \
    truncate -s 819200 /home/user/apps/logs/old/old.log

RUN touch -d '3 days ago' /home/user/apps/logs/app1.log && \
    touch -d '3 days ago' /home/user/apps/logs/app2.log && \
    touch -d '5 days ago' /home/user/apps/logs/old/old.log

RUN chmod 0666 /home/user/apps/logs/app1.log /home/user/apps/logs/app2.log /home/user/apps/logs/old/old.log

RUN chmod 755 /home/user

ENV PYTHONUNBUFFERED=1