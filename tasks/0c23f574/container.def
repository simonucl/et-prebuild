Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author  Permission-Hardening Task Maintainer
    Description  Base image for the “basic permission hardening” exercise.

%post
    set -eux

    # Create a writable home directory for the unprivileged agent.
    mkdir -p /home/user
    chmod 0777 /home/user    # world-writable so any invoking UID can work here.

    # Install Python, pip, and pytest (required by the test harness).
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install pytest via pip.
    pip3 install --no-cache-dir pytest

    # Clean up APT caches to keep the image small.
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    export PATH="$PATH:/usr/local/bin"
    export PYTHONUNBUFFERED=1