Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python 3, pip, and locales, then pytest via pip.
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        locales \
        ca-certificates

    pip3 install --no-cache-dir pytest

    # Generate a UTF-8 locale for general use.
    locale-gen en_US.UTF-8
    update-locale

    # Create a writable home directory expected by the tests.
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up APT caches to keep the image small.
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Do not override HOME (Apptainer binds the invoking user’s $HOME).
    export LC_ALL=C.UTF-8
    export PATH=/usr/local/bin:/usr/bin:/bin

%runscript
    # Default runscript: drop to a shell or execute passed commands.
    /bin/bash "$@"

%help
    This container provides a minimal Ubuntu 22.04 environment with Python 3 and
    pytest installed, plus a writable /home/user directory expected by the
    automated tests for the “UTC time-zone & en_US.UTF-8 locale compliance” task.