FROM ubuntu:22.04

# maintainer="Generated by ChatGPT – Apptainer setup for release-manager task"
LABEL maintainer="Generated by ChatGPT – Apptainer setup for release-manager task"

ENV PATH=$HOME/.local/bin:$PATH

RUN set -e && \
    apt-get update && \
    apt-get install -y --no-install-recommends python3 python3-pip && \
    pip3 install --no-cache-dir pytest

RUN mkdir -p /home/user/releases && \
    chmod 755 /home/user && \
    chmod 755 /home/user/releases

RUN cat > /home/user/releases/versions.txt <<'EOF'
1.0.0
2.0.0
1.5.0
2.1.0
1.0.0
3.0.0
2.1.0
1.2.0
EOF

RUN chmod 644 /home/user/releases/versions.txt

RUN apt-get clean && rm -rf /var/lib/apt/lists/*