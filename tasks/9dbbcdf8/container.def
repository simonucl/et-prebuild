Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state for the “release-manager” exercise
    # ------------------------------------------------------------------
    # Create directories with required permissions
    mkdir -p /home/user/releases
    chmod 755 /home/user
    chmod 755 /home/user/releases

    # Create versions.txt with the exact required content
    cat > /home/user/releases/versions.txt <<'EOF'
1.0.0
2.0.0
1.5.0
2.1.0
1.0.0
3.0.0
2.1.0
1.2.0
EOF
    chmod 644 /home/user/releases/versions.txt

    # Clean up APT cache to keep image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    # Make sure user-installed Python tools (if any) are found
    export PATH="$HOME/.local/bin:$PATH"

%labels
    maintainer="Generated by ChatGPT – Apptainer setup for release-manager task"