Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # 1. Install Python tooling and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3       \
        python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # 2. Provision a regular (non-privileged) user with UID 1000
    #    – this matches the most common UID for the invoking user in
    #      CI environments, helping ensure ownership-based write access.
    if ! id -u 1000 >/dev/null 2>&1; then
        useradd -m -u 1000 -s /bin/bash user
    fi

    # 3. Create initial vulnerable application layout
    mkdir -p /home/user/secure_app
    chmod 0755 /home/user
    chmod 0755 /home/user/secure_app

    cat > /home/user/secure_app/config.ini <<'EOF'
[credentials]
API_KEY = OLDKEY-12345
EOF

    chmod 0644 /home/user/secure_app/config.ini

    # Make the future operator (UID 1000) the owner so they can rotate keys
    chown -R 1000:1000 /home/user/secure_app

%environment
    chmod 755 /home/user

    # No environment overrides are strictly necessary
    export LC_ALL=C.UTF-8

%runscript
    exec "$@"