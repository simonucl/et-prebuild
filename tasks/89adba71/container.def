Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive

    # Update package lists and install Python & pip
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the task’s automated test-suite
    pip3 install --no-cache-dir pytest

    # Ensure the expected home directory exists (but **no** task artefacts yet)
    mkdir -p /home/user
    # Make it writable by any non-root runtime user
    chmod 0777 /home/user

%environment
    chmod 755 /home/user

    export LC_ALL=C.UTF-8
    export PYTHONUNBUFFERED=1

%runscript
    exec "$@"