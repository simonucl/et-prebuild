Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "Updating apt cache and installing required packages..."
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        curl \
        w3m \
        ca-certificates

    echo "Installing pytest via pip..."
    pip3 install --no-cache-dir pytest

    echo "Creating initial directory structure and seed files..."
    # Make /home/user world-writable so the unprivileged runtime user can
    # create additional directories/files (e.g., /home/user/security).
    mkdir -p /home/user/web
    chmod 0777 /home/user

    # Seed credentials.html with the exact expected content.
    cat > /home/user/web/credentials.html <<'EOF'
<div id="current-user">new_admin</div>
EOF
    chmod 0644 /home/user/web/credentials.html

    echo "Cleanup APT caches to keep the image small..."
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%labels
    chmod 755 /home/user

    Author="Automatic build for credential-rotation task"
    Description="Container with preset credential HTML and pytest installed"

%help
    This container provides the initial state for the credential rotation
    exercise.  It includes:
      • /home/user/web/credentials.html          (pre-seeded HTML snippet)
      • Python 3 and pytest                      (for automated grading)
      • curl and w3m                             (optional scraping tools)