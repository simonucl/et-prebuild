Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install required system packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        curl \
        jq
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the grading framework
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare the mock API fixture expected by the exercise & tests
    # ------------------------------------------------------------------
    mkdir -p /home/user/mock_api

    cat > /home/user/mock_api/costs.json <<'EOF'
{
  "instances": [
    { "id": "i-07bd", "state": "running",  "hourly_cost": 0.12 },
    { "id": "i-18ef", "state": "running",  "hourly_cost": 0.45 },
    { "id": "i-21aa", "state": "stopped",  "hourly_cost": 0.37 },
    { "id": "i-3cb2", "state": "running",  "hourly_cost": 0.31 },
    { "id": "i-4ddc", "state": "running",  "hourly_cost": 0.29 }
  ]
}
EOF

    # Ensure accessible permissions (readable by unprivileged user)
    chmod 755 /home/user
    chmod 755 /home/user/mock_api
    chmod 644 /home/user/mock_api/costs.json

%environment
    # Python and pip are already on PATH in Ubuntu; nothing extra required
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%labels
    Author  FinOps-Exercise
    Description  "Container for Investigate Expensive Running Cloud Instances via Curl task"