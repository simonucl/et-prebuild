Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
  Author CloudMigrationPrep
  Description "Environment for rsync-synchronisation assignment"

%post
  set -eux

  #------------------------------------------------------------------
  # Install required system packages
  #------------------------------------------------------------------
  apt-get update
  DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        rsync \
        ca-certificates \
        tzdata
  rm -rf /var/lib/apt/lists/*

  #------------------------------------------------------------------
  # Install pytest for the grader
  #------------------------------------------------------------------
  pip3 install --no-cache-dir --upgrade pip
  pip3 install --no-cache-dir pytest

  #------------------------------------------------------------------
  # Create an unprivileged user that will own the working files
  # UID/GID 1000 is the conventional first user on Linux systems.
  #------------------------------------------------------------------
  groupadd  -g 1000 user
  useradd   -m -u 1000 -g 1000 -s /bin/bash user

  #------------------------------------------------------------------
  # Prepare the initial directory hierarchy expected by the tests
  #------------------------------------------------------------------
  install -o 1000 -g 1000 -d /home/user/project_data
  install -o 1000 -g 1000 -d /home/user/remote_backup
  install -o 1000 -g 1000 -d /home/user/sync_logs   # must start empty

  #------------------------------------------------------------------
  # Populate /home/user/project_data with the required files
  #------------------------------------------------------------------
  cat > /home/user/project_data/data1.txt <<'EOF'
Alpha
Beta
Gamma
EOF

  cat > /home/user/project_data/data2.cfg <<'EOF'
[settings]
mode=production
EOF

  cat > /home/user/project_data/data3.json <<'EOF'
{
  "version": 1.2,
  "enabled": true
}
EOF

  # Ensure correct ownership for the three source files
  chown 1000:1000 /home/user/project_data/data1.txt \
                  /home/user/project_data/data2.cfg \
                  /home/user/project_data/data3.json

  #------------------------------------------------------------------
  # Populate /home/user/remote_backup with a single stale file
  #------------------------------------------------------------------
  echo 'OldData' > /home/user/remote_backup/data1.txt
  chown 1000:1000 /home/user/remote_backup/data1.txt

  #------------------------------------------------------------------
  # Permissions: make sure everything is writable by the non-root user
  #------------------------------------------------------------------
  chmod -R u+rwX,go+rX /home/user

%environment
    chmod 755 /home/user

  # Make sure Python user base and binaries are on the PATH (pip installs here)
  export PATH="$PATH:$HOME/.local/bin"

%runscript
  echo "Container for rsync synchronisation assignment."
  echo "Switch to the 'user' account and complete the exercise as described."