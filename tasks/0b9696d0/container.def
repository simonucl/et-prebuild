Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ------------------------------------------------------------------
    # Install required packages
    # ------------------------------------------------------------------
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        coreutils \
        ca-certificates
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create directory structure and files expected by the grader
    # ------------------------------------------------------------------
    # Base home directory
    mkdir -p /home/user

    # 1. Configuration file directory and empty nginx.conf
    mkdir -p /home/user/configs
    touch /home/user/configs/nginx.conf          # must be empty (0 bytes)

    # 2. Vendor-supplied checksums file
    #    NOTE: two spaces between the hash and the path
    echo "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855  /home/user/configs/nginx.conf" \
        > /home/user/checksums.txt
    chmod 0644 /home/user/checksums.txt

    # 3. Logs directory (writable by non-root user)
    mkdir -p /home/user/logs
    chmod 0777 /home/user/logs      # ensure runtime user can write here

%environment
    chmod 755 /home/user

    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8

%labels
    Author "Apptainer task setup"
    Description "Environment prepared for Nginx checksum verification automation task."