Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Update package index and install Python along with venv support
    DEBIAN_FRONTEND=noninteractive apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        python3 \
        python3-venv \
        python3-pip \
        ca-certificates

    # Install pytest for the grading infrastructure
    pip3 install --no-cache-dir pytest

    # Create a regular user `user` with home directory /home/user, if not present
    if ! id -u user >/dev/null 2>&1; then
        useradd -m -u 1000 -s /bin/bash user
    fi

    # Ensure the home directory is owned by the correct user
    chown -R user:user /home/user

%environment
    chmod 755 /home/user

    # Basic UTF-8 locale
    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8

%runscript
    echo "Apptainer container for the incident diagnostics task. Use as needed."