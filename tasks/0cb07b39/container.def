Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    #---------------------------------------------------------------------
    # 1.  Install Python tooling and pytest for the graders
    #---------------------------------------------------------------------
    apt-get update -qq
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-setuptools \
        ca-certificates
    pip3 install --no-cache-dir pytest

    #---------------------------------------------------------------------
    # 2.  Ensure a regular user with UID 1000 exists (matches common host UID)
    #---------------------------------------------------------------------
    if ! getent passwd 1000 >/dev/null 2>&1; then
        groupadd -g 1000 user || true
        useradd  -m -u 1000 -g 1000 -s /bin/bash user || true
    fi

    #---------------------------------------------------------------------
    # 3.  Prepare backup directory and seed files
    #---------------------------------------------------------------------
    mkdir -p /home/user/backup

    # weekly_backup.dat  – single byte "a" (no newline)
    printf 'a' > /home/user/backup/weekly_backup.dat

    # weekly_backup.sha256 – hash + two spaces + filename + newline
    printf 'ca978112ca1bbdcafac231b39a23dc4da786eff8147c4e72b9807785afee48bb  weekly_backup.dat\n' \
        > /home/user/backup/weekly_backup.sha256

    # Set ownership so the (non-root) runtime user can write to the directory
    chown -R 1000:1000 /home/user

    # Permissions as required by the spec
    chmod 0755 /home/user/backup
    chmod 0644 /home/user/backup/weekly_backup.dat /home/user/backup/weekly_backup.sha256

%environment
    chmod 755 /home/user

    # Ensure Python and user-local bin dirs are on PATH
    export PATH="$PATH:$HOME/.local/bin"

%labels
    Author="Apptainer Task Setup"
    Description="Environment for the backup-and-restore checksum task with pytest pre-installed"

%help
    This container provides the initial filesystem state for the
    “backup-and-restore” integrity-check task. pytest is available for
    automated grading.