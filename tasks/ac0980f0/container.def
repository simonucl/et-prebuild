Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates
    pip3 install --no-cache-dir --upgrade pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial workspace expected by the exercise/tests
    # ------------------------------------------------------------------
    mkdir -p /home/user/services

    cat > /home/user/services/registry.txt <<'EOF'
webapp	8080	up
auth	9090	up
payments	7070	down
monitor	8181	up
search	9200	down
cache	6379	up
EOF

    # Ensure non-root users can create the required output file
    chmod -R a+rwX /home/user/services

%environment
    chmod 755 /home/user

    export LC_ALL=C.UTF-8
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

%labels
    Author="Container Exercise Autogen"
    Description="Environment for the micro-services registry transformation task"

%help
This container image sets up the initial state required for the “active_services.csv”
exercise.  It pre-populates /home/user/services/registry.txt and installs pytest so
that the automated test-suite can verify the pristine state before the learner
executes any commands.