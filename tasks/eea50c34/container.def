Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package list and install Python + pip
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        python3 \
        python3-pip

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create the required user, directories, and initial configuration
    # ------------------------------------------------------------------

    # Add a non-privileged user named "user"
    useradd -m -s /bin/bash user || true

    # Directories
    mkdir -p /home/user/data
    mkdir -p /home/user/alerts
    chmod 0755 /home/user/data
    chmod 0755 /home/user/alerts

    # Initial configuration file with exact content and a trailing newline
    cat > /home/user/data/critical_config.cfg <<'EOF'
DB_HOST=localhost
DB_PORT=5432
DB_USER=monitor
DB_PASS=monitor123
EOF
    chmod 0644 /home/user/data/critical_config.cfg

    # Ensure the "user" account owns its home directory tree
    chown -R user:user /home/user

%environment
    chmod 755 /home/user

    # Minimal PATH setup
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

%labels
    Author setup-script
    Description "Container for checksum monitoring task (pytest pre-state ensured)"