Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    #-----------------------------------------------------------------------
    # Install Python and pytest
    #-----------------------------------------------------------------------
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    #-----------------------------------------------------------------------
    # Create the required INI file fixture
    #-----------------------------------------------------------------------
    mkdir -p /home/user/project

    cat > /home/user/project/perf_settings.ini <<'EOF'
[database]
max_connections = 200
timeout_seconds = 60

[server]
thread_pool_size = 32
enable_caching = true

[logging]
level = INFO
rotate = daily
EOF

    # Ensure world-readable permissions
    chmod 0644 /home/user/project/perf_settings.ini

    # Ensure directory traversal permissions for all users
    chmod 0755 /home
    chmod 0755 /home/user
    chmod 0755 /home/user/project

%environment
    chmod 755 /home/user

    # Make sure Python is available
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%labels
    Maintainer="container-builder"
    Description="Environment for INI summary exercise with pytest pre-installed."