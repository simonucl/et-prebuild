Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # Install Python and pytest
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ---------------------------------------------------------------------
    # Prepare initial deployment tree expected by the automated test suite
    # ---------------------------------------------------------------------
    DEPLOY_DIR="/home/user/deployment"
    CONFIGS_DIR="${DEPLOY_DIR}/configs"

    # Create directory structure
    mkdir -p "${CONFIGS_DIR}"

    # Create initial app.env
    cat > "${CONFIGS_DIR}/app.env" << 'EOF'
APP_NAME=SampleApp
APP_VERSION=1.3.4
APP_PORT=8080
EOF

    # Create initial db.env
    cat > "${CONFIGS_DIR}/db.env" << 'EOF'
DB_NAME=sampledb
DB_HOST=localhost
DB_PORT=5432
DB_USER=sampleuser
DB_PASSWORD=samplepass
EOF

    # Ensure every non-root user can work inside /home/user
    chmod -R a+rwX /home/user

%environment
    chmod 755 /home/user

    # Nothing to override; keep default environment.

%runscript
    exec "$@"

%test
    # The autogenerated test section is intentionally left empty.
    exit 0