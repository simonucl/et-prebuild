Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    ## Install Python and pytest
    apt-get update && \
        apt-get install -y --no-install-recommends \
            python3 python3-pip python3-setuptools ca-certificates && \
        rm -rf /var/lib/apt/lists/*
    pip3 install --no-cache-dir pytest

    ## Create the required initial directory structure and files
    mkdir -p /home/user/experiments/run_01

    # model.bin – 5× repetition of the same line (95 bytes total)
    cat > /home/user/experiments/run_01/model.bin << 'EOF'
MODEL_WEIGHTS_v1.0
MODEL_WEIGHTS_v1.0
MODEL_WEIGHTS_v1.0
MODEL_WEIGHTS_v1.0
MODEL_WEIGHTS_v1.0
EOF

    # metrics.json
    cat > /home/user/experiments/run_01/metrics.json << 'EOF'
{
  "accuracy": 0.93,
  "loss": 0.2
}
EOF

    # config.yaml
    cat > /home/user/experiments/run_01/config.yaml << 'EOF'
learning_rate: 0.001
epochs: 10
EOF

    ## Set permissions so the unprivileged runtime user can write under /home/user
    chmod 0777 /home/user
    chmod 644 /home/user/experiments/run_01/*

%labels
    chmod 755 /home/user

    Author="Apptainer setup for archive-experiment exercise"