Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package index and install Python & Pytest
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Prepare filesystem required for the assessment
    # ------------------------------------------------------------------
    # Create firewall directory and populate iptables.rules
    mkdir -p /home/user/firewall

    cat > /home/user/firewall/iptables.rules <<'EOF'
*filter
:INPUT ACCEPT [0:0]
:FORWARD ACCEPT [0:0]
:OUTPUT ACCEPT [0:0]
-A INPUT -m conntrack --ctstate RELATED,ESTABLISHED -j ACCEPT
-A INPUT -p tcp -m tcp --dport 22 -j ACCEPT
COMMIT
EOF

    # Set appropriate permissions (read-only file, world-readable directory)
    chmod 755 /home/user
    chmod 755 /home/user/firewall
    chmod 644 /home/user/firewall/iptables.rules

    # Ensure audit directory does NOT exist at build time
    rm -rf /home/user/audit

%environment
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%labels
    Author "OpenAI Assistant"
    Description "Environment for SSH firewall audit task with pytest installed"