Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    export DEBIAN_FRONTEND=noninteractive

    # Update package lists and install Python and pip
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install pytest for the test-runner
    pip3 install --no-cache-dir pytest

    # Create the required base workspace directory for the exercise
    mkdir -p /home/user
    chmod 0777 /home/user   # Ensure all future users can write here

    # Clean up apt cache to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Make sure Python user-installed binaries are discoverable
    export PATH=/usr/local/bin:$PATH

%labels
    Author="Apptainer Task Preparation Bot"
    Description="Environment for kernel-release logging exercise (pytest pre-installed)"