Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python tooling and pytest
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Create an unprivileged user
    groupadd -g 1000 user
    useradd  -m -u 1000 -g 1000 -s /bin/bash user

    # ------------------------------------------------------------------
    # Populate the initial working directory structure and manifest files
    # ------------------------------------------------------------------
    mkdir -p /home/user/manifests

    # deployment.yaml (image nginx:1.19 at start)
    cat <<'DEPLOY' > /home/user/manifests/deployment.yaml
apiVersion: apps/v1
kind: Deployment
metadata:
  name: webserver
spec:
  replicas: 2
  selector:
    matchLabels:
      app: web
  template:
    metadata:
      labels:
        app: web
    spec:
      containers:
      - name: nginx
        image: nginx:1.19
        ports:
        - containerPort: 80
DEPLOY

    # service.yaml
    cat <<'SERVICE' > /home/user/manifests/service.yaml
apiVersion: v1
kind: Service
metadata:
  name: web-svc
spec:
  selector:
    app: web
  ports:
  - port: 80
    targetPort: 80
SERVICE

    # configmap.yaml
    cat <<'CONFIG' > /home/user/manifests/configmap.yaml
apiVersion: v1
kind: ConfigMap
metadata:
  name: web-config
data:
  index.html: |
    <h1>Hello World!</h1>
CONFIG

    # Set appropriate permissions
    chmod 644 /home/user/manifests/*.yaml
    chmod 755 /home/user /home/user/manifests
    chown -R 1000:1000 /home/user

%labels
    Author ChatGPT
    Description "Exercise container for Kubernetes YAML manipulation task"

%runscript
    exec /bin/bash "$@"