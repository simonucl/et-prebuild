Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "Updating package index and installing Python tooling..."
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Clean up apt caches to keep the image lean
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    echo "Installing pytest..."
    pip3 install --no-cache-dir pytest

    echo "Creating initial filesystem layout for netdiag assignment..."
    # Base directory
    mkdir -p /home/user/netdiag/configs
    mkdir -p /home/user/netdiag/logs

    # Create the required configuration files
    cat <<'EOF' >/home/user/netdiag/configs/router.conf
# Router config
hostname R1
interface Gi0/0
 ip address 192.168.1.1 255.255.255.0
EOF

    cat <<'EOF' >/home/user/netdiag/configs/switch.conf
# Switch config
hostname SW1
vlan 10
 name USERS
EOF

    # Ensure correct, safe permissions (not world-writable)
    chmod 0755 /home/user
    chmod 0755 /home/user/netdiag
    chmod 0755 /home/user/netdiag/configs
    chmod 0755 /home/user/netdiag/logs
    chmod 0644 /home/user/netdiag/configs/router.conf
    chmod 0644 /home/user/netdiag/configs/switch.conf

    echo "Initial netdiag layout created."

%environment
    chmod 755 /home/user

    # Make sure Python and pip are in the PATH
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%labels
    Author="Generated by ChatGPT"
    Description="Environment for the netdiag symlink/audit assignment with pytest pre-installed."

%help
    This container provides the starting filesystem snapshot for the
    “netdiag” assignment.  Two configuration files are present under
    /home/user/netdiag/configs, and an empty logs directory is ready for use.
    Pytest is installed for automated testing.