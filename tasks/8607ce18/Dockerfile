FROM ubuntu:22.04

# Help text
# This container provides the starting filesystem snapshot for the
# “netdiag” assignment. Two configuration files are present under
# /home/user/netdiag/configs, and an empty logs directory is ready for use.
# Pytest is installed for automated testing.
# Author="Generated by ChatGPT"
# Description="Environment for the netdiag symlink/audit assignment with pytest pre-installed."

ENV PATH="/usr/local/bin:/usr/bin:/bin:${PATH}"

RUN set -e && \
    echo "Updating package index and installing Python tooling..." && \
    apt-get update -y && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

RUN pip3 install --no-cache-dir pytest

RUN mkdir -p /home/user/netdiag/configs && \
    mkdir -p /home/user/netdiag/logs

RUN cat <<'EOF' >/home/user/netdiag/configs/router.conf
# Router config
hostname R1
interface Gi0/0
 ip address 192.168.1.1 255.255.255.0
EOF

RUN cat <<'EOF' >/home/user/netdiag/configs/switch.conf
# Switch config
hostname SW1
vlan 10
 name USERS
EOF

RUN chmod 0755 /home/user && \
    chmod 0755 /home/user/netdiag && \
    chmod 0755 /home/user/netdiag/configs && \
    chmod 0755 /home/user/netdiag/logs && \
    chmod 0644 /home/user/netdiag/configs/router.conf && \
    chmod 0644 /home/user/netdiag/configs/switch.conf