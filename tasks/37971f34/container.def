Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author performance-engineering-setup
    Description Base image for “profiling environment variables” exercise

%post
    # Update package lists and install Python plus pip
    apt-get update && \
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates && \
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the test harness
    pip3 install --no-cache-dir pytest

    # Prepare writable home directory for the unprivileged runtime user
    mkdir -p /home/user
    chmod 0777 /home/user

%environment
    chmod 755 /home/user

    # Ensure the user-installed Python tools are on the PATH
    export PATH="/usr/local/bin:$PATH"

%runscript
    # Default runscript: just execute whatever the caller asked for
    exec "$@"