Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author automated-setup
    Description Ensure initial environment for security audit task and provide test dependencies.

%post
    set -e

    export DEBIAN_FRONTEND=noninteractive

    # Update package lists and install required tools.
    apt-get update -y
    apt-get install -y --no-install-recommends \
        curl \
        python3 \
        python3-pip

    # Install pytest for the automated checks.
    pip3 install --no-cache-dir pytest

    # Create the base home directory expected by the tests.
    mkdir -p /home/user
    chmod 0755 /home/user

    # Clean up APT caches to keep the image small.
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure Python and pip user-level installs (if any) are in PATH.
    export PATH=/usr/local/bin:/usr/local/sbin:/usr/bin:/usr/sbin:/bin:/sbin

%runscript
    echo "Container is ready for the security audit task."
    echo "You are currently inside the runtime shell."
    exec "$@"