Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package index and install Python + pip
    apt-get update && \
        DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
            python3 \
            python3-pip \
            ca-certificates \
            bash && \
        rm -rf /var/lib/apt/lists/*

    # Install pytest globally
    pip3 install --no-cache-dir pytest

    # Create a non-root user `user` with home directory /home/user
    if ! id -u user >/dev/null 2>&1; then
        useradd -m -s /bin/bash user
    fi

    # Ensure the user owns its home directory
    chown -R user:user /home/user

    # IMPORTANT: Do NOT create any mlops benchmark artefacts here;
    # the student workflow must create them during execution.

%environment
    chmod 755 /home/user

    # Minimal environment setup
    export PYTHONDONTWRITEBYTECODE=1

%runscript
    # Default runscript: just execute the given command
    exec "$@"

%labels
    Author  Your Name
    Description  Base image with Python and pytest for MLOps benchmark task