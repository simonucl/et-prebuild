Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial directory structure for the exercise
    # ------------------------------------------------------------------
    mkdir -p /home/user/projects/raw_data

    # Create the required CSV files with sample contents.
    cat > /home/user/projects/raw_data/sales_2023.csv <<'EOF'
id,amount
1,100
EOF

    cat > /home/user/projects/raw_data/inventory_2022.csv <<'EOF'
sku,qty
A1,50
EOF

    cat > /home/user/projects/raw_data/finance_2023.csv <<'EOF'
quarter,profit
Q1,2000
EOF

    # Empty file
    touch /home/user/projects/raw_data/broken.csv

    # ------------------------------------------------------------------
    # Ensure the runtime (non-root) user can modify everything under /home/user
    # ------------------------------------------------------------------
    chmod -R a+rwX /home/user

%environment
    chmod 755 /home/user

    # Keep a reasonable PATH inside the container
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%labels
    Author="Apptainer exercise setup – data-pipeline prototype"
    Description="Container that provides the clean starting state for the shell-based CSV moving exercise."