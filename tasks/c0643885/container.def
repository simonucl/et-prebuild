Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Prepare initial filesystem state expected by the automatic tests
    # ------------------------------------------------------------------

    # Create home and base audit directories; make them writable for any user
    mkdir -p /home/user
    chmod 0777 /home/user

    mkdir -p /home/user/audit
    chmod 0777 /home/user/audit

    # Input directory must exist with 0755 permissions
    mkdir -p /home/user/audit/input
    chmod 0755 /home/user/audit/input

    # Create the CSV file with exact required contents and 0644 permissions
    cat >/home/user/audit/input/user_permissions.csv <<"EOF"
username,uid,permission
alice,1001,read
bob,1002,write
carol,1003,execute
dave,1004,write
erin,1005,read
EOF
    chmod 0644 /home/user/audit/input/user_permissions.csv

%environment
    chmod 755 /home/user

    # Ensure Python and common bin directories are on PATH
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author "Apptainer task setup autogenerated"

%help
    This container image sets up the initial filesystem and environment
    required for the “permissions audit” programming exercise.