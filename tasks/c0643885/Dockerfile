# syntax=docker/dockerfile:1
FROM ubuntu:22.04

# Help text from %help
# This container image sets up the initial filesystem and environment
# required for the “permissions audit” programming exercise.

# %post
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked --mount=type=cache,target=/var/lib/apt,sharing=locked --mount=type=cache,target=/root/.cache/pip set -e && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip && \
    pip3 install --no-cache-dir pytest && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

RUN mkdir -p /home/user && chmod 0777 /home/user
RUN mkdir -p /home/user/audit && chmod 0777 /home/user/audit
RUN mkdir -p /home/user/audit/input && chmod 0755 /home/user/audit/input

RUN cat <<'EOF' >/home/user/audit/input/user_permissions.csv
username,uid,permission
alice,1001,read
bob,1002,write
carol,1003,execute
dave,1004,write
erin,1005,read
EOF

RUN chmod 0644 /home/user/audit/input/user_permissions.csv

# %environment
ENV PATH=/usr/local/bin:/usr/bin:/bin:$PATH

RUN chmod 755 /home/user

# %labels
LABEL Author="Apptainer task setup autogenerated"