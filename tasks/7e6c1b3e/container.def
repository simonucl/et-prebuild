Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author      Apptainer Task Prep Bot
    Description Container providing initial state for the web-analytics cut/paste task

%post
    set -eux

    #######################################################################
    # 1. Install Python and pytest (plus minimal utilities)
    #######################################################################
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Upgrade pip and install pytest
    python3 -m pip install --no-cache-dir --upgrade pip
    python3 -m pip install --no-cache-dir pytest

    #######################################################################
    # 2. Create the required initial directory structure and CSV file
    #######################################################################
    # Directory layout: /home/user/projects/web_analytics/raw
    mkdir -p /home/user/projects/web_analytics/raw

    # Make sure the student can write inside /home/user and sub-dirs
    chmod -R 0777 /home/user

    # Create the raw CSV file with EXACT contents (final newline included)
    cat > /home/user/projects/web_analytics/raw/analytics_2023-10-15.csv << 'EOF'
Date,PageViews,UniqueVisitors,BounceRate,AvgTimeOnPage
2023-10-10,1450,675,0.42,00:03:21
2023-10-11,1320,598,0.38,00:03:10
2023-10-12,1703,840,0.41,00:03:45
2023-10-13,1250,560,0.40,00:03:05
2023-10-14,1800,910,0.39,00:03:50
EOF

    # Ensure readability of the CSV (write permission not required)
    chmod 0644 /home/user/projects/web_analytics/raw/analytics_2023-10-15.csv

%environment
    chmod 755 /home/user

    # Nothing special; retain default HOME binding

%runscript
    # Default runscript — open an interactive shell
    exec bash -l