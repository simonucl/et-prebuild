Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Avoid interactive prompts during package installation
    export DEBIAN_FRONTEND=noninteractive

    # Update package index and install required utilities
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        iproute2

    # Clean up apt caches to keep image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the grading harness
    pip3 install --no-cache-dir pytest

    # Prepare the generic user home so learners have a writable location
    mkdir -p /home/user
    chmod 0777 /home/user

%environment
    chmod 755 /home/user

    # Ensure Python user-installed binaries are on PATH (if any are added later)
    export PATH=/usr/local/bin:$PATH

%labels
    Author network-diagnostic-task
    Description "Base image for network diagnostic exercise with pytest and iproute2 installed."