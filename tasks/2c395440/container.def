Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author  SystemDiagnosticsContainerSetup
    Description "Base image for system diagnostics assignment with pytest installed."

%post
    # Update package index and install required packages
    apt-get update
    # Base utilities are usually present but ensure core packages exist
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        python3 \
        python3-pip \
        procps \
        iproute2

    # Install pytest for the test harness
    pip3 install --no-cache-dir pytest

    # Create writable home directory for the student
    mkdir -p /home/user
    # Make sure any unprivileged container user can write here
    chmod 0777 /home/user

    # Clean up apt caches to keep the image lean
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure Python and local binaries are on PATH
    export PATH="/usr/local/bin:/usr/bin:/bin:${PATH}"

%runscript
    echo "Container for the system diagnostics assignment. Start an interactive shell:"
    exec /bin/bash -l