Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "---- Installing system packages ----"
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        lynx \
        locales \
        ca-certificates

    echo "---- Setting up locale ----"
    locale-gen en_US.UTF-8

    echo "---- Creating non-root user 'user' ----"
    useradd -m -u 1000 -s /bin/bash user

    echo "---- Preparing release_pages directory ----"
    mkdir -p /home/user/release_pages

    # Alpha
    cat > /home/user/release_pages/alpha_release.html <<'EOF'
<html>
<head><title>Alpha Service Releases</title></head>
<body>
<h1>Alpha Service Releases</h1>

<section class="release">
<h2>v2.3.1</h2>
<p>Date: 2024-07-15</p>
<ul>
<li>FIX: Patched security vulnerability ALP-448</li>
<li>IMPROVEMENT: Reduced memory footprint</li>
</ul>
</section>
</body>
</html>
EOF

    # Beta
    cat > /home/user/release_pages/beta_release.html <<'EOF'
<html>
<head><title>Beta Service Releases</title></head>
<body>
<h1>Beta Service Releases</h1>

<section class="release">
<h2>v1.8.0</h2>
<p>Date: 2024-07-14</p>
<ul>
<li>ADD: GraphQL endpoint for analytics</li>
</ul>
</section>
</body>
</html>
EOF

    # Gamma
    cat > /home/user/release_pages/gamma_release.html <<'EOF'
<html>
<head><title>Gamma Service Releases</title></head>
<body>
<h1>Gamma Service Releases</h1>

<section class="release">
<h2>v5.0.0</h2>
<p>Date: 2024-07-10</p>
<ul>
<li>MAJOR: Migrated to service mesh architecture</li>
</ul>
</section>
</body>
</html>
EOF

    # Ensure each file ends with a newline
    echo >> /home/user/release_pages/alpha_release.html
    echo >> /home/user/release_pages/beta_release.html
    echo >> /home/user/release_pages/gamma_release.html

    echo "---- Setting permissions ----"
    chmod 755  /home/user/release_pages
    chmod 644  /home/user/release_pages/*.html
    chown -R   user:user /home/user

    echo "---- Installing Python packages ----"
    pip3 install --no-cache-dir pytest

    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    export LC_ALL=en_US.UTF-8
    export LANG=en_US.UTF-8

%runscript
    echo "Apptainer image for release-scraping task ready."
    exec /bin/bash "$@"