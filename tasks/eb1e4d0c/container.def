Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install Python along with the venv module
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-venv \
        python3-pip \
        ca-certificates

    # Install pytest for the automated checker
    pip3 install --no-cache-dir pytest

    # Ensure a writable home directory for the non-root agent
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up APT cache to keep image size small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Make sure the default python points to python3
    export PATH=/usr/local/bin:/usr/bin:/bin
    export PYTHONIOENCODING=utf-8
    export LANG=C.UTF-8

%runscript
    exec "${@}"