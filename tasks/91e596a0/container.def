Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # Update package lists and install Python & pip
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-setuptools \
        python3-venv

    # Install pytest for the forthcoming test-suites
    pip3 install --no-cache-dir pytest

    # Ensure the working directory for the assignment exists and is writable
    mkdir -p /home/user
    chmod 0777 /home/user   # Give future unprivileged user full write access

%environment
    chmod 755 /home/user

    export PATH=/usr/local/bin:/usr/bin:/bin
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8