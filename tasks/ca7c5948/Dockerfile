FROM ubuntu:22.04

# Labels
LABEL Author="Autogenerated for data-cleaning summary task"
LABEL Description="Container providing initial state and pytest for the data-cleaning log summarization challenge."

# Install Python and Pytest
RUN set -e && \
    apt-get update && \
    apt-get install -y --no-install-recommends python3 python3-pip && \
    pip install --no-cache-dir pytest

# Create the directory structure
RUN mkdir -p /home/user/datasets/logs

# Populate the pre-existing cleaning log
RUN cat > /home/user/datasets/logs/cleaning.log <<'EOF'
2023-08-14 09:00:00 INFO Cleaning script initiated
2023-08-14 09:00:01 INFO Loaded 4789 rows
2023-08-14 09:00:02 WARN Removed 123 rows with missing values
2023-08-14 09:00:03 WARN Removed 56 rows with out-of-range values
2023-08-14 09:00:04 WARN Removed 12 duplicate rows
2023-08-14 09:00:05 INFO Finished cleaning successfully: 4598 rows remaining
EOF

# Ensure sensible permissions (readable by all, writable by owner)
RUN chmod 0644 /home/user/datasets/logs/cleaning.log && \
    chmod 0755 /home/user /home/user/datasets /home/user/datasets/logs

# Environment variables
ENV PATH="/usr/local/bin:$PATH"

# Set working directory
WORKDIR /home/user

# Default command
CMD echo "Container for the data-cleaning summarization task." && echo "Invoke your own commands inside the container to complete the assignment."