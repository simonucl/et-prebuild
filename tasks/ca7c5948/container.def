Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and Pytest
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial data for the student
    # ------------------------------------------------------------------
    # Create the directory structure
    mkdir -p /home/user/datasets/logs

    # Populate the pre-existing cleaning log
    cat > /home/user/datasets/logs/cleaning.log <<'EOF'
2023-08-14 09:00:00 INFO Cleaning script initiated
2023-08-14 09:00:01 INFO Loaded 4789 rows
2023-08-14 09:00:02 WARN Removed 123 rows with missing values
2023-08-14 09:00:03 WARN Removed 56 rows with out-of-range values
2023-08-14 09:00:04 WARN Removed 12 duplicate rows
2023-08-14 09:00:05 INFO Finished cleaning successfully: 4598 rows remaining
EOF

    # Ensure sensible permissions (readable by all, writable by owner)
    chmod 0644 /home/user/datasets/logs/cleaning.log
    chmod 0755 /home/user /home/user/datasets /home/user/datasets/logs

%environment
    chmod 755 /home/user

    # Make sure pip-installed executables are on PATH
    export PATH="/usr/local/bin:$PATH"

%labels
    Author "Autogenerated for data-cleaning summary task"
    Description "Container providing initial state and pytest for the data-cleaning log summarization challenge."

%runscript
    echo "Container for the data-cleaning summarization task."
    echo "Invoke your own commands inside the container to complete the assignment."