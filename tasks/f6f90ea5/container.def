Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Update package index and install required software
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        procps \
        ca-certificates

    # Install pytest for the grading framework
    pip3 install --no-cache-dir pytest

    # Create a writable workspace for the learner
    mkdir -p /home/user/restore_test
    # Ensure no leftover log from previous builds
    rm -f /home/user/restore_test/restore_session.log

    # Make the directory tree writable for the unprivileged runtime user
    chmod 0777 /home/user
    chmod 0777 /home/user/restore_test

    # Clean up APT caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Minimal PATH – do not override HOME
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

%labels
    Author="Apptainer Task Prep"
    Description="Environment prepared for dummy restore drill with pytest pre-installed."