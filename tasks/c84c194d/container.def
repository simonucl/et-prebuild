Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author db-firewall-task
    Description "Environment for the firewall rule single-command task"

%post
    set -eux

    # Update apt cache and install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 python3-pip
    pip3 install --no-cache-dir pytest

    # Create the working directory and baseline firewall configuration
    mkdir -p /home/user

    cat > /home/user/firewall.conf <<'EOF'
*filter
:INPUT DROP [0:0]
:FORWARD DROP [0:0]
:OUTPUT ACCEPT [0:0]

# Allow SSH
-A INPUT -p tcp --dport 22 -j ACCEPT

# DB RULES

COMMIT
EOF

    # Make sure the file is writable by the unprivileged user who will run the task
    chmod 666 /home/user/firewall.conf

    # Clean up apt artifacts to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Keep HOME as provided by Apptainer, just ensure Python and Pip are on PATH
    export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
    export PYTHONIOENCODING="utf-8"

%runscript
    echo "Container for firewall rule task.  Open a shell to begin work:"
    exec /bin/bash -l