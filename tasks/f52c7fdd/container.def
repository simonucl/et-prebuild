Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author AutomatedSetup
    Description "Environment for CSV-to-TSV column-reformatting task."

%post
    set -e

    # Update package list and install Python plus pip
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install pytest for the autograder
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Seed data required by the exercise
    # ------------------------------------------------------------------
    mkdir -p /home/user/data

    cat > /home/user/data/raw_contacts.csv <<'EOF'
id,name,email,department
1,Alice Anderson,alice.anderson@example.com,Finance
2,Bob Brown,bob.brown@example.com,Engineering
3,Charlie Clark,charlie.clark@example.com,Marketing
EOF

    # Make /home/user writable so the learner (non-root inside container)
    # can create /home/user/report and its files.
    chmod 0777 /home/user

    # Reduce image size
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure UTF-8 locale for predictable text handling
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%help
This container provides the starting environment for the CSV→TSV
column-extraction task.  
The file /home/user/data/raw_contacts.csv is pre-populated exactly as
specified, and pytest is available for the automated tests.