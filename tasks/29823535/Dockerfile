# Author: Container build script autogenerated by ChatGPT
# Description: Environment for loop-back diagnostics exercise with pytest pre-installed
# Note: Original Apptainer runscript is not directly supported in Docker.

FROM ubuntu:22.04

RUN set -e && \
    echo "Updating package lists..." && \
    apt-get update -y

RUN set -e && \
    echo "Installing required networking tools and Python utilities..." && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        iputils-ping \
        iproute2 \
        python3-pip \
        ca-certificates

RUN set -e && \
    echo "Installing pytest via pip..." && \
    pip3 install --no-cache-dir pytest

RUN set -e && \
    echo "Creating the student's home directory..." && \
    mkdir -p /home/user && \
    chmod 0755 /home/user

RUN set -e && \
    echo "Cleaning up APT caches to keep the image small..." && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

RUN chmod 755 /home/user

ENV PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin