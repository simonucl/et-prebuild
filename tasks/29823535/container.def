BootStrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "Updating package lists..."
    apt-get update -y

    echo "Installing required networking tools and Python utilities..."
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        iputils-ping \
        iproute2 \
        python3-pip \
        ca-certificates

    echo "Installing pytest via pip..."
    pip3 install --no-cache-dir pytest

    echo "Creating the student's home directory..."
    mkdir -p /home/user
    chmod 0755 /home/user

    echo "Cleaning up APT caches to keep the image small..."
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure standard paths are available
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

%labels
    Author="Container build script autogenerated by ChatGPT"
    Description="Environment for loop-back diagnostics exercise with pytest pre-installed"

%runscript
    # Default action when the container is executed without arguments
    echo "This container is set up for the loop-back diagnostics exercise."
    echo "Open a shell with: apptainer exec <image.sif> /bin/bash"