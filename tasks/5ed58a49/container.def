Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update apt repositories and install Python and pip
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        python3 \
        python3-pip \
        ca-certificates \
        --no-install-recommends

    # Install pytest for the workspace user
    pip3 install --no-cache-dir pytest

    # Ensure a writable, world-accessible home directory for the unprivileged user
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up apt cache to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Make sure Python user installs (pip --user) are on PATH
    export PATH="$HOME/.local/bin:$PATH"

%labels
    Author="Apptainer Auto-Build"
    Description="Base image with pytest and writable /home/user for the Kubernetes mini-operator task."

# No %runscript or %test section required