Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install required packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        sqlite3 \
        python3-pip \
        ca-certificates

    # Clean apt caches to keep image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the checker
    pip3 install --no-cache-dir pytest

    # ---------------------------------------------------------------------
    # Create runtime user and its home directory
    # ---------------------------------------------------------------------
    USERNAME="user"
    USERHOME="/home/${USERNAME}"

    # Create the user if it does not already exist
    if ! id -u "${USERNAME}" >/dev/null 2>&1; then
        groupadd --gid 1000 "${USERNAME}"
        useradd  --uid 1000 \
                 --gid 1000 \
                 --create-home \
                 --home-dir "${USERHOME}" \
                 --shell /bin/bash \
                 "${USERNAME}"
    fi

    # Ensure the home directory exists with correct ownership
    mkdir -p "${USERHOME}"
    chown "${USERNAME}:${USERNAME}" "${USERHOME}"

    # ---------------------------------------------------------------------
    # Create and populate the SQLite helpdesk.db database
    # ---------------------------------------------------------------------
    DB_PATH="${USERHOME}/helpdesk.db"

    # Build the database with the required schema and data
    cat <<'SQL_CMDS' | sqlite3 "${DB_PATH}"
    PRAGMA foreign_keys = OFF;
    BEGIN TRANSACTION;
    CREATE TABLE tickets (
        id          INTEGER PRIMARY KEY,
        status      TEXT,
        assigned_to TEXT
    );
    INSERT INTO tickets (id, status, assigned_to) VALUES
        (1, 'open',   'unassigned'),
        (2, 'closed', 'alice'),
        (3, 'open',   'unassigned'),
        (4, 'open',   'bob'),
        (5, 'closed', 'unassigned'),
        (6, 'open',   'charlie');
    COMMIT;
SQL_CMDS

    # Set correct permissions (rw-r--r--)
    chmod 0644 "${DB_PATH}"
    chown "${USERNAME}:${USERNAME}" "${DB_PATH}"

%environment
    chmod 755 /home/user

    # Ensure /home/user is on PATH for convenience
    export PATH="${PATH}:${HOME}/.local/bin"

%labels
    Author="Apptainer build script"
    Description="Environment for helpdesk ticket counting task with pre-populated SQLite database."

%runscript
    # Default runscript: open a shell
    exec /bin/bash "$@"