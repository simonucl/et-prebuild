Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package listings and install required utilities.
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends \
        iputils-ping \
        python3-pip
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the test harness.
    pip3 install --no-cache-dir pytest

    # Ensure the default working directory for the exercise exists and is writable
    # by any (non-root) user who may enter the container.
    mkdir -p /home/user
    chmod 0777 /home/user

%environment
    chmod 755 /home/user

    # No HOME override—Apptainer will bind the caller’s real $HOME.
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%labels
    Author LoopbackPingExercise
    Description "Base image for the loopback ping logging exercise (with pytest and ping installed)."

%runscript
    echo "Container for the loopback ping logging exercise."
    echo "Invoke a shell or run your commands as needed."