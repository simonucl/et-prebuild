# syntax=docker/dockerfile:1
FROM ubuntu:22.04

# ------------------------------------------------------------------
# Install required system packages and pytest
# ------------------------------------------------------------------
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked --mount=type=cache,target=/var/lib/apt,sharing=locked --mount=type=cache,target=/root/.cache/pip set -e && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        make && \
    pip3 install --no-cache-dir pytest && \
    rm -rf /var/lib/apt/lists/*

# ------------------------------------------------------------------
# Create initial directory structure and seed data files
# ------------------------------------------------------------------
RUN mkdir -p /home/user/compliance_project/data

# policies.json – exactly three lines
RUN cat > /home/user/compliance_project/data/policies.json << 'EOF'
{"id":1,"policy":"encryption"}
{"id":2,"policy":"access-control"}
{"id":3,"policy":"backup"}
EOF

# controls.csv – exactly four lines
RUN cat > /home/user/compliance_project/data/controls.csv << 'EOF'
id,control
1,Full Disk Encryption
2,Role Based Access Control
3,Automated Backups
EOF

# ------------------------------------------------------------------
# Set safe permissions (readable by all, writable by owner)
# ------------------------------------------------------------------
RUN chmod 755 /home/user && \
    chmod -R 755 /home/user/compliance_project && \
    chmod 644 /home/user/compliance_project/data/policies.json && \
    chmod 644 /home/user/compliance_project/data/controls.csv

# ------------------------------------------------------------------
# Environment variables
# ------------------------------------------------------------------
ENV LANG=C.UTF-8 \
    LC_ALL=C.UTF-8

# ------------------------------------------------------------------
# Metadata
# ------------------------------------------------------------------
LABEL Author="Auto-generated by AI" \
      Description="Starter container for the compliance_project exercise with pytest pre-installed."