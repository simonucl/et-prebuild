Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install required system packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 python3-pip make

    # Install pytest for the grading suite
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create initial directory structure and seed data files
    # ------------------------------------------------------------------
    mkdir -p /home/user/compliance_project/data

    # policies.json – exactly three lines
    cat > /home/user/compliance_project/data/policies.json << 'EOF'
{"id":1,"policy":"encryption"}
{"id":2,"policy":"access-control"}
{"id":3,"policy":"backup"}
EOF

    # controls.csv – exactly four lines
    cat > /home/user/compliance_project/data/controls.csv << 'EOF'
id,control
1,Full Disk Encryption
2,Role Based Access Control
3,Automated Backups
EOF

    # Set safe permissions (readable by all, writable by owner)
    chmod 755 /home/user
    chmod -R 755 /home/user/compliance_project
    chmod 644 /home/user/compliance_project/data/policies.json
    chmod 644 /home/user/compliance_project/data/controls.csv

%environment
    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8

%labels
    Author          "Auto-generated by AI"
    Description     "Starter container for the compliance_project exercise with pytest pre-installed."