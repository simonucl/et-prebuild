Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install Python & pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install pytest for the test harness
    pip3 install --no-cache-dir pytest

    # --------------------------------------------------------------------
    # Prepare initial filesystem state expected by the tests
    # --------------------------------------------------------------------

    # Create the user’s home directory structure
    mkdir -p /home/user/app/current

    # Ensure the student will be able to write within /home/user
    chmod 0777 /home/user

    # Populate /home/user/app/current with the two required files
    echo "# placeholder" > /home/user/app/current/app.py
    echo "Demo app"     > /home/user/app/current/README.md

    # Set correct permissions on the files
    chmod 0644 /home/user/app/current/app.py
    chmod 0644 /home/user/app/current/README.md

%environment
    chmod 755 /home/user

    export PATH="/usr/local/bin:/usr/bin:/bin:${PATH}"

%labels
    Author="Automated build"
    Description="Container for deployment snapshot task with initial state and pytest installed."