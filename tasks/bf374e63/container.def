Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package list and install Python and pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    # Install pytest (required by the grader)
    pip3 install --no-cache-dir pytest
    # Clean up apt caches
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Prepare filesystem for the capacity-planner exercise.
    # NOTE:
    #   * /home/user **must** exist and be writable so the student can
    #     create /home/user/capacity_planner.
    #   * /home/user/reports **must** exist and be writable because the
    #     student’s script will append to usage_report.log there.
    # ------------------------------------------------------------------
    mkdir -p /home/user/reports
    chmod 0777 /home/user          # Ensure the future student UID can write
    chmod 0777 /home/user/reports  # Writable by any user

%environment
    chmod 755 /home/user

    # Minimal PATH setup; do NOT override $HOME
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%runscript
    echo "Capacity-planner exercise container."
    echo "Start a shell with:  apptainer exec -e \$0 /bin/bash"

%labels
    Author="Apptainer Task Builder"
    Description="Base image for capacity-planner exercise with pytest pre-installed."