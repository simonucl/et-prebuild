Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    ############################################################
    # 1) Install required packages                             #
    ############################################################
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        sqlite3
    pip install --no-cache-dir pytest

    ############################################################
    # 2) Prepare directory structure                           #
    ############################################################
    # Make sure /home/user exists and is writable by the runtime user
    mkdir -p /home/user
    chmod 777 /home/user

    # Project directories
    mkdir -p /home/user/projects/loc/db
    chmod -R 777 /home/user/projects

    ############################################################
    # 3) Create and seed the SQLite database                   #
    ############################################################
    sqlite3 /home/user/projects/loc/db/translations.db <<'SQL'
    PRAGMA journal_mode=OFF;
    PRAGMA synchronous=OFF;

    CREATE TABLE translations (
        id          INTEGER PRIMARY KEY,
        locale      TEXT,
        key         TEXT,
        value       TEXT,
        updated_at  TEXT
    );

    INSERT INTO translations (id, locale, key, value, updated_at) VALUES
        (1, 'en', 'welcome', 'Welcome', '2023-01-01'),
        (2, 'en', 'logout',  'Logout',  '2023-01-01'),
        (3, 'es', 'welcome', 'Bienvenido', '2023-01-01'),
        (4, 'es', 'logout',  'Cerrar sesión', '2023-01-01');
SQL

    # Database file must be world-readable and writable by the agent
    chmod 666 /home/user/projects/loc/db/translations.db

    ############################################################
    # 4) Clean up to keep image size small                     #
    ############################################################
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Keep locale sane for Python / SQLite
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8