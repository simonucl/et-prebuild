Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install Python tooling
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-venv \
        python3-pip \
        ca-certificates

    # Clean up apt cache to keep the image small
    rm -rf /var/lib/apt/lists/*

    # Upgrade pip itself and install pytest globally
    python3 -m pip install --no-cache-dir --upgrade pip
    python3 -m pip install --no-cache-dir pytest

    # Create a non-root user “user” with home directory /home/user
    useradd --create-home --shell /bin/bash user
    chown -R user:user /home/user
    chmod 755 /home/user   # ensure readable by everyone, writable by owner

%environment
    # Standard PATH so python & pip are accessible
    export PATH=/usr/local/bin:/usr/local/sbin:/usr/bin:/usr/sbin:/bin:/sbin

%runscript
    # Default runscript just executes passed commands
    exec "$@"

%labels
    Author user
    Description Container for the “api-test” programming task – initial clean state with pytest installed.

%help
    This container provides:
      • Python 3 interpreter
      • pip & venv module
      • pytest (system-wide)
    A non-root user “user” with home directory /home/user is present.
    No project artefacts for the assignment are pre-created; the student
    must generate them during their solution steps.