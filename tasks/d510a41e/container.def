Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python, pip, pytest, and useful CLI tooling
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        jq
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Create the required initial filesystem state
    mkdir -p /home/user/data
    cat > /home/user/data/deployments.csv <<'EOF'
namespace,app,image,replicas
default,api-server,nginx:1.21,3
prod,worker,python:3.10,5
dev,frontend,node:14,2
EOF

    # Set the correct permissions
    chmod 755 /home/user/data
    chmod 644 /home/user/data/deployments.csv

%environment
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    echo "Container for the Kubernetes CSV summarisation task."
    echo "Start an interactive shell with: apptainer exec <image> /bin/bash"