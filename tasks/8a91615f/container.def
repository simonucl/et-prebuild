Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author  TaskSetup
    Description "Base image with sqlite3 and pytest pre-installed.  The task-specific artefacts are intentionally absent."

%post
    set -e

    # Update package index and install required tools
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        sqlite3 \
        python3-pip \
        ca-certificates

    # Install pytest for the grading framework
    pip3 install --no-cache-dir pytest

    # Ensure a writable /home/user exists for the unprivileged agent
    mkdir -p /home/user
    # Best-effort ownership change (won't fail if UID 1000 doesn't exist at run time)
    chown -R 1000:1000 /home/user || true

    # Clean up APT caches to keep image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure the standard locations are in PATH
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:$PATH

%runscript
    # Default action when the container is executed without arguments
    exec "$@"