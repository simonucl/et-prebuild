Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Avoid interactive prompts during package installation
    export DEBIAN_FRONTEND=noninteractive

    # Update package lists and install Python + pip
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-setuptools \
        ca-certificates \
        locales

    # Ensure UTF-8 locale is generated (helpful for Python I/O)
    locale-gen en_US.UTF-8

    # Install pytest for the grader
    python3 -m pip install --no-cache-dir --upgrade pip
    python3 -m pip install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare the reference data required by the assignment
    # ------------------------------------------------------------------
    # Create the /home/user hierarchy
    mkdir -p /home/user/reference

    # Populate the mandatory reference file with the authoritative data
    cat > /home/user/reference/perf_sample.dat <<'EOF'
CPU_MAX_OPS=7845
DISK_AVG_LAT_MS=3.45
MEM_AVAIL_MB=2034
EOF

    # Set safe, world-readable permissions so the non-root runtime user
    # can access everything without issues
    chmod 755 /home/user
    chmod 755 /home/user/reference
    chmod 644 /home/user/reference/perf_sample.dat

%environment
    # Make sure Python and pip user-installed binaries are on PATH
    export PATH="/usr/local/bin:/usr/bin:/bin:${PATH}"
    export LC_ALL="en_US.UTF-8"
    export LANG="en_US.UTF-8"
    export LANGUAGE="en_US:en"

%labels
    Author="Compliance Task Container"
    Description="Base image for compliance benchmark task with reference data and pytest pre-installed."