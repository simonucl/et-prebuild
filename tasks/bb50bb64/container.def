Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "Updating package index and installing Python tooling..."
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-setuptools \
        ca-certificates

    echo "Installing pytest via pip..."
    pip3 install --no-cache-dir --upgrade pip
    pip3 install --no-cache-dir pytest

    echo "Creating initial directory structure and seed data..."
    mkdir -p /home/user/data

    cat > /home/user/data/event_feed.csv <<'EOF'
event_id,timestamp,service,severity,message
1001,2024-01-14T09:15:22Z,auth,INFO,User login successful
1002,2024-01-14T09:18:05Z,database,CRITICAL,Database connection lost
1003,2024-01-14T09:20:47Z,web,WARN,High latency detected
1004,2024-01-14T09:22:10Z,filesystem,CRITICAL,Disk space critically low
1005,2024-01-14T09:25:33Z,auth,INFO,User logout
1006,2024-01-14T09:30:01Z,network,MAJOR,Packet loss above threshold
1007,2024-01-14T09:35:17Z,security,CRITICAL,Multiple failed logins
1008,2024-01-14T09:40:00Z,backup,INFO,Backup completed
EOF

    # Ensure the CSV ends with exactly one newline (the heredoc above already does).
    echo "Setting file permissions..."
    chmod 644 /home/user/data/event_feed.csv

    # Allow the runtime (non-root) user to create /home/user/alerts
    chmod 777 /home/user

    echo "Clean-up apt caches..."
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    echo "Container built for the 'alert stream' exercise."
    echo "Invoke your own commands or drop into a shell:"
    echo "  apptainer exec <image> /bin/bash"