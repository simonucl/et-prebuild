Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "Updating package index and installing system packages..."
    apt-get update -y && \
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        git \
        ca-certificates && \
    rm -rf /var/lib/apt/lists/*

    echo "Installing pytest via pip..."
    pip3 install --no-cache-dir pytest

    echo "Creating default non-privileged workspace home..."
    mkdir -p /home/user
    chmod 0755 /home/user

%environment
    chmod 755 /home/user

    # Do not override $HOME as per instructions.
    export PATH=/usr/local/bin:/usr/bin:/bin

%runscript
    exec bash

%help
    Minimal Ubuntu 22.04 image with Python, pip and pytest installed.
    Prepared for DevSecOps policy-as-code training exercise.