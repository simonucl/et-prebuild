Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    #!/bin/bash
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # Update package lists and install system packages
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        nodejs \
        npm \
        git \
        ca-certificates

    # Install Python dependencies
    pip3 install --no-cache-dir pytest

    # Install markdownlint CLI globally
    npm install -g markdownlint-cli

    # ------------------------------------------------------------------
    # Create the initial sample repository expected by the assignment
    # ------------------------------------------------------------------
    mkdir -p /home/user/project/config

    # app.conf
    cat > /home/user/project/config/app.conf <<'EOF'
# Application configuration
ENABLE_FEATURE_X=false
LOG_LEVEL=info
EOF

    # db.conf
    cat > /home/user/project/config/db.conf <<'EOF'
# Database configuration
max_connections=100
shared_buffers=128MB
EOF

    # README.md (content not strictly validated)
    cat > /home/user/project/README.md <<'EOF'
# Sample Project

This is a placeholder README for the configuration-manager exercise.
EOF

    # Ensure the student (non-root) can write into /home/user/**
    chmod -R a+rwX /home/user

%environment
    chmod 755 /home/user

    # Ensure npm global binaries (markdownlint) are on PATH
    export PATH="/usr/local/bin:$PATH"