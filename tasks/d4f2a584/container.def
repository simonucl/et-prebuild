Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial workspace expected by the automated tests
    # ------------------------------------------------------------------
    # Create the required directory structure
    mkdir -p /home/user/test_data

    # Populate test_results.csv with the exact content specified
    cat > /home/user/test_data/test_results.csv <<'EOF'
TC_ID,Status
TC001,PASS
TC002,FAIL
TC003,PASS
TC004,FAIL
TC005,SKIP
TC006,FAIL
TC007,PASS
TC008,SKIP
TC009,PASS
TC010,PASS
EOF

    # Set sensible permissions (readable by any unprivileged user)
    chmod 755 /home/user
    chmod 755 /home/user/test_data
    chmod 644 /home/user/test_data/test_results.csv

%environment
    # Ensure Python output is unbuffered for clarity during grading
    export PYTHONUNBUFFERED=1