Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package list and install required system packages
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        procps \
        psmisc \
        ca-certificates
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the grading harness
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial workspace in /home/user
    # ------------------------------------------------------------------
    mkdir -p /home/user/apps

    # Create the cpu_hog.py script exactly as specified
    cat <<'EOF' > /home/user/apps/cpu_hog.py
#!/usr/bin/env python3
import math, time
while True:
    x = math.sqrt(98765.4321) ** 2      # pointless calculation
EOF

    chmod 0755 /home/user/apps/cpu_hog.py

    # Ensure the base directory is writable by the non-privileged runner
    chmod 0777 /home/user

%environment
    chmod 755 /home/user

    # Make sure Python and pip binaries are on PATH
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author="Apptainer Task Prep Bot"
    Description="Container for CPU/memory snapshot exercise with pytest pre-installed."

%help
    This container provides the starting environment for the CPU/memory
    profiling exercise.  It includes:
      • /home/user/apps/cpu_hog.py   – pre-made CPU burner script
      • pytest                      – installed for the grading suite

    All work must be done from an unprivileged shell after the container is
    built.