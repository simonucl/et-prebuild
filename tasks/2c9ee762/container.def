Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest for the grading framework
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Create the required directory structure and initial files
    # ------------------------------------------------------------------

    # Ensure /home/user exists
    mkdir -p /home/user

    # 1. project directory with app.conf
    mkdir -p /home/user/project
    # Write exactly five bytes: h e l l o   (no newline)
    printf "hello" > /home/user/project/app.conf

    # 2. checksums directory with expected.sha256
    mkdir -p /home/user/checksums
    cat > /home/user/checksums/expected.sha256 <<'EOF'
2cf24dba5fb0a30e26e83b2ac5b9e29e1b161e5c1fa7425e73043362938b9824  app.conf
EOF

    # Set safe permissions (read-only files, accessible directories)
    chmod 755 /home/user /home/user/project /home/user/checksums
    chmod 644 /home/user/project/app.conf /home/user/checksums/expected.sha256

%environment
    # Make sure Python and pip are in PATH
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%labels
    Author          "Apptainer Task Preparation Bot"
    Description     "Environment for checksum verification assignment"

%help
    This container provides the initial file system state required for the
    checksum-verification assignment. pytest is pre-installed for the grader.