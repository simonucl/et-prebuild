Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # Install required packages
    apt-get update && \
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-setuptools \
        python3-wheel \
        procps \
        coreutils && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # Prepare a writable home directory for the unprivileged user
    mkdir -p /home/user
    chmod 0777 /home/user   # Allow any UID to write; do NOT create workflow artefacts

%environment
    chmod 755 /home/user

    # Ensure user-installed binaries are reachable
    export PATH="/usr/local/bin:${PATH}"

%runscript
    # Default action: launch an interactive shell
    exec /bin/bash "$@"