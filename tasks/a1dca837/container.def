Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # --- Base packages --------------------------------------------------------
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 python3-pip python3-setuptools \
        ca-certificates coreutils tar gzip

    # --- Python testing framework --------------------------------------------
    pip3 install --no-cache-dir pytest

    # --- Prepare the backup archive ------------------------------------------
    mkdir -p /home/user/backups

    # Temporary build workspace
    BUILD_DIR="$(mktemp -d)"

    # Directory skeleton
    mkdir -p "${BUILD_DIR}/etc/nginx/conf.d"
    mkdir -p "${BUILD_DIR}/var/www/html/assets"

    # File 1: etc/nginx/nginx.conf  (26 bytes, md5 c3fcd3d76192e4007dfb496cca67e13b)
    printf 'abcdefghijklmnopqrstuvwxyz' > "${BUILD_DIR}/etc/nginx/nginx.conf"

    # File 2: etc/nginx/conf.d/default.conf  (3 bytes, md5 900150983cd24fb0d6963f7d28e17f72)
    printf 'abc' > "${BUILD_DIR}/etc/nginx/conf.d/default.conf"

    # File 3: var/www/html/index.html  (1 byte, md5 0cc175b9c0f1b6a831c399e269772661)
    printf 'a' > "${BUILD_DIR}/var/www/html/index.html"

    # File 4: var/www/html/healthcheck.php  (0 bytes, md5 d41d8cd98f00b204e9800998ecf8427e)
    : > "${BUILD_DIR}/var/www/html/healthcheck.php"

    # File 5: var/www/html/assets/style.css  (14 bytes, md5 f96b697d7cb7938d525a2f31aaf161d0)
    printf 'message digest' > "${BUILD_DIR}/var/www/html/assets/style.css"

    # Create the compressed tarball with paths relative to the filesystem root
    tar -C "${BUILD_DIR}" -czf /home/user/backups/site_config_backup.tar.gz etc var

    # Clean up the temporary workspace
    rm -rf "${BUILD_DIR}"

    # Ensure world-readable access for the non-privileged run-time user
    chmod -R a+rX /home/user

%environment
    chmod 755 /home/user

    # Avoid generation of .pyc files
    export PYTHONDONTWRITEBYTECODE=1

%labels
    Author        backup-exercise-builder
    Description   "Initial state for the restore exercise: backup archive present, pytest installed."