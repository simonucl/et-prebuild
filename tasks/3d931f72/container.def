Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "Updating package index and installing Python tooling..."
    apt-get update -y
    apt-get install -y --no-install-recommends python3 python3-pip ca-certificates
    pip3 install --no-cache-dir pytest

    echo "Creating required directory structure..."
    mkdir -p /home/user/build/infra

    echo "Creating hosts_artifacts file with correct contents and permissions..."
    cat <<'EOF' > /home/user/build/infra/hosts_artifacts
# internal artifact hosts mapping
192.168.45.77 archive.test.lan archive
10.8.0.15     artifacts.dev.local dev-artifacts
172.25.11.60  ci-cache.lan cicache

EOF
    chmod 0644 /home/user/build/infra/hosts_artifacts

    # Ensure directories are world-readable/traversable
    chmod 0755 /home/user
    chmod 0755 /home/user/build
    chmod 0755 /home/user/build/infra

    # Clean up apt caches to keep image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Minimal environment customisation can go here if needed
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    echo "This container is prepared for the 'archive.test.lan DNS verification' exercise."
    echo "Invoke a shell or execute your commands as needed."