Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ------------------------------------------------------------------
    # Basic tools and Python environment
    # ------------------------------------------------------------------
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        build-essential
    pip3 install --no-cache-dir --upgrade pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create initial data set for the exercise
    # ------------------------------------------------------------------
    mkdir -p /home/user/raw_data

    cat > /home/user/raw_data/measurements.txt << 'EOF'
ID F1 F2 target
1 3.5 7.2 10.7
2 NaN 6.1 8.2
3 4.1 5.9 10.0
4 3.9 NaN 9.5
5 4.2 6.5 10.7
EOF

    # ------------------------------------------------------------------
    # Ensure students have write-access to their workspace
    # ------------------------------------------------------------------
    chmod -R a+rwx /home/user

%environment
    chmod 755 /home/user

    export PYTHONUNBUFFERED=1
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    exec "$@"

%labels
    Author "Task Container Generator"
    Description "Environment for optimisation-solver data-prep exercise with pytest pre-installed."