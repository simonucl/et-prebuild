Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python tooling and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3-pip \
        python3-setuptools \
        ca-certificates
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Prepare directory structure required by the task
    mkdir -p /home/user/docs

    # Stub helper script that must pre-exist and be executable
    cat > /home/user/docs/generate_docs.sh <<'EOF'
#!/usr/bin/env bash
# Dummy implementation for test scaffolding
echo "Generating documentation…"
EOF
    chmod 755 /home/user/docs/generate_docs.sh
    chmod 755 /home/user/docs

    # Create a non-root account named "user" and assign ownership
    if ! id -u user >/dev/null 2>&1; then
        useradd -m -d /home/user -s /bin/bash user
    fi
    chown -R user:user /home/user

%labels
    Author="Container for cron-file creation exercise"