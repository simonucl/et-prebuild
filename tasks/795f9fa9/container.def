Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest (plus minimal prerequisites)
    apt-get update && \
        apt-get install -y --no-install-recommends python3 python3-pip ca-certificates && \
        rm -rf /var/lib/apt/lists/*

    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial workspace expected by the grading tests
    # ------------------------------------------------------------------
    # Create the mock_responses directory and populate the JSON files
    mkdir -p /home/user/mock_responses

    # Write the single-line JSON files (no trailing newlines)
    printf '{"service":"alpha","status":"ok"}' \
        > /home/user/mock_responses/status.json
    printf '{"requests":123,"errors":0,"uptime":"48h"}' \
        > /home/user/mock_responses/metrics.json

    # Ensure correct permissions (readable by any user)
    chmod 644 /home/user/mock_responses/status.json \
              /home/user/mock_responses/metrics.json

%environment
    chmod 755 /home/user

    # Ensure standard locations are on PATH
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%runscript
    # Default action: drop to a shell within the container
    exec /bin/bash "$@"

%labels
    Author="ChatGPT"
    Description="Container for the API-summary shell-automation task with pytest pre-installed."