Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package index and install required utilities
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3-pip \
        net-tools \
        iputils-ping \
        dnsutils

    # Install pytest for the grading framework
    pip3 install --no-cache-dir pytest

    # Ensure the expected home directory exists and is writable by any user
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up apt cache to keep the image small
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Basic, sane environment – do NOT override $HOME
    export LC_ALL=C
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

%runscript
    echo "Container for networking-snapshot provisioning task."
    echo "Invoke your own scripts or commands inside this container as needed."