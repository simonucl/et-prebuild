Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package index and install Python tooling
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install pytest for the verification test-suite
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare starter filesystem that the learner’s code will rely on
    # ------------------------------------------------------------------
    # Create required directory tree (except the 'logs' dir which must
    # be absent initially)
    mkdir -p /home/user/qa_env/test_results

    # Seed data file: /home/user/qa_env/test_results/raw_results.txt
    cat > /home/user/qa_env/test_results/raw_results.txt <<'EOF'
auth PASS
auth PASS
auth FAIL
payment PASS
payment PASS
payment PASS
payment FAIL
search PASS
search FAIL
search FAIL
search FAIL
report PASS
report PASS
report PASS
report PASS
EOF

    # Permissions:
    #   - Allow unprivileged container users to create new files like
    #     summary.log inside the tree.
    chmod -R a+rwX /home/user/qa_env

%environment
    chmod 755 /home/user

    # No need to modify $HOME; leave default behavior.

%runscript
    echo "Container for the 'Sort & uniq frequency counting for QA test results' exercise."
    echo "Open a shell with:  apptainer exec <image> /bin/bash"

%labels
    Author qa-preparer
    Description "Starter image for QA frequency-count exercise (pytest pre-seeded)"