Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python tooling and pytest
    apt-get update -y && \
        apt-get install -y --no-install-recommends \
            python3-pip python3-setuptools locales && \
        pip3 install --no-cache-dir pytest && \
        apt-get clean && rm -rf /var/lib/apt/lists/*

    # Create an unprivileged user that the learner will use
    groupadd -g 1000 user
    useradd  -m -u 1000 -g 1000 -s /bin/bash user

    # ------------------------------------------------------------------
    # Populate the initial exercise data (author logs)
    # ------------------------------------------------------------------
    mkdir -p /home/user/ci_data/commit_authors

    cat > /home/user/ci_data/commit_authors/service-a.log <<'EOF'
jane.doe@example.com
john.smith@example.com
jane.doe@example.com
alex.lee@example.com
jane.doe@example.com
jane.doe@example.com
john.smith@example.com
jane.doe@example.com
jane.doe@example.com
john.smith@example.com
jane.doe@example.com
EOF

    cat > /home/user/ci_data/commit_authors/service-b.log <<'EOF'
john.smith@example.com
jane.doe@example.com
john.smith@example.com
john.smith@example.com
jane.doe@example.com
jane.doe@example.com
john.smith@example.com
jane.doe@example.com
jane.doe@example.com
EOF

    cat > /home/user/ci_data/commit_authors/service-c.log <<'EOF'
john.smith@example.com
jane.doe@example.com
alex.lee@example.com
john.smith@example.com
john.smith@example.com
jane.doe@example.com
john.smith@example.com
alex.lee@example.com
john.smith@example.com
jane.doe@example.com
EOF

    # Ensure correct ownership so the non-root user can access/modify its home
    chown -R user:user /home/user

%environment
    chmod 755 /home/user

    # Ensure the user’s local bin (pip --user installs) comes first
    export PATH="/home/user/.local/bin:${PATH}"

%runscript
    # Default action when the container is run without arguments
    exec /bin/bash "$@"