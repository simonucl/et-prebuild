Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    apt-get update
    # Install Python and pytest (plus procps for `free`, `uptime`, etc.)
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        procps

    pip3 install --no-cache-dir pytest

    # Create a writable home for the future non-root agent
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up apt caches to keep the image lean
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Preserve whatever HOME Apptainer sets, but ensure standard paths
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%runscript
    # Default runscript: simply execute whatever was passed in
    exec "$@"