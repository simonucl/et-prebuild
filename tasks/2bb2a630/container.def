Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author fast_linecount_initial_state
    Description "Container image providing the initial filesystem layout for the fast_linecount exercise."

%post
    set -eux

    # Install Python, pip and pytest (needed for the grading harness)
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Create the reference implementation and sample data files expected
    # by the test suite (initial state).
    # ------------------------------------------------------------------
    mkdir -p /home/user/scripts
    mkdir -p /home/user/data

    # Reference 'slow' implementation
    cat > /home/user/scripts/slow_linecount.sh <<'EOF'
#!/bin/bash
# slow_linecount.sh: Count lines in files passed as arguments (slow variant)
total=0
for f in "$@"; do
    lines=$(cat "$f" | wc -l)
    total=$((total + lines))
done
echo "$total"
EOF
    chmod 755 /home/user/scripts/slow_linecount.sh

    # Generate the two sample data files
    yes dummy | head -n 10000 > /home/user/data/file1.txt
    yes dummy | head -n 15000 > /home/user/data/file2.txt
    chmod 644 /home/user/data/file1.txt /home/user/data/file2.txt

%environment
    # Ensure python is on PATH
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%runscript
    echo "This container prepares the initial state for the fast_linecount exercise."
    echo "Execute an interactive shell with: apptainer shell <image>.sif"