Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    #!/bin/bash
    set -e

    # Update package index and install Python + pip
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ---------------------------------------------------------------------
    # Create non-root working user
    # ---------------------------------------------------------------------
    useradd -m -s /bin/bash user

    # ---------------------------------------------------------------------
    # Prepare required starting directories and seed files
    # ---------------------------------------------------------------------
    mkdir -p /home/user/db_logs
    mkdir -p /home/user/db_config

    # Seed: query_performance.log  (must include final newline)
    cat > /home/user/db_logs/query_performance.log <<'EOF'
[2023-06-18 09:00:01] QUERY_ID=1001 duration=250ms select * from accounts where id=1;
[2023-06-18 09:00:05] QUERY_ID=1002 duration=1200ms select * from transactions where amount > 1000;
[2023-06-18 09:00:10] QUERY_ID=1003 duration=810ms update accounts set balance=balance+100 where id=2;
[2023-06-18 09:00:20] QUERY_ID=1004 duration=1350ms delete from sessions where expired=1;
[2023-06-18 09:00:25] QUERY_ID=1005 duration=90ms select * from accounts;
EOF

    # Seed: postgres.conf  (must include final newline)
    cat > /home/user/db_config/postgres.conf <<'EOF'
# Database configuration
work_mem = 4MB
enable_seqscan = off
shared_buffers = 128MB
EOF

    # ---------------------------------------------------------------------
    # Set ownership so the unprivileged user can work freely
    # ---------------------------------------------------------------------
    chown -R user:user /home/user

%environment
    chmod 755 /home/user

    # Preserve normal user environment
    export HOME=/home/user
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author "Generated by ChatGPT"
    Description "Apptainer image that sets up initial state for the DBA slow-query task with pytest installed."