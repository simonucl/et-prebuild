BootStrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ------------------------------------------------------------------
    # System packages and Python tooling
    # ------------------------------------------------------------------
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        tzdata \
        locales
    python3 -m pip install --no-cache-dir --upgrade pip
    python3 -m pip install --no-cache-dir pytest

    # Clean up APT caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Create non-root working user
    # ------------------------------------------------------------------
    groupadd -g 1000 user
    useradd  -m -u 1000 -g 1000 -s /bin/bash user

    # ------------------------------------------------------------------
    # Set up initial filesystem required for the exercise
    # ------------------------------------------------------------------
    PIPELINE_DIR="/home/user/mobile-pipeline"
    mkdir -p "${PIPELINE_DIR}/logs"

    # 1. build_android.sh with deliberately insecure mode 777
    cat > "${PIPELINE_DIR}/build_android.sh" <<'EOF'
#!/bin/bash
# Dummy build script placeholder
echo "Building Android…"
EOF
    chmod 777 "${PIPELINE_DIR}/build_android.sh"

    # 2. logs directory with mode 755
    chmod 755 "${PIPELINE_DIR}/logs"

    # 3. release_signing.key with mode 644 and dummy content
    echo "FAKE-ANDROID-RELEASE-KEY" > "${PIPELINE_DIR}/release_signing.key"
    chmod 644 "${PIPELINE_DIR}/release_signing.key"

    # Ensure ownership by the non-root user so the student can modify them
    chown -R 1000:1000 /home/user

%environment
    chmod 755 /home/user

    # Ensure Python and user paths are available
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    echo "Container for Android permission challenge."
    echo "Switch to the 'user' account to begin."