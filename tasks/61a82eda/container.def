Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # --------------------------------------------------------------------- #
    # Prepare initial exercise data under /home/user/data/staging
    # --------------------------------------------------------------------- #
    mkdir -p /home/user/data/staging/nested

    # Five *.tmp files
    printf "temporary readme\n" > /home/user/data/staging/readme.tmp
    printf "some notes\n"         > /home/user/data/staging/notes.tmp
    : > /home/user/data/staging/empty.tmp                       # zero-byte file
    printf "old tmp\n"            > /home/user/data/staging/nested/old.tmp
    : > /home/user/data/staging/nested/blank.tmp                # zero-byte file

    # Three *.txt files
    printf "sample1-data\n"       > /home/user/data/staging/sample1.txt
    printf "sample2-data\n"       > /home/user/data/staging/sample2.txt
    printf "nested-sample\n"      > /home/user/data/staging/nested/data.txt

    # One log file that must remain untouched by the agent
    printf "keep me\n"            > /home/user/data/staging/ignore.log

    # Ensure the learner (non-root user) can freely manipulate everything
    chmod -R a+rwX /home/user

%environment
    chmod 755 /home/user

    # Nothing special needed; keep default environment

%runscript
    # Default runscript – drop into a shell
    exec /bin/bash "$@"