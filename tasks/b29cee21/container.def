Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    #--------------------------------------------------------------------#
    # Basic tooling
    #--------------------------------------------------------------------#
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        rsync \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

    pip3 install --no-cache-dir pytest

    #--------------------------------------------------------------------#
    # Prepare the initial exercise filesystem under /home/user
    #--------------------------------------------------------------------#
    mkdir -p /home/user/workspace/project/utils
    mkdir -p /home/user/remote_host/project_backup     # must exist but be empty

    # Source-project files
    cat >/home/user/workspace/project/app.py <<'EOF'
print('Hello World')
EOF

    cat >/home/user/workspace/project/config.yaml <<'EOF'
env: dev
EOF

    cat >/home/user/workspace/project/secrets.yaml <<'EOF'
password: hunter2
EOF

    cat >/home/user/workspace/project/notes.tmp <<'EOF'
scratch
EOF

    cat >/home/user/workspace/project/README.md <<'EOF'
# Demo Project
EOF

    cat >/home/user/workspace/project/utils/helper.py <<'EOF'
def helper():
    return 'helper'
EOF

    # Permissions: allow the unprivileged runtime user full access
    chmod -R 0777 /home/user

%environment
    chmod 755 /home/user

    # Nothing to override; keep default HOME binding behaviour
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8