Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    #!/bin/bash
    set -e

    # Update package lists and install required packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        curl \
        ca-certificates \
        git

    # Install pytest for the forthcoming test suites
    pip3 install --no-cache-dir pytest

    # Create the non-root user expected by the tests
    useradd -m -s /bin/bash user
    chown -R user:user /home/user

    # Clean up to keep the image lean
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure the standard locations are in PATH
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%runscript
    # Default runscript: open a shell unless a command is supplied
    exec "${@:-/bin/bash}"

%labels
    Author="Config-Manager Task Environment"
    Description="Ubuntu 22.04 image with curl and pytest, prepared for the configuration-manager exercise."