Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update -y && \
    apt-get install -y --no-install-recommends python3 python3-pip && \
    pip3 install --no-cache-dir pytest && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

    # Create working directory structure
    mkdir -p /home/user/manifests

    # Populate initial deployment.yaml
    cat <<'EOF' > /home/user/manifests/deployment.yaml
apiVersion: apps/v1
kind: Deployment
metadata:
  name: example-operator
spec:
  replicas: 1
  template:
    spec:
      containers:
      - name: operator
        image: ghcr.io/org/example-operator:1.2.3
EOF

    # Populate initial CHANGELOG.md
    cat <<'EOF' > /home/user/CHANGELOG.md
# Changelog

All notable changes to this project will be documented in this file.

## [1.2.3] - 2024-05-01
### Added
- Initial release of example-operator
EOF

    # Ensure writable permissions for non-root agent
    chmod -R 0777 /home/user

%environment
    chmod 755 /home/user

    # Ensure Python is available
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"