Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Update package index and install Python tooling needed by the learner.
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-venv \
        ca-certificates

    # Install pytest globally so the assessment framework can run.
    pip3 install --no-cache-dir pytest==7.4.0

    # Create a writable home directory for the unprivileged user who will
    # run inside the container.  World-writable removes any UID mismatch issues.
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up apt caches to keep the image lean.
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure user-installed Python tools (if any) are on the path.
    export PATH="/home/user/.local/bin:$PATH"

%runscript
    # Default action: drop into a shell if someone just runs the container.
    exec /bin/bash "$@"

%help
    Container for the QA-environment setup exercise.
    Provides Python 3, pip, python3-venv, and pytest 7.4.0.