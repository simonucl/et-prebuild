Bootstrap: localimage
From: ./ubuntu_22.04.sif

%help
Container image for the “Kubernetes manifest backup” exercise.
Provides the initial filesystem state expected by the test-suite and
includes pytest for verification.

%post
    set -e

    # -------------------------------------------------------------------------
    # Install Python 3 and pytest
    # -------------------------------------------------------------------------
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # -------------------------------------------------------------------------
    # Prepare the required directory hierarchy and manifest files
    # -------------------------------------------------------------------------
    # Create base home directory for the non-root user exercised at runtime
    mkdir -p /home/user/k8s/manifests
    mkdir -p /home/user/backup/archives

    # -------------------------------------------------------------------------
    # Kubernetes manifest files (exact byte-for-byte content)
    # -------------------------------------------------------------------------
    cat > /home/user/k8s/manifests/deployment.yaml <<'EOF'
apiVersion: apps/v1
kind: Deployment
metadata:
  name: nginx
spec:
  replicas: 2
EOF

    cat > /home/user/k8s/manifests/service.yaml <<'EOF'
apiVersion: v1
kind: Service
metadata:
  name: nginx
spec:
  type: ClusterIP
EOF

    cat > /home/user/k8s/manifests/configmap.yaml <<'EOF'
apiVersion: v1
kind: ConfigMap
metadata:
  name: nginx-config
data:
  key: value
EOF

    # -------------------------------------------------------------------------
    # Create (empty) backup log file – the exercise will append to this.
    # -------------------------------------------------------------------------
    touch /home/user/backup/backup.log

    # -------------------------------------------------------------------------
    # Permissions
    # -------------------------------------------------------------------------
    # Allow the unprivileged runtime user to read manifests and freely write
    # into /home/user/backup.
    chmod -R a+rX /home/user/k8s
    chmod 0777 /home/user/backup
    chmod 0777 /home/user/backup/archives
    chmod 0666 /home/user/backup/backup.log

%environment
    chmod 755 /home/user

    # Nothing to override – preserve caller’s $HOME
    export LC_ALL=C.UTF-8
    export PYTHONIOENCODING=utf-8