Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Update package lists and install Python + pip
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install pytest for the autograder
    pip3 install --no-cache-dir pytest

    # Ensure the /home/user directory exists and is writable by the
    # (non-root) runtime user so they can create the monitoring files.
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up apt cache to reduce image size
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure typical paths are available
    export PATH="/usr/local/bin:/usr/bin:/bin:${PATH}"

%runscript
    exec /bin/bash "$@"

%help
    This container provides a minimal Ubuntu 22.04 environment with Python 3
    and pytest installed.  The /home/user directory is writable so that
    students can complete the “serverwatch” alert-rules creation task.