Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # Create non-root user and home
    useradd -ms /bin/bash user

    # Populate the required manifests
    mkdir -p /home/user/manifests

    cat > /home/user/manifests/deployment.yaml <<'EOF'
apiVersion: apps/v1
kind: Deployment
metadata:
  name: web
spec:
  replicas: 2
  selector:
    matchLabels:
      app: web
  template:
    metadata:
      labels:
        app: web
    spec:
      containers:
        - name: nginx
          image: nginx:latest
          ports:
            - containerPort: 80
EOF

    cat > /home/user/manifests/statefulset.yaml <<'EOF'
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: cache
spec:
  serviceName: "redis"
  replicas: 1
  selector:
    matchLabels:
      app: cache
  template:
    metadata:
      labels:
        app: cache
    spec:
      containers:
        - name: redis
          image: redis:latest
          ports:
            - containerPort: 6379
EOF

    # Ensure correct ownership for the non-root user
    chown -R user:user /home/user

%environment
    chmod 755 /home/user

    export PATH=/home/user/.local/bin:$PATH

%labels
    Author devsecops-task
    Description Container for Kubernetes “latest” image tag scanning assignment