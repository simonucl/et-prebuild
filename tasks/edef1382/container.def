Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Basic tooling and Python
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        python3 \
        python3-pip \
        locales

    # Generate the required German UTF-8 locale
    locale-gen de_DE.UTF-8

    # Install pytest for the automated checker
    pip3 install --no-cache-dir pytest

    # Prepare writable home for the unprivileged runtime user
    mkdir -p /home/user
    chmod 0777 /home/user

%labels
    chmod 755 /home/user

    Author "Generated for Berlin TZ / German locale task"
    Description "Template image with pytest and writable /home/user; no final solution present."