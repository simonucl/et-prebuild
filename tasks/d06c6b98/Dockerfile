FROM ubuntu:22.04

# Labels
LABEL Author="Generated by ChatGPT"
LABEL Description="Container for DNS resolution reliability check task with pytest pre-installed."

# Update package lists and install Python + pip
RUN set -e && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip && \
    pip3 install --no-cache-dir pytest && \
    rm -rf /var/lib/apt/lists/* && \
    mkdir -p /home/user && \
    chmod 0777 /home/user

# Environment variables
ENV LC_ALL=C
ENV LANG=C

WORKDIR /home/user