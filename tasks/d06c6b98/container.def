Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install Python + pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    # Install pytest for the grading tests
    pip3 install --no-cache-dir pytest

    # Clean up apt caches to keep image small
    rm -rf /var/lib/apt/lists/*

    # Ensure /home/user exists and is writable by any non-root user
    mkdir -p /home/user
    chmod 0777 /home/user

%environment
    chmod 755 /home/user

    # No special environment variables required
    export LC_ALL=C
    export LANG=C

%labels
    Author="Generated by ChatGPT"
    Description="Container for DNS resolution reliability check task with pytest pre-installed."