Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # ---- Install Python and pytest ------------------------------------------------
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ---- Prepare initial filesystem layout ----------------------------------------
    mkdir -p /home/user/monitoring

    # alerts.yaml (exact initial contents)
    cat > /home/user/monitoring/alerts.yaml <<'EOF'
alerts:
  - name: cpu_high
    threshold: 85
    enabled: false
  - name: memory_high
    threshold: 90
    enabled: false
EOF

    # notifications.toml (exact initial contents)
    cat > /home/user/monitoring/notifications.toml <<'EOF'
[smtp]
enabled = false
server  = "smtp.example.com"
port    = 587
sender  = "monitor@example.com"
recipients = ["admin@example.com"]
EOF

    # Ensure sensible permissions (agent runs unprivileged)
    chmod 0644 /home/user/monitoring/alerts.yaml /home/user/monitoring/notifications.toml

%environment
    chmod 755 /home/user

    # Keep UTF-8 as default encoding
    export PYTHONIOENCODING=UTF-8

%labels
    Author      "Generated by ChatGPT"
    Description "Apptainer image for monitoring-configuration exercise: provides initial state and pytest."