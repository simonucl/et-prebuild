FROM ubuntu:22.04

# Author "Generated by ChatGPT"
# Description "Apptainer image for monitoring-configuration exercise: provides initial state and pytest."

ENV PYTHONIOENCODING=UTF-8

RUN set -e && \
    export DEBIAN_FRONTEND=noninteractive && \
    apt-get update && \
    apt-get install -y --no-install-recommends python3 python3-pip && \
    pip3 install --no-cache-dir pytest && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

RUN mkdir -p /home/user/monitoring

RUN cat > /home/user/monitoring/alerts.yaml <<'EOF'
alerts:
  - name: cpu_high
    threshold: 85
    enabled: false
  - name: memory_high
    threshold: 90
    enabled: false
EOF

RUN cat > /home/user/monitoring/notifications.toml <<'EOF'
[smtp]
enabled = false
server  = "smtp.example.com"
port    = 587
sender  = "monitor@example.com"
recipients = ["admin@example.com"]
EOF

RUN chmod 0644 /home/user/monitoring/alerts.yaml /home/user/monitoring/notifications.toml