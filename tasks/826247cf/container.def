Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package index and install Python tooling
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-setuptools \
        python3-venv \
        ca-certificates \
        tzdata \
        git

    # Create the regular (non-root) working user expected by the tasks
    useradd -m -s /bin/bash user
    chown -R user:user /home/user

    # Install pytest for the assessment framework
    pip3 install --no-cache-dir pytest

    # Clean up APT cache to reduce image size
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Basic runtime environment
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH
    export HOME=/home/user

%runscript
    # By default just drop into a shell (as root unless caller specifies --user)
    exec /bin/bash "$@"

%labels
    Author          Apptainer-Task-Builder
    Description     Base image for the DNS snapshot logging exercise (pytest included)