# syntax=docker/dockerfile:1
FROM ubuntu:22.04

# Author "Auto-generated by ChatGPT"
# Description "Container for hardening backup assignment – includes initial hardening files and pytest pre-installed."
# This Apptainer image sets up the initial state for the hardening backup assignment.
# It contains:
#   • /home/user/hardening/ with three pre-staged configuration files.
#   • pytest installed system-wide for the grading test-suite.
# No other artefacts are created so that the learner can perform those steps themselves.

ENV PATH=/usr/local/bin:/usr/bin:/bin:$PATH

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked --mount=type=cache,target=/var/lib/apt,sharing=locked set -e && apt-get update -qq && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    ca-certificates \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

RUN --mount=type=cache,target=/root/.cache/pip python3 -m pip install --no-cache-dir --upgrade pip && python3 -m pip install --no-cache-dir pytest

RUN mkdir -p /home/user/hardening

RUN cat <<'EOF' > /home/user/hardening/sysctl_hardened.conf
# Hardened sysctl settings
net.ipv4.ip_forward = 0
net.ipv4.conf.all.accept_source_route = 0
EOF

RUN cat <<'EOF' > /home/user/hardening/sshd_hardened.conf
# Hardened SSH daemon configuration
PermitRootLogin no
PasswordAuthentication no
EOF

RUN cat <<'EOF' > /home/user/hardening/pam_hardened.conf
# Hardened PAM configuration
password requisite pam_pwquality.so retry=3
auth required pam_faillock.so preauth audit silent deny=5 unlock_time=900
EOF

RUN chmod 755 /home && chmod 755 /home/user && chmod 755 /home/user/hardening && chmod 644 /home/user/hardening/*.conf