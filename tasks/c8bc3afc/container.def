Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "Updating apt repositories and installing required packages..."
    apt-get update -qq
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        && apt-get clean && rm -rf /var/lib/apt/lists/*

    echo "Installing pytest via pip..."
    python3 -m pip install --no-cache-dir --upgrade pip
    python3 -m pip install --no-cache-dir pytest

    echo "Creating initial directory structure and hardening files..."
    mkdir -p /home/user/hardening

    cat > /home/user/hardening/sysctl_hardened.conf <<'EOF'
# Hardened sysctl settings
net.ipv4.ip_forward = 0
net.ipv4.conf.all.accept_source_route = 0
EOF

    cat > /home/user/hardening/sshd_hardened.conf <<'EOF'
# Hardened SSH daemon configuration
PermitRootLogin no
PasswordAuthentication no
EOF

    cat > /home/user/hardening/pam_hardened.conf <<'EOF'
# Hardened PAM configuration
password requisite pam_pwquality.so retry=3
auth required pam_faillock.so preauth audit silent deny=5 unlock_time=900
EOF

    echo "Setting permissions..."
    chmod 755 /home
    chmod 755 /home/user
    chmod 755 /home/user/hardening
    chmod 644 /home/user/hardening/*.conf

%environment
    # Ensure Python and pip are on PATH
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author "Auto-generated by ChatGPT"
    Description "Container for hardening backup assignment – includes initial hardening files and pytest pre-installed."

%help
    This Apptainer image sets up the initial state for the hardening backup
    assignment.  It contains:
      • /home/user/hardening/ with three pre-staged configuration files.
      • pytest installed system-wide for the grading test-suite.
    No other artefacts (archives, recovery_test, operation_logs, etc.) are
    created so that the learner can perform those steps themselves.