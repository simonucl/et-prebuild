Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author example
    Description Container for Python virtual-environment creation task

%post
    set -e

    # Update package lists and install required system packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-venv \
        python3-pip \
        ca-certificates \
        build-essential

    # Install pytest for the grader
    python3 -m pip install --no-cache-dir --upgrade pip
    python3 -m pip install --no-cache-dir pytest

    # -------------------------------------------------------------------------
    # Create a writable workspace for the unprivileged user.
    # The tests/agent will run as a non-root user, so make sure /home/user
    # exists and is world-writable (or at least writable by any UID).
    # Do NOT create the resources that the assignment asks the student to
    # generate; we only prepare the parent directories.
    # -------------------------------------------------------------------------
    mkdir -p /home/user
    chmod 0777 /home/user

    # Provide parent directories (but **not** the target resources themselves)
    mkdir -p /home/user/venvs
    mkdir -p /home/user/research
    chmod 0777 /home/user/venvs /home/user/research

    # Clean up apt caches to keep image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure the system python is on PATH for the agent
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%runscript
    echo "This container is intended for the Python virtual-environment setup task."
    echo "Start an interactive shell with: apptainer shell <container>"