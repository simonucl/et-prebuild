Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python 3 and pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the exercise tests
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare the initial filesystem state expected by the exercise
    # ------------------------------------------------------------------
    # Create required directories
    mkdir -p /home/user/data/dataset_v1
    mkdir -p /home/user/data/dataset_v2
    mkdir -p /home/user/data/dataset_v3
    mkdir -p /home/user/output

    # Ensure the runtime (non-root) user can modify the directories
    chmod -R 0777 /home/user

%environment
    chmod 755 /home/user

    # Keep whatever HOME the runtime sets; just be sure Python is on PATH
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%labels
    Author=Apptainer_Task_Preparation
    Description="Container image for symlink creation exercise. Sets up initial directories and installs pytest."