# syntax=docker/dockerfile:1
FROM ubuntu:22.04

LABEL Author="Autogenerated by ChatGPT" \
      Description="Container for log transformation task – provides initial log files and pytest."

# ---------------------------------------------------------------------
# Basic tools & Python testing framework
# ---------------------------------------------------------------------
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked --mount=type=cache,target=/var/lib/apt,sharing=locked --mount=type=cache,target=/root/.cache/pip set -e && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip && \
    pip3 install --no-cache-dir pytest && \
    rm -rf /var/lib/apt/lists/*

# ---------------------------------------------------------------------
# Initial directory layout and log files
# ---------------------------------------------------------------------
RUN mkdir -p /home/user/server_logs

# serverA.log
RUN cat > /home/user/server_logs/serverA.log <<'EOF'
2024-07-20 08:11:54 INFO Boot sequence initiated
2024-07-20 08:12:13 ERROR Disk sda IO failure
2024-07-20 08:12:15 ERROR Disk sda IO failure resolved
2024-07-20 08:13:00 INFO Service started
EOF

# serverB.log
RUN cat > /home/user/server_logs/serverB.log <<'EOF'
2024-07-20 09:00:00 INFO CRON daily job started
2024-07-20 09:00:02 WARN Low entropy
2024-07-20 09:00:24 ERROR Backup failed: remote host unreachable
2024-07-20 09:00:30 INFO CRON daily job finished
EOF

# serverC.log
RUN cat > /home/user/server_logs/serverC.log <<'EOF'
2024-07-20 10:42:11 INFO Healthcheck OK
2024-07-20 10:45:32 INFO Healthcheck OK
EOF

# ---------------------------------------------------------------------
# Permissions: make sure the student can write to /home/user/*
# ---------------------------------------------------------------------
RUN chmod -R a+rwX /home/user && \
    chmod 755 /home/user

# ---------------------------------------------------------------------
# Environment variables
# ---------------------------------------------------------------------
ENV LC_ALL=C.UTF-8 \
    PYTHONIOENCODING=utf-8