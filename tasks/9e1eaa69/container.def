Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author      OpenAI ChatGPT
    Description "Base image for the OpenSSL compliance audit-trail exercise"

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # Refresh package metadata so `apt-cache policy` can report a Candidate: field
    apt-get update

    # Install required software
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        openssl \
        ca-certificates

    # Python testing framework for the grader
    pip3 install --no-cache-dir pytest

    # Create a writable home for the exercise’s non-privileged user
    mkdir -p /home/user
    chmod 0777 /home/user

    # Keep apt metadata (needed for Candidate queries); just clean archives
    apt-get clean

%environment
    chmod 755 /home/user

    # Standard PATH plus /usr/local for pip-installed tools
    PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

%runscript
    exec "$@"