Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Install Python tooling and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ---------------------------------------------------------------------
    # Prepare initial exercise state in /home/user
    # ---------------------------------------------------------------------
    # Directory layout
    mkdir -p /home/user/project_data
    mkdir -p /home/user/backup/project_data_copy

    # Create source files with exact contents (NO trailing new-lines)
    printf 'abc'  > /home/user/project_data/data1.txt
    printf 'test' > /home/user/project_data/data2.txt

    # Copy files to backup location (byte-for-byte identical)
    cp /home/user/project_data/data1.txt /home/user/backup/project_data_copy/
    cp /home/user/project_data/data2.txt /home/user/backup/project_data_copy/

    # Permissions:
    #  • Allow the unprivileged runtime user to create the verification log
    chmod 0777 /home/user
    chmod -R a+rX /home/user/project_data /home/user/backup

%environment
    chmod 755 /home/user

    # Ensure pip installations are found first
    export PATH="/usr/local/bin:$PATH"

%labels
    Author          backup-integrity-exercise
    Description     "Initial state for the backup verification task"