Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "Updating package lists and installing dependencies..."
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        curl \
        ca-certificates

    echo "Installing pytest for the grading harness..."
    pip3 install --no-cache-dir pytest

    echo "Creating required directory structure..."
    mkdir -p /home/user/releases

    # Ensure the non-root runtime user (whose UID we don’t know in advance)
    # can write inside /home/user and its sub-directories.
    chmod 1777 /home /home/user /home/user/releases

    # Clean up APT caches to keep the image small.
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8