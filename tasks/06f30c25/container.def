Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "Updating package index and installing required packages..."
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    echo "Installing pytest via pip..."
    pip3 install --no-cache-dir pytest

    ###########################################################################
    # Create initial cluster data structure expected by the task and tests.
    ###########################################################################

    BASE_DIR="/home/user/cluster/nodes"
    mkdir -p "${BASE_DIR}/node1" "${BASE_DIR}/node2" "${BASE_DIR}/node3"

    # Helper to create users.txt with correct permissions (0644) and LF endings.
    create_users_file() {
        local path="$1"; shift
        printf "%s\n" "$@" > "${path}"
    chmod 755 /home/user

        chmod 0644 "${path}"
    }

    echo "Populating users.txt files..."

    create_users_file "${BASE_DIR}/node1/users.txt" \
        alice \
        bob \
        charlie \
        dave

    create_users_file "${BASE_DIR}/node2/users.txt" \
        alice \
        charlie \
        eve \
        frank

    create_users_file "${BASE_DIR}/node3/users.txt" \
        alice \
        bob \
        charlie \
        frank

    # Ensure directory permissions are world-readable for non-root execution.
    chmod -R 0755 /home/user

%labels
    Author cluster-audit-setup
    Description "Provides the initial filesystem state for the Cluster Audit task."

%help
    This Apptainer image sets up the initial environment for the “Cluster Audit”
    programming task.  It pre-installs Python 3, pytest, and creates the
    /home/user/cluster directory tree with the required users.txt files so that
    automated tests can verify the starting state.