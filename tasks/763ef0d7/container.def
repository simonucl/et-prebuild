Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install required packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 python3-pip iptables

    # Install pytest for the grading framework
    pip3 install --no-cache-dir pytest

    # Prepare the writable home directory for the unprivileged user
    mkdir -p /home/user
    chmod 0777 /home/user

    # Reduce image size
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure user-installed Python tools are discoverable
    export PATH="/home/user/.local/bin:$PATH"

%runscript
    echo "Apptainer container for the firewall provisioning task."
    exec "$@"