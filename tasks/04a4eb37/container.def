Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
set -eu

# Install Python and pytest
apt-get update
DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
    python3 \
    python3-pip
pip3 install --no-cache-dir pytest
apt-get clean
rm -rf /var/lib/apt/lists/*

# ------------------------------------------------------------------
# Prepare initial filesystem state expected by the grading tests
# ------------------------------------------------------------------
# Create required directories
mkdir -p /home/user/provisioning/input
mkdir -p /home/user/provisioning/output

# Populate CSV input files with exact, byte-for-byte content
cat > /home/user/provisioning/input/servers.csv <<'EOF'
host,ip,cpu,ram
web01,10.10.1.11,4,16
db01,10.10.1.12,8,32
cache01,10.10.1.13,2,8
EOF

cat > /home/user/provisioning/input/network.csv <<'EOF'
ip,vlan,subnet
10.10.1.11,frontend,10.10.1.0/24
10.10.1.12,backend,10.10.1.0/24
10.10.1.13,cache,10.10.1.0/24
EOF

# Permissions:
#  * Read-only inputs (644)
#  * Writable output directory (777 so the non-root runtime user can write)
chmod 644 /home/user/provisioning/input/*.csv
chmod 777 /home/user/provisioning/output
chmod 755 /home/user/provisioning /home/user/provisioning/input

%labels
Author      ChatGPT
Description Initial container state for bare-metal provisioning workflow task