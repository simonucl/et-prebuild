Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state for the learner
    # ------------------------------------------------------------------

    # 1. Create the required directory structure (raw only; no processed yet)
    mkdir -p /home/user/data/raw

    # 2. Populate the raw TSV files with the exact expected content
    cat > /home/user/data/raw/user_features.tsv << 'EOF'
id	age	height_cm	weight_kg
1	25	175	70
2	31	168	80
3	22	180	75
EOF

    cat > /home/user/data/raw/activity_stats.tsv << 'EOF'
id	avg_daily_steps	max_heart_rate
1	8000	190
2	6500	180
3	12000	200
EOF

    # 3. Ensure the learner can write to /home/user and its sub-directories
    chmod -R a+rwX /home/user

%environment
    chmod 755 /home/user

    # Use Python 3 as the default python
    export PYTHONIOENCODING=utf-8
    if [ -x /usr/bin/python3 ]; then
        alias python=/usr/bin/python3
    fi

%runscript
    echo "Container for data-processing task. Start an interactive shell:"
    exec /bin/bash