# syntax=docker/dockerfile:1
FROM ubuntu:22.04

# ------------------------------------------------------------
# Update package index and install Python, pip, and dependencies
# ------------------------------------------------------------
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked --mount=type=cache,target=/var/lib/apt,sharing=locked apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates && \
    rm -rf /var/lib/apt/lists/*

# Install pytest for the grader
RUN --mount=type=cache,target=/root/.cache/pip pip3 install --no-cache-dir pytest

# -----------------------------------------------------------------
# Prepare initial filesystem state for the credential-rotation task
# -----------------------------------------------------------------

# Ensure the /home/user hierarchy exists
RUN mkdir -p /home/user/app-container

# Create the initial secrets file with old credentials
RUN cat > /home/user/app-container/secrets.env <<'EOF'
API_KEY=OLD-KEY-ABC
DB_PASSWORD=OldPass123
EOF

# Set liberal permissions so the unprivileged runtime user can modify
RUN chmod 0777 /home/user/app-container && \
    chmod 0666 /home/user/app-container/secrets.env && \
    chmod 755 /home/user

# ------------------------------------------------------------
# Environment configuration
# ------------------------------------------------------------
ENV PATH=/usr/local/bin:/usr/bin:/bin

# ------------------------------------------------------------
# Metadata labels
# ------------------------------------------------------------
LABEL Author="Generated by ChatGPT – Apptainer task scaffold" \
      Description="Container prepared for in-container credential rotation exercise."