Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Update package index and install Python + pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        && rm -rf /var/lib/apt/lists/*

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # -----------------------------------------------------------------
    # Prepare initial filesystem state for the credential-rotation task
    # -----------------------------------------------------------------
    # Ensure the /home/user hierarchy exists
    mkdir -p /home/user/app-container

    # Create the initial secrets file with old credentials
    cat > /home/user/app-container/secrets.env <<'EOF'
API_KEY=OLD-KEY-ABC
DB_PASSWORD=OldPass123
EOF

    # Set liberal permissions so the unprivileged runtime user can modify
    chmod 0777 /home/user/app-container
    chmod 0666 /home/user/app-container/secrets.env

%environment
    chmod 755 /home/user

    # Minimal PATH
    export PATH=/usr/local/bin:/usr/bin:/bin

%labels
    Author="Generated by ChatGPT – Apptainer task scaffold"
    Description="Container prepared for in-container credential rotation exercise."