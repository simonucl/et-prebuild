Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Prepare initial filesystem state expected by the automated tests
    # ------------------------------------------------------------------
    # Create project directory with placeholder source file
    mkdir -p /home/user/project/src

    cat <<'EOF' >/home/user/project/src/app.py
# sample source file
print("Hello from project")
EOF

    # Ensure the future agent (non-root) can create /home/user/release
    chmod -R 0777 /home/user

%environment
    chmod 755 /home/user

    # Basic environment setting; do not override $HOME
    export PYTHONUNBUFFERED=1