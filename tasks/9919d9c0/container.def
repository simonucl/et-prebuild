Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # Update package lists and install required packages
    apt-get update
    apt-get install -y \
        python3 \
        python3-pip \
        cron

    # Create the non-root target account
    useradd -m -s /bin/bash user

    # Guarantee a pristine workspace for the exercise
    rm -rf /home/user/bin /home/user/logs /home/user/reports /home/user/migration || true

    # Install pytest for the grading harness
    pip3 install --no-cache-dir pytest

    # Clean up apt cache to keep the image slim
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    export PATH=/home/user/.local/bin:$PATH

%labels
    Author cloud-migration-task
    Description "Base image for Cloud Migration Cron Job exercise – initial clean state"