Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "Updating package lists and installing Python tooling..."
    apt-get update -qq
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        && apt-get clean && rm -rf /var/lib/apt/lists/*

    echo "Installing pytest via pip..."
    pip3 install --no-cache-dir --upgrade pip pytest

    echo "Creating project directory tree and populating INI files..."
    mkdir -p /home/user/docs/configs
    mkdir -p /home/user/docs/reports

    # settings.ini
    cat > /home/user/docs/configs/settings.ini <<'EOF'
[general]
author=alice
version=1.2.3

[paths]
home=/home/alice
temp=/tmp/project
EOF

    # database.ini
    cat > /home/user/docs/configs/database.ini <<'EOF'
[connection]
host=localhost
port=5432
user=dbuser

[pools]
min=1
max=15
EOF

    # ui.ini
    cat > /home/user/docs/configs/ui.ini <<'EOF'
[window]
width=1024
height=768

[theme]
color=dark
font=Roboto
EOF

    echo "Adjusting permissions to allow the unprivileged runtime user to write reports..."
    chmod -R a+r /home/user/docs/configs
    chmod -R a+rwX /home/user/docs/reports
    # Allow creation of new files/directories under /home/user/docs
    chmod a+rwX /home/user/docs

%environment
    chmod 755 /home/user

    # Ensure Python and Pip are on the PATH (should be already, but safe to export)
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author="Auto-generated"
    Description="Container for INI summarisation task with pytest pre-installed."