FROM ubuntu:22.04

# Labels
LABEL Author="Generated by ChatGPT"
LABEL Description="Container for configuration backup automation task with pytest pre-installed."

# Install Python and pytest
RUN set -e && \
    apt-get update -y && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip && \
    pip3 install --no-cache-dir pytest && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Create the user home hierarchy
RUN mkdir -p /home/user/configs

# Populate configuration files - app.conf
RUN cat > /home/user/configs/app.conf <<'EOF'
APP_NAME=TestApp
APP_ENV=production
EOF

# Populate configuration files - db.conf
RUN cat > /home/user/configs/db.conf <<'EOF'
DB_HOST=localhost
DB_PORT=5432
EOF

# Ensure permissions allow the (unprivileged) runtime user to modify /home/user
RUN chmod -R a+rwx /home/user

# Environment variables
ENV PYTHONIOENCODING=utf-8

# Default command
CMD ["echo", "This container is prepared for the configuration-backup task. Execute your scripts/tests as needed."]