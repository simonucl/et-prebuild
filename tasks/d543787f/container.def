Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ------------------------------------------------------------------
    # Install Python and pytest
    # ------------------------------------------------------------------
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state expected by the tests
    # ------------------------------------------------------------------
    # Create the user home hierarchy
    mkdir -p /home/user/configs

    # Populate configuration files
    cat > /home/user/configs/app.conf <<'EOF'
APP_NAME=TestApp
APP_ENV=production
EOF

    cat > /home/user/configs/db.conf <<'EOF'
DB_HOST=localhost
DB_PORT=5432
EOF

    # Ensure permissions allow the (unprivileged) runtime user to modify /home/user
    chmod -R a+rwx /home/user

%environment
    chmod 755 /home/user

    # Expose python and pytest to PATH (python3 is already on PATH in ubuntu)
    export PYTHONIOENCODING=utf-8

%labels
    Author="Generated by ChatGPT"
    Description="Container for configuration backup automation task with pytest pre-installed."

%runscript
    echo "This container is prepared for the configuration-backup task. Execute your scripts/tests as needed."