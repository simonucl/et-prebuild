Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package list and install Python + pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 python3-pip locales
    rm -rf /var/lib/apt/lists/*

    # Ensure a UTF-8 locale is available (helps with non-ASCII characters)
    locale-gen en_US.UTF-8

    # Install pytest for the grading system
    pip3 install --no-cache-dir pytest

    # ----------------------------------------------------------------------------
    # Create initial project directory structure and seed files
    # ----------------------------------------------------------------------------
    install -d -m 0777 /home/user/project-locale/config/locales

    # 1. English locale (canonical)
    cat > /home/user/project-locale/config/locales/en.yaml <<'EOF'
greeting: "Hello"
farewell: "Goodbye"
login: "Login"
logout: "Logout"
profile: "Profile"
EOF

    # 2. Spanish locale (missing two keys)
    cat > /home/user/project-locale/config/locales/es.yaml <<'EOF'
greeting: "Hola"
farewell: "Adiós"
login: "Iniciar sesión"
EOF

    # 3. French locale (missing three keys)
    cat > /home/user/project-locale/config/locales/fr.yaml <<'EOF'
greeting: "Bonjour"
farewell: "Au revoir"
EOF

    # 4. build_info.toml with original values
    cat > /home/user/project-locale/config/build_info.toml <<'EOF'
version = "1.4.2"
build_number = 17
EOF

    # Give non-root users full write access inside the project directory
    chmod -R 0777 /home/user/project-locale

%environment
    chmod 755 /home/user

    # Ensure Python is on PATH
    PATH=/usr/local/bin:/usr/bin:/bin
    export PATH