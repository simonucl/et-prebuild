Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # Update package lists and install Python 3 pip
    apt-get update -y
    apt-get install -y --no-install-recommends python3-pip

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # Ensure a writable home directory for the learner
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure Python and pip are in PATH
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%runscript
    exec "${@}"

%labels
    Author="Apptainer Task Preparer"
    Description="Base container for the pre-update diagnostic task with pytest pre-installed."