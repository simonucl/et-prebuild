Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ---------- Basic tooling -------------------------------------------------
    apt-get update -y
    apt-get install -y --no-install-recommends python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ---------- Prepare initial exercise state --------------------------------
    # Create the required directory hierarchy
    mkdir -p /home/user/provisioning/config
    mkdir -p /home/user/provisioning/scripts
    mkdir -p /home/user/provisioning/docs

    # Populate files with exact contents (including trailing newlines)
    printf 'port=8080\nmode=production\n' \
        > /home/user/provisioning/config/app.conf

    printf '#!/bin/bash\necho Deploying...\n' \
        > /home/user/provisioning/scripts/deploy.sh
    chmod +x /home/user/provisioning/scripts/deploy.sh

    printf '# Infrastructure Provisioning\nThis directory contains scripts.\n' \
        > /home/user/provisioning/docs/readme.md

    # Ensure correct permissions for all files (readable by any user)
    chmod 644 /home/user/provisioning/config/app.conf \
              /home/user/provisioning/scripts/deploy.sh \
              /home/user/provisioning/docs/readme.md

    # Leave /home/user/archives, /home/user/recovery, and
    # /home/user/provisioning/logs intentionally absent.

%labels
    chmod 755 /home/user

    Author Infrastructure Exercise Setup
    Description Minimal environment for the Infrastructure Provisioning task

%runscript
    echo "This container is prepared for the Infrastructure Provisioning exercise."
    echo "Invoke your own commands or a test suite as needed."