Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # -------------------------------------------------------------------------
    # System packages
    # -------------------------------------------------------------------------
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    rm -rf /var/lib/apt/lists/*

    # -------------------------------------------------------------------------
    # Python tooling
    # -------------------------------------------------------------------------
    pip3 install --no-cache-dir pytest

    # -------------------------------------------------------------------------
    # Prepare initial exercise state
    # -------------------------------------------------------------------------
    # Create the required directory structure
    mkdir -p /home/user/build_logs
    chmod 0755 /home/user
    chmod 0755 /home/user/build_logs

    # Create the Android build log with the exact expected content
    cat << 'EOF' > /home/user/build_logs/android_build_2023-11-01.log
[2023-11-01 10:00:00] INFO: Build started
[2023-11-01 10:00:05] WARNING: Deprecated API usage in module 'auth'
[2023-11-01 10:00:10] INFO: Compiling resources
[2023-11-01 10:00:12] WARNING: Unused variable in file MainActivity.kt
[2023-11-01 10:00:15] ERROR: Compilation failed
[2023-11-01 10:00:20] INFO: Build finished with errors
EOF
    chmod 0644 /home/user/build_logs/android_build_2023-11-01.log

%environment
    chmod 755 /home/user

    # Keep the user’s PATH sane
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author="Generated by OpenAI ChatGPT"
    Description="Environment for the Android build log – WARNING extraction exercise."

%help
    This Apptainer container provides the starting filesystem state and tools
    required for the “Android build log – WARNING extraction” task.