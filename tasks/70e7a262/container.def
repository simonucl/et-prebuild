Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
Author example
Description "Initial state for symbolic-link audit task"

%post
    set -e

    # Update package lists and install Python + pip
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 python3-pip

    # Install pytest for the autograder
    pip3 install --no-cache-dir pytest

    # --------------------------------------------------------------------
    # Create the required directory / file structure
    # --------------------------------------------------------------------
    mkdir -p /home/user/db_data/bigdata
    mkdir -p /home/user/db_data/fastdata
    mkdir -p /home/user/db_archives/2023_09_prod
    mkdir -p /home/user/db_archives/2023_10_maint
    mkdir -p /home/user/configs

    # Regular file that must already exist
    echo "-- placeholder SQL config" > /home/user/configs/new_config.sql

    # Ensure the symlinks and audit log DO NOT exist (safety in case of rebuilds)
    rm -f /home/user/current_db_data
    rm -f /home/user/db_archives/latest
    rm -f /home/user/query_conf_active.sql
    rm -f /home/user/symlink_audit.log || true

    # --------------------------------------------------------------------
    # Make sure the student (non-root inside container) can write to /home/user
    # --------------------------------------------------------------------
    chmod -R 777 /home/user

    # Clean up apt caches to keep image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure Python and pip are in PATH
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%runscript
    exec /bin/bash

%help
This container provides the initial filesystem state for the “symbolic-link audit”
task.  The required source directories and files are present under /home/user/,
while the symbolic links and the audit log that the learner must create are
intentionally absent.  Pytest is installed for automated grading.