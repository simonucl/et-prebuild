Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Update package lists and install Python tooling
    apt-get update -y
    apt-get install -y python3-pip

    # Install pytest for the automated test-runner
    pip3 install --no-cache-dir pytest

    # Ensure the working directory for the student exists and is writable
    mkdir -p /home/user
    chmod 0777 /home/user

    # House-keeping
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Keep locale predictable for any date/epoch calculations
    export LC_ALL=C.UTF-8

%labels
    Author DevSecOps-Container-Setup
    Description "Base image for benchmarking /bin/true against a 1000 ms policy. Pytest pre-installed."