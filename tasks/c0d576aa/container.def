Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        coreutils \
        findutils
    pip3 install --no-cache-dir pytest

    # Helper to create a file of an exact byte-size
    create_file() {
        # $1 = path, $2 = size in bytes
        dd if=/dev/zero of="$1" bs="$2" count=1 status=none
    }

    # ------------------------------------------------------------------
    # Create initial directory structure and files
    # ------------------------------------------------------------------
    mkdir -p /home/user/repositories/repoA/nested
    mkdir -p /home/user/repositories/repoB

    # repoA
    create_file  /home/user/repositories/repoA/oldlib-1.0.jar          31
    create_file  /home/user/repositories/repoA/newlib-2.0.jar          31
    create_file  /home/user/repositories/repoA/package-1.0.tar.gz      38
    truncate -s 0 /home/user/repositories/repoA/empty.tmp

    # repoA/nested
    create_file  /home/user/repositories/repoA/nested/legacy-0.9.jar   18
    create_file  /home/user/repositories/repoA/nested/sample-archive.tar.gz 36
    truncate -s 0 /home/user/repositories/repoA/nested/zero.txt

    # repoB
    create_file  /home/user/repositories/repoB/obsolete-2.3.jar        28
    create_file  /home/user/repositories/repoB/data-1.1.tar.gz         27
    truncate -s 0 /home/user/repositories/repoB/nothing.txt

    # ------------------------------------------------------------------
    # Set modification times
    #   Aged *.jar  -> > 90 days old (fixed past dates)
    #   Fresh *.tar -> < 30 days old (10 & 20 days ago, plus now)
    # ------------------------------------------------------------------
    touch -d "2020-01-01 00:00:00" /home/user/repositories/repoA/oldlib-1.0.jar
    touch -d "2020-02-01 00:00:00" /home/user/repositories/repoA/nested/legacy-0.9.jar
    touch -d "2019-12-01 00:00:00" /home/user/repositories/repoB/obsolete-2.3.jar

    touch -d "10 days ago"  /home/user/repositories/repoA/nested/sample-archive.tar.gz
    touch -d "20 days ago"  /home/user/repositories/repoB/data-1.1.tar.gz
    # package-1.0.tar.gz keeps the current (build-time) timestamp

    # ------------------------------------------------------------------
    # Relax permissions so the non-root user running the exercise can
    # freely manipulate files under /home/user.
    # ------------------------------------------------------------------
    chmod -R a+rwX /home/user

%labels
    chmod 755 /home/user

    Author artifact-manager bootstrap

%help
This Apptainer image provides the initial repository layout required for
the “artifact-manager” auditing exercise.  It pre-installs Python 3 and
pytest and prepares the exact file hierarchy (with correct sizes and
timestamps) under /home/user/repositories that the test-suite expects.