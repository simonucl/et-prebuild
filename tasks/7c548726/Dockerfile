FROM ubuntu:22.04

# System packages
RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-setuptools \
        ca-certificates \
        tar \
        coreutils && \
    rm -rf /var/lib/apt/lists/*

# Python testing tools
RUN pip3 install --no-cache-dir pytest

# Create the initial project directory tree and seed data
RUN mkdir -p /home/user/etl_project/raw_data && \
    chmod 0777 /home/user

# Seed CSV files
RUN cat >/home/user/etl_project/raw_data/customers.csv <<'EOF'
id,name
1,Alice
2,Bob
EOF

RUN cat >/home/user/etl_project/raw_data/orders.csv <<'EOF'
id,customer_id,total
101,1,19.95
102,2,5.00
EOF

RUN cat >/home/user/etl_project/raw_data/products.csv <<'EOF'
id,description,price
501,Widget,9.99
502,Gadget,5.00
EOF

# Ensure world-readability for the raw data
RUN chmod -R a+rX /home/user/etl_project

# Environment setup
RUN chmod 755 /home/user
ENV PATH="$PATH:/usr/local/bin"

LABEL Author="Generated by ChatGPT"
LABEL Description="Container for ETL backup task – initial dataset plus pytest"