Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ---------------------------------------------------------------------- 
    # System packages
    # ---------------------------------------------------------------------- 
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-setuptools \
        ca-certificates \
        tar \
        coreutils

    # ---------------------------------------------------------------------- 
    # Python testing tools
    # ---------------------------------------------------------------------- 
    pip3 install --no-cache-dir pytest

    # ---------------------------------------------------------------------- 
    # Create the initial project directory tree and seed data
    # ---------------------------------------------------------------------- 
    mkdir -p /home/user/etl_project/raw_data

    # Make /home/user writable by the (non-root) runtime user so that the
    # learner can create the /home/user/backups directory during the exercise.
    chmod 0777 /home/user

    # Seed CSV files
    cat >/home/user/etl_project/raw_data/customers.csv <<'EOF'
id,name
1,Alice
2,Bob
EOF

    cat >/home/user/etl_project/raw_data/orders.csv <<'EOF'
id,customer_id,total
101,1,19.95
102,2,5.00
EOF

    cat >/home/user/etl_project/raw_data/products.csv <<'EOF'
id,description,price
501,Widget,9.99
502,Gadget,5.00
EOF

    # Ensure world-readability for the raw data; write permission not needed.
    chmod -R a+rX /home/user/etl_project

%environment
    chmod 755 /home/user

    # Ensure Python user-installed binaries (if any) are reachable
    export PATH="$PATH:/usr/local/bin"

%labels
    Author="Generated by ChatGPT"
    Description="Container for ETL backup task – initial dataset plus pytest"