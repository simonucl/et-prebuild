Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "Updating package index ..."
    apt-get update -y

    echo "Installing required packages ..."
    DEBIAN_FRONTEND=noninteractive \
        apt-get install -y --no-install-recommends \
            openssh-client \
            python3 \
            python3-pip \
            ca-certificates

    echo "Installing pytest via pip ..."
    pip3 install --no-cache-dir pytest

    echo "Adding non-root user 'user' (uid 1000) ..."
    # Create group/user only if they do not already exist
    if ! getent group 1000 >/dev/null 2>&1; then
        groupadd -g 1000 user
    fi
    if ! id -u 1000 >/dev/null 2>&1; then
        useradd -m -u 1000 -g 1000 -s /bin/bash user
    fi

    # Ensure /home/user exists with sane permissions
    mkdir -p /home/user
    chown 1000:1000 /home/user
    chmod 755 /home/user

    echo "Cleaning up APT caches ..."
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%labels
    Author AI
    Description Environment for SSH-key/log automation exercise with pytest pre-installed

%help
    This container provides:
      • Ubuntu 22.04 base
      • Python 3 and pytest
      • OpenSSH client tools (for ssh-keygen)
    A dedicated non-root account “user” (uid 1000) with home directory /home/user
    is pre-created.  No task-specific files (keys, logs, etc.) are present so that
    assignment instructions can be followed from a pristine state.