Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update OS and install required packages
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        gettext \
        ca-certificates
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create initial directory structure and seed files for the exercise
    # ------------------------------------------------------------------
    mkdir -p /home/user/projects/website/locale/fr/LC_MESSAGES
    mkdir -p /home/user/projects/website/logs
    mkdir -p /home/user/resources

    # messages.po (untranslated)
    cat > /home/user/projects/website/locale/fr/LC_MESSAGES/messages.po <<'EOF'
msgid ""
msgstr ""
"Project-Id-Version: website 1.4\n"
"Language: fr\n"
"Content-Type: text/plain; charset=UTF-8\n"

#: src/errors.c:45
msgid "Server unreachable"
msgstr ""
EOF

    # DNS seed file
    cat > /home/user/resources/dns_seed.txt <<'EOF'
staging.l10n.test 203.0.113.30
api.l10n.test     203.0.113.31
EOF

    # Ensure permissions allow the non-root runtime user to work
    chmod -R a+rwx /home/user

%environment
    chmod 755 /home/user

    # Ensure PATH contains /usr/local/bin for pip installations
    export PATH=/usr/local/bin:$PATH

# No %test section as instructed