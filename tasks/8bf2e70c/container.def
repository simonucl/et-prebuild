Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update APT index and install Python3 and pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y python3 python3-pip --no-install-recommends
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the grader
    pip3 install --no-cache-dir pytest

    # Prepare directory structure for the task
    mkdir -p /home/user/scan_data

    # Make sure the non-root runtime user can write under /home/user
    chmod 0777 /home/user
    chmod 0777 /home/user/scan_data

    # Create the ground-truth inventory file
    cat > /home/user/scan_data/vulnerable-services.ini <<'EOF'
[192.168.1.10-ssh]
port = 22
service = ssh
version = 7.8p1

[192.168.1.11-ssh]
port = 22
service = ssh
version = 8.4p1

[192.168.1.20-apache]
port = 80
service = apache
version = 2.4.48

[192.168.1.21-apache]
port = 80
service = apache
version = 2.4.53

[192.168.1.30-mysql]
port = 3306
service = mysql
version = 5.7.37

[192.168.1.31-mysql]
port = 3306
service = mysql
version = 8.0.32
EOF
    chmod 0666 /home/user/scan_data/vulnerable-services.ini

%environment
    chmod 755 /home/user

    # Ensure the default Python and pip are accessible
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%labels
    Author "Course Autograder"
    Description "Initial environment for vulnerability-scan parsing task, includes pytest and predefined inventory file."