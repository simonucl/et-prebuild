Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip

    pip3 install --no-cache-dir pytest

    # Create a writable /home/user directory for the unprivileged runtime user
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up APT caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Make sure standard binary locations are in PATH
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author="Auto-generated by ChatGPT"
    Description="Base container for the ‘pen-test’ exercise; provides Python and pytest, and prepares an empty /home/user directory."