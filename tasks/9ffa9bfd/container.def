Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package lists and install Python and pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-setuptools \
        ca-certificates
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the grading harness
    pip3 install --no-cache-dir pytest

    # Create a non-root user `user` with home directory /home/user
    useradd -m -u 1000 -s /bin/bash user

    # Ensure ownership of the home directory
    chown -R user:user /home/user

    # NOTE: Do NOT create /home/user/.iot or its contents here.
    # The student/agent will be responsible for doing that during the task.

%environment
    chmod 755 /home/user

    # Make sure user-installed binaries are discoverable (if any)
    export PATH="/home/user/.local/bin:${PATH}"

%labels
    Author="Generated for edge-computing IoT configuration task"
    Description="Base image with Python and pytest, initial state clean for /.iot task."