Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author edge-task-preparer
    Description "Environment for edge-deployment permissions task"

%post
    set -e

    # Basic utilities and Python tooling
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 python3-pip ca-certificates \
        && apt-get clean && rm -rf /var/lib/apt/lists/*

    # Latest pip and pytest for the grading harness
    python3 -m pip install --no-cache-dir --upgrade pip
    python3 -m pip install --no-cache-dir pytest

    # Ensure the expected home directory exists and is writable by any user
    mkdir -p /home/user
    chmod 0777 /home/user

%environment
    chmod 755 /home/user

    # Point HOME to the directory required by the tests
    export HOME=/home/user
    export PATH=$HOME/.local/bin:$PATH

%runscript
    # Default action: drop into a shell
    exec /bin/bash "$@"