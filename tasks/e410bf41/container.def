Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial directory structure and input artefacts
    # ------------------------------------------------------------------
    mkdir -p /home/user/monitoring

    # raw_metrics.csv  (exactly 10 data rows + header)
    cat > /home/user/monitoring/raw_metrics.csv <<'CSV'
timestamp,hostname,cpu_usage,mem_usage,disk_free
2023-08-01T10:00:00Z,web01,45,60,40
2023-08-01T10:05:00Z,db01,85,70,25
2023-08-01T10:10:00Z,web01,90,80,14
2023-08-01T10:15:00Z,web02,70,78,12
2023-08-01T10:20:00Z,db01,65,74,30
2023-08-01T10:25:00Z,web01,55,65,50
2023-08-01T10:30:00Z,web02,82,60,20
2023-08-01T10:35:00Z,db01,75,76,10
2023-08-01T10:40:00Z,web01,60,70,18
2023-08-01T10:45:00Z,web01,88,77,13
CSV

    # thresholds.json
    cat > /home/user/monitoring/thresholds.json <<'JSON'
{
  "cpu_usage": 80,
  "mem_usage": 75,
  "disk_free": 15
}
JSON

    # Ensure world-readable inputs (no root-only permissions)
    chmod -R a+rX /home/user/monitoring

%environment
    chmod 755 /home/user

    export MONITORING_DIR=/home/user/monitoring

%labels
    Maintainer="container-prep bot"