Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    ###############################
    # 1. Install Python & pytest  #
    ###############################
    apt-get update -qq
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    ###############################
    # 2. Prepare initial filesystem
    ###############################
    # Create base home directory with open permissions so the
    # unprivileged runtime user can create / modify files inside.
    mkdir -p /home/user
    chmod 0777 /home/user

    # --- /home/user/scripts ---------------------------------------
    mkdir -p /home/user/scripts
    chmod 0755 /home/user/scripts

    # hello.sh
    cat > /home/user/scripts/hello.sh <<'EOF'
#!/usr/bin/env bash
echo "Hello, World!"
EOF
    chmod 0755 /home/user/scripts/hello.sh

    # README.md
    cat > /home/user/scripts/README.md <<'EOF'
# Utility Scripts
This directory contains small helper scripts used in various automation tasks.
EOF
    chmod 0644 /home/user/scripts/README.md

    # --- Empty directories ---------------------------------------
    mkdir -p /home/user/archives
    mkdir -p /home/user/logs

    # Allow write access for the runtime user
    chmod 0777 /home/user/archives
    chmod 0777 /home/user/logs

    ################################
    # 3. Clean up APT caches        #
    ################################
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure python & pip are in PATH
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author  example_builder
    Description "Base container for compression/archiving task; includes pytest and initial directory state."