Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package index and install required packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        jq \
        ca-certificates
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the automated test suite
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state for the exercise
    # ------------------------------------------------------------------
    mkdir -p /home/user/deployment

    # Create schema.json exactly as specified
    cat > /home/user/deployment/schema.json <<'EOF'
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Update descriptor",
  "type": "object",
  "required": ["update_id", "version", "status"],
  "properties": {
    "update_id": { "type": "string" },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    },
    "status": {
      "type": "string",
      "enum": ["pending", "applied"]
    }
  },
  "additionalProperties": false
}
EOF

    # Create updates.json exactly as specified
    cat > /home/user/deployment/updates.json <<'EOF'
[
  {"update_id":"udp-100","version":"1.2.0","status":"pending"},
  {"update_id":"udp-101","version":"1.2","status":"pending"},
  {"update_id":"udp-102","version":"1.3.0","status":"deploying"},
  {"update_id":"udp-103","version":"1.4.0","status":"applied"},
  {"update_id":"udp-104","version":"1.5.0"}
]
EOF

    # Permissions: directory must be writable by the non-root user running the container
    chmod 777 /home/user/deployment
    chmod 644 /home/user/deployment/schema.json /home/user/deployment/updates.json

%environment
    chmod 755 /home/user

    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8