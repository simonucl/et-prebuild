Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install required packages
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip curl
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Prepare initial filesystem state for the exercise
    mkdir -p /home/user/creds
    chmod 0777 /home/user/creds          # Ensure the unprivileged user can write here

    # Create the initial credential file with exact expected content
    printf '{"api_key":"old_key_123","expires":"2023-01-01T00:00:00Z"}' \
        > /home/user/creds/api_creds.json
    chmod 0666 /home/user/creds/api_creds.json

%runscript
    chmod 755 /home/user

    echo "Apptainer container ready for the API credential rotation exercise."