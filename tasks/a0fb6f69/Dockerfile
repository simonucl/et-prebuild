FROM ubuntu:22.04

# Help text
# Container for the “accounts tidy-up” exercise.
# Provides the initial filesystem state and the Python/pytest tooling
# required by the automated grader.

LABEL Author="Generated by ChatGPT – Apptainer setup for symlink exercise"

RUN set -e && \
    apt-get update -y && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip && \
    pip3 install --no-cache-dir pytest

RUN if [ ! -e /usr/bin/python ]; then ln -s /usr/bin/python3 /usr/bin/python; fi

RUN mkdir -p /home/user && \
    chmod 0777 /home/user

RUN mkdir -p /home/user/userdirs && \
    for name in alice bob carla dave erin; do mkdir -p "/home/user/userdirs/${name}"; done && \
    chmod -R 0755 /home/user/userdirs