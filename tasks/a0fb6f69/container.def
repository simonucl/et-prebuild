Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # Make `python` invoke Python 3 for convenience (some test harnesses rely on it)
    if [ ! -e /usr/bin/python ]; then
        ln -s /usr/bin/python3 /usr/bin/python
    fi

    # ------------------------------------------------------------------
    # Prepare the initial filesystem state expected by the exercise
    # ------------------------------------------------------------------

    # Create the base directory and make it writable for the non-root agent
    mkdir -p /home/user
    chmod 0777 /home/user

    # Real user directories that must pre-exist
    mkdir -p /home/user/userdirs
    for name in alice bob carla dave erin; do
        mkdir -p "/home/user/userdirs/${name}"
    done
    chmod -R 0755 /home/user/userdirs

    # NOTE:
    #   We deliberately do NOT create /home/user/accounts/, the account
    #   sub-directories, any symbolic links, or the log file.  Those are
    #   part of the task the agent will perform.
    # ------------------------------------------------------------------

%labels
    chmod 755 /home/user

    Author "Generated by ChatGPT – Apptainer setup for symlink exercise"

%help
    Container for the “accounts tidy-up” exercise.
    Provides the initial filesystem state and the Python/pytest tooling
    required by the automated grader.