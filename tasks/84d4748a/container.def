Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    #!/bin/bash
    set -e

    echo "Updating package index and installing dependencies ..."
    apt-get update

    # Core tools required for the task and for running the test-suite
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        sqlite3 \
        python3 \
        python3-pip

    # Install pytest via pip (avoids any version discrepancies)
    pip3 install --no-cache-dir pytest

    # Ensure the expected home directory exists for the learner
    mkdir -p /home/user
    chmod 755 /home/user

    # Clean up APT cache to keep image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    # Minimal locale / PATH settings
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
    export PATH=/usr/local/bin:/usr/bin:/bin

%labels
    Author build-release-task
    Description "Environment for 'Create and Maintain a Build-Artifacts SQLite Inventory' task"