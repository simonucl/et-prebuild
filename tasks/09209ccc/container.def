Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and Pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Prepare initial data set expected by the test harness
    # ------------------------------------------------------------------
    mkdir -p /home/user/data_to_backup/images
    mkdir -p /home/user/data_to_backup/scripts

    # 1. doc1.txt  (exact text with trailing newline)
    printf 'First document\n' > /home/user/data_to_backup/doc1.txt

    # 2. images/photo.jpg  (any non-empty binary file)
    dd if=/dev/urandom of=/home/user/data_to_backup/images/photo.jpg \
       bs=1024 count=1 status=none

    # 3. scripts/backup.sh  (exact two-line shell script)
    printf '#!/bin/bash\necho backup\n' > /home/user/data_to_backup/scripts/backup.sh
    chmod +x /home/user/data_to_backup/scripts/backup.sh

    # Ensure all users can read the prepared files and directories
    chmod -R a+rX /home/user

%environment
    chmod 755 /home/user

    # No special environment variables required
    export LC_ALL=C.UTF-8

%runscript
    echo "Apptainer image for the backup task."
    echo "Navigate to /home/user and follow the instructions to create the backup bundle."