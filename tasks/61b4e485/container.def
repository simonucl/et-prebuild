Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    ########## Install required software ##########
    apt-get update -y
    # python3 is present on the base image, but make sure pip is available
    apt-get install -y python3-pip
    pip3 install --no-cache-dir pytest

    ########## Prepare initial dataset layout ##########
    # Create the user's data directory tree
    mkdir -p /home/user/datasets

    # Generate the five dataset files with the exact byte sizes required
    # We use /dev/zero piped through tr to produce clean ASCII files
    head -c 21 /dev/zero | tr '\0' 'a' > /home/user/datasets/sample1.csv
    head -c 14 /dev/zero | tr '\0' 'b' > /home/user/datasets/sample2.csv
    head -c 13 /dev/zero | tr '\0' 'c' > /home/user/datasets/sample3.csv
    head -c 22 /dev/zero | tr '\0' 'd' > /home/user/datasets/config.json
    head -c 20 /dev/zero | tr '\0' 'e' > /home/user/datasets/meta.json

    # Make sure permissions allow the unprivileged runtime user to modify the files
    chmod 777 /home/user /home/user/datasets
    chmod 666 /home/user/datasets/*

%environment
    chmod 755 /home/user

    # Nothing to override; keep the container environment clean.
    :