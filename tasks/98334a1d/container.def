Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update APT and install Python + pip
    apt-get update && \
        DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
            python3 \
            python3-pip \
            ca-certificates \
        && apt-get clean && rm -rf /var/lib/apt/lists/*

    # Install pytest for the grading harness
    pip3 install --no-cache-dir pytest

    # ----------------------------------------------------------------------------
    # Create the initial repository state expected by the tests
    # ----------------------------------------------------------------------------
    PROJECT_ROOT="/home/user/project-docs"
    mkdir -p "${PROJECT_ROOT}"

    # VERSION file (exactly "1.4.2\n")
    printf "1.4.2\n" > "${PROJECT_ROOT}/VERSION"

    # CHANGELOG.md with the precise initial content
    cat > "${PROJECT_ROOT}/CHANGELOG.md" <<'EOF'
# Changelog

All notable changes to this project will be documented in this file following Keep a Changelog principles.

## [1.4.2] - 2024-01-10
### Changed
- Tweaked API docs.
EOF

    # Make sure ownership and permissions allow the unprivileged user to work
    chmod -R u+rwX,go+rX "${PROJECT_ROOT}"

%environment
    chmod 755 /home/user

    # Ensure Python and pip are on PATH for any user
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author "Apptainer setup for version-bump task"

%help
    This Apptainer image provides the initial filesystem state for the
    “project-docs” version-bump exercise and includes pytest for automated grading.