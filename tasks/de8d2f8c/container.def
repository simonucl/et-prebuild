Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author Docker-Expert
    Description Base image for diagnostics-logging exercise. Pytest installed; writable /home/user prepared.

%post
    # Update package lists and install Python and pip
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-setuptools \
        python3-wheel
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the test harness
    pip3 install --no-cache-dir pytest

    # Prepare writable home directory for the non-root user who will run the container
    mkdir -p /home/user
    chmod 0777 /home/user

%environment
    chmod 755 /home/user

    # Ensure Python and pip are on PATH
    export PATH="/usr/local/bin:/usr/bin:/bin:${PATH}"

%runscript
    echo "Container for diagnostics-logging task. This image is intended to be used by the automated grader."