Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Basic tooling and Python + pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Prepare initial diagnostic logs expected by the exercise
    # ------------------------------------------------------------------
    mkdir -p /home/user/diag_logs

    cat > /home/user/diag_logs/cpu_stats.txt <<'EOF'
timestamp,cpu_usage
2023-08-01T10:00:00Z,17
2023-08-01T10:05:00Z,19
2023-08-01T10:10:00Z,17
EOF

    cat > /home/user/diag_logs/mem_stats.txt <<'EOF'
timestamp,mem_total,mem_used,mem_free
2023-08-01T10:00:00Z,8000,5600,2400
2023-08-01T10:05:00Z,8000,5700,2300
2023-08-01T10:10:00Z,8000,5500,2500
EOF

    cat > /home/user/diag_logs/disk_stats.txt <<'EOF'
timestamp,disk_use_pct
2023-08-01T10:00:00Z,50
2023-08-01T10:05:00Z,50.8
2023-08-01T10:10:00Z,51.2
EOF

    # Ensure the files and directories are readable by non-root users
    chmod -R a+r /home/user

%labels
    chmod 755 /home/user

    Author      "Autogenerated by ChatGPT"
    Description "Environment for diagnostic log summarisation task with pytest pre-installed"