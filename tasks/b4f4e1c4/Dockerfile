# syntax=docker/dockerfile:1
FROM ubuntu:22.04

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked --mount=type=cache,target=/var/lib/apt,sharing=locked --mount=type=cache,target=/root/.cache/pip set -e && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip && \
    pip3 install --no-cache-dir pytest && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

RUN mkdir -p /home/user/diag_logs

RUN cat > /home/user/diag_logs/cpu_stats.txt <<'EOF'
timestamp,cpu_usage
2023-08-01T10:00:00Z,17
2023-08-01T10:05:00Z,19
2023-08-01T10:10:00Z,17
EOF

RUN cat > /home/user/diag_logs/mem_stats.txt <<'EOF'
timestamp,mem_total,mem_used,mem_free
2023-08-01T10:00:00Z,8000,5600,2400
2023-08-01T10:05:00Z,8000,5700,2300
2023-08-01T10:10:00Z,8000,5500,2500
EOF

RUN cat > /home/user/diag_logs/disk_stats.txt <<'EOF'
timestamp,disk_use_pct
2023-08-01T10:00:00Z,50
2023-08-01T10:05:00Z,50.8
2023-08-01T10:10:00Z,51.2
EOF

RUN chmod -R a+r /home/user && chmod 755 /home/user

LABEL Author="Autogenerated by ChatGPT"
LABEL Description="Environment for diagnostic log summarisation task with pytest pre-installed"