Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-setuptools \
        ca-certificates \
        tzdata
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state required by the assignment
    # ------------------------------------------------------------------

    # Create the user’s home hierarchy if it does not already exist
    mkdir -p /home/user

    # diagnostics directory must be writable by the runtime (non-root) user
    mkdir -p /home/user/diagnostics/certs
    chmod 777 /home/user/diagnostics          # world-writable as tests expect

    # ------------------------------------------------------------------
    # Seed the certificate files with the expected contents
    # ------------------------------------------------------------------

    cat > /home/user/diagnostics/certs/db.crt <<'EOF'
-----BEGIN CERTIFICATE-----
MIIDFA...
NotAfter=2024-12-31T23:59:59Z
-----END CERTIFICATE-----
EOF

    cat > /home/user/diagnostics/certs/webapp.crt <<'EOF'
-----BEGIN CERTIFICATE-----
MIIDFA...
NotAfter=2026-06-11T12:00:00Z
-----END CERTIFICATE-----
EOF

    # Make sure everything is world-readable
    chmod -R a+r /home/user/diagnostics/certs
    # (directories themselves already have appropriate write perms)

%environment
    chmod 755 /home/user

    # Ensure Python binaries installed via pip are in PATH
    export PATH=/usr/local/bin:$PATH

%labels
    Author chatGPT
    Description "Container for certificate-expiry report task — initial state ready for testing."

%help
    This container image provides the initial filesystem state for the
    certificate-expiry report exercise.