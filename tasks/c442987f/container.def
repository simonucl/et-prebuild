Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Install Python tooling and a common sync utility
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 python3-pip rsync ca-certificates
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Establish initial filesystem state for the credential-rotation task
    # ------------------------------------------------------------------
    # Home hierarchy
    mkdir -p /home/user

    # 1. Source directory with credential files
    mkdir -p /home/user/secure_configs

    cat > /home/user/secure_configs/secret.conf <<'EOF'
DB_PASSWORD=oldpassword
API_KEY=123abc
EOF

    cat > /home/user/secure_configs/vault.conf <<'EOF'
TOKEN=abcdef
ROTATION_DATE=2023-09-09
EOF

    # 2. Empty destination directory (must be writable later)
    mkdir -p /home/user/remote_backup

    # 3. Log directory (log file intentionally NOT created)
    mkdir -p /home/user/rotation_logs

    # ------------------------------------------------------------------
    # Permissions
    # ------------------------------------------------------------------
    chmod 0755 /home/user
    chmod 0755 /home/user/secure_configs
    chmod 0777 /home/user/remote_backup
    chmod 0777 /home/user/rotation_logs
    chmod 0644 /home/user/secure_configs/*.conf

    # Clean up APT caches to keep image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    export LANG=C
    export LC_ALL=C

%labels
    Author "OpenAI ChatGPT"
    Description "Apptainer image pre-configured for the credential rotation challenge."