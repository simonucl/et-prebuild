Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install required packages
    apt-get update
    apt-get install -y --no-install-recommends \
        python3-pip \
        time \
        ca-certificates

    # Install pytest for the runtime test harness
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create the expected directory layout and files for the assignment
    # ------------------------------------------------------------------
    # Ensure the home directory exists (and create an entry in /etc/passwd
    # so utilities that look up the current user do not fail).
    if ! id -u user >/dev/null 2>&1; then
        useradd -m -d /home/user -s /bin/bash user
    fi
    mkdir -p /home/user

    # 1. Kubernetes manifests
    MANIFEST_DIR="/home/user/k8s_manifests"
    mkdir -p "${MANIFEST_DIR}"

    cat > "${MANIFEST_DIR}/01-namespace.yaml" <<'EOF'
---
apiVersion: v1
kind: Namespace
metadata:
  name: test-namespace
EOF

    cat > "${MANIFEST_DIR}/02-configmap.yaml" <<'EOF'
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: test-config
  namespace: test-namespace
data:
  key: value
EOF

    cat > "${MANIFEST_DIR}/03-secret.yaml" <<'EOF'
---
apiVersion: v1
kind: Secret
metadata:
  name: test-secret
  namespace: test-namespace
stringData:
  password: s3cr3t
EOF

    cat > "${MANIFEST_DIR}/04-deployment.yaml" <<'EOF'
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: test-deploy
  namespace: test-namespace
spec:
  replicas: 1
  selector:
    matchLabels:
      app: test
  template:
    metadata:
      labels:
        app: test
    spec:
      containers:
        - name: nginx
          image: nginx:1.25-alpine
EOF

    cat > "${MANIFEST_DIR}/05-service.yaml" <<'EOF'
---
apiVersion: v1
kind: Service
metadata:
  name: test-svc
  namespace: test-namespace
spec:
  type: ClusterIP
  selector:
    app: test
  ports:
    - port: 80
      targetPort: 80
EOF

    cat > "${MANIFEST_DIR}/06-crd.yaml" <<'EOF'
---
apiVersion: apiextensions.k8s.io/v1
kind: CustomResourceDefinition
metadata:
  name: widgets.example.com
spec:
  group: example.com
  names:
    kind: Widget
    plural: widgets
    singular: widget
  scope: Namespaced
  versions:
    - name: v1
      served: true
      storage: true
      schema:
        openAPIV3Schema:
          type: object
          properties:
            spec:
              type: object
  status:
    acceptedNames: {}
    conditions: []
    storedVersions: []
EOF

    # Ensure permissions on the manifest files (0644)
    chmod 0644 "${MANIFEST_DIR}"/*.yaml

    # 2. Helper script simulating an operator
    OP_DIR="/home/user/k8s_operator"
    mkdir -p "${OP_DIR}"

    cat > "${OP_DIR}/apply.sh" <<'EOF'
#!/usr/bin/env bash
# Simulate "kubectl apply -f ..." by concatenating manifests to /dev/null.
# Exit status is always 0.
cat "$@" > /dev/null
EOF

    chmod 0755 "${OP_DIR}/apply.sh"

    # Make sure everything is owned by the non-root user for clarity
    chown -R user:user /home/user

%environment
    chmod 755 /home/user

    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    echo "Container for Kubernetes manifest benchmarking challenge."
    echo "Refer to the task instructions for details on what to do."