Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    apt-get install -y --no-install-recommends python3 python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Prepare the datasets directory and initial CSV
    mkdir -p /home/user/datasets
    chmod 0777 /home/user/datasets   # Ensure learners can write new files

    cat > /home/user/datasets/raw.csv <<'EOF'
id,name,age,score
1,Alice,30,85
2,Bob,,90
3,Charlie,25,
4,,27,88
5,David,22,92
EOF
    chmod 0644 /home/user/datasets/raw.csv

%environment
    chmod 755 /home/user

    export LC_ALL=C.UTF-8
    export PYTHONIOENCODING=utf-8

%labels
    Author  Data-Cleaning Exercise Base Image
    Description  Provides initial raw.csv and pytest for automated grading