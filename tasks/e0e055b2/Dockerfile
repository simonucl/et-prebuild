FROM ubuntu:22.04

# Labels
LABEL Author="Generated by ChatGPT"
LABEL Description="Environment for the iptables rule insertion exercise with pytest pre-installed."

# Install Python and pytest for the grader
RUN set -e && \
    apt-get update && \
    apt-get install -y --no-install-recommends python3 python3-pip && \
    pip3 install --no-cache-dir pytest

# Prepare initial filesystem state
RUN mkdir -p /home/user/firewall && \
    chmod 755 /home/user/firewall

RUN cat > /home/user/firewall/iptables_rules.v4 <<'EOF'
*filter
:INPUT DROP [0:0]
:FORWARD DROP [0:0]
:OUTPUT ACCEPT [0:0]
-A INPUT -p tcp --dport 22 -j ACCEPT
COMMIT
EOF

RUN chmod 644 /home/user/firewall/iptables_rules.v4

# Help information (as comments):
# This container sets up the initial state for the "iptables rule insertion" task:
# - /home/user/firewall exists with 0755 permissions.
# - /home/user/firewall/iptables_rules.v4 exists with 0644 permissions and the required starter rules.
# Pytest is installed for automated grading.