Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package list and install required packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        iproute2 \
        iputils-ping

    # Install pytest for the evaluation framework
    pip3 install --no-cache-dir pytest

    # Ensure the /home/user directory exists and is writable
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up apt cache to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Keep default HOME; no override needed
    export PYTHONUNBUFFERED=1
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%labels
    Author task-preparer
    Description "Base image for network audit task – installs pytest and ensures writable /home/user."

%runscript
    echo "Container for network audit task is ready."