Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # 1. Create the required raw data directory and populate it
    mkdir -p /home/user/raw_data

    cat > /home/user/raw_data/raw1.json <<'EOF'
{"id": "sensor-A", "timestamp": "2023-09-01T12:00:00Z", "value": 42.7, "tags": ["lab","temperature"]}
EOF

    cat > /home/user/raw_data/raw2.json <<'EOF'
{"id": 123, "timestamp": "2023-09-01T12:05:00Z", "value": "40.1", "tags": ["lab","temperature"]}
EOF

    cat > /home/user/raw_data/raw3.json <<'EOF'
{"id": "sensor-B", "timestamp": "BADDATE", "value": 37.2, "tags": "humidity"}
EOF

    # Ensure sensible permissions
    chmod -R 755 /home/user

    # 2. Install system utilities and Python testing framework
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3-pip jq ca-certificates
    pip3 install --no-cache-dir pytest

    # 3. Clean up APT caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%labels
    Author      "ChatGPT"
    Description "Ubuntu 22.04 image prepared for data-science task: contains draft raw JSON files, jq, and pytest."