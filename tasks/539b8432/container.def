Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Basic tooling
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial exercise state under /home/user
    # ------------------------------------------------------------------
    mkdir -p /home/user/data
    mkdir -p /home/user/output

    # Permissions exactly as required (0755 for directories)
    chmod 0755 /home/user
    chmod 0755 /home/user/data
    chmod 0755 /home/user/output

    # Populate the sample CSV file
    cat > /home/user/data/quarterly_sales.csv <<'EOF'
region,quarter,profit
north,1,23500
south,1,19800
east,1,17500
west,1,16000
north,2,24000
south,2,21000
east,2,18000
west,2,16500
EOF
    chmod 0644 /home/user/data/quarterly_sales.csv

    # Clean up APT caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%runscript
    chmod 755 /home/user

    # Default entry: provide an interactive shell unless overridden
    exec /bin/bash "$@"