FROM ubuntu:22.04

# Update package lists and install required software
RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        python3 \
        python3-pip \
        gzip \
        coreutils

# Upgrade pip and install pytest for the checker
RUN python3 -m pip install --no-cache --upgrade pip && \
    python3 -m pip install --no-cache pytest

# Prepare the initial exercise data under /home/user
RUN mkdir -p /home/user/db_backups/raw

# Create the first SQL-dump file
RUN cat <<'EOF' > /home/user/db_backups/raw/employees_2023-07-10.sql
-- Backup generated by pg_dump
CREATE TABLE employees(id INT, name TEXT);
INSERT INTO employees VALUES (1,'Alice');
EOF

# Create the second SQL-dump file
RUN cat <<'EOF' > /home/user/db_backups/raw/employees_2023-07-11.sql
-- Backup generated by pg_dump
CREATE TABLE employees(id INT, name TEXT);
INSERT INTO employees VALUES (2,'Bob');
EOF

# Ensure the default user inside the container can read/write the files
RUN chmod -R a+rwX /home/user

# Environment variables
ENV PATH="/usr/local/bin:/usr/bin:/bin:${PATH}"

# Set working directory
WORKDIR /home/user

# Default command
CMD echo "Container for the database-reliability exercise." && echo "Run your own commands or tests inside this container."