Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Update package lists and install required software
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        python3 \
        python3-pip \
        gzip \
        coreutils

    # Upgrade pip and install pytest for the checker
    python3 -m pip install --no-cache --upgrade pip
    python3 -m pip install --no-cache pytest

    # ------------------------------------------------------------------
    # Prepare the initial exercise data under /home/user
    # ------------------------------------------------------------------
    mkdir -p /home/user/db_backups/raw

    # Create the first SQL-dump file
    cat <<'EOF' > /home/user/db_backups/raw/employees_2023-07-10.sql
-- Backup generated by pg_dump
CREATE TABLE employees(id INT, name TEXT);
INSERT INTO employees VALUES (1,'Alice');
EOF

    # Create the second SQL-dump file
    cat <<'EOF' > /home/user/db_backups/raw/employees_2023-07-11.sql
-- Backup generated by pg_dump
CREATE TABLE employees(id INT, name TEXT);
INSERT INTO employees VALUES (2,'Bob');
EOF

    # Ensure the default user inside the container can read/write the files
    chmod -R a+rwX /home/user

%environment
    chmod 755 /home/user

    # Nothing special required; just ensure /usr/local/bin is in PATH for pytest
    export PATH="/usr/local/bin:/usr/bin:/bin:${PATH}"

%runscript
    echo "Container for the database-reliability exercise."
    echo "Run your own commands or tests inside this container."