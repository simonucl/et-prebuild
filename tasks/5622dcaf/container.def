Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install required packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        sqlite3 \
        python3 \
        python3-pip

    # Install pytest for the evaluation suite
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare the filesystem layout expected by the tests and the agent
    # ------------------------------------------------------------------
    mkdir -p /home/user/helpdesk

    # Create the SQLite database with the required schema and rows
    sqlite3 /home/user/helpdesk/tickets.db <<'SQL'
CREATE TABLE tickets (
    id       INTEGER PRIMARY KEY,
    title    TEXT,
    assignee TEXT,
    status   TEXT,
    priority TEXT
);
INSERT INTO tickets (id, title, assignee, status, priority) VALUES
    (1, 'Email not working', 'Alice',   'open',   'High'),
    (2, 'VPN issue',         'Bob',     'closed', 'Medium'),
    (3, 'Computer hangs',    'Alice',   'open',   'Low'),
    (4, 'Printer offline',   'Charlie', 'open',   'Medium'),
    (5, 'Password reset',    'Alice',   'closed', 'Low');
SQL

    # Ensure non-root users can read the database and write the output CSV
    chmod 777 /home/user/helpdesk
    chmod 666 /home/user/helpdesk/tickets.db

%environment
    chmod 755 /home/user

    export HELP_DESK_DIR=/home/user/helpdesk

%labels
    Author "ChatGPT-generated definition file"
    Description "Environment for the 'Alice open tickets' SQLite/CSV export task"

%runscript
    echo "Help-desk task container. Start working inside /home/user/helpdesk."
    exec /bin/bash "$@"