Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install system packages
    apt-get update -y
    apt-get install -y --no-install-recommends \
        python3-pip \
        parallel \
        ca-certificates \
        locales
    rm -rf /var/lib/apt/lists/*

    # Install pytest
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create directory structure
    # ------------------------------------------------------------------
    mkdir -p /home/user/data/raw
    mkdir -p /home/user/data/processed     # must exist but stay empty
    mkdir -p /home/user/project

    # ------------------------------------------------------------------
    # Populate raw CSV files
    # ------------------------------------------------------------------
    cat >/home/user/data/raw/sales_q1.csv <<'EOF'
id,region,amount
1,North,1000
2,South,1500
3,East,800
EOF

    cat >/home/user/data/raw/sales_q2.csv <<'EOF'
id,region,amount
4,North,1100
5,South,1600
6,West,900
EOF

    cat >/home/user/data/raw/sales_q3.csv <<'EOF'
id,region,amount
7,East,1200
8,West,950
9,North,1300
EOF

    # ------------------------------------------------------------------
    # Supply the intentionally faulty processing script
    # ------------------------------------------------------------------
    cat >/home/user/project/process_data.sh <<'EOF'
#!/bin/bash
# WRONG: simply concatenates files and duplicates headers
cat /home/user/data/raw/*.csv > /home/user/data/processed/all_sales_2023.csv
echo "done"
EOF
    chmod 0777 /home/user/project/process_data.sh   # executable & writeable

    # ------------------------------------------------------------------
    # Ensure the non-root user who will run tests can modify everything
    # ------------------------------------------------------------------
    chmod -R 0777 /home/user

%environment
    chmod 755 /home/user

    export PATH=/usr/local/bin:/usr/bin:/bin

%labels
    Author="AI-Generated"
    Description="Starting environment for the CSV-processing parallelization task"

%runscript
    echo "Container for CSV-processing task. Open a shell to start working."