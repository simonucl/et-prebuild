Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    ####
    # Install Python and pytest (plus minimal build tools needed by pip).
    ####
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 python3-pip ca-certificates
    pip3 install --no-cache-dir pytest

    ####
    # Prepare initial file system state for the exercise.
    ####
    # Create the home base directory for the exercise and make sure it is
    # writable by any unprivileged user who will run inside the container.
    mkdir -p /home/user
    chmod 0777 /home/user

    # Create the data directory with the exact permissions expected.
    mkdir -p /home/user/data
    chmod 0755 /home/user/data

    # Populate the three required files with their precise contents.
    printf 'Alpha backup test file.\n' > /home/user/data/file1.txt

    printf 'Bravo second file line 1.\nBravo line 2.\n' > /home/user/data/file2.txt

    printf 'Charlie 3rd file\nlineB\n' > /home/user/data/file3.txt

    # Ensure files have predictable permissions.
    chmod 0644 /home/user/data/file1.txt /home/user/data/file2.txt /home/user/data/file3.txt

    # Make absolutely sure that no directories the student must create already
    # exist.
    rm -rf /home/user/backup_logs /home/user/restored_data

%environment
    chmod 755 /home/user

    # Use UTF-8 locale to avoid encoding surprises.
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%labels
    Author      "Apptainer Automation"
    Description "Environment for backup / restore verification exercise with pytest pre-installed."

%help
    This container image provides the initial state for the
    “backup-operator test restore” task.  Three source data files are
    placed under /home/user/data.  No backup_logs or restored_data
    directories exist yet.  Pytest is installed system-wide so that the
    grading harness can verify the environment and results.