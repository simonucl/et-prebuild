Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package index and install the essentials
    apt-get update && \
        apt-get install -y --no-install-recommends \
            python3 \
            python3-venv \
            python3-pip \
        && \
        apt-get clean && rm -rf /var/lib/apt/lists/*

    # Install pytest (required by the automated tests)
    pip3 install --no-cache-dir pytest

    # Create a writable home directory for the future “user” account
    mkdir -p /home/user
    chmod 0777 /home/user   # make it writable regardless of the invoking UID

%environment
    chmod 755 /home/user

    # Ensure user-installed Python packages (if any) are discoverable
    export PATH="$HOME/.local/bin:$PATH"

%runscript
    echo "Container for the exp1 virtual-environment exercise."
    echo "You are now inside the runtime shell."
    exec "$@"

%labels
    Author  "Apptainer Build System"
    Description "Base image for the exp1 virtual-environment exercise. Pytest pre-installed."