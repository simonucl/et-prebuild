Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update && \
        apt-get install -y --no-install-recommends python3 python3-pip && \
        pip3 install --no-cache-dir pytest && \
        apt-get clean && \
        rm -rf /var/lib/apt/lists/*

    # Create the required directory structure and INI file
    mkdir -p /home/user/server_configs

    cat > /home/user/server_configs/appserver.ini << 'EOF'
[web]
enabled = true
port = 8080

[db]
enabled = false
port = 5432

[cache]
enabled = true
port = 6379
EOF

    # Ensure appropriate permissions
    chmod 1777 /home/user            # Writable by any user, sticky bit set
    chmod 755  /home/user/server_configs
    chmod 644  /home/user/server_configs/appserver.ini

%environment
    chmod 755 /home/user

    # Ensure Python is callable as `python`
    export PATH=/usr/local/bin:$PATH
    if ! command -v python >/dev/null 2>&1; then
        ln -sf /usr/bin/python3 /usr/local/bin/python
    fi

%runscript
    echo "Container for the network-service INI parsing task."