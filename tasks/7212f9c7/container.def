Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Prepare initial filesystem state expected by the grader
    # ------------------------------------------------------------------
    mkdir -p /home/user/experiments/exp_alpha
    mkdir -p /home/user/experiments/exp_beta
    mkdir -p /home/user/experiments/exp_gamma

    cat > /home/user/experiments/exp_alpha/config.ini <<'EOF'
[metadata]
experiment_name=exp_alpha
timestamp=2023-08-23T15:34:12Z

[training]
learning_rate=0.001
batch_size=32

[results]
accuracy=0.88
EOF

    cat > /home/user/experiments/exp_beta/config.ini <<'EOF'
[metadata]
experiment_name=exp_beta
timestamp=2023-08-24T09:18:45Z

[training]
learning_rate=0.0005
batch_size=64

[results]
accuracy=0.93
EOF

    cat > /home/user/experiments/exp_gamma/config.ini <<'EOF'
[metadata]
experiment_name=exp_gamma
timestamp=2023-08-24T17:02:01Z

[training]
learning_rate=0.002
batch_size=32

[results]
accuracy=0.89
EOF

    # Allow any non-root user to create new files/directories under /home/user
    chmod 0777 /home/user
    chmod -R a+rX /home/user/experiments

%environment
    chmod 755 /home/user

    # Make sure Python is on the PATH
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%runscript
    echo "Apptainer image for the experiment-report task. Run your own script inside."