Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install required packages and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        curl \
        ca-certificates
    pip3 install --no-cache-dir pytest

    # Set up the mock “API” directory and JSON payload
    mkdir -p /home/user/api_source
    chmod 0777 /home/user          # Allow the unprivileged learner to write here
    chmod 0775 /home/user/api_source

    cat > /home/user/api_source/dataset_schema.json <<'EOF'
{
  "dataset": "iris",
  "version": "1.0",
  "features": ["sepal_length", "sepal_width", "petal_length", "petal_width"],
  "target": "species",
  "classes": ["setosa", "versicolor", "virginica"]
}
EOF
    chmod 0644 /home/user/api_source/dataset_schema.json

    # Clean up
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8