Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python tooling and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3-pip \
        python3-setuptools \
        python3-wheel
    pip3 install --no-cache-dir pytest

    # Prepare the /home/user directory for the learner
    mkdir -p /home/user
    chmod 0777 /home/user         # Allow any unprivileged user to write here

%environment
    chmod 755 /home/user

    # Keep environment minimal; do NOT override HOME.
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%runscript
    exec "$@"