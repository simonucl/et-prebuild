Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    apt-get install -y python3 python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state expected by the assignment/tests
    # ------------------------------------------------------------------
    # Create the experiment directory structure
    mkdir -p /home/user/experiments/exp_v1

    # Populate metrics.csv with the required historical data
    cat > /home/user/experiments/exp_v1/metrics.csv <<'EOF'
epoch,loss,accuracy
1,0.678,0.75
2,0.432,0.82
3,0.321,0.86
EOF

    # Ensure permissions allow the (non-root) runtime user to create / overwrite
    # latest_metrics.log and read/write the CSV.
    chmod -R a+rwx /home/user/experiments

    # Make sure the target log file does NOT exist yet
    rm -f /home/user/experiments/exp_v1/latest_metrics.log

%environment
    chmod 755 /home/user

    # Keep locale sane
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%labels
    Author "MLOps Task Setup"
    Description "Container for latest-metrics logging exercise with pytest pre-installed."