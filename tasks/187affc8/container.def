Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update apt metadata and install required system packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        python3 \
        python3-pip \
        diffutils \
        --no-install-recommends

    # Install Python testing framework
    pip3 install --no-cache-dir pytest

    # Prepare writable home directory for the exercise
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up apt caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure Python and local binaries are on PATH
    export PATH="/usr/local/bin:/usr/bin:$PATH"

%runscript
    # Default action: start a shell
    exec /bin/bash