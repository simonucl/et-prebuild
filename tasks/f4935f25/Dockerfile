FROM ubuntu:22.04

# Update APT and install Python + pip
RUN apt-get update -y && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        build-essential

# Install Python packages needed for the course and for the grader
RUN pip3 install --no-cache-dir --upgrade \
        pytest \
        pulp

# Prepare the filesystem layout expected by the grading tests
RUN mkdir -p /home/user/capacity/data

# Create workloads.csv
RUN cat << 'EOF' > /home/user/capacity/data/workloads.csv
workload,cpu,ram,storage
Analytics,4,16,50
Web,2,8,20
Database,6,24,100
Batch,3,12,40
EOF

# Create servers.csv
RUN cat << 'EOF' > /home/user/capacity/data/servers.csv
server,cpu,ram,storage,cost
alpha,8,32,200,50
bravo,16,64,500,90
charlie,4,16,100,30
delta,6,24,120,40
EOF

# Ensure permissive read permissions (the container will run unprivileged)
RUN chmod -R a+rX /home/user && \
    chmod 755 /home/user

# Labels
LABEL Author="Capacity-Planning-Container"
LABEL Description="Base image for the capacity-planning optimisation task"

# Help information (as comments):
# This container image contains:
#   • Python 3 with pip
#   • pytest (for the grader)
#   • pulp (MILP modelling library with CBC solver)
#
# Pre-populated files:
#   /home/user/capacity/data/workloads.csv
#   /home/user/capacity/data/servers.csv
#
# The /home/user/capacity/output and /home/user/capacity/logs directories
# are intentionally NOT created; they must be generated by the student's
# solution script at run-time.