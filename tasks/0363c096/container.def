Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author      Pip-Package-Inventory
    Description Base image for the “pip package inventory” task. Provides
                Python, pip, pytest, and ensures /home/user exists while
                leaving the etl workspace empty.

%post
    set -e

    # Install Python and essential tools
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates

    # Upgrade pip and install pytest (needed by the test harness)
    python3 -m pip install --no-cache-dir --upgrade pip
    python3 -m pip install --no-cache-dir pytest

    # Create the required home directory; leave /home/user/etl untouched
    mkdir -p /home/user
    chmod 0777 /home/user   # allow the unprivileged runtime user to write here

    # Clean up apt caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure standard PATH inside the container
    export PATH=/usr/local/bin:/usr/local/sbin:/usr/bin:/usr/sbin:/bin:/sbin

%runscript
    # Default behaviour: run whatever the caller asks
    exec "$@"