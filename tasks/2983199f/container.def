Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Refresh apt metadata and install required packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        openssh-client \
        python3 \
        python3-pip

    # Install pytest for the automated grading suite
    pip3 install --no-cache-dir pytest

    # Prepare a writable home directory expected by the tests
    mkdir -p /home/user
    # Give write permission to whatever UID/GID runs inside the container
    chmod 0777 /home/user

    # Clean up apt caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure Python and pip are on PATH (should already be, but explicit is safe)
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%runscript
    echo "Container ready. Execute your commands inside the shell."