Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Install Python and pytest for the verification suite
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state for the “artifact-manager” task
    # ------------------------------------------------------------------
    mkdir -p /home/user/artifact-manager/repos

    # Create the initial configuration file with exactly three lines
    cat > /home/user/artifact-manager/artifact-manager.conf <<'EOF'
# Artifact Manager Configuration
[global]
storage_root = /home/user/artifact-manager/repos
EOF

    # Ensure the student (non-root runtime user) can write where needed
    chmod -R 0777 /home/user/artifact-manager

%environment
    chmod 755 /home/user

    # Make sure user-installed Python tools are on PATH
    export PATH="/home/user/.local/bin:${PATH}"