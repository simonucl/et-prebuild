Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update && \
        apt-get install -y --no-install-recommends python3 python3-pip && \
        rm -rf /var/lib/apt/lists/*
    pip3 install --no-cache-dir pytest

    # Create required directory structure and JSON stubs
    mkdir -p /home/user/project/api_responses

    cat > /home/user/project/api_responses/response_200.json <<'EOF'
{"status":200,"message":"OK"}
EOF

    cat > /home/user/project/api_responses/response_400.json <<'EOF'
{"status":400,"message":"Bad Request"}
EOF

    cat > /home/user/project/api_responses/response_500.json <<'EOF'
{"status":500,"message":"Server Error"}
EOF

    # Ensure the future test directory can be created by the unprivileged user
    chmod -R 777 /home/user/project

%environment
    chmod 755 /home/user

    # No modifications to $HOME; rely on Apptainer defaults
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8