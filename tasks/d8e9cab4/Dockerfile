FROM ubuntu:22.04

# Labels
LABEL Author="Generated by AI assistant"
LABEL Description="Container for symlink restore exercise; includes pytest and pre-populated backup data."

# Install Python and pytest
RUN set -e && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip && \
    pip3 install --no-cache-dir pytest && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Create required directory structure
RUN mkdir -p /home/user/backup/2023-10-10

# Create the backup file with exact contents ending with a single newline
RUN cat > /home/user/backup/2023-10-10/settings.ini <<'EOF'
[General]
version=1
EOF

# Set correct permissions
RUN chmod 0755 /home/user/backup/2023-10-10 && \
    chmod 0644 /home/user/backup/2023-10-10/settings.ini

# Ensure the restore directory does NOT exist initially
RUN rm -rf /home/user/restore || true

# Set permissions for home directory
RUN chmod 755 /home/user

# Environment variables
ENV PYTHONUNBUFFERED=1

# Default command
CMD ["/bin/bash"]