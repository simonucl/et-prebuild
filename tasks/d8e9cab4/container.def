Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # Create required directory structure and files for the exercise
    mkdir -p /home/user/backup/2023-10-10

    # Create the backup file with exact contents ending with a single newline
    cat > /home/user/backup/2023-10-10/settings.ini <<'EOF'
[General]
version=1
EOF

    # Set correct permissions
    chmod 0755 /home/user/backup/2023-10-10
    chmod 0644 /home/user/backup/2023-10-10/settings.ini

    # Ensure the restore directory does NOT exist initially
    rm -rf /home/user/restore || true

%environment
    chmod 755 /home/user

    export PYTHONUNBUFFERED=1

%labels
    Author="Generated by AI assistant"
    Description="Container for symlink restore exercise; includes pytest and pre-populated backup data."

%runscript
    exec "$@"