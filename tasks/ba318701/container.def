Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author example
    Description "Base image for cron-scheduling exercise"

%post
    #!/bin/bash
    set -e

    # Update package lists and install Python tooling
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3-pip \
        python3-setuptools \
        python3-venv \
        ca-certificates

    # Install pytest for the exercise test-suite
    pip3 install --no-cache-dir pytest

    # Create a writable home directory for the unprivileged run-time user
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up apt caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure Python and pip are on the default PATH
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"

%runscript
    echo "Container for cron scheduling exercise. Launch an interactive shell or run the provided tests with pytest."