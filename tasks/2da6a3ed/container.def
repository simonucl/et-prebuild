Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -eux

    # Install required packages
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        iputils-ping \
        traceroute \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------
    # Create non-root user “user”
    # ------------------------------------------------------------------
    useradd --create-home --shell /bin/bash --uid 1000 user

    # ------------------------------------------------------------------
    # Prepare initial filesystem state for the exercise
    # ------------------------------------------------------------------
    # 1. /home/user/repositories with targets.list
    install -d -m 0755 /home/user/repositories
    cat > /home/user/repositories/targets.list <<'EOF'
repo-alpha 127.0.0.1
repo-beta 127.0.0.1
repo-gamma 127.0.0.1
EOF
    chmod 0644 /home/user/repositories/targets.list

    # 2. /home/user/artifacts (empty)
    install -d -m 0755 /home/user/artifacts

    # Ensure “user” owns all of /home/user
    chown -R user:user /home/user

%environment
    chmod 755 /home/user

    # Keep PATH sensible and make sure python/pip are available
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

%runscript
    echo "Container built for the Network Diagnostics Bundle exercise."
    echo "Switch to the 'user' account to begin:"
    echo "    sudo -u user -i"
    exec /bin/bash

%help
    This container provides the initial environment for the
    “Network Diagnostics Bundle” exercise.  It includes:

      • A non-root user named “user”
      • Pre-populated /home/user/repositories/targets.list
      • An empty /home/user/artifacts directory
      • Necessary networking tools (ping, traceroute)
      • Python 3 with pytest installed

    Build with:
        apptainer build netdiag.sif <this-definition-file>