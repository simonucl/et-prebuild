Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "Updating package index..."
    apt-get update -y

    echo "Installing required utilities and Python tooling..."
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        iproute2 \
        iputils-ping \
        python3-pip \
        ca-certificates

    echo "Installing pytest via pip..."
    pip3 install --no-cache-dir pytest

    echo "Creating the expected user home directory..."
    mkdir -p /home/user
    chmod 0755 /home/user

    echo "Cleaning up APT caches..."
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure standard binary locations are in PATH
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

%labels
    Author="Generated by ChatGPT"
    Description="Container prepared for Network Diagnostic Report task - includes ip, ss, ping, and pytest."

%runscript
    echo "This container is prepared for the Network Diagnostic Report task."
    echo "Execute your diagnostic script within the container environment."