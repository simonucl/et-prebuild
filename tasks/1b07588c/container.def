Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ------------------------------------------------------------------
    # Install required software
    # ------------------------------------------------------------------
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        curl \
        jq \
        ca-certificates
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Create directory structure for the mini-mock API
    # ------------------------------------------------------------------
    mkdir -p /home/user/mockapi/data
    mkdir -p /home/user/mockapi/logs

    # ------------------------------------------------------------------
    # Static JSON “end-point” files (exact contents)
    # ------------------------------------------------------------------
    echo '{"id":101,"username":"testuser","email":"tester@example.com"}' \
        > /home/user/mockapi/data/user.json

    echo '{"id":501,"name":"Widget","price":19.99}' \
        > /home/user/mockapi/data/product.json

    # ------------------------------------------------------------------
    # Pre-compute the verification log with the expected values
    # ------------------------------------------------------------------
    timestamp=$(date -u +%Y-%m-%dT%H:%M:%SZ)
    chmod 755 /home/user


    cat > /home/user/mockapi/logs/api_test.log <<EOF
TIMESTAMP:${timestamp}
USER_STATUS:000
PRODUCT_STATUS:000
POST_STATUS:000
USERNAME:testuser
PRODUCT_NAME:Widget
EOF

    # ------------------------------------------------------------------
    # Permissions – ensure every unprivileged user can at least read
    # ------------------------------------------------------------------
    chmod -R a+rX /home/user

%environment
    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8

%labels
    Author mockapi-builder
    Description "Pre-seeded container for the mini-mock API smoke-test assignment."