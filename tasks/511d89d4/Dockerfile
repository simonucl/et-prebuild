FROM ubuntu:22.04

# Install required system packages and pytest, create user, set up files
RUN set -e && \
    export DEBIAN_FRONTEND=noninteractive && \
    apt-get update && \
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        rsync \
        ca-certificates && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/* && \
    pip3 install --no-cache-dir pytest && \
    useradd -m -s /bin/bash user || true && \
    mkdir -p /home/user/test_env/local_src && \
    mkdir -p /home/user/test_env/remote_dst && \
    printf 'QA sync test file 1\n' > /home/user/test_env/local_src/file1.txt && \
    printf 'QA sync test file 2\n' > /home/user/test_env/local_src/file2.txt && \
    chmod 0644 /home/user/test_env/local_src/file1.txt && \
    chmod 0644 /home/user/test_env/local_src/file2.txt && \
    chmod -R 0777 /home/user/test_env && \
    chown -R user:user /home/user || true

# Apply environment-time chmod of /home/user
RUN chmod 755 /home/user

# Ensure python exists as /usr/bin/python if missing
RUN if [ ! -e /usr/bin/python ] && [ -e /usr/bin/python3 ]; then ln -s /usr/bin/python3 /usr/bin/python; fi

# Labels
LABEL Author="Generated by ChatGPT – Apptainer preparation"
LABEL Description="Environment for file-synchronisation QA task with pytest pre-installed."

CMD ["/bin/bash"]