Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # Install required system packages
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        rsync \
        ca-certificates
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the test harness
    pip3 install --no-cache-dir pytest

    # Create a non-privileged user for runtime (optional but harmless)
    if ! id -u user >/dev/null 2>&1; then
        useradd -m -s /bin/bash user
    fi

    # Set up the initial directory structure and files
    mkdir -p /home/user/test_env/local_src
    mkdir -p /home/user/test_env/remote_dst

    # Create the initial source files
    printf 'QA sync test file 1\n' > /home/user/test_env/local_src/file1.txt
    printf 'QA sync test file 2\n' > /home/user/test_env/local_src/file2.txt

    # Permissions: files readable, directories writable for future actions
    chmod 0644 /home/user/test_env/local_src/file1.txt
    chmod 0644 /home/user/test_env/local_src/file2.txt
    chmod -R 0777 /home/user/test_env

    # Give ownership to the non-privileged user (ignore if it fails)
    chown -R user:user /home/user || true

%environment
    chmod 755 /home/user

    # Ensure Python is available via the default python command if needed
    if [ ! -e /usr/bin/python ] && [ -e /usr/bin/python3 ]; then
        export PATH="/usr/local/bin:/usr/bin:/bin"
        alias python='python3'
    fi

%runscript
    # Default action when the container is executed without arguments
    exec /bin/bash "$@"

%labels
    Author="Generated by ChatGPT – Apptainer preparation"
    Description="Environment for file-synchronisation QA task with pytest pre-installed."