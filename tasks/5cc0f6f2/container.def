Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # ------------------------------------------------------------------
    # 1. Base packages and Python tooling
    # ------------------------------------------------------------------
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        tzdata

    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # 2. Create the required directory hierarchy
    # ------------------------------------------------------------------
    mkdir -p /home/user/audit_targets/webserver
    mkdir -p /home/user/audit_targets/db
    mkdir -p /home/user/audit_targets/app/settings
    mkdir -p /home/user/audit_targets/app/archive

    # ------------------------------------------------------------------
    # 3. Populate *.conf files with the exact specified contents
    # ------------------------------------------------------------------
    cat >/home/user/audit_targets/webserver/httpd.conf <<'EOF'
ServerName localhost
Listen 80
EOF

    cat >/home/user/audit_targets/db/mysql.conf <<'EOF'
[mysqld]
port=3306
EOF

    cat >/home/user/audit_targets/app/settings/app.conf <<'EOF'
debug=false
api_key=XYZ123
EOF

    cat >/home/user/audit_targets/app/archive/oldapp.conf <<'EOF'
version=1.2.3
EOF

    # “Recent” files that should NOT be backed up by the student’s script
    cat >/home/user/audit_targets/webserver/newhttpd.conf <<'EOF'
# recent config placeholder
EOF

    cat >/home/user/audit_targets/app/settings/recent.conf <<'EOF'
# recent config placeholder
EOF

    # ------------------------------------------------------------------
    # 4. Adjust modification times
    #      • Old files  : fixed timestamp far in the past (Jan 1 2020)
    #      • Recent files: 1 day ago (guaranteed < 30 days)
    # ------------------------------------------------------------------
    OLD_TIMESTAMP="202001010000"   # YYYYMMDDhhmm
    touch -m -t ${OLD_TIMESTAMP} /home/user/audit_targets/webserver/httpd.conf
    touch -m -t ${OLD_TIMESTAMP} /home/user/audit_targets/db/mysql.conf
    touch -m -t ${OLD_TIMESTAMP} /home/user/audit_targets/app/settings/app.conf
    touch -m -t ${OLD_TIMESTAMP} /home/user/audit_targets/app/archive/oldapp.conf

    touch -m -d '1 day ago' /home/user/audit_targets/webserver/newhttpd.conf
    touch -m -d '1 day ago' /home/user/audit_targets/app/settings/recent.conf

    # ------------------------------------------------------------------
    # 5. Permissions: make sure the non-root runtime user can read/write
    # ------------------------------------------------------------------
    chmod -R a+r /home/user/audit_targets
    find /home/user/audit_targets -type d -exec chmod a+rx {} +

%labels
    chmod 755 /home/user

    Author " autogenerated "
    Description "Container providing the initial filesystem state for the Historical Configuration Audit task."