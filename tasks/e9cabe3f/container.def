Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install required packages and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # Prepare initial filesystem state for the task
    mkdir -p /home/user/firewall

    cat > /home/user/firewall/base_rules.v4 <<'EOL'
*filter
:INPUT ACCEPT [0:0]
:FORWARD ACCEPT [0:0]
:OUTPUT ACCEPT [0:0]
-A INPUT -p tcp --dport 22 -j ACCEPT
-A INPUT -p tcp --dport 80 -j ACCEPT
-A INPUT -p tcp --dport 443 -j ACCEPT
-A INPUT -p tcp --dport 8080 -j ACCEPT
-A INPUT -p tcp --dport 3306 -j ACCEPT
COMMIT
EOL

    chmod 755 /home/user/firewall
    chmod 644 /home/user/firewall/base_rules.v4

%runscript
    exec "$@"