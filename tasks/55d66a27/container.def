Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    export DEBIAN_FRONTEND=noninteractive

    # Update package index and install Python 3 + pip
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        git \
        build-essential

    # Install pytest for the validation suite
    python3 -m pip install --no-cache-dir --upgrade pip
    python3 -m pip install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial workspace expected by the grading tests
    # ------------------------------------------------------------------

    # Create the home directory and make it writable for any container user
    mkdir -p /home/user
    chmod 0777 /home/user

    # Create the tracked directory and the zero-byte empty.conf file
    mkdir -p /home/user/tracked
    touch /home/user/tracked/empty.conf
    chmod 0644 /home/user/tracked/empty.conf

    # Ensure the checksum log does NOT exist at build time
    rm -f /home/user/config_checksums.log

    # Clean up APT caches to keep the image size small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure Python and user-installed binaries are on PATH
    export PATH="$PATH:/usr/local/bin"

%labels
    Author="Generated by ChatGPT – Apptainer configuration"
    Description="Container with initial state for the 'record SHA-256 checksum' task"

%help
    This container provides the pristine workspace required for the
    configuration-management SHA-256 logging exercise.