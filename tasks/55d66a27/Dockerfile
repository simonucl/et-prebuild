FROM ubuntu:22.04

# Labels
LABEL Author="Generated by ChatGPT – Apptainer configuration"
LABEL Description="Container with initial state for the 'record SHA-256 checksum' task"

# Help information (as comments):
# This container provides the pristine workspace required for the
# configuration-management SHA-256 logging exercise.

# Set environment variables
ENV DEBIAN_FRONTEND=noninteractive
ENV PATH="$PATH:/usr/local/bin"

# Update package index and install Python 3 + pip
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        ca-certificates \
        git \
        build-essential && \
    # Install pytest for the validation suite
    python3 -m pip install --no-cache-dir --upgrade pip && \
    python3 -m pip install --no-cache-dir pytest && \
    # Clean up APT caches to keep the image size small
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Prepare initial workspace expected by the grading tests
# Create the home directory and make it writable for any container user
RUN mkdir -p /home/user && \
    chmod 0777 /home/user

# Create the tracked directory and the zero-byte empty.conf file
RUN mkdir -p /home/user/tracked && \
    touch /home/user/tracked/empty.conf && \
    chmod 0644 /home/user/tracked/empty.conf

# Ensure the checksum log does NOT exist at build time
RUN rm -f /home/user/config_checksums.log

# Set working directory
WORKDIR /home/user