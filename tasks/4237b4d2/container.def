Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    apt-get update && apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        && rm -rf /var/lib/apt/lists/*

    pip3 install --no-cache-dir pytest

    # Ensure the target user exists (UID/GID 1000 is the common default)
    if ! id -u user >/dev/null 2>&1; then
        groupadd -g 1000 user || true
        useradd  -m -u 1000 -g 1000 user || true
    fi

    # Create the required directory structure and initial configuration files
    mkdir -p /home/user/app/config

    cat > /home/user/app/config/settings.yml <<'EOF'
database:
  user: admin
  password: OldPass123
aws:
  access_key: OLDACCESSKEY
  secret_key: OLDSECRETKEY
  region: us-east-1
EOF

    cat > /home/user/app/config/credentials.toml <<'EOF'
[default]
username = "admin"
password = "OldPass123"
token    = "OLDTOKEN987"
EOF

    # Set required permissions
    chmod 0644 /home/user/app/config/settings.yml /home/user/app/config/credentials.toml
    chown -R user:user /home/user

%environment
    chmod 755 /home/user

    export PATH=/usr/local/bin:/usr/bin:/bin