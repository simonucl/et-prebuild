Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare initial filesystem state for the storage-administrator task
    # ------------------------------------------------------------------
    # Create the required directory tree and sample log files
    mkdir -p /home/user/logs/app1
    mkdir -p /home/user/logs/app2

    # Populate log files with the exact contents (including trailing newline)
    printf 'Error ABC\n'   > /home/user/logs/app1/log1.txt
    printf 'Warning XYZ\n' > /home/user/logs/app1/log2.txt
    printf 'Debug 123\n'   > /home/user/logs/app2/logA.txt

    # Ensure writable permissions so the non-root learner can modify them
    chmod -R 777 /home/user

    # Do NOT create /home/user/archive, symlinks, or symlink_audit.log.
    # These are to be created by the learner during the exercise.

%labels
    chmod 755 /home/user

    Author  example@example.com
    Description  "Starter environment for the storage-administrator symlink exercise"

%help
    This container provides the initial state and tooling for the
    “storage administrator” task.  The learner will enter the container
    and perform the required filesystem operations.  pytest is installed
    for automated grading.

%environment
    # Make sure python3 is the default python
    export PYTHONIOENCODING=UTF8
    export LC_ALL=C.UTF-8