Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Maintainer    Apptainer Task Preparer
    Description   Base image for “training_pipeline” exercise – clean initial state with pytest installed.

%post
    set -e

    # Update package lists and install required system packages
    apt-get update && \
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-setuptools \
        python3-venv \
        procps \
        ca-certificates && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the grader/learner
    pip3 install --no-cache-dir pytest

    # Create the base home directory expected by the tests, but DO NOT create
    # any of the artefact paths such as training_pipeline/.
    mkdir -p /home/user
    # Give wide permissions so whichever (non-root) UID runs the container
    # can write into it during the exercise.
    chmod 777 /home/user

%environment
    chmod 755 /home/user

    # Ensure python and pytest are on the PATH
    export PATH=/usr/local/bin:$PATH
    export PYTHONIOENCODING=utf-8

%runscript
    echo "This container sets up the environment for the training_pipeline exercise."
    echo "Open a shell in the container and follow the task instructions."