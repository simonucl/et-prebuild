Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package list and install Python + pip
    apt-get update -y
    apt-get install -y --no-install-recommends python3 python3-pip

    # Install pytest for the autograder
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare workspace expected by the assignment/autograder
    # ------------------------------------------------------------------
    # Create the user home and data pipeline directories with write perms
    mkdir -p /home/user/data_pipeline
    chmod 0777 /home/user
    chmod 0777 /home/user/data_pipeline

    # Create update.sh with the required behaviour and make it executable
    cat >/home/user/data_pipeline/update.sh <<'EOF'
#!/usr/bin/env bash
if [[ "$1" == "--force" ]]; then
    echo "Applying forced update …"
    echo "Update applied successfully."
    exit 0
else
    echo "Attempting dry-run update …"
    echo "DRY-RUN FAILED – manual confirmation required" >&2
    exit 1
fi
EOF
    chmod 0755 /home/user/data_pipeline/update.sh

%environment
    chmod 755 /home/user

    # Ensure python and pip are in PATH
    export PATH="/usr/bin:$PATH"

%labels
    Author example
    Description "Environment for Data-Mule deployment task with pytest installed"

%runscript
    # Default action when container is run without commands
    bash