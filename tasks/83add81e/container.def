Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    echo "Updating package index and installing Python tooling..."
    apt-get update -qq
    DEBIAN_FRONTEND=noninteractive apt-get install -y -qq python3-pip --no-install-recommends
    pip3 install --no-cache-dir pytest

    echo "Creating required directory structure..."
    mkdir -p /home/user/metrics/raw
    mkdir -p /home/user/grafana/dashboards

    echo "Populating raw latency log files..."
    cat > /home/user/metrics/raw/serviceA-2023-10-01.log <<'EOF'
2023-10-01T00:00:01Z serviceA 120 200
2023-10-01T00:00:02Z serviceA 250 200
2023-10-01T00:00:03Z serviceA 110 500
EOF

    cat > /home/user/metrics/raw/serviceB-2023-10-01.log <<'EOF'
2023-10-01T00:00:01Z serviceB 95 200
2023-10-01T00:00:02Z serviceB 105 200
EOF

    echo "Creating Grafana dashboard template..."
    cat > /home/user/grafana/dashboards/sample_dashboard.conf <<'EOF'
cpu_threshold=PLACEHOLDER_CPU_THRESHOLD
mem_threshold=PLACEHOLDER_MEM_THRESHOLD
disk_threshold=PLACEHOLDER_DISK_THRESHOLD
EOF

    echo "Setting liberal permissions so the unprivileged user can write outputs..."
    chmod -R 0777 /home/user

%labels
    chmod 755 /home/user

    Author "Apptainer Task Preparer"
    Description "Environment for observability shell-task with pytest installed"

%environment
    # Ensure Python and pip are on the path
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%runscript
    exec "$@"