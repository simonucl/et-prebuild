Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update package index and install Python along with pip
    apt-get update -y
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-setuptools \
        python3-wheel \
        ca-certificates

    # Install pytest for the test-harness
    python3 -m pip install --no-cache-dir --upgrade pip
    python3 -m pip install --no-cache-dir pytest

    # Create a writable home for the future non-root user executing the exercise
    mkdir -p /home/user
    chmod 0777 /home/user

    # Clean up apt caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%labels
    chmod 755 /home/user

    Author      Observability-Exercise
    Description Base image for latency-overview tuning exercise (pytest included)

%help
    This container provides the environment for the Grafana “latency-overview”
    tuning confirmation exercise.  Pytest is pre-installed, and a writable
    /home/user directory is available for the student.