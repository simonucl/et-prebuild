Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Refresh APT metadata
    apt-get update

    # Essential packages: SSH client for ssh-keygen, Python & pip for pytest
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        openssh-client \
        python3 \
        python3-pip \
        ca-certificates

    # Python testing framework
    pip3 install --no-cache-dir pytest

    # Provide a writable workspace expected by the tests and the learner
    mkdir -p /home/user
    chmod 0777 /home/user

%environment
    chmod 755 /home/user

    # Basic locale and path settings
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
    export PYTHONDONTWRITEBYTECODE=1

%labels
    Author="Apptainer Task Preparation"
    Description="Base image for the SSH-key deployment exercise"