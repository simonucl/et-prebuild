Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Install Python tooling and pytest
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y python3 python3-pip
    pip3 install --no-cache-dir --upgrade pip pytest
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # Seed directory structure and initial files
    mkdir -p /home/user/terraform-module

    # VERSION file
    printf '0.4.5\n' > /home/user/terraform-module/VERSION

    # CHANGELOG.md with exact initial content
    cat > /home/user/terraform-module/CHANGELOG.md <<'EOF'
# Changelog
All notable changes to this project will be documented in this file.

## [0.4.5] - 2023-08-01
### Added
- Initial support for cross-region replication.
EOF

    # Ensure non-root users can modify the exercise files
    chmod -R a+rwX /home/user

%labels
    chmod 755 /home/user

    Author "Apptainer Exercise Preparation"
    Description "Seeds terraform-module version-bump exercise and installs pytest."

%help
    This container provides the starting state for the terraform-module
    version-bump exercise and includes pytest for automated testing.