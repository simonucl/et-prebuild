# Help: This container image provides a minimal Ubuntu 22.04 environment with
# sqlite3 and pytest pre-installed. It is prepared for the “SQLite experiment
# tracking” CLI exercise: no artefacts from the assignment are present, so
# automated pre-tests will confirm a clean initial state.

FROM ubuntu:22.04

LABEL Author="Generated by ChatGPT"
LABEL Description="Base image for SQLite experiment tracking CLI exercise with pytest and sqlite3 installed."

RUN set -e && \
    export DEBIAN_FRONTEND=noninteractive && \
    apt-get update && \
    apt-get install -y --no-install-recommends \
        sqlite3 \
        python3 \
        python3-pip && \
    pip3 install --no-cache-dir pytest && \
    if ! id -u user >/dev/null 2>&1; then useradd -m -s /bin/bash user; fi && \
    chown -R user:user /home/user && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

RUN chmod 755 /home/user

ENV LC_ALL=C
ENV PATH=/usr/local/bin:/usr/bin:/bin