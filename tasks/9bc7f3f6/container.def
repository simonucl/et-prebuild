Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Ensure non-interactive apt transactions
    export DEBIAN_FRONTEND=noninteractive

    # Update package index and install required system tools
    apt-get update
    apt-get install -y --no-install-recommends \
        sqlite3 \
        python3 \
        python3-pip

    # Install pytest for the grading framework
    pip3 install --no-cache-dir pytest

    # Create a standard, non-privileged user that owns /home/user
    if ! id -u user >/dev/null 2>&1; then
        useradd -m -s /bin/bash user
    fi
    chown -R user:user /home/user

    # Clean up apt caches to minimize image size
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Basic locale and PATH setup
    export LC_ALL=C
    export PATH=/usr/local/bin:/usr/bin:/bin

%labels
    Author="Generated by ChatGPT"
    Description="Base image for SQLite experiment tracking CLI exercise with pytest and sqlite3 installed."

%help
    This container image provides a minimal Ubuntu 22.04 environment with
    sqlite3 and pytest pre-installed.  It is prepared for the “SQLite experiment
    tracking” CLI exercise: no artefacts from the assignment are present, so
    automated pre-tests will confirm a clean initial state.