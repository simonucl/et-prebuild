Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    #-------------------------------------------
    # Install system packages
    #-------------------------------------------
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3-pip \
        sqlite3 \
        ca-certificates \
        locales

    # Minimal locale setup (avoids warnings)
    locale-gen en_US.UTF-8
    update-locale LANG=en_US.UTF-8

    #-------------------------------------------
    # Python packages required by the grader
    #-------------------------------------------
    pip3 install --no-cache-dir pytest

    #-------------------------------------------
    # Prepare initial filesystem state for tests
    #-------------------------------------------
    mkdir -p /home/user/app/data

    # Create and seed the SQLite database exactly as required
    sqlite3 /home/user/app/data/service.db <<'EOF'
CREATE TABLE customers(
    id INTEGER PRIMARY KEY,
    name TEXT,
    city TEXT
);
INSERT INTO customers (id, name, city) VALUES
(1,'Alice','London'),
(2,'Bob','Paris'),
(3,'Charlie','Berlin'),
(4,'Dana','London');

CREATE TABLE orders(
    id INTEGER PRIMARY KEY,
    customer_id INTEGER,
    amount REAL
);
INSERT INTO orders (id, customer_id, amount) VALUES
(1,1,100.50),
(2,2,200.00),
(3,1,50.00),
(4,3,75.25);
EOF

    # Ensure the student (unprivileged) user can read/write everything under /home/user
    chmod -R a+rwX /home/user

%runscript
    chmod 755 /home/user

    echo "Diagnostic snapshot container ready. Start an interactive shell with 'apptainer shell'."

%labels
    Author="task-prep"
    Description="Apptainer image with SQLite database and pytest installed for diagnostic snapshot exercise."