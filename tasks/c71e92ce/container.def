Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author    task-setup
    Description   Base image for backup-restore virtual-environment exercise

%post
    set -e

    # Refresh package index and install required Python tooling
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 \
        python3-venv \
        python3-pip

    # Install pytest so the grading harness can run its tests
    python3 -m pip install --no-cache-dir --upgrade pip
    python3 -m pip install --no-cache-dir pytest

    # Prepare the reference home directory that the tests expect
    mkdir -p /home/user
    chmod 0777 /home/user   # Ensure writability for whichever UID runs inside the container

    # Clean up apt caches to keep the image small
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%runscript
    chmod 755 /home/user

    # Default runscript just executes whatever the user passes
    exec "$@"