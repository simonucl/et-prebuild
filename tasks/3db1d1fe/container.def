Bootstrap: localimage
From: ./ubuntu_22.04.sif

%labels
    Author Env-Report-Setup
    Description "Base container for env_report task; provides /home/user/project, Python, pytest, and jq."

%post
    set -e

    # Configure non-interactive APT
    export DEBIAN_FRONTEND=noninteractive

    # Update package lists and install required OS packages
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        jq \
        ca-certificates

    # Upgrade pip itself for good measure
    python3 -m pip install --no-cache-dir --upgrade pip

    # Install pytest for the test harness
    python3 -m pip install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Prepare workspace expected by the automated tests
    # ------------------------------------------------------------------
    # Create /home/user and the project directory, ensuring they are
    # writable by any user that will run inside the container.
    mkdir -p /home/user/project
    chmod 0777 /home/user
    chmod 0777 /home/user/project

    # Do NOT create env_report/ or pip_packages.json here; the student
    # workflow must generate those.

    # Clean up APT caches to reduce image size
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    chmod 755 /home/user

    # Ensure python and pip are on PATH (they already are, but be explicit)
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%runscript
    echo "Container for env_report task is ready. Drop into a shell."
    exec /bin/bash -l "$@"