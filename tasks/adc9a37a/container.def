Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    set -e

    # Update APT index and install Python + pip
    apt-get update -y && \
    apt-get install -y --no-install-recommends python3 python3-pip && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

    # Install pytest for the grading tests
    pip3 install --no-cache-dir pytest

    # ------------------------------------------------------------------
    # Set up initial filesystem state expected by the exercise
    # ------------------------------------------------------------------
    # Create directories
    mkdir -p /home/user/ml_data/train
    mkdir -p /home/user/backups

    # Create training data files with exact contents and Unix LF endings
    cat > /home/user/ml_data/train/features.csv << 'EOF'
f1,f2,f3
1,2,3
4,5,6
EOF

    cat > /home/user/ml_data/train/targets.csv << 'EOF'
t
0
1
EOF

    # Permissions:
    #  - Directories readable & traversable by everyone
    #  - /home/user/backups writable so the agent can create artefacts
    chmod 755 /home/user
    chmod 755 /home/user/ml_data /home/user/ml_data/train
    chmod 777 /home/user/backups

    # Files readable by everyone
    chmod 644 /home/user/ml_data/train/features.csv
    chmod 644 /home/user/ml_data/train/targets.csv

%environment
    # Ensure Python and common paths are available
    export PATH=/usr/local/bin:/usr/local/sbin:/usr/sbin:/usr/bin:/sbin:/bin

%labels
    Author="Apptainer Task Prep"
    Description="Container for ML data backup CI exercise with pytest pre-installed."